---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Chat">
  <!-- Help banner -->
  <div id="chat-help-banner" class="stat-card animate-in" style="margin-bottom:20px;background:linear-gradient(135deg,#0c2d3f,#084D6E);border:1px solid rgba(111,207,245,0.15);display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
    <div style="width:40px;height:40px;border-radius:12px;background:rgba(111,207,245,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg style="width:20px;height:20px;color:#6fcff5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
    </div>
    <div style="flex:1;min-width:200px;">
      <h3 style="font-size:14px;font-weight:800;color:#fff;margin-bottom:2px;">Bandeja unificada</h3>
      <p style="font-size:12px;color:rgba(255,255,255,0.6);">Todos los mensajes de WhatsApp, Facebook Messenger, Instagram DM y correo llegan aqui. Responde desde un solo lugar sin cambiar de app.</p>
    </div>
    <button onclick="dismissChatHelp()" style="width:32px;height:32px;border-radius:8px;border:none;background:rgba(255,255,255,0.15);cursor:pointer;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;" onmouseover="this.style.background='rgba(255,255,255,0.25)'" onmouseout="this.style.background='rgba(255,255,255,0.15)'">
      <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:20px;" class="animate-in">
    <div class="stat-card" style="padding:16px 20px;">
      <p class="chat-stat-label">Total conversaciones</p>
      <p class="chat-stat-value">5</p>
    </div>
    <div class="stat-card" style="padding:16px 20px;">
      <p class="chat-stat-label">Sin contestar</p>
      <p class="chat-stat-value" style="color:#f97316;">1</p>
    </div>
    <div class="stat-card" style="padding:16px 20px;">
      <p class="chat-stat-label" style="display:flex;align-items:center;gap:4px;">Tiempo promedio <span class="chat-tooltip-trigger" data-tip="Tiempo promedio que tardas en responder el primer mensaje de un cliente">?</span></p>
      <p class="chat-stat-value" style="color:#22c55e;">4 min</p>
    </div>
    <div class="stat-card" style="padding:16px 20px;">
      <p class="chat-stat-label">Satisfaccion</p>
      <p class="chat-stat-value" style="color:#8b5cf6;">94%</p>
    </div>
  </div>

  <!-- Autopilot bar -->
  <div class="stat-card animate-in" style="margin-bottom:20px;padding:14px 20px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:8px;">
      <svg style="width:18px;height:18px;color:#8b5cf6;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <span style="font-size:13px;font-weight:800;color:var(--text-primary);">Autopilot</span>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;flex:1;">
      <button class="chat-autopilot-btn chat-autopilot-active" id="chat-ap-horario" onclick="toggleAutopilot('horario',this)">
        <span class="chat-ap-dot"></span> Auto-respuesta fuera de horario
      </button>
      <button class="chat-autopilot-btn" id="chat-ap-faq" onclick="toggleAutopilot('faq',this)">
        <span class="chat-ap-dot" style="background:#475569;"></span> Bot de preguntas frecuentes
      </button>
      <button class="chat-autopilot-btn" id="chat-ap-assign" onclick="toggleAutopilot('assign',this)">
        <span class="chat-ap-dot" style="background:#475569;"></span> Asignar automatico por tema
      </button>
    </div>
  </div>

  <!-- Main chat container -->
  <div class="chat-container animate-in">
    <!-- Left panel: conversation list -->
    <div class="chat-left-panel">
      <!-- Search & filter -->
      <div class="chat-search-bar">
        <div class="chat-search-input-wrap">
          <svg style="width:16px;height:16px;color:var(--text-faint);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text" id="chat-search" placeholder="Buscar conversacion..." class="chat-search-field" oninput="filterConversations()" />
        </div>
        <div class="chat-channel-filters">
          <button class="chat-channel-btn chat-channel-active" data-channel="todos" onclick="filterByChannel('todos',this)">Todos</button>
          <button class="chat-channel-btn" data-channel="whatsapp" onclick="filterByChannel('whatsapp',this)">
            <span class="chat-channel-icon" style="color:#25D366;">&#9679;</span> WhatsApp
          </button>
          <button class="chat-channel-btn" data-channel="facebook" onclick="filterByChannel('facebook',this)">
            <span class="chat-channel-icon" style="color:#1877F2;">&#9679;</span> Facebook
          </button>
          <button class="chat-channel-btn" data-channel="instagram" onclick="filterByChannel('instagram',this)">
            <span class="chat-channel-icon" style="color:#E4405F;">&#9679;</span> Instagram
          </button>
          <button class="chat-channel-btn" data-channel="email" onclick="filterByChannel('email',this)">
            <span class="chat-channel-icon" style="color:#64748b;">&#9679;</span> Email
          </button>
        </div>
      </div>
      <!-- Conversation list -->
      <div class="chat-conv-list" id="chat-conv-list"></div>
    </div>

    <!-- Right panel: active conversation -->
    <div class="chat-right-panel" id="chat-right-panel">
      <!-- Empty state -->
      <div id="chat-empty-state" class="chat-empty-state">
        <svg style="width:56px;height:56px;color:var(--accent);opacity:0.4;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 4px;">Selecciona una conversacion</h3>
        <p style="font-size:12px;color:var(--text-faint);">Elige una conversacion del panel izquierdo para empezar a responder</p>
      </div>

      <!-- Active conversation view (hidden initially) -->
      <div id="chat-active-conv" style="display:none;height:100%;display:none;flex-direction:column;">
        <!-- Header -->
        <div class="chat-conv-header" id="chat-conv-header"></div>
        <!-- Messages -->
        <div class="chat-messages" id="chat-messages"></div>
        <!-- Input bar -->
        <div class="chat-input-bar">
          <div class="chat-input-actions">
            <button class="chat-input-icon-btn" onclick="toggleQuickReplies()" title="Respuestas rapidas">
              <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </button>
            <button class="chat-input-icon-btn" title="Adjuntar archivo">
              <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
            </button>
          </div>
          <input type="text" id="chat-msg-input" class="chat-msg-field" placeholder="Escribe un mensaje..." onkeydown="if(event.key==='Enter')sendMessage()" />
          <button class="chat-send-btn" onclick="sendMessage()">
            <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            Enviar
          </button>
        </div>
        <!-- Quick replies dropdown -->
        <div id="chat-quick-replies" class="chat-quick-replies" style="display:none;">
          <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;padding:10px 14px 6px;">Respuestas rapidas</p>
          <button class="chat-qr-item" onclick="useQuickReply('Gracias por tu mensaje, en breve te atendemos.')">Gracias por tu mensaje</button>
          <button class="chat-qr-item" onclick="useQuickReply('Tu pedido va en camino, te llegara en 2-3 dias habiles.')">Tu pedido va en camino</button>
          <button class="chat-qr-item" onclick="useQuickReply('Aqui esta tu numero de guia: SKY-TRACK-00123. Puedes rastrearlo en nuestra pagina.')">Aqui esta tu numero de guia</button>
          <button class="chat-qr-item" onclick="useQuickReply('Si tenemos disponible, te mando el link de pago.')">Si tenemos disponible</button>
          <button class="chat-qr-item" onclick="useQuickReply('Te generamos tu factura en las proximas 24 horas.')">Te generamos tu factura</button>
          <button class="chat-qr-item" onclick="useQuickReply('Nuestro horario de atencion es de lunes a viernes de 9am a 6pm.')">Horario de atencion</button>
        </div>
      </div>
    </div>
  </div>

  <style>
    .chat-stat-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-faint);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }
    .chat-stat-value {
      font-size: 26px;
      font-weight: 900;
      color: var(--text-primary);
    }
    .chat-tooltip-trigger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--input-bg);
      border: 1px solid var(--border);
      font-size: 10px;
      font-weight: 800;
      color: var(--text-faint);
      cursor: help;
      position: relative;
    }
    .chat-tooltip-trigger:hover::after {
      content: attr(data-tip);
      position: absolute;
      bottom: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--bg-sidebar);
      color: var(--text-secondary);
      font-size: 11px;
      font-weight: 500;
      padding: 8px 12px;
      border-radius: 8px;
      border: 1px solid var(--border);
      white-space: normal;
      width: 220px;
      z-index: 20;
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    /* Autopilot */
    .chat-autopilot-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .chat-autopilot-btn:hover {
      border-color: var(--border-hover);
      color: var(--text-secondary);
    }
    .chat-autopilot-active {
      border-color: rgba(34,197,94,0.3);
      background: rgba(34,197,94,0.08);
      color: #22c55e;
    }
    .chat-ap-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #22c55e;
      flex-shrink: 0;
    }

    /* Main container */
    .chat-container {
      display: flex;
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      height: calc(100vh - 380px);
      min-height: 480px;
      background: var(--bg-card);
    }

    /* Left panel */
    .chat-left-panel {
      width: 340px;
      min-width: 280px;
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      background: var(--bg-sidebar);
    }
    .chat-search-bar {
      padding: 14px;
      border-bottom: 1px solid var(--border);
    }
    .chat-search-input-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--input-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 8px 12px;
      margin-bottom: 10px;
    }
    .chat-search-field {
      flex: 1;
      background: none;
      border: none;
      outline: none;
      color: var(--text-primary);
      font-size: 13px;
      font-family: 'Inter', sans-serif;
    }
    .chat-search-field::placeholder {
      color: var(--text-faint);
    }
    .chat-channel-filters {
      display: flex;
      gap: 4px;
      overflow-x: auto;
      padding-bottom: 2px;
    }
    .chat-channel-btn {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 5px 10px;
      border-radius: 8px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--text-muted);
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }
    .chat-channel-btn:hover {
      background: var(--nav-hover);
      color: var(--text-secondary);
    }
    .chat-channel-active {
      background: var(--accent-bg);
      color: var(--accent);
      border-color: rgba(111,207,245,0.2);
    }
    .chat-channel-icon {
      font-size: 8px;
    }

    /* Conversation list */
    .chat-conv-list {
      flex: 1;
      overflow-y: auto;
    }
    .chat-conv-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px;
      cursor: pointer;
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }
    .chat-conv-item:hover {
      background: var(--nav-hover);
    }
    .chat-conv-item.chat-conv-active {
      background: var(--accent-bg);
      border-left: 3px solid var(--accent);
    }
    .chat-conv-avatar {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      font-weight: 800;
      color: #fff;
      flex-shrink: 0;
      position: relative;
    }
    .chat-conv-channel-badge {
      position: absolute;
      bottom: -2px;
      right: -2px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      border: 2px solid var(--bg-sidebar);
    }
    .chat-conv-info {
      flex: 1;
      min-width: 0;
    }
    .chat-conv-name {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 2px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .chat-conv-preview {
      font-size: 12px;
      color: var(--text-muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .chat-conv-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
      flex-shrink: 0;
    }
    .chat-conv-time {
      font-size: 10px;
      color: var(--text-faint);
      white-space: nowrap;
    }
    .chat-conv-unread {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--accent);
      color: #0f172a;
      font-size: 10px;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .chat-conv-tag {
      display: inline-block;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }

    /* Right panel */
    .chat-right-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      position: relative;
      min-width: 0;
    }
    .chat-empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      text-align: center;
      padding: 40px;
    }

    /* Conversation header */
    .chat-conv-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 20px;
      border-bottom: 1px solid var(--border);
      background: var(--bg-sidebar);
      flex-wrap: wrap;
    }
    .chat-header-name {
      font-size: 14px;
      font-weight: 800;
      color: var(--text-primary);
    }
    .chat-header-channel {
      font-size: 11px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 6px;
    }
    .chat-header-actions {
      display: flex;
      gap: 6px;
      margin-left: auto;
    }
    .chat-header-btn {
      padding: 6px 12px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .chat-header-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* Messages area */
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .chat-bubble {
      max-width: 70%;
      padding: 10px 14px;
      border-radius: 12px;
      font-size: 13px;
      line-height: 1.5;
      position: relative;
    }
    .chat-bubble-in {
      align-self: flex-start;
      background: var(--input-bg);
      color: var(--text-secondary);
      border-bottom-left-radius: 4px;
    }
    .chat-bubble-out {
      align-self: flex-end;
      background: linear-gradient(135deg, #084D6E, #0a6b9a);
      color: #fff;
      border-bottom-right-radius: 4px;
    }
    .chat-bubble-time {
      font-size: 10px;
      color: var(--text-faint);
      margin-top: 4px;
      display: block;
    }
    .chat-bubble-out .chat-bubble-time {
      color: rgba(255,255,255,0.5);
      text-align: right;
    }

    /* Input bar */
    .chat-input-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      border-top: 1px solid var(--border);
      background: var(--bg-sidebar);
    }
    .chat-input-actions {
      display: flex;
      gap: 4px;
    }
    .chat-input-icon-btn {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      border: none;
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    .chat-input-icon-btn:hover {
      background: var(--nav-hover);
      color: var(--accent);
    }
    .chat-msg-field {
      flex: 1;
      padding: 10px 14px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--input-bg);
      color: var(--text-primary);
      font-size: 13px;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border-color 0.2s;
    }
    .chat-msg-field:focus {
      border-color: var(--accent);
    }
    .chat-msg-field::placeholder {
      color: var(--text-faint);
    }
    .chat-send-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 18px;
      border-radius: 10px;
      border: none;
      background: var(--accent);
      color: #0f172a;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
      font-family: 'Inter', sans-serif;
    }
    .chat-send-btn:hover {
      filter: brightness(1.1);
      transform: translateY(-1px);
    }

    /* Quick replies */
    .chat-quick-replies {
      position: absolute;
      bottom: 60px;
      left: 16px;
      right: 16px;
      background: var(--bg-sidebar);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.3);
      z-index: 10;
      overflow: hidden;
    }
    .chat-qr-item {
      display: block;
      width: 100%;
      padding: 10px 14px;
      border: none;
      background: transparent;
      color: var(--text-secondary);
      font-size: 12px;
      text-align: left;
      cursor: pointer;
      transition: background 0.15s;
      font-family: 'Inter', sans-serif;
    }
    .chat-qr-item:hover {
      background: var(--accent-bg);
      color: var(--accent);
    }

    /* Assign modal */
    .chat-modal-overlay {
      position: fixed;
      inset: 0;
      z-index: 60;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .chat-modal-bg {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.6);
      backdrop-filter: blur(4px);
    }
    .chat-modal-content {
      position: relative;
      width: 100%;
      max-width: 400px;
      background: var(--bg-sidebar);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px;
    }
    .chat-modal-title {
      font-size: 16px;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 16px;
    }
    .chat-modal-option {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: transparent;
      width: 100%;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: 8px;
      color: var(--text-secondary);
      font-size: 13px;
      font-family: 'Inter', sans-serif;
    }
    .chat-modal-option:hover {
      border-color: var(--accent);
      background: var(--accent-bg);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .chat-container {
        flex-direction: column;
        height: auto;
      }
      .chat-left-panel {
        width: 100%;
        min-width: 0;
        max-height: 300px;
        border-right: none;
        border-bottom: 1px solid var(--border);
      }
    }
  </style>

  <script is:inline>
