        ]
      }
    ];

    const teamMembers = [
      { name: 'Ana Lopez', role: 'Ventas' },
      { name: 'Pedro Ramirez', role: 'Soporte' },
      { name: 'Sofia Martinez', role: 'CRM' }
    ];

    const tagOptions = [
      { label: 'Venta', color: '#22c55e' },
      { label: 'Soporte', color: '#6fcff5' },
      { label: 'Queja', color: '#ef4444' },
      { label: 'Devolucion', color: '#f97316' },
      { label: 'Facturacion', color: '#8b5cf6' },
      { label: 'Informacion', color: '#eab308' }
    ];

    let activeConvId = null;
    let activeChannel = 'todos';

    // ═══════ HELPERS ═══════
    function showToast(msg) {
      const ex = document.getElementById('chat-toast');
      if (ex) ex.remove();
      const t = document.createElement('div');
      t.id = 'chat-toast';
      t.textContent = msg;
      Object.assign(t.style, {
        position: 'fixed', bottom: '24px', right: '24px',
        background: '#22c55e', color: '#fff',
        padding: '12px 24px', borderRadius: '10px',
        fontSize: '13px', fontWeight: '700',
        zIndex: '9999', boxShadow: '0 4px 20px rgba(0,0,0,0.3)',
        fontFamily: "'Inter', sans-serif"
      });
      document.body.appendChild(t);
      setTimeout(() => {
        t.style.opacity = '0';
        t.style.transition = 'opacity 0.3s';
        setTimeout(() => t.remove(), 300);
      }, 3000);
    }

    function dismissChatHelp() {
      const banner = document.getElementById('chat-help-banner');
      if (banner) {
        banner.style.transition = 'opacity 0.3s, transform 0.3s';
        banner.style.opacity = '0';
        banner.style.transform = 'translateY(-10px)';
        setTimeout(() => { banner.style.display = 'none'; }, 300);
      }
      localStorage.setItem('chat_help_dismissed', '1');
    }

    if (localStorage.getItem('chat_help_dismissed') === '1') {
      const b = document.getElementById('chat-help-banner');
      if (b) b.style.display = 'none';
    }

    // ═══════ RENDER CONVERSATION LIST ═══════
    function renderConvList() {
      const list = document.getElementById('chat-conv-list');
      const search = (document.getElementById('chat-search').value || '').toLowerCase();
      let convs = chatConversations;

      if (activeChannel !== 'todos') {
        convs = convs.filter(c => c.channel === activeChannel);
      }
      if (search) {
        convs = convs.filter(c =>
          c.name.toLowerCase().includes(search) ||
          c.lastMessage.toLowerCase().includes(search)
        );
      }

      if (convs.length === 0) {
        list.innerHTML = '<div style="padding:30px;text-align:center;"><p style="font-size:13px;color:var(--text-faint);">No se encontraron conversaciones</p></div>';
        return;
      }

      list.innerHTML = convs.map(c => `
        <div class="chat-conv-item ${activeConvId === c.id ? 'chat-conv-active' : ''}" onclick="openConversation(${c.id})">
          <div class="chat-conv-avatar" style="background:${c.avatarBg};">
            ${c.avatar}
            <div class="chat-conv-channel-badge" style="background:${c.channelColor};">
              ${c.channel === 'whatsapp' ? '<svg style="width:10px;height:10px;color:#fff;" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>' : ''}
              ${c.channel === 'facebook' ? '<svg style="width:10px;height:10px;color:#fff;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.936 1.444 5.544 3.7 7.254V22l3.3-1.813c.88.244 1.813.376 2.786.376h.214C17.523 20.563 22 16.418 22 11.243S17.523 2 12 2z"/></svg>' : ''}
              ${c.channel === 'instagram' ? '<svg style="width:10px;height:10px;color:#fff;" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0z"/></svg>' : ''}
              ${c.channel === 'email' ? '<svg style="width:10px;height:10px;color:#fff;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>' : ''}
            </div>
          </div>
          <div class="chat-conv-info">
            <div class="chat-conv-name">
              ${c.name}
              ${c.tag ? `<span class="chat-conv-tag" style="background:${c.tagColor}15;color:${c.tagColor};">${c.tag}</span>` : ''}
            </div>
            <p class="chat-conv-preview">${c.lastMessage}</p>
          </div>
          <div class="chat-conv-meta">
            <span class="chat-conv-time">${c.time}</span>
            ${c.unread > 0 ? `<span class="chat-conv-unread">${c.unread}</span>` : ''}
          </div>
        </div>
      `).join('');
    }

    // ═══════ OPEN CONVERSATION ═══════
    function openConversation(id) {
      activeConvId = id;
      const conv = chatConversations.find(c => c.id === id);
      if (!conv) return;

      // Mark as read
      conv.unread = 0;

      // Show conversation panel
      document.getElementById('chat-empty-state').style.display = 'none';
      const activeEl = document.getElementById('chat-active-conv');
      activeEl.style.display = 'flex';

      // Header
      document.getElementById('chat-conv-header').innerHTML = `
        <div class="chat-conv-avatar" style="background:${conv.avatarBg};width:36px;height:36px;font-size:13px;">
          ${conv.avatar}
        </div>
        <div>
          <p class="chat-header-name">${conv.name}</p>
          <span class="chat-header-channel" style="background:${conv.channelColor}20;color:${conv.channelColor};">${conv.channelLabel}</span>
          ${conv.assignedTo ? `<span style="font-size:11px;color:var(--text-faint);margin-left:8px;">Asignado a: ${conv.assignedTo}</span>` : ''}
        </div>
        <div class="chat-header-actions">
          <button class="chat-header-btn" onclick="openAssignModal(${conv.id})">
            <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Asignar
          </button>
          <button class="chat-header-btn" onclick="openTagModal(${conv.id})">
            <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
            Etiquetar
          </button>
        </div>
      `;

      // Messages
      renderMessages(conv);
      renderConvList();

      // Hide quick replies
      document.getElementById('chat-quick-replies').style.display = 'none';
    }

    function renderMessages(conv) {
      const container = document.getElementById('chat-messages');
      container.innerHTML = conv.messages.map(m => `
        <div class="chat-bubble ${m.from === 'customer' ? 'chat-bubble-in' : 'chat-bubble-out'}">
          ${m.text}
          <span class="chat-bubble-time">${m.time}</span>
        </div>
      `).join('');
      container.scrollTop = container.scrollHeight;
    }

    // ═══════ SEND MESSAGE ═══════
    function sendMessage() {
      const input = document.getElementById('chat-msg-input');
      const text = input.value.trim();
      if (!text || !activeConvId) return;

      const conv = chatConversations.find(c => c.id === activeConvId);
      if (!conv) return;

      const now = new Date();
      const time = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');

      conv.messages.push({ from: 'agent', text: text, time: time });
      conv.lastMessage = text;
      conv.time = 'Ahora';

      input.value = '';
      renderMessages(conv);
      renderConvList();
      document.getElementById('chat-quick-replies').style.display = 'none';
      showToast('Mensaje enviado');
    }

    // ═══════ QUICK REPLIES ═══════
    function toggleQuickReplies() {
      const el = document.getElementById('chat-quick-replies');
      el.style.display = el.style.display === 'none' ? 'block' : 'none';
    }

    function useQuickReply(text) {
      document.getElementById('chat-msg-input').value = text;
      document.getElementById('chat-quick-replies').style.display = 'none';
      document.getElementById('chat-msg-input').focus();
    }

    // ═══════ FILTERS ═══════
    function filterByChannel(channel, btn) {
      activeChannel = channel;
      document.querySelectorAll('.chat-channel-btn').forEach(b => b.classList.remove('chat-channel-active'));
      btn.classList.add('chat-channel-active');
      renderConvList();
    }

    function filterConversations() {
      renderConvList();
    }

    // ═══════ ASSIGN MODAL ═══════
    function openAssignModal(convId) {
      closeModals();
      const conv = chatConversations.find(c => c.id === convId);
      const modal = document.createElement('div');
      modal.className = 'chat-modal-overlay';
      modal.id = 'chat-modal';
      modal.innerHTML = `
        <div class="chat-modal-bg" onclick="closeModals()"></div>
        <div class="chat-modal-content">
          <p class="chat-modal-title">Asignar conversacion</p>
          <p style="font-size:12px;color:var(--text-faint);margin-bottom:14px;">Selecciona un miembro del equipo para atender a ${conv.name}:</p>
          ${teamMembers.map(m => `
            <button class="chat-modal-option" onclick="assignConversation(${convId},'${m.name}')">
              <div style="width:32px;height:32px;border-radius:50%;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;">
                <span style="font-size:12px;font-weight:800;color:var(--accent);">${m.name.split(' ').map(w => w[0]).join('')}</span>
              </div>
              <div>
                <p style="font-size:13px;font-weight:700;color:var(--text-primary);">${m.name}</p>
                <p style="font-size:11px;color:var(--text-faint);">${m.role}</p>
              </div>
            </button>
          `).join('')}
          <button class="chat-modal-option" onclick="assignConversation(${convId},null)" style="justify-content:center;">
            <span style="font-size:13px;color:var(--text-muted);">Sin asignar</span>
          </button>
          <button onclick="closeModals()" style="margin-top:8px;width:100%;padding:10px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;">Cancelar</button>
        </div>
      `;
      document.body.appendChild(modal);
    }

    function assignConversation(convId, name) {
      const conv = chatConversations.find(c => c.id === convId);
      if (conv) {
        conv.assignedTo = name;
        showToast(name ? 'Conversacion asignada a ' + name : 'Asignacion removida');
        if (activeConvId === convId) openConversation(convId);
      }
      closeModals();
    }

    // ═══════ TAG MODAL ═══════
    function openTagModal(convId) {
      closeModals();
      const conv = chatConversations.find(c => c.id === convId);
      const modal = document.createElement('div');
      modal.className = 'chat-modal-overlay';
      modal.id = 'chat-modal';
      modal.innerHTML = `
        <div class="chat-modal-bg" onclick="closeModals()"></div>
        <div class="chat-modal-content">
          <p class="chat-modal-title">Etiquetar conversacion</p>
          <p style="font-size:12px;color:var(--text-faint);margin-bottom:14px;">Selecciona una etiqueta para ${conv.name}:</p>
          ${tagOptions.map(t => `
            <button class="chat-modal-option" onclick="tagConversation(${convId},'${t.label}','${t.color}')">
              <span style="width:12px;height:12px;border-radius:3px;background:${t.color};flex-shrink:0;"></span>
              <span style="font-size:13px;font-weight:600;">${t.label}</span>
            </button>
          `).join('')}
          <button class="chat-modal-option" onclick="tagConversation(${convId},null,null)" style="justify-content:center;">
            <span style="font-size:13px;color:var(--text-muted);">Sin etiqueta</span>
          </button>
          <button onclick="closeModals()" style="margin-top:8px;width:100%;padding:10px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;cursor:pointer;font-family:'Inter',sans-serif;">Cancelar</button>
        </div>
      `;
      document.body.appendChild(modal);
    }

    function tagConversation(convId, label, color) {
      const conv = chatConversations.find(c => c.id === convId);
      if (conv) {
        conv.tag = label;
        conv.tagColor = color;
        showToast(label ? 'Etiqueta: ' + label : 'Etiqueta removida');
        if (activeConvId === convId) openConversation(convId);
        renderConvList();
      }
      closeModals();
    }

    function closeModals() {
      const m = document.getElementById('chat-modal');
      if (m) m.remove();
    }

    // ═══════ AUTOPILOT ═══════
    function toggleAutopilot(type, btn) {
      const isActive = btn.classList.contains('chat-autopilot-active');
      const dot = btn.querySelector('.chat-ap-dot');
      if (isActive) {
        btn.classList.remove('chat-autopilot-active');
        dot.style.background = '#475569';
        showToast('Autopilot desactivado: ' + type);
      } else {
        btn.classList.add('chat-autopilot-active');
        dot.style.background = '#22c55e';
        showToast('Autopilot activado: ' + type);
      }
    }

    // ═══════ INIT ═══════
    renderConvList();

    // Close quick replies on outside click
    document.addEventListener('click', function(e) {
      const qr = document.getElementById('chat-quick-replies');
      if (qr && qr.style.display === 'block') {
        if (!e.target.closest('.chat-quick-replies') && !e.target.closest('.chat-input-icon-btn')) {
          qr.style.display = 'none';
        }
      }
    });
  </script>
</DashboardLayout>
