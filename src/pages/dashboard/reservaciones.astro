function resGetWeekDates(offset){
  const now = new Date();
  const day = now.getDay();
  const diff = now.getDate() - day + (day===0?-6:1) + (offset*7);
  const monday = new Date(now);
  monday.setDate(diff);
  const dates=[];
  for(let i=0;i<7;i++){
    const d = new Date(monday);
    d.setDate(monday.getDate()+i);
    dates.push(d);
  }
  return dates;
}

function resRenderCalendar(){
  const dates = resGetWeekDates(resCalWeekOffset);
  const today = resToday();
  const label = document.getElementById('res-cal-week-label');
  if(label){
    const m1 = dates[0].toLocaleDateString('es-MX',{month:'short',day:'numeric'});
    const m2 = dates[6].toLocaleDateString('es-MX',{month:'short',day:'numeric',year:'numeric'});
    label.textContent = m1 + ' — ' + m2;
  }

  const hours = [];
  for(let h=8;h<=20;h++) hours.push(h);
  const dayNames = ['Lun','Mar','Mie','Jue','Vie','Sab','Dom'];

  let html = '<table style="width:100%;border-collapse:collapse;min-width:700px;">';
  html += '<thead><tr><th style="padding:10px 8px;font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;border-bottom:1px solid var(--border);width:60px;text-align:center;">Hora</th>';
  dates.forEach((d,i)=>{
    const ds = d.toISOString().split('T')[0];
    const isToday = ds===today;
    html += `<th style="padding:10px 8px;font-size:11px;font-weight:700;color:${isToday?'var(--accent)':'var(--text-faint)'};text-transform:uppercase;border-bottom:1px solid var(--border);text-align:center;${isToday?'background:var(--accent-bg);':''}">${dayNames[i]}<br><span style="font-size:13px;font-weight:900;color:${isToday?'var(--accent)':'var(--text-primary)'};">${d.getDate()}</span></th>`;
  });
  html += '</tr></thead><tbody>';

  hours.forEach(h=>{
    html += '<tr>';
    html += `<td style="padding:6px 8px;font-size:11px;font-weight:600;color:var(--text-faint);border-right:1px solid var(--border);text-align:center;vertical-align:top;">${h}:00</td>`;
    dates.forEach(d=>{
      const ds = d.toISOString().split('T')[0];
      const isToday = ds===today;
      const cellAppts = resAppointments.filter(a=>a.date===ds && parseInt(a.time.split(':')[0])===h);
      html += `<td class="res-cal-cell${isToday?' today':''}" onclick="resQuickBook('${ds}','${String(h).padStart(2,'0')}:00')" style="border-bottom:1px solid var(--border);">`;
      cellAppts.forEach(a=>{
        const svc = resServices.find(s=>s.id===a.service);
        const color = a.status==='cancelada'?'#ef4444':a.status==='completada'?'#22c55e':a.status==='pendiente'?'#f97316':(svc?svc.color:'#6fcff5');
        html += `<div class="res-cal-event" style="background:${color}22;color:${color};border-left:3px solid ${color};" title="${a.client} - ${svc?svc.name:''}">${a.time} ${a.client.split(' ')[0]}</div>`;
      });
      html += '</td>';
    });
    html += '</tr>';
  });
  html += '</tbody></table>';
  document.getElementById('res-cal-grid').innerHTML = html;
}

