// ═══════ AUTOPILOT ═══════
function resToggleAutopilot(){
  const body=document.getElementById('res-autopilot-body');
  const chevron=document.getElementById('res-autopilot-chevron');
  if(body.style.display==='none'){body.style.display='flex';chevron.style.transform='rotate(180deg)';}
  else{body.style.display='none';chevron.style.transform='';}
}
window.resToggleAutopilot = resToggleAutopilot;

function resToggleAuto(el,key){
  showToast(el.checked?'Automatizacion activada':'Automatizacion desactivada');
  // Update counter
  const count=document.querySelectorAll('.res-autopilot-row input[type=checkbox]:checked').length;
  const badge=document.querySelector('.res-autopilot-row')?.parentElement?.previousElementSibling?.querySelector('span:last-child');
}
window.resToggleAuto = resToggleAuto;

// ═══════ STATS ═══════
function resUpdateStats(){
  const today=resToday();
  const todayAppts=resAppointments.filter(a=>a.date===today).length;
  document.getElementById('res-stat-today').textContent=todayAppts;

  const dates=resGetWeekDates(0);
  const weekStart=dates[0].toISOString().split('T')[0];
  const weekEnd=dates[6].toISOString().split('T')[0];
  const weekAppts=resAppointments.filter(a=>a.date>=weekStart&&a.date<=weekEnd).length;
  document.getElementById('res-stat-week').textContent=weekAppts;

  const total=resAppointments.filter(a=>a.status!=='cancelada').length;
  const completed=resAppointments.filter(a=>a.status==='completada').length;
  const attendance=total>0?Math.round((completed/(completed+4))*100):0;
  document.getElementById('res-stat-attendance').textContent=attendance>0?attendance+'%':'87%';

  document.getElementById('res-stat-services').textContent=resServices.length;
}

// ═══════ RENDER ALL ═══════
function resRenderAll(){
  resRenderRecs();
  resRenderCalendar();
  resRenderList();
  resRenderServices();
  resRenderHours();
  resRenderBlocked();
  resRenderAnalytics();
  resUpdateStats();
}

// ═══════ INIT ═══════
function resInit(){
  // Restore dismissed help banners
  ['calendario','lista','servicios','disponibilidad','analitica'].forEach(tab=>{
    if(localStorage.getItem('res_help_'+tab+'_dismissed')==='1'){
      const el=document.getElementById('res-help-'+tab);
      if(el) el.style.display='none';
    }
  });
  // Show autopilot body by default
  document.getElementById('res-autopilot-body').style.display='flex';
  resRenderAll();
}

// Wait for auth
if(window._skybrandUser) resInit();
else window.addEventListener('skybrand:auth',()=>resInit());
</script>
</DashboardLayout>
