  if(todayPending > 0) recs.push({icon:'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',text:todayPending+' cita'+(todayPending>1?'s':'')+' hoy sin confirmar',action:'Enviar recordatorio',color:'#f97316',fn:'resRemindPending()'});
