// ═══════ HELPERS ═══════
function showToast(msg, type='success'){
  const c = document.getElementById('res-toast-container');
  if(!c) return;
  const t = document.createElement('div');
  const bg = type==='error'?'#ef4444':type==='warning'?'#f97316':'#22c55e';
  t.style.cssText = `padding:12px 20px;border-radius:10px;background:${bg};color:#fff;font-size:13px;font-weight:700;font-family:inherit;box-shadow:0 4px 20px rgba(0,0,0,0.3);animation:fadeIn 0.3s ease;`;
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity 0.3s';setTimeout(()=>t.remove(),300);},3000);
}

function resDismissHelp(tab){ const el=document.getElementById('res-help-'+tab); if(el) el.style.display='none'; localStorage.setItem('res_help_'+tab+'_dismissed','1'); }

function switchResTab(tab){
  document.querySelectorAll('.res-tab').forEach(t=>t.classList.remove('active'));
