function resRenderList(){
  const search = (document.getElementById('res-list-search')?.value||'').toLowerCase();
  const filterStatus = document.getElementById('res-list-filter-status')?.value||'';
  const filterService = document.getElementById('res-list-filter-service')?.value||'';

  let filtered = resAppointments.filter(a=>{
    const svc = resServices.find(s=>s.id===a.service);
    if(search && !a.client.toLowerCase().includes(search) && !(svc&&svc.name.toLowerCase().includes(search))) return false;
    if(filterStatus && a.status!==filterStatus) return false;
    if(filterService && a.service!==parseInt(filterService)) return false;
    return true;
  });
  filtered.sort((a,b)=>b.date.localeCompare(a.date)||b.time.localeCompare(a.time));

  const tbody = document.getElementById('res-list-body');
  const empty = document.getElementById('res-list-empty');
  const table = document.getElementById('res-list-table');
  if(!tbody) return;

  if(filtered.length===0){
    if(table) table.style.display='none';
    if(empty) empty.style.display='';
    return;
  }
  if(table) table.style.display='';
  if(empty) empty.style.display='none';

  tbody.innerHTML = filtered.map((a,i)=>{
    const svc = resServices.find(s=>s.id===a.service);
    const dateStr = new Date(a.date+'T12:00:00').toLocaleDateString('es-MX',{day:'numeric',month:'short',year:'numeric'});
    return `<tr>
      <td style="font-weight:700;color:var(--text-faint);">${i+1}</td>
      <td><div style="font-weight:700;color:var(--text-primary);">${a.client}</div><div style="font-size:11px;color:var(--text-muted);">${a.phone}</div></td>
      <td>${svc?svc.name:'-'}</td>
      <td>${dateStr}</td>
      <td style="font-weight:600;">${a.time}</td>
      <td>${svc?svc.duration+' min':'-'}</td>
      <td><span class="res-badge res-badge-${a.status}">${a.status.charAt(0).toUpperCase()+a.status.slice(1)}</span></td>
      <td style="white-space:nowrap;">
        ${a.status==='pendiente'?`<button class="res-action-btn" onclick="resConfirmAppt(${a.id})" title="Confirmar"><svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg></button>`:''}
        ${a.status!=='cancelada'&&a.status!=='completada'?`<button class="res-action-btn" onclick="resCancelAppt(${a.id})" title="Cancelar"><svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>`:''}
        ${a.status==='confirmada'?`<button class="res-action-btn" onclick="resCompleteAppt(${a.id})" title="Completar"><svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></button>`:''}
        <button class="res-action-btn" onclick="resShareLink(${a.id})" title="Enviar enlace al cliente"><svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg></button>
      </td>
    </tr>`;
  }).join('');
}

