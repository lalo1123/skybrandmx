---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:6100';
---

<DashboardLayout title="Reservaciones">
  <!-- Smart Recommendations -->
  <div id="res-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Sector selector -->
  <div class="stat-card animate-in" style="padding:14px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
    <svg style="width:18px;height:18px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
    <label style="font-size:13px;font-weight:700;color:var(--text-secondary);">Tipo de negocio:</label>
    <select id="res-sector" onchange="resChangeSector()" class="res-input" style="width:auto;cursor:pointer;">
      <option value="belleza">Belleza / Estetica</option>
      <option value="restaurante">Restaurante</option>
      <option value="salud">Salud / Consultorio</option>
      <option value="fitness">Fitness / Gym</option>
      <option value="profesional">Servicios profesionales</option>
      <option value="otro">Otro</option>
    </select>
    <span class="res-tip" data-tip="Cambia la terminologia: mesa, cita, sesion, consulta, segun tu giro">?</span>
  </div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="res-stat-label"><span class="res-term-citas">Citas</span> hoy</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="res-stat-today" class="res-stat-val" style="color:var(--accent);">5</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="res-stat-label"><span class="res-term-citas">Citas</span> esta semana</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="res-stat-week" class="res-stat-val">24</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="res-stat-label">Ingresos del mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="res-stat-revenue" class="res-stat-val" style="color:#22c55e;">$18,450</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="res-stat-label">Tasa de asistencia <span class="res-tip" data-tip="De cada 100 citas agendadas, cuantas personas si asistieron">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="res-stat-attendance" class="res-stat-val" style="color:#8b5cf6;">87%</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="res-stat-label">No-shows <span class="res-tip" data-tip="Personas que tenian cita pero no se presentaron">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="res-stat-noshow" class="res-stat-val" style="color:#ef4444;">4</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="res-stat-label">Servicios activos</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="res-stat-services" class="res-stat-val" style="color:#f97316;">6</p></div>
    </div>
  </div>

  <!-- Autopilot -->
  <div class="stat-card animate-in" style="padding:18px 20px;margin-bottom:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;cursor:pointer;" onclick="resToggleAutopilot()">
      <div style="display:flex;align-items:center;gap:10px;">
        <svg style="width:18px;height:18px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        <h3 style="font-size:14px;font-weight:800;color:var(--text-primary);">Autopilot de reservaciones</h3>
        <span style="font-size:11px;font-weight:700;color:var(--accent);background:var(--accent-bg);padding:2px 8px;border-radius:6px;">3/5 activos</span>
      </div>
      <svg id="res-autopilot-chevron" style="width:16px;height:16px;color:var(--text-muted);transition:transform 0.2s;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </div>
    <div id="res-autopilot-body" style="display:none;display:flex;flex-direction:column;gap:10px;">
      <div class="res-autopilot-row">
        <div><p class="res-autopilot-title">Confirmacion automatica por WhatsApp</p><p class="res-autopilot-desc">Envia un mensaje de confirmacion cuando se agenda una cita</p></div>
        <label class="res-toggle"><input type="checkbox" checked onchange="resToggleAuto(this,'confirm_wa')"><span class="res-toggle-slider"></span></label>
      </div>
      <div class="res-autopilot-row">
        <div><p class="res-autopilot-title">Recordatorio 24h antes</p><p class="res-autopilot-desc">Envia un recordatorio un dia antes de la cita</p></div>
        <label class="res-toggle"><input type="checkbox" checked onchange="resToggleAuto(this,'remind_24h')"><span class="res-toggle-slider"></span></label>
      </div>
      <div class="res-autopilot-row">
        <div><p class="res-autopilot-title">Recordatorio 1h antes</p><p class="res-autopilot-desc">Envia un recordatorio una hora antes de la cita</p></div>
        <label class="res-toggle"><input type="checkbox" checked onchange="resToggleAuto(this,'remind_1h')"><span class="res-toggle-slider"></span></label>
      </div>
      <div class="res-autopilot-row">
        <div><p class="res-autopilot-title">Auto-cancelar si no confirma</p><p class="res-autopilot-desc">Cancela la cita si el cliente no confirma 2 horas antes</p></div>
        <label class="res-toggle"><input type="checkbox" onchange="resToggleAuto(this,'auto_cancel')"><span class="res-toggle-slider"></span></label>
      </div>
      <div class="res-autopilot-row">
        <div><p class="res-autopilot-title">Pedir resena despues de la cita</p><p class="res-autopilot-desc">Envia un enlace para dejar resena 1 hora despues de la cita</p></div>
        <label class="res-toggle"><input type="checkbox" onchange="resToggleAuto(this,'ask_review')"><span class="res-toggle-slider"></span></label>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="res-tab-calendario" class="res-tab active" onclick="switchResTab('calendario')">Calendario</button>
    <button id="res-tab-lista" class="res-tab" onclick="switchResTab('lista')">Lista de citas</button>
    <button id="res-tab-servicios" class="res-tab" onclick="switchResTab('servicios')">Servicios</button>
    <button id="res-tab-disponibilidad" class="res-tab" onclick="switchResTab('disponibilidad')">Disponibilidad</button>
    <button id="res-tab-analitica" class="res-tab" onclick="switchResTab('analitica')">Analitica</button>
  </div>

  <!-- ══════════ Tab: Calendario ══════════ -->
  <div id="res-panel-calendario">
    <div id="res-help-calendario" class="res-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Calendario semanal de citas. Haz clic en cualquier hora para agendar rapidamente. Los colores indican el tipo de servicio.</p>
      <button onclick="resDismissHelp('calendario')" class="res-help-close">&times;</button>
    </div>

    <!-- Calendar navigation -->
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div style="display:flex;align-items:center;gap:12px;">
        <button onclick="resCalNavPrev()" class="res-btn-secondary" style="padding:8px 12px;">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <h3 id="res-cal-week-label" style="font-size:15px;font-weight:800;color:var(--text-primary);min-width:200px;text-align:center;"></h3>
        <button onclick="resCalNavNext()" class="res-btn-secondary" style="padding:8px 12px;">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
        <button onclick="resCalToday()" class="res-btn-secondary" style="padding:8px 12px;font-size:12px;">Hoy</button>
      </div>
      <div style="display:flex;gap:12px;align-items:center;">
        <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:3px;background:#6fcff5;"></div><span style="font-size:11px;color:var(--text-muted);">Confirmada</span></div>
        <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:3px;background:#f97316;"></div><span style="font-size:11px;color:var(--text-muted);">Pendiente</span></div>
        <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:3px;background:#22c55e;"></div><span style="font-size:11px;color:var(--text-muted);">Completada</span></div>
        <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:3px;background:#ef4444;"></div><span style="font-size:11px;color:var(--text-muted);">Cancelada</span></div>
      </div>
      <button onclick="resQuickBook()" class="res-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Agendar rapido
      </button>
    </div>

    <!-- Calendar grid -->
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div id="res-cal-grid" style="overflow-x:auto;"></div>
    </div>
  </div>

  <!-- ══════════ Tab: Lista de citas ══════════ -->
  <div id="res-panel-lista" style="display:none;">
    <div id="res-help-lista" class="res-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Todas tus citas en lista. Filtra por estado, busca por nombre y gestiona cada cita con las acciones rapidas.</p>
      <button onclick="resDismissHelp('lista')" class="res-help-close">&times;</button>
    </div>

    <!-- Toolbar -->
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="res-list-search" type="text" placeholder="Buscar por cliente, servicio..." oninput="resFilterList()" class="res-input" style="padding-left:38px;"/>
      </div>
      <select id="res-list-filter-status" onchange="resFilterList()" class="res-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="confirmada">Confirmada</option>
        <option value="pendiente">Pendiente</option>
        <option value="completada">Completada</option>
        <option value="cancelada">Cancelada</option>
      </select>
      <select id="res-list-filter-service" onchange="resFilterList()" class="res-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los servicios</option>
      </select>
      <button onclick="resQuickBook()" class="res-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva cita
      </button>
    </div>

    <!-- Table -->
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table id="res-list-table" class="res-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Cliente</th>
              <th>Servicio</th>
              <th>Fecha</th>
              <th>Hora</th>
              <th>Duracion</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="res-list-body"></tbody>
        </table>
      </div>
      <div id="res-list-empty" style="display:none;text-align:center;padding:48px 20px;">
        <svg style="width:48px;height:48px;color:var(--accent);opacity:0.5;margin:0 auto 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin-bottom:6px;">No hay citas</h3>
        <p style="font-size:13px;color:var(--text-muted);max-width:320px;margin:0 auto;line-height:1.5;">Agenda tu primera cita para empezar a organizar tu agenda.</p>
        <button onclick="resQuickBook()" class="res-btn-primary" style="margin-top:16px;padding:12px 28px;">Agendar primera cita</button>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Servicios ══════════ -->
  <div id="res-panel-servicios" style="display:none;">
    <div id="res-help-servicios" class="res-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Define los servicios que ofreces, con precio, duracion y capacidad. Estos aparecen cuando agendas una cita.</p>
      <button onclick="resDismissHelp('servicios')" class="res-help-close">&times;</button>
    </div>

    <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
      <button onclick="resAddService()" class="res-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Agregar servicio
      </button>
    </div>

    <div id="res-services-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;"></div>

    <div id="res-services-empty" style="display:none;text-align:center;padding:48px 20px;">
      <svg style="width:48px;height:48px;color:var(--accent);opacity:0.5;margin:0 auto 12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin-bottom:6px;">No tienes servicios</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:320px;margin:0 auto;line-height:1.5;">Agrega tus servicios para que los clientes puedan agendar.</p>
      <button onclick="resAddService()" class="res-btn-primary" style="margin-top:16px;padding:12px 28px;">Agregar primer servicio</button>
    </div>
  </div>

  <!-- ══════════ Tab: Disponibilidad ══════════ -->
  <div id="res-panel-disponibilidad" style="display:none;">
    <div id="res-help-disponibilidad" class="res-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Configura tus horarios de atencion por dia de la semana y bloquea fechas especificas. Tambien puedes definir cuantas citas puedes atender por hora.</p>
      <button onclick="resDismissHelp('disponibilidad')" class="res-help-close">&times;</button>
    </div>

    <!-- Business hours -->
    <div class="stat-card animate-in" style="padding:20px;margin-bottom:20px;">
      <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Horario de atencion</h4>
      <div id="res-hours-grid" style="display:flex;flex-direction:column;gap:10px;"></div>
    </div>

    <!-- Capacity -->
    <div class="stat-card animate-in" style="padding:20px;margin-bottom:20px;">
      <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:8px;">Capacidad por franja horaria <span class="res-tip" data-tip="Cuantas citas puedes atender al mismo tiempo en cada hora. Ej: si tienes 3 sillones de corte, puedes atender 3 a la vez">?</span></h4>
      <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
        <label class="res-label" style="min-width:auto;">Citas simultaneas:</label>
        <input id="res-capacity" type="number" min="1" max="50" value="3" class="res-input" style="width:80px;" onchange="showToast('Capacidad actualizada')"/>
        <p style="font-size:12px;color:var(--text-muted);">Por cada franja horaria</p>
      </div>
    </div>

    <!-- Blocked dates -->
    <div class="stat-card animate-in" style="padding:20px;">
      <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:8px;">Fechas bloqueadas <span class="res-tip" data-tip="Dias que no atiendes: vacaciones, dias festivos, etc.">?</span></h4>
      <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:12px;">
        <input id="res-block-date" type="date" class="res-input" style="width:auto;"/>
        <input id="res-block-reason" type="text" placeholder="Motivo (opcional)" class="res-input" style="width:200px;"/>
        <button onclick="resBlockDate()" class="res-btn-primary" style="padding:10px 16px;">Bloquear</button>
      </div>
      <div id="res-blocked-list" style="display:flex;flex-direction:column;gap:8px;"></div>
      <div id="res-blocked-empty" style="text-align:center;padding:20px;">
        <p style="font-size:13px;color:var(--text-muted);">No hay fechas bloqueadas. Agrega una para evitar agendamientos en dias no laborables.</p>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Analitica ══════════ -->
  <div id="res-panel-analitica" style="display:none;">
    <div id="res-help-analitica" class="res-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Estadisticas de tu agenda: cuantas citas tienes por dia, cuales son tus servicios mas populares y a que horas tienes mas demanda.</p>
      <button onclick="resDismissHelp('analitica')" class="res-help-close">&times;</button>
    </div>

    <!-- Reservations by day -->
    <div class="stat-card animate-in" style="padding:24px;margin-bottom:20px;">
      <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Reservaciones por dia</h3>
      <p style="font-size:12px;color:var(--text-muted);margin-bottom:20px;">Ultimos 7 dias</p>
      <div id="res-chart-daily" style="display:flex;align-items:flex-end;gap:12px;height:180px;padding:0 8px;"></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
      <!-- Top services -->
      <div class="stat-card animate-in" style="padding:24px;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Servicios mas populares</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Por numero de reservaciones</p>
        <div id="res-chart-services" style="display:flex;flex-direction:column;gap:12px;"></div>
      </div>

      <!-- No-shows rate -->
      <div class="stat-card animate-in" style="padding:24px;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Tasa de no-shows</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Comparado con el mes anterior</p>
        <div style="display:flex;align-items:center;justify-content:center;gap:24px;padding:20px 0;">
          <div style="text-align:center;">
            <p style="font-size:42px;font-weight:900;color:#ef4444;">13%</p>
            <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">Este mes</p>
          </div>
