---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:6100';
---

<DashboardLayout title="Configuraci&oacute;n">
  <!-- Two column layout -->
  <div style="display:grid;grid-template-columns:320px 1fr;gap:20px;">
    <!-- Left: Profile card -->
    <div>
      <div class="stat-card animate-in" style="text-align:center;padding:32px 24px;">
        <!-- Logo -->
        <div id="company-logo-preview" style="width:100px;height:100px;border-radius:20px;background:linear-gradient(135deg,var(--accent-gradient-start),var(--accent-gradient-end));display:flex;align-items:center;justify-content:center;margin:0 auto 16px;overflow:hidden;cursor:pointer;transition:all 0.3s;position:relative;box-shadow:0 8px 32px rgba(0,0,0,0.2);" onclick="document.getElementById('logo-upload').click()" onmouseover="this.querySelector('.logo-overlay').style.opacity='1'" onmouseout="this.querySelector('.logo-overlay').style.opacity='0'">
          <span id="company-logo-initials" style="font-size:36px;font-weight:900;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,0.2);">S</span>
          <img id="company-logo-img" src="" style="display:none;width:100%;height:100%;object-fit:cover;position:absolute;inset:0;" />
          <div class="logo-overlay" style="position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;opacity:0;transition:opacity 0.2s;border-radius:20px;">
            <svg style="width:20px;height:20px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span style="font-size:10px;font-weight:700;color:#fff;">Cambiar</span>
          </div>
          <input type="file" id="logo-upload" accept="image/*" style="display:none;" />
        </div>
        <h3 id="profile-company-name" style="font-size:18px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Mi empresa</h3>
        <p id="profile-email" style="font-size:12px;color:var(--text-faint);margin-bottom:16px;">serratos@skybrandmx.com</p>
        <div style="display:flex;gap:8px;justify-content:center;">
          <button onclick="document.getElementById('logo-upload').click()" style="padding:8px 16px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;font-weight:700;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">Subir logo</button>
          <button id="remove-logo-btn" onclick="removeLogo()" style="display:none;padding:8px 16px;border-radius:10px;border:1px solid rgba(239,68,68,0.3);background:transparent;color:#ef4444;font-size:11px;font-weight:700;cursor:pointer;">Quitar</button>
        </div>
        <!-- Plan badge -->
        <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border);">
          <div style="display:flex;align-items:center;justify-content:center;gap:6px;">
            <div style="width:8px;height:8px;border-radius:50%;background:#22c55e;"></div>
            <span style="font-size:12px;font-weight:700;color:var(--text-secondary);">Plan Growth</span>
          </div>
          <p style="font-size:11px;color:var(--text-faintest);margin-top:4px;">$1,999 MXN/mes</p>
        </div>
      </div>
    </div>

    <!-- Right: Forms -->
    <div>
      <!-- Company info -->
      <div class="stat-card animate-in" style="margin-bottom:20px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
          <div style="width:32px;height:32px;border-radius:10px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;">
            <svg style="width:16px;height:16px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);">Datos de empresa</h3>
        </div>
        <div style="display:grid;gap:16px;">
          <div>
            <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Nombre de la empresa</label>
            <input id="settings-company-name" type="text" placeholder="Ej: SkyBrandMX S.A. de C.V." style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:600;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">RFC</label>
              <input id="settings-rfc" type="text" placeholder="XAXX010101000" style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:600;text-transform:uppercase;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
            </div>
            <div>
              <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">R&eacute;gimen fiscal</label>
              <select style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--bg-sidebar);color:var(--text-primary);font-size:13px;font-weight:600;-webkit-appearance:none;appearance:none;background-image:url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2364748b%22 stroke-width=%222%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 16px center;padding-right:40px;cursor:pointer;">
                <option value="">Seleccionar...</option>
                <option>601 - General de Ley</option>
                <option>612 - Personas F&iacute;sicas con Act. Empresarial</option>
                <option>621 - Incorporaci&oacute;n Fiscal</option>
                <option>626 - Simplificado de Confianza</option>
              </select>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div>
              <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Tel&eacute;fono</label>
              <input type="tel" placeholder="+52 55 1234 5678" style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:600;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
            </div>
            <div>
              <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Sitio web</label>
              <input type="url" placeholder="https://tuempresa.com" style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:600;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
            </div>
          </div>
          <div>
            <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Direcci&oacute;n fiscal</label>
            <input type="text" placeholder="Calle, Numero, Colonia, CP, Ciudad, Estado" style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:600;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
          </div>
          <div style="display:flex;gap:10px;">
            <button style="padding:12px 28px;border-radius:12px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:800;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.opacity='0.9';this.style.transform='translateY(-1px)'" onmouseout="this.style.opacity='1';this.style.transform='none'">Guardar cambios</button>
          </div>
        </div>
      </div>

      <!-- Personal Account -->
      <div class="stat-card animate-in" style="margin-bottom:20px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
          <div style="width:32px;height:32px;border-radius:10px;background:rgba(168,85,247,0.1);display:flex;align-items:center;justify-content:center;">
            <svg style="width:16px;height:16px;color:#a855f7;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);">Mi cuenta</h3>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div>
            <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Nombre completo</label>
            <input id="settings-name" type="text" placeholder="Tu nombre" style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:600;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
          </div>
          <div>
            <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Email</label>
            <input id="settings-email" type="email" disabled style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-muted);font-size:13px;font-weight:600;cursor:not-allowed;opacity:0.6;" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Integrations -->
  <div class="stat-card animate-in" style="margin-bottom:20px;">
    <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:16px;">Integraciones</h3>
    <div style="display:flex;flex-direction:column;gap:12px;">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;border-radius:10px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;">
            <svg style="width:18px;height:18px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          </div>
          <div>
            <p style="font-size:13px;font-weight:700;color:var(--text-primary);">Shopify / WooCommerce</p>
            <p style="font-size:11px;color:var(--text-faint);">Sincroniza productos y pedidos</p>
          </div>
        </div>
        <span style="font-size:11px;font-weight:700;color:var(--text-faintest);background:var(--input-bg);border:1px solid var(--border);padding:4px 10px;border-radius:6px;">Pr&oacute;ximamente</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;border-radius:10px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;">
            <svg style="width:18px;height:18px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21l-7-5-7 5V5a2 2 0 012-2h10a2 2 0 012 2v16z"/></svg>
          </div>
          <div>
            <p style="font-size:13px;font-weight:700;color:var(--text-primary);">Facturama / SAT</p>
            <p style="font-size:11px;color:var(--text-faint);">Facturaci&oacute;n electr&oacute;nica CFDI 4.0</p>
          </div>
        </div>
        <span style="font-size:11px;font-weight:700;color:var(--text-faintest);background:var(--input-bg);border:1px solid var(--border);padding:4px 10px;border-radius:6px;">Pr&oacute;ximamente</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:36px;height:36px;border-radius:10px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;">
            <svg style="width:18px;height:18px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          </div>
          <div>
            <p style="font-size:13px;font-weight:700;color:var(--text-primary);">Estafeta / FedEx / DHL</p>
            <p style="font-size:11px;color:var(--text-faint);">Gu&iacute;as y rastreo autom&aacute;tico</p>
          </div>
        </div>
        <span style="font-size:11px;font-weight:700;color:var(--text-faintest);background:var(--input-bg);border:1px solid var(--border);padding:4px 10px;border-radius:6px;">Pr&oacute;ximamente</span>
      </div>
    </div>
  </div>

  <!-- Appearance -->
  <div class="stat-card animate-in" style="margin-bottom:20px;">
    <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:16px;">Apariencia</h3>
    <div style="display:flex;flex-direction:column;gap:16px;">
      <!-- Theme mode -->
      <div>
        <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:8px;">Modo</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <button id="setting-mode-dark" onclick="setThemeMode('dark')" style="padding:14px;border-radius:12px;border:2px solid var(--accent);background:var(--input-bg);cursor:pointer;text-align:center;transition:all 0.2s;">
            <svg style="width:20px;height:20px;color:var(--text-muted);margin:0 auto 4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            <p style="font-size:12px;font-weight:700;color:var(--text-secondary);">Oscuro</p>
          </button>
          <button id="setting-mode-light" onclick="setThemeMode('light')" style="padding:14px;border-radius:12px;border:2px solid var(--border);background:var(--input-bg);cursor:pointer;text-align:center;transition:all 0.2s;">
            <svg style="width:20px;height:20px;color:var(--text-muted);margin:0 auto 4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            <p style="font-size:12px;font-weight:700;color:var(--text-secondary);">Claro</p>
          </button>
        </div>
      </div>
      <!-- Accent color -->
      <div>
        <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:8px;">Color del tema</label>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
          <button class="color-swatch selected" style="background:#6fcff5;width:36px;height:36px;border-radius:10px;border:2px solid transparent;cursor:pointer;" onclick="setAccentColor('#6fcff5','#084D6E')"></button>
          <button class="color-swatch" style="background:#22c55e;width:36px;height:36px;border-radius:10px;border:2px solid transparent;cursor:pointer;" onclick="setAccentColor('#22c55e','#166534')"></button>
          <button class="color-swatch" style="background:#3b82f6;width:36px;height:36px;border-radius:10px;border:2px solid transparent;cursor:pointer;" onclick="setAccentColor('#3b82f6','#1e40af')"></button>
          <button class="color-swatch" style="background:#8b5cf6;width:36px;height:36px;border-radius:10px;border:2px solid transparent;cursor:pointer;" onclick="setAccentColor('#8b5cf6','#5b21b6')"></button>
          <button class="color-swatch" style="background:#ec4899;width:36px;height:36px;border-radius:10px;border:2px solid transparent;cursor:pointer;" onclick="setAccentColor('#ec4899','#9d174d')"></button>
          <button class="color-swatch" style="background:#f97316;width:36px;height:36px;border-radius:10px;border:2px solid transparent;cursor:pointer;" onclick="setAccentColor('#f97316','#9a3412')"></button>
        </div>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="color" id="settings-custom-color" value="#6fcff5" style="width:40px;height:40px;border:none;border-radius:8px;cursor:pointer;background:transparent;padding:0;" />
          <input type="text" id="settings-custom-hex" value="#6fcff5" placeholder="#hex" style="flex:1;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-family:monospace;" />
          <button onclick="const h=document.getElementById('settings-custom-hex').value;if(/^#[0-9a-fA-F]{6}$/.test(h))setAccentColor(h,h);" style="padding:10px 16px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:12px;font-weight:800;cursor:pointer;">Aplicar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Subscription -->
  <div class="stat-card animate-in" style="margin-bottom:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);">Suscripci&oacute;n</h3>
      <span style="font-size:11px;font-weight:800;color:#22c55e;background:rgba(34,197,94,0.1);padding:4px 12px;border-radius:999px;">Activa</span>
    </div>
    <div style="padding:16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);margin-bottom:16px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <div>
          <p style="font-size:14px;font-weight:800;color:var(--text-primary);">Plan Growth</p>
          <p style="font-size:12px;color:var(--text-faint);">Facturaci&oacute;n mensual</p>
        </div>
        <p style="font-size:24px;font-weight:900;color:var(--text-primary);">$1,999<span style="font-size:12px;font-weight:600;color:var(--text-faint);">/mes</span></p>
      </div>
      <div style="height:4px;border-radius:999px;background:var(--border);overflow:hidden;">
        <div style="height:100%;width:45%;border-radius:999px;background:var(--accent);"></div>
      </div>
      <p style="font-size:11px;color:var(--text-faint);margin-top:8px;">15 de 30 d&iacute;as del ciclo actual. Pr&oacute;ximo cobro: 15 abril 2026</p>
    </div>
    <div style="display:flex;gap:8px;">
      <button style="padding:10px 20px;border-radius:10px;border:1px solid var(--accent);background:transparent;color:var(--accent);font-size:12px;font-weight:700;cursor:pointer;">Cambiar plan</button>
      <button style="padding:10px 20px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;">Ver facturas</button>
    </div>
  </div>

  <!-- Security -->
  <div class="stat-card animate-in" style="margin-bottom:20px;">
    <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:16px;">Seguridad</h3>
    <div style="display:grid;gap:14px;">
      <div>
        <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Contrase&ntilde;a actual</label>
        <input type="password" placeholder="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;" style="width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;" />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div>
          <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Nueva contrase&ntilde;a</label>
          <input type="password" placeholder="M&iacute;nimo 8 caracteres" style="width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;" />
        </div>
        <div>
          <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Confirmar nueva contrase&ntilde;a</label>
          <input type="password" placeholder="Repite la contrase&ntilde;a" style="width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;" />
        </div>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);">
        <div>
          <p style="font-size:13px;font-weight:700;color:var(--text-primary);">Autenticaci&oacute;n 2FA</p>
          <p style="font-size:11px;color:var(--text-faint);">C&oacute;digo por email al iniciar sesi&oacute;n</p>
        </div>
        <span style="font-size:11px;font-weight:800;color:#22c55e;background:rgba(34,197,94,0.1);padding:4px 10px;border-radius:6px;">Activo</span>
      </div>
      <button style="padding:12px 20px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:800;cursor:pointer;width:fit-content;">Actualizar contrase&ntilde;a</button>
    </div>
  </div>

  <!-- Danger zone -->
  <div class="stat-card animate-in" style="border-color:rgba(239,68,68,0.2);">
    <h3 style="font-size:16px;font-weight:900;color:#ef4444;margin-bottom:8px;">Zona de peligro</h3>
    <p style="font-size:12px;color:var(--text-faint);margin-bottom:16px;">Estas acciones son irreversibles. Ten cuidado.</p>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <button onclick="localStorage.removeItem('skybrand_token');window.location.href='/login';" style="padding:10px 20px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;">Cerrar sesi&oacute;n</button>
      <button style="padding:10px 20px;border-radius:10px;border:1px solid #ef4444;background:transparent;color:#ef4444;font-size:12px;font-weight:700;cursor:pointer;" onclick="if(confirm('Estas seguro que quieres eliminar tu cuenta? Esta accion no se puede deshacer.'))alert('Funcionalidad en desarrollo. Contacta a soporte.')">Eliminar mi cuenta</button>
    </div>
  </div>

  <script define:vars={{ API_URL }}>
    // Logo upload preview
    document.getElementById('logo-upload')?.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      if (file.size > 2 * 1024 * 1024) { alert('El archivo es muy grande. Maximo 2MB.'); return; }
      const reader = new FileReader();
      reader.onload = (ev) => {
        const img = document.getElementById('company-logo-img');
        const initials = document.getElementById('company-logo-initials');
        const removeBtn = document.getElementById('remove-logo-btn');
        img.src = ev.target.result;
        img.style.display = 'block';
        initials.style.display = 'none';
        removeBtn.style.display = 'inline-block';
        localStorage.setItem('skybrand_company_logo', ev.target.result);
      };
      reader.readAsDataURL(file);
    });

    window.removeLogo = function() {
      document.getElementById('company-logo-img').style.display = 'none';
      document.getElementById('company-logo-initials').style.display = 'block';
      document.getElementById('remove-logo-btn').style.display = 'none';
      document.getElementById('logo-upload').value = '';
      localStorage.removeItem('skybrand_company_logo');
    };

    // Load saved logo
    const savedLogo = localStorage.getItem('skybrand_company_logo');
    if (savedLogo) {
      const img = document.getElementById('company-logo-img');
      if (img) { img.src = savedLogo; img.style.display = 'block'; }
      const initials = document.getElementById('company-logo-initials');
      if (initials) initials.style.display = 'none';
      const removeBtn = document.getElementById('remove-logo-btn');
      if (removeBtn) removeBtn.style.display = 'inline-block';
    }

    // Sync color picker
    document.getElementById('settings-custom-color')?.addEventListener('input', (e) => {
      document.getElementById('settings-custom-hex').value = e.target.value;
    });

    // Fill user settings on auth
    function fillSettings(user) {
      const settingsName = document.getElementById('settings-name');
      const settingsEmail = document.getElementById('settings-email');
      const profileEmail = document.getElementById('profile-email');
      if (settingsName) settingsName.value = user.full_name || '';
      if (settingsEmail) settingsEmail.value = user.email || '';
      if (profileEmail) profileEmail.textContent = user.email || '';
    }

    window.addEventListener('skybrand:auth', (e) => { fillSettings(e.detail); });
    if (window._skybrandUser) { fillSettings(window._skybrandUser); }
  </script>
</DashboardLayout>
