---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:6100';
---

<DashboardLayout title="Pedidos">
  <!-- Smart Recommendations -->
  <div id="ped-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Pedidos hoy</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-today" class="ped-stat-val">--</p><span id="ped-trend-today" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Ingresos del mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-revenue" class="ped-stat-val" style="color:#22c55e;">--</p><span id="ped-trend-revenue" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Ticket promedio <span class="ped-tip" data-tip="Lo que gasta en promedio cada cliente por pedido">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-avg" class="ped-stat-val" style="color:var(--accent);">--</p><span id="ped-trend-avg" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Pendientes de envío <span class="ped-tip" data-tip="Pedidos que ya están pagados pero aún no se envían al cliente">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-pending" class="ped-stat-val" style="color:#f97316;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Tasa de conversión <span class="ped-tip" data-tip="De cada 100 personas que visitan tu tienda, ¿cuántas terminan comprando?">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-conv" class="ped-stat-val">--</p><span id="ped-trend-conv" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Devoluciones <span class="ped-tip" data-tip="Pedidos que el cliente pidió regresar o cancelar después de recibirlos">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-returns" class="ped-stat-val" style="color:#ef4444;">--</p><span id="ped-trend-returns" class="ped-trend"></span></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="ped-tab-all" class="ped-tab active" onclick="switchPedTab('all')">Todos los pedidos</button>
    <button id="ped-tab-ship" class="ped-tab" onclick="switchPedTab('ship')">Por enviar <span id="ped-ship-badge" class="ped-tab-badge">0</span></button>
    <button id="ped-tab-returns" class="ped-tab" onclick="switchPedTab('returns')">Devoluciones</button>
    <button id="ped-tab-analytics" class="ped-tab" onclick="switchPedTab('analytics')">Analítica</button>
  </div>

  <!-- ══════════ Tab: All Orders ══════════ -->
  <div id="ped-panel-all">
    <div id="ped-help-all" class="ped-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aquí ves todos los pedidos de tu tienda. Puedes filtrar por estado, buscar por nombre o número de pedido.</p>
      <button onclick="pedDismissHelp('all')" class="ped-help-close">&times;</button>
    </div>
    <div id="ped-empty-all" style="display:none;" class="ped-empty-state">
      <svg style="width:56px;height:56px;color:var(--accent);opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">Aún no tienes pedidos</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:360px;line-height:1.5;">Cuando tus clientes compren en tu tienda, sus pedidos aparecerán aquí automáticamente.</p>
      <button onclick="openOrderWizard()" class="ped-btn-primary" style="margin-top:16px;padding:12px 28px;">Crear pedido manual</button>
    </div>
    <!-- Toolbar -->
    <div id="ped-toolbar" class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="ped-search" type="text" placeholder="Buscar por nombre, # pedido..." oninput="pedFilter()" class="ped-input" style="padding-left:38px;"/>
      </div>
      <select id="ped-filter-status" onchange="pedFilter()" class="ped-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="new">Nuevo</option>
        <option value="paid">Pagado</option>
        <option value="preparing">Preparando</option>
        <option value="shipped">Enviado</option>
        <option value="delivered">Entregado</option>
        <option value="cancelled">Cancelado</option>
      </select>
      <select id="ped-filter-date" onchange="pedFilter()" class="ped-input" style="width:auto;cursor:pointer;">
        <option value="">Todas las fechas</option>
        <option value="today">Hoy</option>
        <option value="week">Esta semana</option>
        <option value="month">Este mes</option>
      </select>
      <button onclick="openOrderWizard()" class="ped-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Crear pedido
      </button>
      <div style="position:relative;" id="ped-more-wrap">
        <button onclick="pedToggleMore()" class="ped-btn-secondary" style="padding:10px 14px;display:flex;align-items:center;gap:4px;">Más <svg style="width:12px;height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></button>
        <div id="ped-more-menu" style="display:none;position:absolute;top:100%;right:0;margin-top:4px;background:var(--bg-sidebar);border:1px solid var(--border);border-radius:10px;padding:6px;min-width:160px;z-index:50;box-shadow:0 4px 20px rgba(0,0,0,0.3);">
          <button onclick="showToast('CSV exportado');pedToggleMore()" class="ped-dropdown-item">📄 Exportar CSV</button>
          <button onclick="showToast('Lista impresa');pedToggleMore()" class="ped-dropdown-item">🖨 Imprimir lista</button>
        </div>
      </div>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="ped-th"># Pedido</th><th class="ped-th">Cliente</th><th class="ped-th">Productos</th>
            <th class="ped-th" style="text-align:right;">Total</th><th class="ped-th">Estado</th>
            <th class="ped-th">Pago</th><th class="ped-th">Fecha</th><th class="ped-th" style="text-align:center;">Acciones</th>
          </tr></thead>
          <tbody id="ped-orders-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Por enviar ══════════ -->
  <div id="ped-panel-ship" style="display:none;">
    <div id="ped-help-ship" class="ped-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Estos pedidos ya están pagados y esperan ser enviados. Entre más rápido los envíes, mejor experiencia para tu cliente.</p>
      <button onclick="pedDismissHelp('ship')" class="ped-help-close">&times;</button>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
      <button onclick="pedShipAll()" class="ped-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
        Generar todas las guías
      </button>
    </div>
    <div id="ped-ship-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;"></div>
    <div id="ped-empty-ship" style="display:none;" class="ped-empty-state">
      <svg style="width:56px;height:56px;color:#22c55e;opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">¡Todo enviado!</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:360px;line-height:1.5;">No tienes pedidos pendientes de envío. ¡Excelente trabajo!</p>
    </div>
  </div>

  <!-- ══════════ Tab: Devoluciones ══════════ -->
  <div id="ped-panel-returns" style="display:none;">
    <div id="ped-help-returns" class="ped-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Solicitudes de devolución de tus clientes. Revisa cada caso y decide si apruebas el reembolso.</p>
      <button onclick="pedDismissHelp('returns')" class="ped-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="ped-th"># Pedido</th><th class="ped-th">Cliente</th><th class="ped-th">Motivo</th>
            <th class="ped-th">Estado</th><th class="ped-th" style="text-align:right;">Monto</th>
            <th class="ped-th">Fecha</th><th class="ped-th" style="text-align:center;">Acciones</th>
          </tr></thead>
          <tbody id="ped-returns-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Analítica ══════════ -->
  <div id="ped-panel-analytics" style="display:none;">
    <div id="ped-help-analytics" class="ped-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Mira cómo van tus ventas. Descubre qué productos se venden más y a qué hora compran tus clientes.</p>
      <button onclick="pedDismissHelp('analytics')" class="ped-help-close">&times;</button>
    </div>
    <!-- Weekly report -->
    <div class="stat-card animate-in" style="padding:20px;margin-bottom:20px;background:linear-gradient(135deg,rgba(111,207,245,0.06),rgba(139,92,246,0.06));border:1px solid rgba(111,207,245,0.15);">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:10px;">
          <div style="width:36px;height:36px;border-radius:10px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;">
            <svg style="width:18px;height:18px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <div><h4 style="font-size:14px;font-weight:800;color:var(--text-primary);">Reporte semanal de ventas</h4><p style="font-size:11px;color:var(--text-muted);">Recibe un resumen cada lunes</p></div>
        </div>
        <div style="display:flex;align-items:center;gap:10px;">
          <label class="ped-toggle-wrap"><input type="checkbox" checked onchange="pedToggleReport(this.checked)"/><span class="ped-toggle-slider"></span></label>
          <span id="ped-report-status" style="font-size:11px;font-weight:700;color:#22c55e;">Activo</span>
        </div>
      </div>
      <div id="ped-weekly-report"></div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:20px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Ingresos por mes</h4>
        <div id="ped-chart-revenue" style="height:200px;display:flex;align-items:flex-end;gap:6px;"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Productos más vendidos</h4>
        <div id="ped-chart-top"></div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Horario pico de compras <span class="ped-tip" data-tip="Muestra a qué hora y día compran más tus clientes">?</span></h4>
        <div id="ped-chart-hours"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Métodos de pago</h4>
        <div id="ped-chart-payments"></div>
      </div>
    </div>
  </div>

  <!-- Autopilot (collapsed) -->
  <div class="stat-card animate-in" style="padding:0;margin-top:20px;overflow:hidden;">
    <button onclick="pedToggleSection('ped-autopilot-content')" class="ped-collapse-header">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,rgba(34,197,94,0.15),rgba(111,207,245,0.15));display:flex;align-items:center;justify-content:center;">
          <svg style="width:14px;height:14px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div style="text-align:left;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">Piloto automático de pedidos</p><p style="font-size:11px;color:var(--text-faint);">Automatiza notificaciones y seguimiento</p></div>
      </div>
      <svg style="width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </button>
    <div id="ped-autopilot-content" style="display:none;padding:20px;">
      <div id="ped-autopilot-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;"></div>
    </div>
  </div>

  <!-- Modal: Order Detail -->
  <div id="ped-modal-detail" class="ped-modal-overlay" style="display:none;">
    <div class="ped-modal-box" style="max-width:700px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 id="ped-detail-title" style="font-size:17px;font-weight:900;color:var(--text-primary);">Pedido #--</h3>
        <button onclick="closeOrderDetail()" class="ped-modal-close">&times;</button>
      </div>
      <div id="ped-detail-body"></div>
    </div>
  </div>

  <!-- Modal: Create Order Wizard -->
  <div id="ped-modal-wizard" class="ped-modal-overlay" style="display:none;">
    <div class="ped-modal-box" style="max-width:580px;">
      <div style="display:flex;align-items:center;gap:0;margin-bottom:24px;">
        <div id="ped-wiz-step-1" class="ped-wiz-step active"><span class="ped-wiz-num">1</span><span class="ped-wiz-label">Cliente</span></div>
        <div class="ped-wiz-conn" id="ped-wiz-conn-1"></div>
        <div id="ped-wiz-step-2" class="ped-wiz-step"><span class="ped-wiz-num">2</span><span class="ped-wiz-label">Productos</span></div>
        <div class="ped-wiz-conn" id="ped-wiz-conn-2"></div>
        <div id="ped-wiz-step-3" class="ped-wiz-step"><span class="ped-wiz-num">3</span><span class="ped-wiz-label">Confirmar</span></div>
      </div>
      <div id="ped-wiz-panel-1" class="ped-wiz-panel">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">¿Para quién es el pedido?</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Busca un cliente existente o agrega uno nuevo.</p>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div><label class="ped-label">Nombre del cliente</label><input id="ped-wiz-client" type="text" placeholder="Ej: María García López" class="ped-input"/></div>
          <div><label class="ped-label">Email</label><input id="ped-wiz-email" type="email" placeholder="cliente@email.com" class="ped-input"/></div>
          <div><label class="ped-label">Teléfono</label><input id="ped-wiz-phone" type="tel" placeholder="55 1234 5678" class="ped-input"/></div>
          <div><label class="ped-label">Dirección de envío</label><input id="ped-wiz-address" type="text" placeholder="Calle, número, colonia, CP, ciudad" class="ped-input"/></div>
        </div>
      </div>
      <div id="ped-wiz-panel-2" class="ped-wiz-panel" style="display:none;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">¿Qué productos lleva?</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Agrega los productos y cantidades del pedido.</p>
        <div id="ped-wiz-products" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button onclick="pedWizAddProduct()" style="margin-top:10px;padding:8px 16px;border-radius:8px;border:1px dashed var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:600;cursor:pointer;width:100%;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">+ Agregar producto</button>
        <div style="display:flex;justify-content:flex-end;margin-top:12px;padding-top:12px;border-top:1px solid var(--border);">
          <div style="text-align:right;"><p style="font-size:11px;color:var(--text-faint);">Total</p><p id="ped-wiz-total" style="font-size:22px;font-weight:900;color:var(--text-primary);">$0.00</p></div>
        </div>
      </div>
      <div id="ped-wiz-panel-3" class="ped-wiz-panel" style="display:none;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Revisa el pedido</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Verifica que todo esté correcto.</p>
        <div id="ped-wiz-summary" style="border:1px solid var(--border);border-radius:10px;padding:16px;background:var(--input-bg);"></div>
        <div style="margin-top:14px;"><label class="ped-label">Método de pago</label><select id="ped-wiz-payment" class="ped-input" style="cursor:pointer;"><option value="card">Tarjeta</option><option value="oxxo">OXXO</option><option value="transfer">Transferencia</option><option value="cash">Efectivo</option></select></div>
        <div style="margin-top:10px;"><label class="ped-label">Notas (opcional)</label><input id="ped-wiz-notes" type="text" placeholder="Instrucciones especiales..." class="ped-input"/></div>
      </div>
      <div style="display:flex;gap:10px;margin-top:20px;">
        <button id="ped-wiz-back" onclick="pedWizBack()" class="ped-btn-secondary" style="flex:1;display:none;">← Anterior</button>
        <button id="ped-wiz-next" onclick="pedWizNext()" class="ped-btn-primary" style="flex:1;">Siguiente →</button>
        <button id="ped-wiz-create" onclick="pedWizCreate()" class="ped-btn-primary" style="flex:1;display:none;background:#22c55e;">Crear pedido</button>
