        <a href="/dashboard/reportes" class="stat-card" style="padding:14px;cursor:pointer;transition:border-color 0.2s;text-decoration:none;text-align:center;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
          <span style="font-size:24px;display:block;margin-bottom:6px;">📊</span>
          <p style="font-size:12px;font-weight:700;color:var(--text-primary);">Reportes</p>
