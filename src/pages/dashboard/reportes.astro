// ═══════ CASH FLOW CHART ═══════
function renderCashflowChart() {
  const container = document.getElementById('rep-chart-flujo');
  const maxVal = Math.max(...repCashflow.map(w => Math.max(w.inflow, w.outflow)));
  container.innerHTML = repCashflow.map(w => {
    const inH = (w.inflow / maxVal * 160);
    const outH = (w.outflow / maxVal * 160);
    const saldo = w.inflow - w.outflow;
    const saldoH = Math.abs(saldo) / maxVal * 160;
    return `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;">
      <div style="display:flex;gap:2px;align-items:flex-end;height:160px;">
        <div class="rep-bar" style="width:14px;height:${inH}px;background:#22c55e;"><span class="rep-bar-label">${repFmt(w.inflow)}</span></div>
        <div class="rep-bar" style="width:14px;height:${outH}px;background:#ef4444;"><span class="rep-bar-label">${repFmt(w.outflow)}</span></div>
        <div class="rep-bar" style="width:14px;height:${saldoH}px;background:var(--accent);"><span class="rep-bar-label">${saldo >= 0 ? '+' : ''}${repFmt(saldo)}</span></div>
      </div>
      <span style="font-size:9px;font-weight:700;color:var(--text-faint);text-align:center;line-height:1.2;">${w.week}</span>
    </div>`;
  }).join('');
}

// ═══════ CASH FLOW TABLE ═══════
function renderCashflowTable() {
  const tbody = document.getElementById('rep-flujo-tbody');
  tbody.innerHTML = repCashflow.map(w => {
    const saldo = w.inflow - w.outflow;
    const saldoColor = saldo >= 0 ? '#22c55e' : '#ef4444';
    return `<tr class="rep-pnl-row">
      <td style="font-weight:700;">${w.week}</td>
      <td style="text-align:right;color:#22c55e;font-weight:700;">${repFmt(w.inflow)}</td>
      <td style="text-align:right;color:#ef4444;font-weight:700;">${repFmt(w.outflow)}</td>
      <td style="text-align:right;color:${saldoColor};font-weight:700;">${saldo >= 0 ? '+' : ''}${repFmt(saldo)}</td>
    </tr>`;
  }).join('');
}

// ═══════ PRODUCT CHART ═══════
function renderProductChart() {
