---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:6100';
---

<DashboardLayout title="Reportes">
  <!-- ══════════ Smart Recommendations ══════════ -->
  <div id="rep-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Ingresos totales <span class="rep-tip" data-tip="Todo el dinero que entra a tu negocio por ventas, antes de restar gastos">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="rep-stat-revenue" style="font-size:28px;font-weight:900;color:#22c55e;">$158,200</p><span class="rep-trend rep-trend-up">+18.2%</span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Utilidad neta <span class="rep-tip" data-tip="Lo que realmente ganas despues de todos los gastos: productos, envios, comisiones y publicidad">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="rep-stat-profit" style="font-size:28px;font-weight:900;color:var(--text-primary);">$48,600</p><span class="rep-trend rep-trend-up">+12.4%</span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Margen de utilidad <span class="rep-tip" data-tip="De cada peso que vendes, cuantos centavos te quedan de ganancia. Arriba de 25% es bueno para e-commerce">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="rep-stat-margin" style="font-size:28px;font-weight:900;color:var(--accent);">30.7%</p><span class="rep-trend rep-trend-down">-3.0%</span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Gastos del mes <span class="rep-tip" data-tip="Suma de todos tus costos: productos, envios, comisiones de plataformas y publicidad">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="rep-stat-expenses" style="font-size:28px;font-weight:900;color:#f97316;">$109,600</p><span class="rep-trend rep-trend-up">+22.1%</span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">IVA por declarar <span class="rep-tip" data-tip="IVA que cobraste a tus clientes menos el IVA que pagaste en tus compras. Esto lo debes declarar al SAT">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="rep-stat-iva" style="font-size:28px;font-weight:900;color:#ef4444;">$8,200</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Mejor producto <span class="rep-tip" data-tip="El producto que te genera mas ganancia este mes">?</span></p>
      <div><p style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Playera Premium</p><p style="font-size:11px;color:#22c55e;font-weight:700;">$18,400 utilidad</p></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="rep-tab-resumen" class="rep-tab active" onclick="switchRepTab('resumen')">Resumen financiero</button>
    <button id="rep-tab-flujo" class="rep-tab" onclick="switchRepTab('flujo')">Flujo de caja</button>
    <button id="rep-tab-producto" class="rep-tab" onclick="switchRepTab('producto')">Por producto</button>
    <button id="rep-tab-impuestos" class="rep-tab" onclick="switchRepTab('impuestos')">Impuestos</button>
    <button id="rep-tab-exportar" class="rep-tab" onclick="switchRepTab('exportar')">Exportar</button>
  </div>

  <!-- ══════════ Tab: Resumen Financiero ══════════ -->
  <div id="rep-panel-resumen">
    <div id="rep-help-resumen" class="rep-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Este es tu estado de resultados simplificado. Muestra cuanto vendes, cuanto gastas y cuanto te queda de ganancia cada mes.</p>
      <button onclick="repDismissHelp('resumen')" class="rep-help-close">&times;</button>
    </div>

    <!-- Bar chart -->
    <div class="stat-card animate-in" style="padding:24px;margin-bottom:20px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
        <div>
          <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Ingresos vs Utilidad</h3>
          <p style="font-size:12px;color:var(--text-muted);">Ultimos 6 meses</p>
        </div>
        <div style="display:flex;gap:16px;align-items:center;">
          <div style="display:flex;align-items:center;gap:6px;"><div style="width:12px;height:12px;border-radius:3px;background:#22c55e;"></div><span style="font-size:11px;color:var(--text-muted);font-weight:600;">Ingresos</span></div>
          <div style="display:flex;align-items:center;gap:6px;"><div style="width:12px;height:12px;border-radius:3px;background:var(--accent);"></div><span style="font-size:11px;color:var(--text-muted);font-weight:600;">Utilidad</span></div>
          <div style="display:flex;align-items:center;gap:6px;"><div style="width:12px;height:12px;border-radius:3px;background:#f97316;"></div><span style="font-size:11px;color:var(--text-muted);font-weight:600;">Gastos</span></div>
        </div>
      </div>
      <div id="rep-chart-resumen" style="display:flex;align-items:flex-end;gap:12px;height:220px;padding:0 8px;"></div>
    </div>

    <!-- P&L Table -->
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="padding:20px 20px 12px;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Estado de resultados <span class="rep-tip" data-tip="Resumen de cuanto vendes, cuanto gastas y cuanto ganas. Es la base para saber si tu negocio es rentable">?</span></h3>
        <p style="font-size:12px;color:var(--text-muted);">Desglose mensual simplificado</p>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid var(--border);">
              <th class="rep-th" style="min-width:180px;">Concepto</th>
              <th class="rep-th" style="text-align:right;">Nov</th>
              <th class="rep-th" style="text-align:right;">Dic</th>
              <th class="rep-th" style="text-align:right;">Ene</th>
              <th class="rep-th" style="text-align:right;">Feb</th>
              <th class="rep-th" style="text-align:right;">Mar</th>
              <th class="rep-th" style="text-align:right;">Abr</th>
            </tr>
          </thead>
          <tbody id="rep-pnl-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Flujo de Caja ══════════ -->
  <div id="rep-panel-flujo" style="display:none;">
    <div id="rep-help-flujo" class="rep-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Flujo de caja = dinero que entra vs dinero que sale de tu negocio cada semana. Te ayuda a saber si vas a tener suficiente dinero para pagar tus gastos.</p>
      <button onclick="repDismissHelp('flujo')" class="rep-help-close">&times;</button>
    </div>

    <!-- Cash flow chart -->
    <div class="stat-card animate-in" style="padding:24px;margin-bottom:20px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
        <div>
          <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Flujo de caja semanal</h3>
          <p style="font-size:12px;color:var(--text-muted);">Dinero que entra y sale de tu negocio <span class="rep-tip" data-tip="Dinero que entra vs dinero que sale de tu negocio. Si sale mas de lo que entra, vas a tener problemas de liquidez">?</span></p>
        </div>
        <div style="display:flex;gap:16px;align-items:center;">
          <div style="display:flex;align-items:center;gap:6px;"><div style="width:12px;height:12px;border-radius:3px;background:#22c55e;"></div><span style="font-size:11px;color:var(--text-muted);font-weight:600;">Entradas</span></div>
          <div style="display:flex;align-items:center;gap:6px;"><div style="width:12px;height:12px;border-radius:3px;background:#ef4444;"></div><span style="font-size:11px;color:var(--text-muted);font-weight:600;">Salidas</span></div>
          <div style="display:flex;align-items:center;gap:6px;"><div style="width:12px;height:12px;border-radius:3px;background:var(--accent);"></div><span style="font-size:11px;color:var(--text-muted);font-weight:600;">Saldo</span></div>
        </div>
      </div>
      <div id="rep-chart-flujo" style="display:flex;align-items:flex-end;gap:8px;height:200px;padding:0 8px;"></div>
    </div>

    <!-- Cash flow table -->
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="padding:20px 20px 12px;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Detalle semanal</h3>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid var(--border);">
              <th class="rep-th">Semana</th>
              <th class="rep-th" style="text-align:right;">Entradas <span class="rep-tip" data-tip="Pagos de clientes, reembolsos recibidos, otros ingresos">?</span></th>
              <th class="rep-th" style="text-align:right;">Salidas <span class="rep-tip" data-tip="Pagos a proveedores, envios, comisiones, publicidad, otros gastos">?</span></th>
              <th class="rep-th" style="text-align:right;">Saldo <span class="rep-tip" data-tip="Entradas menos salidas. Si es positivo, te quedo dinero. Si es negativo, gastaste mas de lo que ganaste">?</span></th>
            </tr>
          </thead>
          <tbody id="rep-flujo-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Por Producto ══════════ -->
  <div id="rep-panel-producto" style="display:none;">
    <div id="rep-help-producto" class="rep-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Descubre cuales productos te dejan mas ganancia. No siempre el que mas vendes es el que mas dinero te genera.</p>
      <button onclick="repDismissHelp('producto')" class="rep-help-close">&times;</button>
    </div>

    <!-- Product revenue chart -->
    <div class="stat-card animate-in" style="padding:24px;margin-bottom:20px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
        <div>
          <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Rentabilidad por producto</h3>
          <p style="font-size:12px;color:var(--text-muted);">Cuales productos te generan mas dinero</p>
        </div>
      </div>
      <div id="rep-chart-producto" style="display:flex;flex-direction:column;gap:12px;"></div>
    </div>

    <!-- Product table -->
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="padding:20px 20px 12px;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Desglose por producto</h3>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid var(--border);">
              <th class="rep-th">Producto</th>
              <th class="rep-th" style="text-align:right;">Unidades</th>
              <th class="rep-th" style="text-align:right;">Ingresos <span class="rep-tip" data-tip="Total de ventas de este producto">?</span></th>
              <th class="rep-th" style="text-align:right;">Costo <span class="rep-tip" data-tip="Lo que te cuesta comprar o fabricar este producto">?</span></th>
              <th class="rep-th" style="text-align:right;">Utilidad <span class="rep-tip" data-tip="Lo que te queda despues de restar el costo del producto">?</span></th>
              <th class="rep-th" style="text-align:right;">Margen <span class="rep-tip" data-tip="Porcentaje de ganancia. Si vendes en $100 y te cuesta $60, tu margen es 40%">?</span></th>
              <th class="rep-th" style="text-align:center;">Tendencia</th>
            </tr>
          </thead>
          <tbody id="rep-producto-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Impuestos ══════════ -->
  <div id="rep-panel-impuestos" style="display:none;">
    <div id="rep-help-impuestos" class="rep-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Resumen de impuestos para que tu contador lo tenga facil. Recuerda declarar tu IVA antes del dia 17 de cada mes.</p>
      <button onclick="repDismissHelp('impuestos')" class="rep-help-close">&times;</button>
    </div>

    <!-- SAT reminder -->
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;background:linear-gradient(135deg,rgba(239,68,68,0.08),rgba(249,115,22,0.08));border:1px solid rgba(239,68,68,0.15);">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <div style="width:40px;height:40px;border-radius:10px;background:rgba(239,68,68,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg style="width:20px;height:20px;color:#ef4444;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div style="flex:1;">
          <h4 style="font-size:13px;font-weight:800;color:#ef4444;margin-bottom:2px;">Proxima declaracion: 17 de abril 2026</h4>
          <p style="font-size:12px;color:var(--text-muted);">Tienes $8,200 de IVA por declarar correspondiente a marzo 2026. No olvides presentar tu declaracion mensual ante el SAT.</p>
        </div>
        <button onclick="repExportTax()" class="rep-btn-primary" style="background:#ef4444;padding:10px 20px;white-space:nowrap;">Exportar para mi contador</button>
      </div>
    </div>

    <!-- Tax summary cards -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-bottom:20px;">
      <div class="stat-card animate-in" style="padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">IVA cobrado <span class="rep-tip" data-tip="El IVA que cobraste a tus clientes en cada venta. Esto se lo debes al SAT">?</span></p>
        <p style="font-size:24px;font-weight:900;color:#ef4444;">$25,312</p>
      </div>
      <div class="stat-card animate-in" style="padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">IVA pagado <span class="rep-tip" data-tip="El IVA que pagaste al comprar productos, insumos y servicios. Esto se resta del IVA que debes">?</span></p>
        <p style="font-size:24px;font-weight:900;color:#22c55e;">$17,112</p>
      </div>
      <div class="stat-card animate-in" style="padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">IVA por pagar <span class="rep-tip" data-tip="IVA cobrado menos IVA pagado. Es lo que debes declarar y pagar al SAT">?</span></p>
        <p style="font-size:24px;font-weight:900;color:#f97316;">$8,200</p>
      </div>
      <div class="stat-card animate-in" style="padding:18px 20px;">
        <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">ISR estimado <span class="rep-tip" data-tip="Impuesto Sobre la Renta estimado basado en tu utilidad. El calculo exacto depende de tu regimen fiscal">?</span></p>
        <p style="font-size:24px;font-weight:900;color:var(--text-primary);">$14,580</p>
      </div>
    </div>

    <!-- Tax monthly table -->
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="padding:20px 20px 12px;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Desglose mensual de impuestos</h3>
        <p style="font-size:12px;color:var(--text-muted);">Estos datos son estimaciones. Confirma con tu contador antes de declarar.</p>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid var(--border);">
              <th class="rep-th">Mes</th>
              <th class="rep-th" style="text-align:right;">Ingresos</th>
              <th class="rep-th" style="text-align:right;">IVA cobrado <span class="rep-tip" data-tip="16% del total de tus ventas">?</span></th>
              <th class="rep-th" style="text-align:right;">IVA pagado</th>
              <th class="rep-th" style="text-align:right;">IVA por pagar</th>
              <th class="rep-th" style="text-align:right;">ISR estimado <span class="rep-tip" data-tip="Estimacion basada en tasa del 30% sobre utilidad. Tu contador calculara la tasa real segun tu regimen">?</span></th>
              <th class="rep-th" style="text-align:center;">Declarado</th>
            </tr>
          </thead>
          <tbody id="rep-impuestos-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- SAT dates -->
    <div class="stat-card animate-in" style="padding:20px;margin-top:20px;">
      <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:12px;">Calendario de declaraciones SAT</h3>
      <div id="rep-sat-calendar" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;"></div>
    </div>
  </div>

  <!-- ══════════ Tab: Exportar ══════════ -->
  <div id="rep-panel-exportar" style="display:none;">
    <div id="rep-help-exportar" class="rep-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Descarga tus reportes en CSV o PDF para compartir con tu contador o guardarlos en tus archivos.</p>
      <button onclick="repDismissHelp('exportar')" class="rep-help-close">&times;</button>
    </div>

    <!-- Export form -->
    <div class="stat-card animate-in" style="padding:24px;margin-bottom:20px;">
      <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:16px;">Descargar reportes</h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:20px;">
        <div>
          <label class="rep-label">Tipo de reporte</label>
          <select id="rep-export-type" class="rep-input" style="cursor:pointer;">
            <option value="pnl">Estado de resultados</option>
            <option value="cashflow">Flujo de caja</option>
            <option value="products">Rentabilidad por producto</option>
            <option value="taxes">Impuestos (IVA e ISR)</option>
            <option value="all">Reporte completo</option>
          </select>
        </div>
        <div>
          <label class="rep-label">Desde</label>
          <input id="rep-export-from" type="date" class="rep-input" value="2025-11-01"/>
        </div>
        <div>
          <label class="rep-label">Hasta</label>
          <input id="rep-export-to" type="date" class="rep-input" value="2026-04-01"/>
