// ═══════ RESUMEN CHART ═══════
function renderResumenChart() {
  const container = document.getElementById('rep-chart-resumen');
  const maxVal = Math.max(...repPnlData.ingresos);
  container.innerHTML = repMonths.map((m, i) => {
    const ingH = (repPnlData.ingresos[i] / maxVal * 180);
    const utilH = (repPnlData.utilidad[i] / maxVal * 180);
    const gastoH = ((repPnlData.ingresos[i] - repPnlData.utilidad[i]) / maxVal * 180);
    return `<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;">
      <div style="display:flex;gap:3px;align-items:flex-end;height:180px;">
        <div class="rep-bar" style="width:18px;height:${ingH}px;background:#22c55e;"><span class="rep-bar-label">${repFmt(repPnlData.ingresos[i])}</span></div>
        <div class="rep-bar" style="width:18px;height:utilH > 0 ? ${utilH}px : '2px';background:var(--accent);"><span class="rep-bar-label">${repFmt(repPnlData.utilidad[i])}</span></div>
        <div class="rep-bar" style="width:18px;height:${gastoH}px;background:#f97316;opacity:0.6;"><span class="rep-bar-label">${repFmt(repPnlData.ingresos[i] - repPnlData.utilidad[i])}</span></div>
      </div>
      <span style="font-size:11px;font-weight:700;color:var(--text-faint);">${m}</span>
    </div>`;
  }).join('');
}

