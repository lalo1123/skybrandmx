    const profit = p.revenue - p.cost;
    const margin = ((profit / p.revenue) * 100);
    const barW = (p.revenue / maxRevenue * 100);
    const profitW = (profit / maxRevenue * 100);
    return `<div style="display:flex;align-items:center;gap:12px;">
      <div style="width:120px;flex-shrink:0;"><p style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:1px;">${p.name}</p><p style="font-size:10px;color:var(--text-faint);">${repPct(margin)} margen</p></div>
      <div style="flex:1;position:relative;height:28px;">
        <div class="rep-hbar" style="width:${barW}%;background:${p.color};opacity:0.2;position:absolute;top:0;"></div>
        <div class="rep-hbar" style="width:${profitW}%;background:${p.color};position:absolute;top:0;"></div>
        <span style="position:absolute;right:8px;top:50%;transform:translateY(-50%);font-size:11px;font-weight:800;color:var(--text-primary);">${repFmt(profit)}</span>
      </div>
    </div>`;
  }).join('');
}

// ═══════ PRODUCT TABLE ═══════
function renderProductTable() {
  const tbody = document.getElementById('rep-producto-tbody');
  tbody.innerHTML = repProducts.map(p => {
    const profit = p.revenue - p.cost;
    const margin = ((profit / p.revenue) * 100);
    const trendIcon = p.trend === 'up' ? '<span style="color:#22c55e;font-weight:800;">&#9650;</span>' : p.trend === 'down' ? '<span style="color:#ef4444;font-weight:800;">&#9660;</span>' : '<span style="color:var(--text-faint);font-weight:800;">&#9654;</span>';
    return `<tr class="rep-pnl-row">
      <td><div style="display:flex;align-items:center;gap:8px;"><div style="width:8px;height:8px;border-radius:50%;background:${p.color};flex-shrink:0;"></div><span style="font-weight:700;">${p.name}</span></div></td>
      <td style="text-align:right;">${p.units}</td>
      <td style="text-align:right;font-weight:700;">${repFmt(p.revenue)}</td>
      <td style="text-align:right;color:var(--text-muted);">${repFmt(p.cost)}</td>
      <td style="text-align:right;color:#22c55e;font-weight:700;">${repFmt(profit)}</td>
      <td style="text-align:right;font-weight:700;">${repPct(margin)}</td>
      <td style="text-align:center;">${trendIcon}</td>
    </tr>`;
  }).join('');
}

// ═══════ TAX TABLE ═══════
function renderTaxTable() {
  const tbody = document.getElementById('rep-impuestos-tbody');
  tbody.innerHTML = repTaxData.map(t => {
    const ivaPagar = t.ivaCobrado - t.ivaPagado;
    const statusHtml = t.declared
      ? '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:6px;background:rgba(34,197,94,0.1);color:#22c55e;font-size:11px;font-weight:700;"><svg style="width:12px;height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Si</span>'
      : '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:6px;background:rgba(239,68,68,0.1);color:#ef4444;font-size:11px;font-weight:700;">Pendiente</span>';
    return `<tr class="rep-pnl-row">
      <td style="font-weight:700;">${t.month}</td>
      <td style="text-align:right;">${repFmt(t.revenue)}</td>
      <td style="text-align:right;color:#ef4444;font-weight:600;">${repFmt(t.ivaCobrado)}</td>
      <td style="text-align:right;color:#22c55e;font-weight:600;">${repFmt(t.ivaPagado)}</td>
      <td style="text-align:right;color:#f97316;font-weight:700;">${repFmt(ivaPagar)}</td>
      <td style="text-align:right;font-weight:600;">${repFmt(t.isr)}</td>
      <td style="text-align:center;">${statusHtml}</td>
    </tr>`;
  }).join('');
}

// ═══════ SAT CALENDAR ═══════
function renderSATCalendar() {
  const container = document.getElementById('rep-sat-calendar');
  const months = [
    { month:'Nov 2025', date:'17 Dic', status:'done' },
    { month:'Dic 2025', date:'17 Ene', status:'done' },
    { month:'Ene 2026', date:'17 Feb', status:'done' },
    { month:'Feb 2026', date:'17 Mar', status:'done' },
    { month:'Mar 2026', date:'17 Abr', status:'pending' },
    { month:'Abr 2026', date:'17 May', status:'future' }
  ];
  container.innerHTML = months.map(m => {
    const bg = m.status === 'done' ? 'rgba(34,197,94,0.08)' : m.status === 'pending' ? 'rgba(239,68,68,0.08)' : 'var(--input-bg)';
    const border = m.status === 'done' ? 'rgba(34,197,94,0.2)' : m.status === 'pending' ? 'rgba(239,68,68,0.2)' : 'var(--border)';
    const icon = m.status === 'done' ? '<svg style="width:14px;height:14px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'
      : m.status === 'pending' ? '<svg style="width:14px;height:14px;color:#ef4444;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
      : '<svg style="width:14px;height:14px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>';
    return `<div style="padding:12px;border-radius:10px;background:${bg};border:1px solid ${border};text-align:center;">
      ${icon}
      <p style="font-size:11px;font-weight:700;color:var(--text-primary);margin-top:6px;">${m.month}</p>
      <p style="font-size:10px;color:var(--text-faint);margin-top:2px;">Vence: ${m.date}</p>
    </div>`;
  }).join('');
}

// ═══════ EXPORTS TABLE ═══════
function renderExportsTable() {
  const tbody = document.getElementById('rep-exports-tbody');
  tbody.innerHTML = repExports.map(e => {
    const formatBadge = e.format === 'PDF'
      ? '<span style="padding:3px 10px;border-radius:6px;background:rgba(239,68,68,0.1);color:#ef4444;font-size:11px;font-weight:700;">PDF</span>'
      : '<span style="padding:3px 10px;border-radius:6px;background:rgba(34,197,94,0.1);color:#22c55e;font-size:11px;font-weight:700;">CSV</span>';
    return `<tr class="rep-pnl-row">
      <td style="font-weight:700;">${e.name}</td>
      <td>${e.period}</td>
      <td>${formatBadge}</td>
      <td>${e.date}</td>
      <td style="text-align:center;"><button onclick="repToast('Descargando ${e.name}...')" class="rep-tbl-btn">Descargar</button></td>
    </tr>`;
  }).join('');
}

// ═══════ AUTOPILOT ═══════
function renderRepAutopilot() {
  const container = document.getElementById('rep-autopilot-list');
  container.innerHTML = repAutopilotItems.map(item => `
    <div style="display:flex;align-items:center;gap:14px;padding:12px 0;${item !== repAutopilotItems[repAutopilotItems.length-1] ? 'border-bottom:1px solid var(--border);' : ''}">
      <label class="rep-toggle-wrap">
        <input type="checkbox" ${item.enabled ? 'checked' : ''} onchange="repToggleAutopilot('${item.id}', this.checked)"/>
        <span class="rep-toggle-slider"></span>
      </label>
      <div style="flex:1;">
        <p style="font-size:13px;font-weight:700;color:var(--text-primary);margin-bottom:2px;">${item.label}</p>
        <p style="font-size:11px;color:var(--text-muted);">${item.desc}</p>
      </div>
      <span style="font-size:10px;font-weight:700;color:${item.enabled ? '#22c55e' : 'var(--text-faint)'};">${item.enabled ? 'ACTIVO' : 'INACTIVO'}</span>
    </div>
  `).join('');
}

function repToggleAutopilot(id, on) {
  const item = repAutopilotItems.find(i => i.id === id);
  if (item) item.enabled = on;
  renderRepAutopilot();
  repToast(on ? 'Automatizacion activada' : 'Automatizacion desactivada');
}

// ═══════ ACTIONS ═══════
function repDownloadReport() {
  const type = document.getElementById('rep-export-type').value;
  const format = document.getElementById('rep-export-format').value;
  const names = { pnl:'Estado de resultados', cashflow:'Flujo de caja', products:'Rentabilidad por producto', taxes:'Impuestos', all:'Reporte completo' };
  repToast('Generando ' + names[type] + ' en ' + format.toUpperCase() + '...');
  setTimeout(() => repToast('Reporte descargado correctamente'), 1500);
}

function repSendToAccountant() {
  const email = document.getElementById('rep-accountant-email').value;
  if (!email) { repToast('Configura el email de tu contador primero'); return; }
  repToast('Enviando reporte a ' + email + '...');
  setTimeout(() => repToast('Reporte enviado a tu contador'), 1500);
}

function repSaveAccountant() {
  repToast('Datos de tu contador guardados');
}

function repExportTax() {
  repToast('Generando reporte de impuestos para tu contador...');
  setTimeout(() => repToast('Reporte de impuestos descargado'), 1500);
}

// ═══════ INIT ═══════
document.addEventListener('DOMContentLoaded', () => {
  renderRepSmartRecs();
  renderResumenChart();
  renderPnlTable();
  renderCashflowChart();
  renderCashflowTable();
  renderProductChart();
  renderProductTable();
  renderTaxTable();
  renderSATCalendar();
  renderExportsTable();
  renderRepAutopilot();
});
</script>
