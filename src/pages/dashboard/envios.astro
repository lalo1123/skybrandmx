// ═══════ COTIZADOR ═══════
function envCotizar(){
  const dest=document.getElementById('env-q-dest').value;
  if(!dest){alert('Ingresa el código postal de destino');return;}
  const peso=parseFloat(document.getElementById('env-q-peso').value)||1;
  const el=document.getElementById('env-q-results');
  el.innerHTML='<div class="stat-card animate-in" style="padding:24px;text-align:center;"><p style="color:var(--text-muted);">Cotizando con 5 paqueterías...</p></div>';

  setTimeout(()=>{
    const base=peso*45;
    const quotes=[
      {carrier:'Estafeta',price:Math.round(base*0.85+25),days:'3-5 días',type:'Terrestre',logo:'#ED1C24'},
      {carrier:'DHL',price:Math.round(base*1.2+40),days:'1-2 días',type:'Express',logo:'#FFCC00'},
      {carrier:'FedEx',price:Math.round(base*1.1+35),days:'2-3 días',type:'Estándar',logo:'#4D148C'},
      {carrier:'Redpack',price:Math.round(base*0.9+30),days:'3-4 días',type:'Terrestre',logo:'#E31937'},
      {carrier:'99 Minutos',price:Math.round(base*0.7+20),days:'Mismo día',type:'Local CDMX',logo:'#00C853'},
    ].sort((a,b)=>a.price-b.price);
    const cheapest=quotes[0].carrier;

    el.innerHTML=`<div style="display:flex;flex-direction:column;gap:12px;">${quotes.map(q=>`
      <div class="env-quote-card ${q.carrier===cheapest?'env-quote-best':''}" onclick="envSelectQuote('${q.carrier}',${q.price})">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:12px;height:12px;border-radius:3px;background:${q.logo};flex-shrink:0;"></div>
            <div>
              <p style="font-size:14px;font-weight:800;color:var(--text-primary);">${q.carrier} ${q.carrier===cheapest?'<span style="font-size:10px;padding:2px 8px;border-radius:4px;background:rgba(34,197,94,0.1);color:#22c55e;font-weight:700;margin-left:6px;">Más barata</span>':''}</p>
              <p style="font-size:11px;color:var(--text-muted);">${q.type} · ${q.days}</p>
            </div>
          </div>
          <div style="text-align:right;">
            <p style="font-size:20px;font-weight:900;color:var(--text-primary);">$${q.price}</p>
            <p style="font-size:10px;color:var(--text-faint);">MXN + IVA</p>
          </div>
        </div>
      </div>`).join('')}
      <p style="font-size:11px;color:var(--text-faint);text-align:center;margin-top:4px;">Precios incluyen recolección. Haz clic para generar la guía.</p>
    </div>`;
  },800);
}

function envSelectQuote(carrier,price){
  demoShipments.unshift({id:Date.now(),tracking:carrier.substring(0,3).toUpperCase()+Date.now().toString().slice(-9),carrier:carrier.replace('99 Minutos','99Min'),client:'(Nueva guía)',origin:document.getElementById('env-q-origin').value,dest:document.getElementById('env-q-dest').value,status:'created',cost:price,weight:document.getElementById('env-q-peso').value+'kg',date:'2026-04-01',events:[{date:'2026-04-01',text:'Guía creada',loc:'CDMX'}]});
  renderShipments();renderEnvStats();switchEnvTab('shipments');
  showToast(`Guía generada con ${carrier} por $${price} MXN`);
}

// ═══════ TRACKING ═══════
function envTrack(){
  const num=document.getElementById('env-track-num').value.trim();
  if(!num){alert('Ingresa un número de guía');return;}
  const el=document.getElementById('env-track-result');
  el.innerHTML='<p style="color:var(--text-muted);font-size:13px;padding:16px;">Buscando...</p>';

  setTimeout(()=>{
    const found=demoShipments.find(s=>s.tracking.toLowerCase()===num.toLowerCase());
    if(found){
      const st=statusMap[found.status];
      el.innerHTML=`
        <div style="padding:16px;border-radius:10px;border:1px solid ${st.c}30;background:${st.b};margin-bottom:16px;">
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div><p style="font-size:16px;font-weight:900;color:${st.c};">${st.l}</p><p style="font-size:12px;color:var(--text-muted);">${found.carrier} · ${found.tracking}</p></div>
            <span style="font-size:28px;">${found.status==='delivered'?'✅':found.status==='returned'?'↩️':'📦'}</span>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:0;">
          ${found.events.map((e,i)=>`<div style="display:flex;gap:12px;padding:10px 0;${i<found.events.length-1?'border-bottom:1px solid var(--border);':''}"><div style="width:8px;height:8px;border-radius:50%;background:${i===0?st.c:'var(--border)'};margin-top:4px;flex-shrink:0;"></div><div><p style="font-size:13px;font-weight:600;color:var(--text-primary);">${e.text}</p><p style="font-size:11px;color:var(--text-faint);">${e.date} · ${e.loc}</p></div></div>`).join('')}
        </div>`;
    } else {
      el.innerHTML='<div style="padding:20px;text-align:center;border-radius:10px;border:1px solid var(--border);"><p style="font-size:14px;font-weight:700;color:var(--text-muted);">No se encontró la guía</p><p style="font-size:12px;color:var(--text-faint);margin-top:4px;">Verifica el número e intenta de nuevo</p></div>';
    }
  },600);
}

