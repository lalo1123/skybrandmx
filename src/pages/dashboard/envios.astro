function openEnvMassModal(){document.getElementById('env-modal-mass').style.display='flex';}
function envMassPreview(input){
  if(!input.files[0])return;
  const file=input.files[0];const reader=new FileReader();
  reader.onload=function(e){
    const lines=e.target.result.split('\n').filter(l=>l.trim());
    const total=lines.length-1;
    document.getElementById('env-mass-preview').style.display='block';
    document.getElementById('env-mass-preview').innerHTML=`<div style="padding:12px;border-radius:8px;background:var(--accent-bg);border:1px solid rgba(111,207,245,0.15);"><p style="font-size:13px;font-weight:700;color:var(--accent);">✓ ${file.name}</p><p style="font-size:11px;color:var(--text-muted);margin-top:2px;">${total} envíos encontrados</p></div>`;
  };reader.readAsText(file);
}
