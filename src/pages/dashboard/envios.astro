// ═══════ PESO VOLUMÉTRICO ═══════
function envCalcVolumetric(){
  const l=parseFloat(document.getElementById('env-q-largo')?.value)||30;
  const w=parseFloat(document.getElementById('env-q-ancho')?.value)||20;
  const h=parseFloat(document.getElementById('env-q-alto')?.value)||15;
  const real=parseFloat(document.getElementById('env-q-peso')?.value)||1;
  const vol=((l*w*h)/5000).toFixed(1);
  const el=document.getElementById('env-vol-val');
  const msg=document.getElementById('env-vol-msg');
  if(el)el.textContent=vol+' kg';
  if(msg){
    if(parseFloat(vol)>real)msg.textContent=`⚠ Te cobrarán por peso volumétrico (${vol}kg) porque es mayor que el real (${real}kg)`;
    else msg.textContent='✓ Te cobrarán por peso real porque es mayor que el volumétrico';
  }
}
// Auto-calc on dimension change
['env-q-largo','env-q-ancho','env-q-alto','env-q-peso'].forEach(id=>{
  document.getElementById(id)?.addEventListener('input',envCalcVolumetric);
});

