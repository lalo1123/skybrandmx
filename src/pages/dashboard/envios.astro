  // Destinations
  const dests=[{city:'Guadalajara',pct:22},{city:'Monterrey',pct:28},{city:'CDMX',pct:18},{city:'Puebla',pct:12},{city:'Cancún',pct:10},{city:'Querétaro',pct:10}];
