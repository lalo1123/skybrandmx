// ═══════ HELPERS ═══════
function envDismissHelp(t){document.getElementById('env-help-'+t).style.display='none';localStorage.setItem('env_help_'+t+'_dismissed','1');}
function envToggleSection(id){const el=document.getElementById(id);el.style.display=el.style.display==='none'?'block':'none';}
function showToast(msg){const ex=document.getElementById('env-toast');if(ex)ex.remove();const t=document.createElement('div');t.id='env-toast';t.textContent=msg;Object.assign(t.style,{position:'fixed',bottom:'24px',right:'24px',background:'#22c55e',color:'#fff',padding:'12px 24px',borderRadius:'10px',fontSize:'13px',fontWeight:'700',zIndex:'9999',animation:'fadeInUp 0.3s ease',boxShadow:'0 4px 20px rgba(0,0,0,0.3)'});document.body.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity 0.3s';setTimeout(()=>t.remove(),300);},3000);}
function switchEnvTab(tab){document.querySelectorAll('.env-tab').forEach(t=>t.classList.remove('active'));document.getElementById('env-tab-'+tab).classList.add('active');['shipments','quote','tracking','returns','analytics'].forEach(p=>document.getElementById('env-panel-'+p).style.display=p===tab?'':'none');}

// ═══════ STATS ═══════
function renderEnvStats(){
  document.getElementById('env-stat-total').textContent=demoShipments.length;
  document.getElementById('env-stat-transit').textContent=demoShipments.filter(s=>s.status==='in_transit'||s.status==='out_for_delivery').length;
  document.getElementById('env-stat-delivered').textContent=demoShipments.filter(s=>s.status==='delivered').length;
  const costs=demoShipments.map(s=>s.cost);const avg=Math.round(costs.reduce((a,b)=>a+b,0)/costs.length);
  document.getElementById('env-stat-avg').textContent='$'+avg;
  document.getElementById('env-stat-spent').textContent='$'+costs.reduce((a,b)=>a+b,0).toLocaleString();
  document.getElementById('env-stat-returns').textContent=demoShipments.filter(s=>s.status==='returned').length;
  setT('env-trend-total','+3');setT('env-trend-delivered','+2');setT('env-trend-avg','-$15');setT('env-trend-spent','+12%');
}
function setT(id,val){const el=document.getElementById(id);if(!el)return;const up=val.startsWith('+');const color=id.includes('spent')?(up?'#ef4444':'#22c55e'):id.includes('avg')?(up?'#ef4444':'#22c55e'):(up?'#22c55e':'#ef4444');el.innerHTML=`<span style="color:${color};">${up?'▲':'▼'} ${val}</span>`;}

// ═══════ SMART RECS ═══════
function renderEnvRecs(){
  const el=document.getElementById('env-smart-recs');if(!el)return;const recs=[];
  const created=demoShipments.filter(s=>s.status==='created');
  if(created.length>0)recs.push({icon:'📦',color:'#eab308',title:`${created.length} guía(s) sin recolectar`,desc:'Programa la recolección para que la paquetería pase por ellas.',btn:'Programar',action:"showToast('Recolección programada')"});
  const outForDel=demoShipments.filter(s=>s.status==='out_for_delivery');
  if(outForDel.length>0)recs.push({icon:'🚚',color:'#f97316',title:`${outForDel.length} paquete(s) en reparto hoy`,desc:'Tu cliente recibirá su pedido hoy.',btn:'Ver detalle',action:"openEnvDetail(5)"});
  const returned=demoShipments.filter(s=>s.status==='returned');
  if(returned.length>0)recs.push({icon:'↩️',color:'#ef4444',title:`${returned.length} paquete devuelto`,desc:'Un envío fue devuelto. Revisa qué pasó.',btn:'Ver',action:"openEnvDetail(8)"});
  if(!recs.length){el.style.display='none';return;}
  el.style.display='flex';
  el.innerHTML=recs.map(r=>`<div style="display:flex;align-items:center;gap:14px;padding:14px 18px;border-radius:12px;background:${r.color}08;border:1px solid ${r.color}20;"><span style="font-size:24px;flex-shrink:0;">${r.icon}</span><div style="flex:1;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">${r.title}</p><p style="font-size:11px;color:var(--text-muted);margin-top:2px;">${r.desc}</p></div><button onclick="${r.action}" style="padding:8px 16px;border-radius:8px;border:none;background:${r.color};color:#fff;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">${r.btn}</button><button onclick="this.closest('div[style]').remove()" style="border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:14px;padding:0 4px;">✕</button></div>`).join('');
}

// ═══════ SHIPMENTS TABLE ═══════
function renderShipments(){
  const tbody=document.getElementById('env-shipments-tbody');let data=[...demoShipments];
  const search=document.getElementById('env-search').value.toLowerCase();
  const cf=document.getElementById('env-filter-carrier').value;
  const sf=document.getElementById('env-filter-status').value;
  if(search)data=data.filter(s=>s.tracking.toLowerCase().includes(search)||s.client.toLowerCase().includes(search)||s.dest.toLowerCase().includes(search));
  if(cf)data=data.filter(s=>s.carrier===cf);
  if(sf)data=data.filter(s=>s.status===sf);
  if(!data.length){tbody.innerHTML='<tr><td colspan="8" style="padding:40px;text-align:center;color:var(--text-faint);">No se encontraron guías</td></tr>';return;}
  tbody.innerHTML=data.map(s=>{const st=statusMap[s.status];const cc=carrierColors[s.carrier]||'var(--accent)';return`<tr style="border-bottom:1px solid var(--border);transition:background 0.15s;cursor:pointer;" onmouseover="this.style.background='var(--bg-card-hover)'" onmouseout="this.style.background='transparent'" onclick="openEnvDetail(${s.id})">
    <td style="padding:14px 16px;font-weight:700;color:var(--accent);font-size:12px;font-family:monospace;">${s.tracking}</td>
    <td style="padding:14px 16px;"><div style="display:flex;align-items:center;gap:6px;"><div style="width:8px;height:8px;border-radius:2px;background:${cc};"></div><span style="font-size:12px;font-weight:600;color:var(--text-primary);">${s.carrier}</span></div></td>
    <td style="padding:14px 16px;"><p style="font-weight:600;color:var(--text-primary);font-size:12px;">${s.client}</p><p style="font-size:11px;color:var(--text-faint);">${s.dest}</p></td>
    <td style="padding:14px 16px;"><span style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;color:${st.c};background:${st.b};">${st.l}</span></td>
    <td style="padding:14px 16px;text-align:right;font-weight:800;color:var(--text-primary);">$${s.cost}</td>
    <td style="padding:14px 16px;font-size:12px;color:var(--text-muted);">${s.weight}</td>
    <td style="padding:14px 16px;font-size:12px;color:var(--text-muted);">${s.date}</td>
    <td style="padding:14px 16px;text-align:center;" onclick="event.stopPropagation()"><div style="display:flex;gap:4px;justify-content:center;"><button onclick="openEnvDetail(${s.id})" class="env-tbl-btn">Ver</button><button onclick="showToast('Etiqueta impresa')" class="env-tbl-btn">🖨</button></div></td>
  </tr>`;}).join('');
}
function envFilter(){renderShipments();}

// ═══════ SHIPMENT DETAIL ═══════
function openEnvDetail(id){
  const s=demoShipments.find(x=>x.id===id);if(!s)return;
  const st=statusMap[s.status];const cc=carrierColors[s.carrier];
  document.getElementById('env-detail-title').textContent='Guía '+s.tracking;
  document.getElementById('env-detail-body').innerHTML=`
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;padding:14px;border-radius:10px;background:${st.b};border:1px solid ${st.c}30;">
      <span style="font-size:24px;">${s.status==='delivered'?'✅':s.status==='returned'?'↩️':s.status==='out_for_delivery'?'🚚':'📦'}</span>
      <div><p style="font-size:14px;font-weight:800;color:${st.c};">${st.l}</p><p style="font-size:12px;color:var(--text-muted);">${s.carrier} · ${s.weight} · $${s.cost} MXN</p></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;">
      <div><p class="env-label">Origen</p><p style="font-size:13px;color:var(--text-primary);">${s.origin}</p></div>
      <div><p class="env-label">Destino</p><p style="font-size:13px;color:var(--text-primary);">${s.dest}</p></div>
      <div><p class="env-label">Cliente</p><p style="font-size:13px;font-weight:700;color:var(--text-primary);">${s.client}</p></div>
      <div><p class="env-label">Fecha de creación</p><p style="font-size:13px;color:var(--text-primary);">${s.date}</p></div>
    </div>
    <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">Historial de rastreo</h4>
    <div style="display:flex;flex-direction:column;gap:0;">
      ${s.events.map((e,i)=>`<div style="display:flex;gap:12px;padding:12px 0;${i<s.events.length-1?'border-bottom:1px solid var(--border);':''}">
        <div style="display:flex;flex-direction:column;align-items:center;">
          <div style="width:10px;height:10px;border-radius:50%;background:${i===0?st.c:'var(--border)'};flex-shrink:0;"></div>
          ${i<s.events.length-1?'<div style="width:2px;flex:1;background:var(--border);margin-top:4px;"></div>':''}
        </div>
        <div><p style="font-size:13px;font-weight:700;color:${i===0?st.c:'var(--text-primary)'};">${e.text}</p><p style="font-size:11px;color:var(--text-faint);">${e.date} · ${e.loc}</p></div>
      </div>`).join('')}
    </div>
    <div style="display:flex;gap:10px;margin-top:20px;">
      <button onclick="envShowLabel(${s.id})" class="env-btn-primary" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;">🖨 Ver etiqueta</button>
