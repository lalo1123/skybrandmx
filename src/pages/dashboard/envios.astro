---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:6100';
---

<DashboardLayout title="Envíos">
  <!-- Smart Recommendations -->
  <div id="env-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Guías generadas</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-total" class="env-stat-val">--</p><span id="env-trend-total" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">En tránsito</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-transit" class="env-stat-val" style="color:#8b5cf6;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Entregadas</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-delivered" class="env-stat-val" style="color:#22c55e;">--</p><span id="env-trend-delivered" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Costo promedio <span class="env-tip" data-tip="Lo que te cuesta en promedio enviar un paquete">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-avg" class="env-stat-val" style="color:var(--accent);">--</p><span id="env-trend-avg" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Gasto total mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-spent" class="env-stat-val" style="color:#f97316;">--</p><span id="env-trend-spent" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Devoluciones <span class="env-tip" data-tip="Paquetes que fueron devueltos por el cliente o por la paquetería">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-returns" class="env-stat-val" style="color:#ef4444;">--</p></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="env-tab-shipments" class="env-tab active" onclick="switchEnvTab('shipments')">Mis guías</button>
    <button id="env-tab-quote" class="env-tab" onclick="switchEnvTab('quote')">Cotizar envío</button>
    <button id="env-tab-tracking" class="env-tab" onclick="switchEnvTab('tracking')">Rastrear paquete</button>
    <button id="env-tab-returns" class="env-tab" onclick="switchEnvTab('returns')">Devoluciones</button>
    <button id="env-tab-analytics" class="env-tab" onclick="switchEnvTab('analytics')">Analítica</button>
  </div>

  <!-- ══════════ Tab: Mis guías ══════════ -->
  <div id="env-panel-shipments">
    <div id="env-help-shipments" class="env-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aquí ves todas las guías de envío que has generado. Puedes rastrear cada paquete en tiempo real.</p>
      <button onclick="envDismissHelp('shipments')" class="env-help-close">&times;</button>
    </div>
    <div id="env-toolbar" class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="env-search" type="text" placeholder="Buscar por guía, cliente, destino..." oninput="envFilter()" class="env-input" style="padding-left:38px;"/>
      </div>
      <select id="env-filter-carrier" onchange="envFilter()" class="env-input" style="width:auto;cursor:pointer;">
        <option value="">Todas las paqueterías</option>
        <option value="DHL">DHL</option>
        <option value="Estafeta">Estafeta</option>
        <option value="FedEx">FedEx</option>
        <option value="Redpack">Redpack</option>
        <option value="99Min">99 Minutos</option>
      </select>
      <select id="env-filter-status" onchange="envFilter()" class="env-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="created">Creada</option>
        <option value="picked_up">Recolectada</option>
        <option value="in_transit">En tránsito</option>
        <option value="out_for_delivery">En reparto</option>
        <option value="delivered">Entregada</option>
        <option value="returned">Devuelta</option>
      </select>
      <button onclick="switchEnvTab('quote')" class="env-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva guía
      </button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="env-th"># Guía</th><th class="env-th">Paquetería</th><th class="env-th">Cliente / Destino</th>
            <th class="env-th">Estado</th><th class="env-th" style="text-align:right;">Costo</th><th class="env-th">Peso</th>
            <th class="env-th">Fecha</th><th class="env-th" style="text-align:center;">Acciones</th>
          </tr></thead>
          <tbody id="env-shipments-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Cotizar envío ══════════ -->
  <div id="env-panel-quote" style="display:none;">
    <div id="env-help-quote" class="env-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Compara precios de diferentes paqueterías y genera la guía con la mejor opción. Nosotros negociamos las tarifas por ti.</p>
      <button onclick="envDismissHelp('quote')" class="env-help-close">&times;</button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <!-- Left: Form -->
      <div class="stat-card animate-in" style="padding:24px;">
        <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:16px;">Datos del envío</h3>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div><label class="env-label">CP Origen</label><input id="env-q-origin" type="text" value="03100" class="env-input" placeholder="Ej: 03100"/></div>
            <div><label class="env-label">CP Destino</label><input id="env-q-dest" type="text" class="env-input" placeholder="Ej: 44100"/></div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
            <div><label class="env-label">Largo (cm)</label><input id="env-q-largo" type="number" value="30" class="env-input"/></div>
            <div><label class="env-label">Ancho (cm)</label><input id="env-q-ancho" type="number" value="20" class="env-input"/></div>
            <div><label class="env-label">Alto (cm)</label><input id="env-q-alto" type="number" value="15" class="env-input"/></div>
          </div>
          <div><label class="env-label">Peso real (kg)</label><input id="env-q-peso" type="number" value="2" class="env-input" oninput="envCalcVolumetric()"/></div>
          <!-- Peso volumétrico auto-calc -->
          <div id="env-vol-weight" style="padding:10px 14px;border-radius:10px;background:rgba(234,179,8,0.06);border:1px solid rgba(234,179,8,0.15);display:flex;align-items:center;gap:10px;">
            <svg style="width:16px;height:16px;color:#eab308;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div style="flex:1;">
              <p style="font-size:11px;color:#eab308;font-weight:700;">Peso volumétrico: <span id="env-vol-val">1.8 kg</span></p>
              <p style="font-size:10px;color:var(--text-faint);" id="env-vol-msg">Las paqueterías cobran el peso mayor entre real y volumétrico</p>
            </div>
          </div>
          <div><label class="env-label">Contenido</label><input id="env-q-contenido" type="text" class="env-input" placeholder="Ej: Ropa, accesorios"/></div>
          <!-- Valor declarado + seguro -->
          <div style="display:grid;grid-template-columns:1fr auto;gap:12px;align-items:end;">
            <div><label class="env-label">Valor del paquete (MXN) <span class="env-tip" data-tip="Para calcular el costo del seguro de envío">?</span></label><input id="env-q-valor" type="number" value="0" class="env-input" placeholder="0"/></div>
            <label style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;white-space:nowrap;">
              <input type="checkbox" id="env-q-seguro" style="accent-color:var(--accent);"/>
              <span style="font-size:12px;font-weight:600;color:var(--text-secondary);">Agregar seguro</span>
            </label>
          </div>
          <!-- Guías masivas link -->
          <div style="display:flex;justify-content:flex-end;">
            <button onclick="openEnvMassModal()" style="padding:6px 14px;border-radius:8px;border:1px dashed var(--border);background:transparent;color:var(--text-faint);font-size:11px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-faint)'">📄 Generar guías masivas (CSV)</button>
          </div>
          <button onclick="envCotizar()" class="env-btn-primary" style="display:flex;align-items:center;justify-content:center;gap:6px;">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            Cotizar envío
          </button>
        </div>
      </div>
      <!-- Right: Results -->
      <div>
        <div id="env-q-results">
          <div class="stat-card animate-in" style="padding:40px;text-align:center;">
            <svg style="width:48px;height:48px;color:var(--text-faintest);margin-bottom:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>
            <p style="font-size:14px;font-weight:700;color:var(--text-muted);">Ingresa los datos y cotiza</p>
            <p style="font-size:12px;color:var(--text-faint);margin-top:4px;">Comparamos precios de 5+ paqueterías al instante</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Rastrear ══════════ -->
  <div id="env-panel-tracking" style="display:none;">
    <div id="env-help-tracking" class="env-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Pega un número de guía para rastrear tu paquete en tiempo real. Funciona con cualquier paquetería.</p>
      <button onclick="envDismissHelp('tracking')" class="env-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:24px;max-width:600px;">
      <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:16px;">Rastrear paquete</h3>
      <div style="display:flex;gap:10px;">
        <input id="env-track-num" type="text" placeholder="Número de guía (Ej: FDX123456789)" class="env-input" style="flex:1;"/>
        <button onclick="envTrack()" class="env-btn-primary" style="padding:10px 20px;white-space:nowrap;">Rastrear</button>
      </div>
      <div id="env-track-result" style="margin-top:20px;"></div>
    </div>
  </div>

  <!-- ══════════ Tab: Devoluciones envío ══════════ -->
  <div id="env-panel-returns" style="display:none;">
    <div id="env-help-returns" class="env-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Genera guías de retorno para que tus clientes te devuelvan productos fácilmente.</p>
      <button onclick="envDismissHelp('returns')" class="env-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="env-th"># Guía retorno</th><th class="env-th">Guía original</th><th class="env-th">Cliente</th>
            <th class="env-th">Paquetería</th><th class="env-th">Estado</th><th class="env-th">Fecha</th>
          </tr></thead>
          <tbody id="env-returns-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Analítica ══════════ -->
  <div id="env-panel-analytics" style="display:none;">
    <div id="env-help-analytics" class="env-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Analiza tus costos de envío, tiempos de entrega y rendimiento por paquetería.</p>
      <button onclick="envDismissHelp('analytics')" class="env-help-close">&times;</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:20px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Gasto por paquetería</h4>
        <div id="env-chart-carriers"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Tiempo de entrega promedio <span class="env-tip" data-tip="Días que tarda en promedio cada paquetería en entregar">?</span></h4>
        <div id="env-chart-times"></div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Destinos frecuentes</h4>
        <div id="env-chart-destinations"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Envíos por mes</h4>
        <div id="env-chart-monthly" style="height:180px;display:flex;align-items:flex-end;gap:6px;"></div>
      </div>
    </div>
    <!-- Tarifas por estado -->
    <div class="stat-card animate-in" style="padding:20px;margin-top:20px;">
      <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:4px;">Tarifas por estado <span class="env-tip" data-tip="Costo promedio de enviar un paquete de 2kg a cada estado de México">?</span></h4>
      <p style="font-size:11px;color:var(--text-faint);margin-bottom:16px;">Paquete estándar de 2kg desde CDMX. Precios aproximados.</p>
      <div id="env-tariff-map" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px;"></div>
    </div>
  </div>

  <!-- Modal: Guías masivas -->
  <div id="env-modal-mass" class="env-modal-overlay" style="display:none;">
    <div class="env-modal-box" style="max-width:560px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);">Generar guías masivas</h3>
        <button onclick="document.getElementById('env-modal-mass').style.display='none'" class="env-modal-close">&times;</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <p style="font-size:12px;color:var(--text-muted);line-height:1.5;">Sube un archivo CSV con los datos de envío y generamos todas las guías de una vez. Ideal si tienes muchos pedidos.</p>
        <div style="border:2px dashed var(--border);border-radius:10px;padding:28px;text-align:center;cursor:pointer;transition:all 0.2s;" onclick="document.getElementById('env-mass-file').click()" ondragover="event.preventDefault();this.style.borderColor='var(--accent)'" ondragleave="this.style.borderColor='var(--border)'">
          <svg style="width:32px;height:32px;color:var(--text-faint);margin-bottom:8px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
          <p style="font-size:13px;color:var(--text-muted);font-weight:600;">Arrastra tu archivo CSV aquí</p>
          <p style="font-size:11px;color:var(--text-faint);margin-top:4px;">o haz clic para seleccionar</p>
          <input type="file" id="env-mass-file" accept=".csv" style="display:none;" onchange="envMassPreview(this)"/>
        </div>
        <div id="env-mass-preview" style="display:none;"></div>
        <div style="padding:10px;border-radius:8px;background:var(--input-bg);">
          <p style="font-size:11px;font-weight:700;color:var(--text-faint);margin-bottom:4px;">Formato del CSV:</p>
          <code style="font-size:10px;color:var(--accent);">nombre,email,telefono,calle,cp_destino,peso_kg,contenido</code>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div><label class="env-label">Paquetería</label><select id="env-mass-carrier" class="env-input" style="cursor:pointer;"><option value="cheapest">La más barata</option><option value="DHL">DHL</option><option value="FedEx">FedEx</option><option value="Estafeta">Estafeta</option></select></div>
          <div><label class="env-label">CP Origen</label><input id="env-mass-origin" type="text" value="03100" class="env-input"/></div>
        </div>
        <button onclick="envMassGenerate()" class="env-btn-primary" style="background:#22c55e;">Generar guías masivas</button>
      </div>
    </div>
  </div>

  <!-- Modal: Etiqueta preview -->
  <div id="env-modal-label" class="env-modal-overlay" style="display:none;">
    <div class="env-modal-box" style="max-width:400px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);">Etiqueta de envío</h3>
        <button onclick="document.getElementById('env-modal-label').style.display='none'" class="env-modal-close">&times;</button>
      </div>
      <div id="env-label-preview" style="background:#fff;border:2px solid #000;border-radius:8px;padding:20px;color:#000;font-family:monospace;"></div>
      <button onclick="showToast('Etiqueta impresa')" class="env-btn-primary" style="margin-top:16px;width:100%;">🖨 Imprimir etiqueta</button>
    </div>
  </div>

  <!-- Modal: Notificación preview -->
  <div id="env-modal-notif" class="env-modal-overlay" style="display:none;">
    <div class="env-modal-box" style="max-width:420px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);">Vista previa de notificación</h3>
        <button onclick="document.getElementById('env-modal-notif').style.display='none'" class="env-modal-close">&times;</button>
      </div>
      <div id="env-notif-preview"></div>
    </div>
