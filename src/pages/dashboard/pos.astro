---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Punto de Venta">
  <!-- Top bar: sucursal + online/offline + shortcuts -->
  <div class="stat-card animate-in" style="padding:14px 20px;margin-bottom:20px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
    <svg style="width:18px;height:18px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
    <label style="font-size:13px;font-weight:700;color:var(--text-secondary);">Sucursal:</label>
    <select id="pos-sucursal" onchange="posChangeSucursal()" class="pos-input" style="width:auto;cursor:pointer;">
      <option value="matriz">Matriz CDMX</option>
      <option value="norte">Sucursal Norte</option>
      <option value="sur">Sucursal Sur</option>
    </select>
    <span class="pos-tip" data-tip="Cambia entre tus sucursales. Cada una tiene su propio inventario y caja.">?</span>
    <div style="flex:1;"></div>
    <div id="pos-online-indicator" style="display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:8px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);">
      <div style="width:8px;height:8px;border-radius:50%;background:#22c55e;"></div>
      <span id="pos-online-text" style="font-size:11px;font-weight:800;color:#22c55e;">En linea</span>
    </div>
    <div style="display:flex;gap:8px;align-items:center;font-size:10px;color:var(--text-faint);">
      <span class="pos-kbd">F1</span>Buscar
      <span class="pos-kbd">F2</span>Cobrar
      <span class="pos-kbd">ESC</span>Cancelar
    </div>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="pos-stat-label">Ventas de hoy</p>
      <p id="pos-stat-ventas" class="pos-stat-val" style="color:#22c55e;">$4,850</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="pos-stat-label">Tickets de hoy</p>
      <p id="pos-stat-tickets" class="pos-stat-val">8</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="pos-stat-label">Ticket promedio <span class="pos-tip" data-tip="Lo que gasta en promedio cada cliente">?</span></p>
      <p id="pos-stat-promedio" class="pos-stat-val" style="color:var(--accent);">$606</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="pos-stat-label">Sucursal actual</p>
      <p id="pos-stat-sucursal" class="pos-stat-val" style="font-size:18px;">Matriz CDMX</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="pos-stat-label">Caja actual</p>
      <p id="pos-stat-caja" class="pos-stat-val" style="font-size:18px;color:#22c55e;">Abierta</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="pos-stat-label">Usuarios activos</p>
      <p id="pos-stat-users" class="pos-stat-val" style="color:#8b5cf6;">3</p>
    </div>
  </div>

  <!-- Autopilot -->
  <div class="stat-card animate-in" style="padding:18px 20px;margin-bottom:20px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;cursor:pointer;" onclick="posToggleAutopilot()">
      <div style="display:flex;align-items:center;gap:10px;">
        <svg style="width:18px;height:18px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        <h3 style="font-size:14px;font-weight:800;color:var(--text-primary);">Autopilot del punto de venta</h3>
        <span id="pos-autopilot-count" style="font-size:11px;font-weight:700;color:var(--accent);background:var(--accent-bg);padding:2px 8px;border-radius:6px;">3/5 activos</span>
      </div>
      <svg id="pos-autopilot-chevron" style="width:16px;height:16px;color:var(--text-muted);transition:transform 0.2s;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </div>
    <div id="pos-autopilot-body" style="display:none;flex-direction:column;gap:10px;">
      <div class="pos-autopilot-row">
        <div><p class="pos-autopilot-title">Facturar automaticamente al cerrar venta</p><p class="pos-autopilot-desc">Genera la factura electronica (CFDI) en cuanto cobras</p></div>
        <label class="pos-toggle"><input type="checkbox" onchange="posToggleAuto(this,'auto_cfdi')"><span class="pos-toggle-slider"></span></label>
      </div>
      <div class="pos-autopilot-row">
        <div><p class="pos-autopilot-title">Imprimir ticket automatico</p><p class="pos-autopilot-desc">Imprime el ticket en la impresora termica al cobrar</p></div>
        <label class="pos-toggle"><input type="checkbox" checked onchange="posToggleAuto(this,'auto_print')"><span class="pos-toggle-slider"></span></label>
      </div>
      <div class="pos-autopilot-row">
        <div><p class="pos-autopilot-title">Descontar del inventario al cobrar</p><p class="pos-autopilot-desc">Resta el stock automaticamente de la sucursal actual</p></div>
        <label class="pos-toggle"><input type="checkbox" checked onchange="posToggleAuto(this,'auto_stock')"><span class="pos-toggle-slider"></span></label>
      </div>
      <div class="pos-autopilot-row">
        <div><p class="pos-autopilot-title">Abrir/cerrar caja automatico por horario</p><p class="pos-autopilot-desc">Abre la caja al inicio del turno y la cierra al final</p></div>
        <label class="pos-toggle"><input type="checkbox" onchange="posToggleAuto(this,'auto_caja')"><span class="pos-toggle-slider"></span></label>
      </div>
      <div class="pos-autopilot-row">
        <div><p class="pos-autopilot-title">Alertar cuando stock bajo en sucursal</p><p class="pos-autopilot-desc">Te avisa cuando algun producto esta por agotarse</p></div>
        <label class="pos-toggle"><input type="checkbox" checked onchange="posToggleAuto(this,'auto_alert')"><span class="pos-toggle-slider"></span></label>
      </div>
    </div>
  </div>

  <!-- ═════════ Main POS view: two panels ═════════ -->
  <div id="pos-help-main" class="pos-help-banner">
    <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <p style="flex:1;font-size:12px;color:var(--text-secondary);">Toca un producto para agregarlo al carrito. Cuando el cliente este listo, presiona <b>Cobrar</b>. Puedes agregar modificadores, aplicar descuentos y elegir el metodo de pago.</p>
    <button onclick="posDismissHelp('main')" class="pos-help-close">&times;</button>
  </div>

  <div class="pos-main-grid">
    <!-- LEFT: Product grid -->
    <div class="stat-card animate-in" style="padding:16px;display:flex;flex-direction:column;gap:12px;min-height:560px;">
      <!-- Search -->
      <div style="position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="pos-search" type="text" placeholder="Buscar producto... (F1)" oninput="posRenderProducts()" class="pos-input" style="padding-left:38px;"/>
      </div>
      <!-- Category tabs -->
      <div id="pos-categories" style="display:flex;gap:6px;flex-wrap:wrap;">
        <button class="pos-cat active" data-cat="todos" onclick="posFilterCat('todos')">Todos</button>
        <button class="pos-cat" data-cat="bebidas" onclick="posFilterCat('bebidas')">Bebidas</button>
        <button class="pos-cat" data-cat="comidas" onclick="posFilterCat('comidas')">Comidas</button>
        <button class="pos-cat" data-cat="postres" onclick="posFilterCat('postres')">Postres</button>
        <button class="pos-cat" data-cat="otros" onclick="posFilterCat('otros')">Otros</button>
      </div>
      <!-- Products grid -->
      <div id="pos-products" class="pos-products-grid"></div>
    </div>

    <!-- RIGHT: Cart -->
    <div class="stat-card animate-in" style="padding:16px;display:flex;flex-direction:column;gap:10px;min-height:560px;">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);">Venta actual</h3>
        <button onclick="posClearCart()" class="pos-btn-secondary" style="padding:6px 10px;font-size:11px;">Vaciar</button>
      </div>
      <!-- Customer selector -->
      <div>
        <label class="pos-label">Cliente (opcional)</label>
        <select id="pos-customer" class="pos-input" style="cursor:pointer;">
          <option value="">Publico en general</option>
          <option value="1">Juan Perez Garcia</option>
          <option value="2">Maria Lopez Hernandez</option>
          <option value="3">Roberto Sanchez</option>
        </select>
      </div>
      <!-- Cart items -->
      <div id="pos-cart-items" style="flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:8px;max-height:260px;min-height:120px;"></div>
      <!-- Totals -->
      <div style="border-top:1px solid var(--border);padding-top:10px;display:flex;flex-direction:column;gap:6px;">
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);"><span>Subtotal</span><span id="pos-subtotal">$0.00</span></div>
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);"><span>Descuento</span><span id="pos-discount-val" style="color:#ef4444;">-$0.00</span></div>
        <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);"><span>IVA (16%)</span><span id="pos-iva">$0.00</span></div>
        <div style="display:flex;justify-content:space-between;font-size:18px;font-weight:900;color:var(--text-primary);padding-top:6px;border-top:1px dashed var(--border);"><span>Total</span><span id="pos-total">$0.00</span></div>
      </div>
      <!-- Payment methods -->
      <div>
        <label class="pos-label">Metodo de pago</label>
        <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:6px;">
          <button id="pos-pay-efectivo" class="pos-pay-btn active" onclick="posSelectPay('efectivo')">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Efectivo
          </button>
          <button id="pos-pay-tarjeta" class="pos-pay-btn" onclick="posSelectPay('tarjeta')">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            Tarjeta
          </button>
          <button id="pos-pay-transfer" class="pos-pay-btn" onclick="posSelectPay('transfer')">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            Transferencia
          </button>
          <button id="pos-pay-qr" class="pos-pay-btn" onclick="posSelectPay('qr')">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>
            QR
          </button>
        </div>
      </div>
      <!-- Action buttons -->
      <div style="display:flex;gap:8px;">
        <button onclick="posOpenDiscount()" class="pos-btn-secondary" style="flex:1;">Descuento</button>
        <button onclick="posPrintTicket()" class="pos-btn-secondary" style="flex:1;">Ticket</button>
      </div>
      <button onclick="posCobrar()" class="pos-btn-cobrar">
        <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Cobrar (F2)
      </button>
    </div>
  </div>

  <!-- ═════════ Tabs ═════════ -->
  <div style="display:flex;gap:4px;margin:28px 0 20px 0;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="pos-tab-ventas" class="pos-tab active" onclick="switchPosTab('ventas')">Ventas del dia</button>
    <button id="pos-tab-cortes" class="pos-tab" onclick="switchPosTab('cortes')">Cortes de caja</button>
    <button id="pos-tab-inventario" class="pos-tab" onclick="switchPosTab('inventario')">Inventario por sucursal</button>
    <button id="pos-tab-turnos" class="pos-tab" onclick="switchPosTab('turnos')">Turnos y cajeros</button>
  </div>

  <!-- Tab: Ventas del dia -->
  <div id="pos-panel-ventas">
    <div id="pos-help-ventas" class="pos-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Todas las ventas del dia. Puedes reimprimir tickets, cancelar ventas o enviarlas por email al cliente.</p>
      <button onclick="posDismissHelp('ventas')" class="pos-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table class="pos-table">
          <thead>
            <tr><th>Ticket</th><th>Hora</th><th>Items</th><th>Metodo</th><th>Total</th><th>Acciones</th></tr>
          </thead>
          <tbody id="pos-ventas-body"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Tab: Cortes de caja -->
  <div id="pos-panel-cortes" style="display:none;">
    <div id="pos-help-cortes" class="pos-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Abre la caja al inicio del turno con el efectivo inicial. Al cerrar, compara el efectivo esperado contra el real para detectar faltantes o sobrantes.</p>
      <button onclick="posDismissHelp('cortes')" class="pos-help-close">&times;</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-bottom:20px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <p class="pos-stat-label">Apertura de caja</p>
        <p style="font-size:22px;font-weight:900;color:var(--text-primary);margin-top:4px;">$2,000.00</p>
        <p style="font-size:11px;color:var(--text-muted);margin-top:4px;">Hoy 08:00 AM</p>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <p class="pos-stat-label">Efectivo esperado</p>
        <p style="font-size:22px;font-weight:900;color:var(--accent);margin-top:4px;">$4,120.00</p>
        <p style="font-size:11px;color:var(--text-muted);margin-top:4px;">Apertura + ventas en efectivo</p>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <p class="pos-stat-label">Efectivo real en caja</p>
        <input id="pos-corte-real" type="number" step="0.01" value="4100" class="pos-input" style="font-size:22px;font-weight:900;padding:6px 10px;margin-top:4px;" oninput="posCalcDiferencia()"/>
        <p id="pos-corte-diff" style="font-size:11px;color:#ef4444;margin-top:4px;">Diferencia: -$20.00</p>
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-bottom:20px;">
      <button onclick="posCerrarCaja()" class="pos-btn-primary" style="padding:12px 24px;">Cerrar caja y generar corte</button>
      <button onclick="posAbrirCaja()" class="pos-btn-secondary" style="padding:12px 24px;">Abrir nueva caja</button>
    </div>
    <div class="stat-card animate-in" style="padding:20px;">
      <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">Historial de cortes</h4>
      <div style="overflow-x:auto;">
        <table class="pos-table">
          <thead><tr><th>Fecha</th><th>Cajero</th><th>Apertura</th><th>Cierre</th><th>Diferencia</th><th>Estado</th></tr></thead>
          <tbody id="pos-cortes-body"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Tab: Inventario -->
  <div id="pos-panel-inventario" style="display:none;">
    <div id="pos-help-inventario" class="pos-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Stock de productos por sucursal. Si a una sucursal le falta mercancia, usa el boton Transferir para moverla desde otra.</p>
      <button onclick="posDismissHelp('inventario')" class="pos-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table class="pos-table">
          <thead><tr><th>Producto</th><th>Matriz CDMX</th><th>Suc. Norte</th><th>Suc. Sur</th><th>Total</th><th>Accion</th></tr></thead>
          <tbody id="pos-inv-body"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Tab: Turnos -->
  <div id="pos-panel-turnos" style="display:none;">
    <div id="pos-help-turnos" class="pos-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Consulta quien esta trabajando, cuanto ha vendido cada cajero y sus comisiones.</p>
      <button onclick="posDismissHelp('turnos')" class="pos-help-close">&times;</button>
    </div>
    <div id="pos-turnos-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;"></div>
  </div>

  <!-- ═════════ Modifier modal ═════════ -->
  <div id="pos-mod-overlay" class="pos-modal-overlay" onclick="posCloseModModal()"></div>
  <div id="pos-mod-modal" class="pos-modal">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h3 id="pos-mod-title" style="font-size:16px;font-weight:900;color:var(--text-primary);">Modificadores</h3>
      <button onclick="posCloseModModal()" style="width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:8px;border:none;background:transparent;cursor:pointer;color:var(--text-muted);">
        <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <p style="font-size:12px;color:var(--text-muted);margin-bottom:14px;">Elige los extras para este producto.</p>
    <div id="pos-mod-list" style="display:flex;flex-direction:column;gap:8px;max-height:300px;overflow-y:auto;"></div>
    <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:16px;">
      <button onclick="posCloseModModal()" class="pos-btn-secondary" style="padding:10px 18px;">Cancelar</button>
      <button onclick="posConfirmMods()" class="pos-btn-primary" style="padding:10px 22px;">Agregar al carrito</button>
    </div>
  </div>

  <!-- ═════════ Discount modal ═════════ -->
  <div id="pos-disc-overlay" class="pos-modal-overlay" onclick="posCloseDiscount()"></div>
  <div id="pos-disc-modal" class="pos-modal">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
