// ═══════ HELPERS ═══════
function showToast(msg, type){
  type = type || 'success';
  const c = document.getElementById('pos-toast-container');
  if(!c) return;
  const t = document.createElement('div');
  const bg = type==='error' ? '#ef4444' : type==='warning' ? '#f97316' : '#22c55e';
  t.style.cssText = 'padding:12px 20px;border-radius:10px;background:'+bg+';color:#fff;font-size:13px;font-weight:700;font-family:inherit;box-shadow:0 4px 20px rgba(0,0,0,0.3);';
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(function(){ t.style.opacity='0'; t.style.transition='opacity 0.3s'; setTimeout(function(){ t.remove(); },300); }, 3000);
}
window.showToast = window.showToast || showToast;

function posFmt(n){ return '$' + Number(n).toLocaleString('es-MX',{minimumFractionDigits:2,maximumFractionDigits:2}); }

function posDismissHelp(tab){
  const el = document.getElementById('pos-help-'+tab);
  if(el) el.style.display = 'none';
  try { localStorage.setItem('pos_help_'+tab+'_dismissed','1'); } catch(e){}
}
window.posDismissHelp = posDismissHelp;

// ═══════ TABS ═══════
function switchPosTab(tab){
  document.querySelectorAll('.pos-tab').forEach(function(t){ t.classList.remove('active'); });
  const tabBtn = document.getElementById('pos-tab-'+tab);
  if(tabBtn) tabBtn.classList.add('active');
  ['ventas','cortes','inventario','turnos'].forEach(function(p){
    const panel = document.getElementById('pos-panel-'+p);
    if(panel) panel.style.display = p===tab ? '' : 'none';
  });
}
window.switchPosTab = switchPosTab;

// ═══════ SUCURSAL ═══════
function posChangeSucursal(){
  posCurrentSucursal = document.getElementById('pos-sucursal').value;
  const s = posSucursales[posCurrentSucursal];
  document.getElementById('pos-stat-ventas').textContent = posFmt(s.ventas);
  document.getElementById('pos-stat-tickets').textContent = s.tickets;
  const promedio = s.tickets > 0 ? s.ventas / s.tickets : 0;
  document.getElementById('pos-stat-promedio').textContent = posFmt(promedio);
  document.getElementById('pos-stat-sucursal').textContent = s.name;
  document.getElementById('pos-stat-users').textContent = s.users;
  const cajaEl = document.getElementById('pos-stat-caja');
  cajaEl.textContent = s.cajaOpen ? 'Abierta' : 'Cerrada';
  cajaEl.style.color = s.cajaOpen ? '#22c55e' : '#ef4444';
  showToast('Cambiaste a ' + s.name);
  posRenderProducts();
}
window.posChangeSucursal = posChangeSucursal;

// ═══════ AUTOPILOT ═══════
function posToggleAutopilot(){
  const body = document.getElementById('pos-autopilot-body');
  const chev = document.getElementById('pos-autopilot-chevron');
  if(body.style.display === 'none'){
    body.style.display = 'flex';
    chev.style.transform = 'rotate(180deg)';
  } else {
    body.style.display = 'none';
    chev.style.transform = 'rotate(0deg)';
  }
}
window.posToggleAutopilot = posToggleAutopilot;

function posToggleAuto(el, key){
  const active = document.querySelectorAll('#pos-autopilot-body input[type=checkbox]:checked').length;
  document.getElementById('pos-autopilot-count').textContent = active + '/5 activos';
  showToast(el.checked ? 'Automatizacion activada' : 'Automatizacion desactivada');
}
window.posToggleAuto = posToggleAuto;

// ═══════ PRODUCTS GRID ═══════
function posFilterCat(cat){
  posCurrentCategory = cat;
  document.querySelectorAll('.pos-cat').forEach(function(b){
    b.classList.toggle('active', b.getAttribute('data-cat') === cat);
  });
  posRenderProducts();
}
window.posFilterCat = posFilterCat;

function posRenderProducts(){
  const grid = document.getElementById('pos-products');
  if(!grid) return;
  const search = (document.getElementById('pos-search').value || '').toLowerCase();
  const stock = posStock[posCurrentSucursal];
  const filtered = posProducts.filter(function(p){
    if(posCurrentCategory !== 'todos' && p.category !== posCurrentCategory) return false;
    if(search && p.name.toLowerCase().indexOf(search) < 0) return false;
    return true;
  });
  if(filtered.length === 0){
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:30px;color:var(--text-muted);font-size:13px;">No hay productos que coincidan con tu busqueda.</div>';
    return;
  }
  grid.innerHTML = filtered.map(function(p){
    const s = stock[p.id] || 0;
    const low = s <= 5;
    return '<button class="pos-product-btn" style="background:linear-gradient(135deg,'+p.color+'22,'+p.color+'11);border-color:'+p.color+'44;" onclick="posAddProduct('+p.id+')">'
      + '<div class="pos-product-name">'+p.name+'</div>'
      + '<div class="pos-product-price">'+posFmt(p.price)+'</div>'
      + '<div class="pos-product-stock" style="color:'+(low?'#ef4444':'var(--text-muted)')+';">Stock: '+s+(low?' (bajo)':'')+'</div>'
      + '</button>';
  }).join('');
}
window.posRenderProducts = posRenderProducts;

// ═══════ CART ═══════
function posAddProduct(id){
  const p = posProducts.find(function(x){ return x.id === id; });
  if(!p) return;
  const stock = posStock[posCurrentSucursal][p.id] || 0;
  if(stock <= 0){
    showToast('Sin stock en esta sucursal', 'error');
    return;
  }
  if(p.mods && p.mods.length > 0){
    posPendingProduct = p;
    posPendingMods = [];
    posOpenModModal(p);
  } else {
    posAddToCart(p, []);
  }
}
window.posAddProduct = posAddProduct;

function posOpenModModal(p){
  document.getElementById('pos-mod-title').textContent = 'Modificadores: ' + p.name;
  const list = document.getElementById('pos-mod-list');
  list.innerHTML = p.mods.map(function(m, i){
    return '<label style="display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;background:var(--input-bg);border:1px solid var(--border);cursor:pointer;font-size:13px;color:var(--text-secondary);">'
      + '<input type="checkbox" data-idx="'+i+'" style="accent-color:var(--accent);"/>'
      + '<span>'+m+'</span></label>';
  }).join('');
  document.getElementById('pos-mod-overlay').classList.add('active');
  document.getElementById('pos-mod-modal').classList.add('active');
}

function posCloseModModal(){
  document.getElementById('pos-mod-overlay').classList.remove('active');
  document.getElementById('pos-mod-modal').classList.remove('active');
  posPendingProduct = null;
}
window.posCloseModModal = posCloseModModal;

function posConfirmMods(){
  if(!posPendingProduct) return;
  const selected = [];
  document.querySelectorAll('#pos-mod-list input[type=checkbox]:checked').forEach(function(cb){
    const idx = parseInt(cb.getAttribute('data-idx'));
    selected.push(posPendingProduct.mods[idx]);
  });
  posAddToCart(posPendingProduct, selected);
  posCloseModModal();
}
window.posConfirmMods = posConfirmMods;

function posModExtraPrice(mods){
  let extra = 0;
  mods.forEach(function(m){
    const match = m.match(/\+\$(\d+)/);
    if(match) extra += parseInt(match[1]);
  });
  return extra;
}

function posAddToCart(p, mods){
  const modKey = mods.slice().sort().join('|');
  const existing = posCart.find(function(i){ return i.id === p.id && i.modKey === modKey; });
  if(existing){
    existing.qty += 1;
  } else {
    const unit = p.price + posModExtraPrice(mods);
    posCart.push({ id:p.id, name:p.name, unit:unit, qty:1, mods:mods, modKey:modKey });
  }
  posRenderCart();
  showToast(p.name + ' agregado');
}

function posRenderCart(){
  const box = document.getElementById('pos-cart-items');
  if(!box) return;
  if(posCart.length === 0){
    box.innerHTML = '<div class="pos-cart-empty">Carrito vacio. Toca un producto para agregarlo.</div>';
  } else {
    box.innerHTML = posCart.map(function(item, idx){
      return '<div class="pos-cart-item">'
        + '<div class="pos-cart-item-info">'
        +   '<div class="pos-cart-item-name">'+item.name+'</div>'
        +   (item.mods.length ? '<div class="pos-cart-item-mods">'+item.mods.join(', ')+'</div>' : '')
        + '</div>'
        + '<div class="pos-cart-item-qty">'
        +   '<button class="pos-qty-btn" onclick="posChangeQty('+idx+',-1)">-</button>'
        +   '<span style="min-width:20px;text-align:center;font-weight:800;color:var(--text-primary);">'+item.qty+'</span>'
        +   '<button class="pos-qty-btn" onclick="posChangeQty('+idx+',1)">+</button>'
        + '</div>'
        + '<div class="pos-cart-item-price">'+posFmt(item.unit * item.qty)+'</div>'
        + '</div>';
    }).join('');
  }
  posUpdateTotals();
}

function posChangeQty(idx, delta){
  if(!posCart[idx]) return;
  posCart[idx].qty += delta;
  if(posCart[idx].qty <= 0) posCart.splice(idx, 1);
  posRenderCart();
}
window.posChangeQty = posChangeQty;

function posClearCart(){
  if(posCart.length === 0) return;
  posCart = [];
  posDiscount = { type:'percent', value:0 };
  posRenderCart();
  showToast('Carrito vaciado');
}
window.posClearCart = posClearCart;

function posUpdateTotals(){
  let subtotal = 0;
  posCart.forEach(function(i){ subtotal += i.unit * i.qty; });
  let discountAmount = 0;
  if(posDiscount.type === 'percent') discountAmount = subtotal * (posDiscount.value / 100);
  else discountAmount = posDiscount.value;
  if(discountAmount > subtotal) discountAmount = subtotal;
  const afterDiscount = subtotal - discountAmount;
  const iva = afterDiscount * 0.16;
  const total = afterDiscount + iva;
  document.getElementById('pos-subtotal').textContent = posFmt(subtotal);
  document.getElementById('pos-discount-val').textContent = '-' + posFmt(discountAmount);
  document.getElementById('pos-iva').textContent = posFmt(iva);
  document.getElementById('pos-total').textContent = posFmt(total);
}

// ═══════ PAYMENT ═══════
function posSelectPay(method){
  posPayMethod = method;
  ['efectivo','tarjeta','transfer','qr'].forEach(function(m){
    const b = document.getElementById('pos-pay-'+m);
    if(b) b.classList.toggle('active', m === method);
  });
}
window.posSelectPay = posSelectPay;

// ═══════ DISCOUNT ═══════
function posOpenDiscount(){
  if(posCart.length === 0){ showToast('El carrito esta vacio', 'warning'); return; }
  document.getElementById('pos-disc-overlay').classList.add('active');
  document.getElementById('pos-disc-modal').classList.add('active');
}
window.posOpenDiscount = posOpenDiscount;

function posCloseDiscount(){
  document.getElementById('pos-disc-overlay').classList.remove('active');
  document.getElementById('pos-disc-modal').classList.remove('active');
}
window.posCloseDiscount = posCloseDiscount;

function posUpdateDiscountPlaceholder(){
  const t = document.getElementById('pos-disc-type').value;
  document.getElementById('pos-disc-value').placeholder = t === 'percent' ? '10' : '50.00';
}
window.posUpdateDiscountPlaceholder = posUpdateDiscountPlaceholder;

function posApplyDiscount(){
  const type = document.getElementById('pos-disc-type').value;
  const value = parseFloat(document.getElementById('pos-disc-value').value) || 0;
  if(value < 0){ showToast('Valor invalido', 'error'); return; }
  posDiscount = { type:type, value:value };
  posUpdateTotals();
  posCloseDiscount();
  showToast('Descuento aplicado');
}
window.posApplyDiscount = posApplyDiscount;

// ═══════ COBRAR ═══════
function posCobrar(){
  if(posCart.length === 0){
    showToast('El carrito esta vacio', 'warning');
    return;
  }
  const totalText = document.getElementById('pos-total').textContent;
  const itemCount = posCart.reduce(function(a,b){ return a + b.qty; }, 0);
  // Add to ventas hoy
  posVentasHoy.unshift({
    num: posNextTicketNum++,
    hora: new Date().toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'}),
    items: itemCount,
    metodo: posPayMethod,
    total: parseFloat(totalText.replace(/[^0-9.-]/g,''))
  });
  // Discount stock
  posCart.forEach(function(item){
    if(posStock[posCurrentSucursal][item.id] != null){
      posStock[posCurrentSucursal][item.id] = Math.max(0, posStock[posCurrentSucursal][item.id] - item.qty);
    }
  });
  showToast('Venta cobrada: ' + totalText + ' | Ticket impreso');
  posCart = [];
  posDiscount = { type:'percent', value:0 };
  posRenderCart();
  posRenderProducts();
  posRenderVentas();
  posRenderInventario();
}
window.posCobrar = posCobrar;

function posPrintTicket(){
  if(posCart.length === 0){ showToast('El carrito esta vacio', 'warning'); return; }
  showToast('Imprimiendo ticket (compatible SAT e-ticket)');
}
window.posPrintTicket = posPrintTicket;

// ═══════ VENTAS DEL DIA ═══════
function posMetodoLabel(m){
  return m === 'efectivo' ? 'Efectivo' : m === 'tarjeta' ? 'Tarjeta' : m === 'transfer' ? 'Transferencia' : m === 'qr' ? 'QR' : m;
}

function posRenderVentas(){
  const body = document.getElementById('pos-ventas-body');
  if(!body) return;
  body.innerHTML = posVentasHoy.map(function(v){
    return '<tr>'
      + '<td style="font-weight:800;color:var(--text-primary);">#'+v.num+'</td>'
      + '<td>'+v.hora+'</td>'
      + '<td>'+v.items+' item'+(v.items===1?'':'s')+'</td>'
      + '<td><span class="pos-badge" style="background:var(--accent-bg);color:var(--accent);">'+posMetodoLabel(v.metodo)+'</span></td>'
      + '<td style="font-weight:800;color:#22c55e;">'+posFmt(v.total)+'</td>'
      + '<td>'
      +   '<button class="pos-action-btn" title="Reimprimir ticket" onclick="posReimprimir('+v.num+')"><svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg></button>'
      +   '<button class="pos-action-btn" title="Enviar por email" onclick="posEnviarEmail('+v.num+')"><svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></button>'
      +   '<button class="pos-action-btn" title="Cancelar venta" onclick="posCancelarVenta('+v.num+')"><svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>'
      + '</td>'
      + '</tr>';
  }).join('');
}

function posReimprimir(num){ showToast('Ticket #'+num+' reimpreso'); }
window.posReimprimir = posReimprimir;
function posEnviarEmail(num){ showToast('Ticket #'+num+' enviado por email'); }
window.posEnviarEmail = posEnviarEmail;
function posCancelarVenta(num){ showToast('Venta #'+num+' cancelada', 'warning'); }
window.posCancelarVenta = posCancelarVenta;

// ═══════ CORTES DE CAJA ═══════
function posCalcDiferencia(){
  const real = parseFloat(document.getElementById('pos-corte-real').value) || 0;
  const esperado = 4120;
  const diff = real - esperado;
  const el = document.getElementById('pos-corte-diff');
  if(diff === 0){
    el.textContent = 'Diferencia: $0.00 (cuadrado)';
    el.style.color = '#22c55e';
  } else if(diff > 0){
    el.textContent = 'Diferencia: +' + posFmt(diff) + ' (sobrante)';
    el.style.color = '#f97316';
  } else {
    el.textContent = 'Diferencia: ' + posFmt(diff) + ' (faltante)';
    el.style.color = '#ef4444';
  }
}
window.posCalcDiferencia = posCalcDiferencia;

function posCerrarCaja(){ showToast('Corte generado. Caja cerrada.'); }
window.posCerrarCaja = posCerrarCaja;
function posAbrirCaja(){ showToast('Nueva caja abierta con efectivo inicial'); }
window.posAbrirCaja = posAbrirCaja;

function posRenderCortes(){
  const body = document.getElementById('pos-cortes-body');
  if(!body) return;
  body.innerHTML = posCortesHistorial.map(function(c){
    let color = '#22c55e', label = 'Cuadrado';
    if(c.estado === 'faltante'){ color = '#ef4444'; label = 'Faltante'; }
    else if(c.estado === 'sobrante'){ color = '#f97316'; label = 'Sobrante'; }
    const diffTxt = c.diff === 0 ? '$0.00' : (c.diff > 0 ? '+' : '') + posFmt(c.diff);
    return '<tr>'
      + '<td>'+c.fecha+'</td>'
      + '<td>'+c.cajero+'</td>'
      + '<td>'+posFmt(c.apertura)+'</td>'
      + '<td>'+posFmt(c.cierre)+'</td>'
      + '<td style="color:'+color+';font-weight:800;">'+diffTxt+'</td>'
      + '<td><span class="pos-badge" style="background:'+color+'22;color:'+color+';">'+label+'</span></td>'
      + '</tr>';
  }).join('');
}

// ═══════ INVENTARIO ═══════
function posRenderInventario(){
  const body = document.getElementById('pos-inv-body');
  if(!body) return;
  body.innerHTML = posProducts.map(function(p){
    const m = posStock.matriz[p.id] || 0;
    const n = posStock.norte[p.id] || 0;
    const s = posStock.sur[p.id] || 0;
    const total = m + n + s;
    function cell(v){ const low = v <= 5; return '<span style="color:'+(low?'#ef4444':'var(--text-secondary)')+';font-weight:'+(low?'800':'600')+';">'+v+(low?' !':'')+'</span>'; }
    return '<tr>'
      + '<td style="font-weight:700;color:var(--text-primary);">'+p.name+'</td>'
      + '<td>'+cell(m)+'</td>'
      + '<td>'+cell(n)+'</td>'
      + '<td>'+cell(s)+'</td>'
      + '<td style="font-weight:800;color:var(--accent);">'+total+'</td>'
      + '<td><button class="pos-btn-secondary" style="padding:6px 12px;font-size:11px;" onclick="posTransferir('+p.id+')">Transferir</button></td>'
      + '</tr>';
  }).join('');
}

function posTransferir(id){
  const p = posProducts.find(function(x){ return x.id === id; });
  showToast('Transferencia iniciada para ' + (p ? p.name : 'producto'));
}
window.posTransferir = posTransferir;

// ═══════ TURNOS ═══════
function posRenderTurnos(){
  const grid = document.getElementById('pos-turnos-grid');
  if(!grid) return;
  grid.innerHTML = posTurnos.map(function(t){
    const statusColor = t.activo ? '#22c55e' : 'var(--text-muted)';
    const statusLabel = t.activo ? 'Trabajando' : 'Libre';
    const initials = t.nombre.split(' ').map(function(n){ return n[0]; }).slice(0,2).join('');
    return '<div class="stat-card animate-in" style="padding:18px;">'
      + '<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">'
      +   '<div style="width:44px;height:44px;border-radius:50%;background:var(--accent-bg);color:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:15px;">'+initials+'</div>'
      +   '<div style="flex:1;min-width:0;">'
      +     '<p style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:2px;">'+t.nombre+'</p>'
      +     '<p style="font-size:11px;color:var(--text-muted);">'+t.rol+'</p>'
      +   '</div>'
      +   '<span class="pos-badge" style="background:'+statusColor+'22;color:'+statusColor+';">'+statusLabel+'</span>'
      + '</div>'
      + '<p style="font-size:11px;color:var(--text-faint);margin-bottom:10px;">'+t.turno+'</p>'
      + '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding-top:10px;border-top:1px solid var(--border);">'
      +   '<div><p style="font-size:10px;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Ventas</p><p style="font-size:14px;font-weight:900;color:#22c55e;">'+posFmt(t.ventas)+'</p></div>'
      +   '<div><p style="font-size:10px;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Tickets</p><p style="font-size:14px;font-weight:900;color:var(--text-primary);">'+t.tickets+'</p></div>'
      +   '<div><p style="font-size:10px;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Comision</p><p style="font-size:14px;font-weight:900;color:var(--accent);">'+posFmt(t.comision)+'</p></div>'
      + '</div>'
      + '</div>';
  }).join('');
}

// ═══════ KEYBOARD SHORTCUTS ═══════
function posKeyboardHandler(e){
  if(e.key === 'F1'){
    e.preventDefault();
    const s = document.getElementById('pos-search');
    if(s) s.focus();
  } else if(e.key === 'F2'){
    e.preventDefault();
    posCobrar();
  } else if(e.key === 'Escape'){
    // Close modals if open
    if(document.getElementById('pos-mod-modal').classList.contains('active')){
      posCloseModModal();
    } else if(document.getElementById('pos-disc-modal').classList.contains('active')){
      posCloseDiscount();
    } else if(posCart.length > 0){
      posClearCart();
    }
  }
}

// ═══════ ONLINE INDICATOR ═══════
function posUpdateOnlineStatus(){
  const ind = document.getElementById('pos-online-indicator');
  const txt = document.getElementById('pos-online-text');
  if(!ind || !txt) return;
  if(navigator.onLine){
    ind.style.background = 'rgba(34,197,94,0.1)';
    ind.style.borderColor = 'rgba(34,197,94,0.2)';
    ind.querySelector('div').style.background = '#22c55e';
    txt.style.color = '#22c55e';
    txt.textContent = 'En linea';
  } else {
    ind.style.background = 'rgba(249,115,22,0.1)';
    ind.style.borderColor = 'rgba(249,115,22,0.2)';
    ind.querySelector('div').style.background = '#f97316';
    txt.style.color = '#f97316';
    txt.textContent = 'Sin conexion (modo offline)';
  }
}

// ═══════ INIT ═══════
function posInit(){
  // Restore dismissed helps
  try {
    ['main','ventas','cortes','inventario','turnos'].forEach(function(tab){
      if(localStorage.getItem('pos_help_'+tab+'_dismissed') === '1'){
        const el = document.getElementById('pos-help-'+tab);
        if(el) el.style.display = 'none';
      }
    });
  } catch(e){}

  posRenderProducts();
  posRenderCart();
  posRenderVentas();
  posRenderCortes();
  posRenderInventario();
  posRenderTurnos();
  posUpdateOnlineStatus();

  document.addEventListener('keydown', posKeyboardHandler);
  window.addEventListener('online', posUpdateOnlineStatus);
  window.addEventListener('offline', posUpdateOnlineStatus);
}

if(document.readyState === 'loading'){
  document.addEventListener('DOMContentLoaded', posInit);
} else {
  posInit();
}
</script>
</DashboardLayout>
