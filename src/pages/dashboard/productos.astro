const prodAutoFlows = [
  { id:'lowstock', name:'Alertar bajo stock', desc:'Notifica por email cuando un producto tenga menos de 5 unidades', icon:'📦', color:'#f97316', active:true },
  { id:'hideout', name:'Ocultar agotados automaticamente', desc:'Esconde de la tienda los productos sin stock', icon:'👁', color:'#ef4444', active:true },
