];

let prodEditCatId = null;
let prodStockEditId = null;

// ═══════ SMART RECOMMENDATIONS ═══════
function prodLoadRecs() {
  const recs = [];
  const outOfStock = demoProducts.filter(p => p.stock === 0).length;
  const lowStock = demoProducts.filter(p => p.stock > 0 && p.stock < 5).length;
  if (outOfStock > 0) recs.push({ type:'warning', text:'Tienes ' + outOfStock + ' producto(s) agotados. Tus clientes no pueden comprarlos.', action:'Ver agotados', fn:'prodFilterByStatus("agotado")' });
  if (lowStock > 0) recs.push({ type:'alert', text:'Hay ' + lowStock + ' producto(s) con bajo stock que se agotaran pronto.', action:'Ver bajo stock', fn:'switchProdTab("inventory")' });
  const noCat = demoProducts.filter(p => !p.category).length;
  if (noCat > 0) recs.push({ type:'info', text:noCat + ' producto(s) sin categoria asignada.', action:'Organizar', fn:'switchProdTab("categories")' });

  const wrap = document.getElementById('prod-smart-recs');
  if (!wrap) return;
  wrap.innerHTML = recs.map(r => {
    const colors = { warning:'#ef4444', alert:'#f97316', info:'var(--accent)' };
    return '<div class="stat-card animate-in" style="padding:14px 18px;display:flex;align-items:center;gap:12px;border-left:3px solid '+colors[r.type]+';">' +
      '<svg style="width:16px;height:16px;color:'+colors[r.type]+';flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>' +
      '<p style="flex:1;font-size:12px;color:var(--text-secondary);">'+r.text+'</p>' +
      '<button onclick="'+r.fn+'" style="padding:6px 14px;border-radius:8px;border:1px solid '+colors[r.type]+';background:transparent;color:'+colors[r.type]+';font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">'+r.action+'</button>' +
      '</div>';
  }).join('');
}

// ═══════ STATS ═══════
function prodUpdateStats() {
  document.getElementById('prod-stat-total').textContent = demoProducts.length;
  const invValue = demoProducts.reduce((s,p) => s + p.cost * p.stock, 0);
  document.getElementById('prod-stat-value').textContent = '$' + invValue.toLocaleString('es-MX');
  document.getElementById('prod-stat-outofstock').textContent = demoProducts.filter(p => p.stock === 0).length;
  document.getElementById('prod-stat-lowstock').textContent = demoProducts.filter(p => p.stock > 0 && p.stock < 5).length;
  document.getElementById('prod-stat-cats').textContent = demoCategories.length;
  const margins = demoProducts.filter(p => p.cost > 0).map(p => ((p.price - p.cost) / p.price) * 100);
  const avgMargin = margins.length > 0 ? (margins.reduce((s,m) => s + m, 0) / margins.length) : 0;
  document.getElementById('prod-stat-margin').textContent = avgMargin.toFixed(1) + '%';
}

// ═══════ TABS ═══════
window.switchProdTab = function(tab) {
  var tabs = ['catalog','add','categories','inventory','analytics'];
  tabs.forEach(function(t) {
    var panel = document.getElementById('prod-panel-' + t);
    var btn = document.getElementById('prod-tab-' + t);
    if (panel) panel.style.display = t === tab ? '' : 'none';
    if (btn) { btn.classList.toggle('active', t === tab); }
  });
  if (tab === 'catalog') prodRenderCatalog();
  if (tab === 'categories') prodRenderCategories();
  if (tab === 'inventory') prodRenderInventory();
  if (tab === 'analytics') prodRenderAnalytics();
};

// ═══════ CATALOG ═══════
function prodRenderCatalog() {
  var grid = document.getElementById('prod-grid');
  var emptyEl = document.getElementById('prod-empty-catalog');
  var toolbar = document.getElementById('prod-toolbar');
  if (!grid) return;

  var search = (document.getElementById('prod-search').value || '').toLowerCase();
  var catFilter = document.getElementById('prod-filter-cat').value;
  var statusFilter = document.getElementById('prod-filter-status').value;

  var filtered = demoProducts.filter(function(p) {
    var matchSearch = !search || p.name.toLowerCase().indexOf(search) !== -1 || p.sku.toLowerCase().indexOf(search) !== -1;
    var matchCat = !catFilter || p.category === catFilter;
    var matchStatus = !statusFilter || p.status === statusFilter;
    return matchSearch && matchCat && matchStatus;
  });

  if (demoProducts.length === 0) {
    emptyEl.style.display = '';
    toolbar.style.display = 'none';
    grid.innerHTML = '';
    return;
  }
  emptyEl.style.display = 'none';
  toolbar.style.display = '';

  var statusColors = { activo:{ c:'#22c55e', b:'rgba(34,197,94,0.1)' }, agotado:{ c:'#ef4444', b:'rgba(239,68,68,0.1)' }, borrador:{ c:'#f97316', b:'rgba(249,115,22,0.1)' } };

  grid.innerHTML = filtered.map(function(p) {
    var sc = statusColors[p.status] || statusColors.activo;
    var compareHtml = p.compare > 0 ? '<span style="text-decoration:line-through;color:var(--text-faint);font-size:11px;font-weight:400;">$' + p.compare.toLocaleString('es-MX') + '</span>' : '';
    var stockColor = p.stock === 0 ? '#ef4444' : p.stock < 5 ? '#f97316' : '#22c55e';
    return '<div class="prod-card" onclick="prodShowDetail('+p.id+')">' +
      '<div style="height:160px;background:linear-gradient(135deg,var(--input-bg),var(--nav-hover));display:flex;align-items:center;justify-content:center;">' +
        '<svg style="width:48px;height:48px;color:var(--text-faint);opacity:0.4;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>' +
      '</div>' +
      '<div style="padding:14px 16px;">' +
        '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">' +
          '<span class="prod-badge" style="background:'+sc.b+';color:'+sc.c+';">'+p.status+'</span>' +
          '<span style="font-size:10px;color:var(--text-faint);">'+p.category+'</span>' +
        '</div>' +
        '<h4 style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:6px;line-height:1.3;">'+p.name+'</h4>' +
        '<div style="display:flex;align-items:baseline;gap:6px;margin-bottom:8px;">' +
          '<span style="font-size:18px;font-weight:900;color:var(--text-primary);">$'+p.price.toLocaleString('es-MX')+'</span>' +
          compareHtml +
        '</div>' +
        '<div style="display:flex;align-items:center;justify-content:space-between;">' +
          '<span style="font-size:11px;font-weight:700;color:'+stockColor+';">Stock: '+p.stock+'</span>' +
          '<span style="font-size:10px;color:var(--text-faint);">'+p.sku+'</span>' +
        '</div>' +
      '</div>' +
    '</div>';
  }).join('');

  if (filtered.length === 0) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-faint);font-size:13px;">No se encontraron productos con esos filtros.</div>';
  }
}

window.prodFilterCatalog = function() { prodRenderCatalog(); };

window.prodFilterByStatus = function(status) {
  switchProdTab('catalog');
  document.getElementById('prod-filter-status').value = status;
  prodRenderCatalog();
};

// ═══════ PRODUCT DETAIL MODAL ═══════
window.prodShowDetail = function(id) {
  var p = demoProducts.find(function(x) { return x.id === id; });
  if (!p) return;
  document.getElementById('prod-detail-title').textContent = p.name;
  var margin = p.cost > 0 ? (((p.price - p.cost) / p.price) * 100).toFixed(1) : '--';
  var statusColors = { activo:{ c:'#22c55e', b:'rgba(34,197,94,0.1)' }, agotado:{ c:'#ef4444', b:'rgba(239,68,68,0.1)' }, borrador:{ c:'#f97316', b:'rgba(249,115,22,0.1)' } };
  var sc = statusColors[p.status] || statusColors.activo;
  document.getElementById('prod-detail-body').innerHTML =
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">' +
      '<div>' +
        '<div style="height:180px;background:linear-gradient(135deg,var(--input-bg),var(--nav-hover));border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:12px;">' +
          '<svg style="width:48px;height:48px;color:var(--text-faint);opacity:0.4;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>' +
        '</div>' +
        '<p style="font-size:12px;color:var(--text-secondary);line-height:1.5;">'+p.desc+'</p>' +
      '</div>' +
      '<div style="display:flex;flex-direction:column;gap:10px;">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;"><span style="font-size:11px;color:var(--text-faint);">Estado</span><span class="prod-badge" style="background:'+sc.b+';color:'+sc.c+';">'+p.status+'</span></div>' +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Precio</span><span style="font-size:14px;font-weight:800;color:var(--text-primary);">$'+p.price.toLocaleString('es-MX')+'</span></div>' +
        (p.compare > 0 ? '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Precio tachado</span><span style="font-size:13px;text-decoration:line-through;color:var(--text-faint);">$'+p.compare.toLocaleString('es-MX')+'</span></div>' : '') +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Costo</span><span style="font-size:13px;color:var(--text-secondary);">$'+p.cost.toLocaleString('es-MX')+'</span></div>' +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Margen</span><span style="font-size:13px;font-weight:700;color:#8b5cf6;">'+margin+'%</span></div>' +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Categoria</span><span style="font-size:13px;color:var(--text-secondary);">'+p.category+'</span></div>' +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">SKU</span><span style="font-size:13px;color:var(--text-secondary);">'+p.sku+'</span></div>' +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Stock</span><span style="font-size:13px;font-weight:700;color:'+(p.stock===0?'#ef4444':p.stock<5?'#f97316':'#22c55e')+';">'+p.stock+' unidades</span></div>' +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Vendidos</span><span style="font-size:13px;font-weight:700;color:var(--text-primary);">'+p.sold+'</span></div>' +
        (p.sizes ? '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Tallas</span><span style="font-size:12px;color:var(--text-secondary);">'+p.sizes+'</span></div>' : '') +
        (p.colors ? '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Colores</span><span style="font-size:12px;color:var(--text-secondary);">'+p.colors+'</span></div>' : '') +
        '<div style="display:flex;justify-content:space-between;"><span style="font-size:11px;color:var(--text-faint);">Peso</span><span style="font-size:13px;color:var(--text-secondary);">'+p.weight+' kg</span></div>' +
      '</div>' +
    '</div>' +
    '<div style="display:flex;gap:10px;margin-top:20px;">' +
      '<button onclick="showToast(\'Producto editado\');prodCloseDetail()" class="prod-btn-primary" style="flex:1;">Editar producto</button>' +
      '<button onclick="showToast(\'Producto duplicado\');prodCloseDetail()" class="prod-btn-secondary" style="flex:1;">Duplicar</button>' +
    '</div>';
  document.getElementById('prod-modal-detail').style.display = 'flex';
};

window.prodCloseDetail = function() {
  document.getElementById('prod-modal-detail').style.display = 'none';
};

// ═══════ ADD PRODUCT ═══════
window.prodCalcMargin = function() {
  var price = parseFloat(document.getElementById('prod-add-price').value) || 0;
  var cost = parseFloat(document.getElementById('prod-add-cost').value) || 0;
  var el = document.getElementById('prod-add-margin');
  if (price > 0 && cost > 0) {
    var margin = ((price - cost) / price * 100).toFixed(1);
    el.textContent = margin + '%';
    el.style.color = parseFloat(margin) >= 30 ? '#22c55e' : parseFloat(margin) >= 15 ? '#f97316' : '#ef4444';
  } else {
    el.textContent = '--%';
    el.style.color = 'var(--accent)';
  }
};

window.prodUpdateSeoCount = function(type) {
  if (type === 'title') {
    var v = document.getElementById('prod-add-metatitle').value;
    document.getElementById('prod-seo-title-count').textContent = v.length + '/70';
  } else {
    var v2 = document.getElementById('prod-add-metadesc').value;
    document.getElementById('prod-seo-desc-count').textContent = v2.length + '/160';
  }
};

window.prodSaveProduct = function() {
  var name = document.getElementById('prod-add-name').value.trim();
  var price = parseFloat(document.getElementById('prod-add-price').value);
  var cat = document.getElementById('prod-add-cat').value;
  var stock = parseInt(document.getElementById('prod-add-stock').value);
  if (!name) { showToast('Escribe el nombre del producto'); return; }
  if (!price || price <= 0) { showToast('El precio debe ser mayor a 0'); return; }
  if (!cat) { showToast('Selecciona una categoria'); return; }
  if (isNaN(stock) || stock < 0) { showToast('Indica el stock disponible'); return; }

  var newProd = {
    id: demoProducts.length + 1,
    name: name,
    price: price,
    compare: parseFloat(document.getElementById('prod-add-compare').value) || 0,
    cost: parseFloat(document.getElementById('prod-add-cost').value) || 0,
    sku: document.getElementById('prod-add-sku').value || 'SKU-' + (demoProducts.length + 1),
    barcode: document.getElementById('prod-add-barcode').value || '',
    category: cat,
    weight: parseFloat(document.getElementById('prod-add-weight').value) || 0,
    stock: stock,
    status: stock === 0 ? 'agotado' : 'activo',
    sizes: document.getElementById('prod-add-sizes').value || '',
    colors: document.getElementById('prod-add-colors').value || '',
    desc: document.getElementById('prod-add-desc').value || '',
    sold: 0
  };
  demoProducts.push(newProd);
  showToast('Producto "' + name + '" guardado correctamente');
  // Clear form
  ['prod-add-name','prod-add-desc','prod-add-price','prod-add-compare','prod-add-cost','prod-add-sku','prod-add-barcode','prod-add-weight','prod-add-stock','prod-add-sizes','prod-add-colors','prod-add-metatitle','prod-add-metadesc'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('prod-add-cat').value = '';
  document.getElementById('prod-add-margin').textContent = '--%';
  document.getElementById('prod-seo-title-count').textContent = '0/70';
  document.getElementById('prod-seo-desc-count').textContent = '0/160';
  prodUpdateStats();
  prodLoadRecs();
  switchProdTab('catalog');
};

// ═══════ CATEGORIES ═══════
function prodRenderCategories() {
  var grid = document.getElementById('prod-categories-grid');
  if (!grid) return;
  grid.innerHTML = demoCategories.map(function(c) {
    var prodCount = demoProducts.filter(function(p) { return p.category === c.name; }).length;
    return '<div class="stat-card animate-in" style="padding:20px;">' +
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">' +
        '<div style="display:flex;align-items:center;gap:10px;">' +
          '<span style="font-size:28px;">'+c.icon+'</span>' +
          '<div><h4 style="font-size:14px;font-weight:800;color:var(--text-primary);">'+c.name+'</h4><p style="font-size:11px;color:var(--text-faint);">'+c.desc+'</p></div>' +
        '</div>' +
        '<span style="font-size:22px;font-weight:900;color:var(--accent);">'+prodCount+'</span>' +
      '</div>' +
      '<div style="display:flex;gap:8px;">' +
        '<button onclick="prodEditCat('+c.id+')" class="prod-btn-secondary" style="flex:1;padding:8px;font-size:11px;">Editar</button>' +
        '<button onclick="prodDeleteCat('+c.id+')" style="flex:1;padding:8px;border-radius:8px;border:1px solid rgba(239,68,68,0.3);background:transparent;color:#ef4444;font-size:11px;font-weight:700;cursor:pointer;">Eliminar</button>' +
      '</div>' +
    '</div>';
  }).join('');
}

window.prodOpenCatModal = function(editId) {
  prodEditCatId = editId || null;
  document.getElementById('prod-cat-modal-title').textContent = editId ? 'Editar categoria' : 'Nueva categoria';
  if (editId) {
    var cat = demoCategories.find(function(c) { return c.id === editId; });
    if (cat) {
      document.getElementById('prod-cat-name').value = cat.name;
      document.getElementById('prod-cat-desc').value = cat.desc;
      document.getElementById('prod-cat-icon').value = cat.icon;
    }
  } else {
    document.getElementById('prod-cat-name').value = '';
    document.getElementById('prod-cat-desc').value = '';
    document.getElementById('prod-cat-icon').value = '';
  }
  document.getElementById('prod-modal-cat').style.display = 'flex';
};

window.prodCloseCatModal = function() {
  document.getElementById('prod-modal-cat').style.display = 'none';
  prodEditCatId = null;
};

window.prodSaveCat = function() {
  var name = document.getElementById('prod-cat-name').value.trim();
  if (!name) { showToast('Escribe el nombre de la categoria'); return; }
  if (prodEditCatId) {
    var cat = demoCategories.find(function(c) { return c.id === prodEditCatId; });
    if (cat) {
      cat.name = name;
      cat.desc = document.getElementById('prod-cat-desc').value;
      cat.icon = document.getElementById('prod-cat-icon').value || '📁';
    }
    showToast('Categoria actualizada');
  } else {
    demoCategories.push({
      id: demoCategories.length + 1,
      name: name,
      desc: document.getElementById('prod-cat-desc').value,
      icon: document.getElementById('prod-cat-icon').value || '📁',
      count: 0
    });
    showToast('Categoria "' + name + '" creada');
  }
  prodCloseCatModal();
  prodRenderCategories();
  prodUpdateStats();
};

window.prodEditCat = function(id) { prodOpenCatModal(id); };

window.prodDeleteCat = function(id) {
  var cat = demoCategories.find(function(c) { return c.id === id; });
  if (!cat) return;
  var prodCount = demoProducts.filter(function(p) { return p.category === cat.name; }).length;
  if (prodCount > 0) {
    showToast('No puedes eliminar "' + cat.name + '" porque tiene ' + prodCount + ' productos');
    return;
  }
  var idx = demoCategories.indexOf(cat);
  if (idx !== -1) demoCategories.splice(idx, 1);
  showToast('Categoria "' + cat.name + '" eliminada');
  prodRenderCategories();
  prodUpdateStats();
};

// ═══════ INVENTORY ═══════
function prodRenderInventory() {
  var tbody = document.getElementById('prod-inventory-tbody');
  var alertsWrap = document.getElementById('prod-low-stock-alerts');
  if (!tbody) return;

  // Low stock alerts
  var lowItems = demoProducts.filter(function(p) { return p.stock > 0 && p.stock < 5; });
  var outItems = demoProducts.filter(function(p) { return p.stock === 0; });
  var alertHtml = '';
  if (outItems.length > 0) {
    alertHtml += '<div class="stat-card animate-in" style="padding:14px 18px;display:flex;align-items:center;gap:12px;border-left:3px solid #ef4444;margin-bottom:10px;">' +
      '<svg style="width:16px;height:16px;color:#ef4444;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>' +
      '<p style="flex:1;font-size:12px;color:var(--text-secondary);"><strong style="color:#ef4444;">'+outItems.length+' producto(s) agotados:</strong> '+outItems.map(function(p){return p.name;}).join(', ')+'</p></div>';
  }
  if (lowItems.length > 0) {
    alertHtml += '<div class="stat-card animate-in" style="padding:14px 18px;display:flex;align-items:center;gap:12px;border-left:3px solid #f97316;margin-bottom:10px;">' +
      '<svg style="width:16px;height:16px;color:#f97316;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>' +
      '<p style="flex:1;font-size:12px;color:var(--text-secondary);"><strong style="color:#f97316;">'+lowItems.length+' producto(s) con bajo stock:</strong> '+lowItems.map(function(p){return p.name+' ('+p.stock+')';}).join(', ')+'</p></div>';
  }
  if (alertsWrap) alertsWrap.innerHTML = alertHtml;

  // Table
  tbody.innerHTML = demoProducts.map(function(p) {
    var stockColor = p.stock === 0 ? '#ef4444' : p.stock < 5 ? '#f97316' : 'var(--text-primary)';
    var statusLabel = p.stock === 0 ? 'Agotado' : p.stock < 5 ? 'Bajo stock' : 'Disponible';
    var statusBg = p.stock === 0 ? 'rgba(239,68,68,0.1)' : p.stock < 5 ? 'rgba(249,115,22,0.1)' : 'rgba(34,197,94,0.1)';
    var statusC = p.stock === 0 ? '#ef4444' : p.stock < 5 ? '#f97316' : '#22c55e';
    return '<tr style="border-bottom:1px solid var(--border);">' +
      '<td style="padding:12px 16px;font-weight:700;color:var(--text-primary);">'+p.name+'</td>' +
      '<td style="padding:12px 16px;color:var(--text-muted);font-size:12px;">'+p.sku+'</td>' +
      '<td style="padding:12px 16px;text-align:right;font-weight:800;color:'+stockColor+';">'+p.stock+'</td>' +
      '<td style="padding:12px 16px;"><span class="prod-badge" style="background:'+statusBg+';color:'+statusC+';">'+statusLabel+'</span></td>' +
      '<td style="padding:12px 16px;text-align:right;color:var(--text-secondary);">$'+p.cost.toLocaleString('es-MX')+'</td>' +
      '<td style="padding:12px 16px;text-align:right;font-weight:700;color:var(--text-primary);">$'+(p.cost * p.stock).toLocaleString('es-MX')+'</td>' +
      '<td style="padding:12px 16px;text-align:center;"><button onclick="prodOpenStockModal('+p.id+')" style="padding:5px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor=\'var(--accent)\';this.style.color=\'var(--accent)\'" onmouseout="this.style.borderColor=\'var(--border)\';this.style.color=\'var(--text-muted)\'">Ajustar</button></td>' +
    '</tr>';
  }).join('');

  // Adjustment log
  var logWrap = document.getElementById('prod-adjustment-log');
  if (logWrap) {
    logWrap.innerHTML = demoAdjustments.map(function(a) {
      var diff = a.to - a.from;
      var diffStr = diff > 0 ? '+'+diff : ''+diff;
      var diffColor = diff > 0 ? '#22c55e' : '#ef4444';
      return '<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);">' +
        '<div style="width:8px;height:8px;border-radius:50%;background:'+diffColor+';flex-shrink:0;"></div>' +
        '<div style="flex:1;"><p style="font-size:12px;font-weight:700;color:var(--text-primary);">'+a.product+'</p><p style="font-size:11px;color:var(--text-faint);">'+a.reason+' por '+a.user+' - '+a.date+'</p></div>' +
        '<span style="font-size:13px;font-weight:800;color:'+diffColor+';">'+diffStr+'</span>' +
        '<span style="font-size:12px;color:var(--text-muted);">'+a.from+' &rarr; '+a.to+'</span>' +
      '</div>';
    }).join('');
    if (demoAdjustments.length === 0) {
      logWrap.innerHTML = '<p style="text-align:center;padding:20px;color:var(--text-faint);font-size:13px;">No hay ajustes registrados.</p>';
    }
  }
}

window.prodOpenStockModal = function(id) {
  var p = demoProducts.find(function(x) { return x.id === id; });
  if (!p) return;
  prodStockEditId = id;
  document.getElementById('prod-stock-product-name').textContent = p.name;
  document.getElementById('prod-stock-current').textContent = p.stock;
  document.getElementById('prod-stock-new').value = '';
  document.getElementById('prod-stock-reason').value = 'restock';
  document.getElementById('prod-modal-stock').style.display = 'flex';
};

window.prodCloseStockModal = function() {
  document.getElementById('prod-modal-stock').style.display = 'none';
  prodStockEditId = null;
};

window.prodConfirmStock = function() {
  var newStock = parseInt(document.getElementById('prod-stock-new').value);
  if (isNaN(newStock) || newStock < 0) { showToast('Ingresa una cantidad valida'); return; }
  var p = demoProducts.find(function(x) { return x.id === prodStockEditId; });
  if (!p) return;
  var reason = document.getElementById('prod-stock-reason').selectedOptions[0].textContent;
  demoAdjustments.unshift({ id:demoAdjustments.length+1, product:p.name, from:p.stock, to:newStock, reason:reason, date:new Date().toISOString().slice(0,10), user:'Admin' });
  p.stock = newStock;
  p.status = newStock === 0 ? 'agotado' : 'activo';
  showToast('Stock de "'+p.name+'" actualizado a '+newStock);
  prodCloseStockModal();
  prodRenderInventory();
  prodUpdateStats();
  prodLoadRecs();
};

window.prodBulkUpdate = function() {
  showToast('Actualizacion en lote: todos los productos +5 unidades (demo)');
  demoProducts.forEach(function(p) {
    var old = p.stock;
    p.stock += 5;
    p.status = p.stock === 0 ? 'agotado' : 'activo';
    demoAdjustments.unshift({ id:demoAdjustments.length+1, product:p.name, from:old, to:p.stock, reason:'Reabastecimiento en lote', date:new Date().toISOString().slice(0,10), user:'Admin' });
  });
  prodRenderInventory();
  prodUpdateStats();
  prodLoadRecs();
};

// ═══════ ANALYTICS ═══════
function prodRenderAnalytics() {
  // Top selling products
  var topWrap = document.getElementById('prod-chart-topselling');
  if (topWrap) {
    var sorted = demoProducts.slice().sort(function(a,b) { return b.sold - a.sold; }).slice(0,5);
    var maxSold = sorted[0] ? sorted[0].sold : 1;
    topWrap.innerHTML = sorted.map(function(p) {
      var pct = (p.sold / maxSold * 100).toFixed(0);
      return '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">' +
        '<span style="font-size:12px;font-weight:700;color:var(--text-primary);min-width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+p.name+'</span>' +
        '<div style="flex:1;height:20px;background:var(--input-bg);border-radius:6px;overflow:hidden;"><div style="height:100%;width:'+pct+'%;background:linear-gradient(90deg,var(--accent),#8b5cf6);border-radius:6px;transition:width 0.5s;"></div></div>' +
        '<span style="font-size:12px;font-weight:800;color:var(--text-primary);min-width:30px;text-align:right;">'+p.sold+'</span>' +
      '</div>';
    }).join('');
  }

  // Revenue by category
  var catWrap = document.getElementById('prod-chart-catrevenue');
  if (catWrap) {
    var catRevenue = {};
    demoProducts.forEach(function(p) {
      if (!catRevenue[p.category]) catRevenue[p.category] = 0;
      catRevenue[p.category] += p.price * p.sold;
    });
    var cats = Object.keys(catRevenue).sort(function(a,b) { return catRevenue[b] - catRevenue[a]; });
    var maxRev = cats.length > 0 ? catRevenue[cats[0]] : 1;
    var catColors = { Ropa:'#6fcff5', Accesorios:'#8b5cf6', Artesanias:'#f97316', Bebidas:'#22c55e', Hogar:'#eab308' };
    catWrap.innerHTML = cats.map(function(c) {
      var pct = (catRevenue[c] / maxRev * 100).toFixed(0);
      var col = catColors[c] || 'var(--accent)';
      return '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">' +
        '<span style="font-size:12px;font-weight:700;color:var(--text-primary);min-width:100px;">'+c+'</span>' +
        '<div style="flex:1;height:20px;background:var(--input-bg);border-radius:6px;overflow:hidden;"><div style="height:100%;width:'+pct+'%;background:'+col+';border-radius:6px;transition:width 0.5s;"></div></div>' +
        '<span style="font-size:11px;font-weight:800;color:var(--text-primary);min-width:70px;text-align:right;">$'+(catRevenue[c]).toLocaleString('es-MX')+'</span>' +
      '</div>';
    }).join('');
  }

  // Stock value by category
  var stockValWrap = document.getElementById('prod-chart-stockvalue');
  if (stockValWrap) {
    var catStockVal = {};
    demoProducts.forEach(function(p) {
      if (!catStockVal[p.category]) catStockVal[p.category] = 0;
      catStockVal[p.category] += p.cost * p.stock;
    });
    var svCats = Object.keys(catStockVal).sort(function(a,b) { return catStockVal[b] - catStockVal[a]; });
    var maxSV = svCats.length > 0 ? catStockVal[svCats[0]] : 1;
    var catColors2 = { Ropa:'#6fcff5', Accesorios:'#8b5cf6', Artesanias:'#f97316', Bebidas:'#22c55e', Hogar:'#eab308' };
    stockValWrap.innerHTML = svCats.map(function(c) {
      var pct = maxSV > 0 ? (catStockVal[c] / maxSV * 100).toFixed(0) : 0;
      var col = catColors2[c] || 'var(--accent)';
      return '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">' +
        '<span style="font-size:12px;font-weight:700;color:var(--text-primary);min-width:100px;">'+c+'</span>' +
        '<div style="flex:1;height:20px;background:var(--input-bg);border-radius:6px;overflow:hidden;"><div style="height:100%;width:'+pct+'%;background:'+col+';border-radius:6px;transition:width 0.5s;"></div></div>' +
        '<span style="font-size:11px;font-weight:800;color:var(--text-primary);min-width:70px;text-align:right;">$'+(catStockVal[c]).toLocaleString('es-MX')+'</span>' +
      '</div>';
    }).join('');
  }

  // Products needing restock
  var restockWrap = document.getElementById('prod-chart-restock');
  if (restockWrap) {
    var needRestock = demoProducts.filter(function(p) { return p.stock < 5; }).sort(function(a,b) { return a.stock - b.stock; });
    if (needRestock.length === 0) {
      restockWrap.innerHTML = '<p style="text-align:center;padding:20px;color:var(--text-faint);font-size:13px;">Todos los productos tienen stock suficiente.</p>';
    } else {
      restockWrap.innerHTML = needRestock.map(function(p) {
        var urgency = p.stock === 0 ? '#ef4444' : '#f97316';
        return '<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border);">' +
          '<div style="width:8px;height:8px;border-radius:50%;background:'+urgency+';flex-shrink:0;"></div>' +
          '<span style="flex:1;font-size:12px;font-weight:700;color:var(--text-primary);">'+p.name+'</span>' +
          '<span style="font-size:12px;font-weight:800;color:'+urgency+';">'+p.stock+' uds</span>' +
          '<span style="font-size:10px;color:var(--text-faint);">'+p.category+'</span>' +
        '</div>';
      }).join('');
    }
  }
}

// ═══════ AUTOPILOT ═══════
function prodRenderAutopilot() {
  var wrap = document.getElementById('prod-autopilot-list');
  if (!wrap) return;
  wrap.innerHTML = prodAutoFlows.map(function(f) {
    return '<div class="stat-card" style="padding:16px;display:flex;align-items:center;gap:12px;">' +
      '<span style="font-size:24px;">'+f.icon+'</span>' +
      '<div style="flex:1;">' +
        '<p style="font-size:13px;font-weight:700;color:var(--text-primary);">'+f.name+'</p>' +
        '<p style="font-size:11px;color:var(--text-faint);">'+f.desc+'</p>' +
      '</div>' +
      '<div style="display:flex;align-items:center;gap:8px;">' +
        '<label class="prod-toggle-wrap"><input type="checkbox" '+(f.active?'checked':'')+' onchange="prodToggleAuto(\''+f.id+'\',this.checked)"/><span class="prod-toggle-slider" style="--toggle-color:'+f.color+';"></span></label>' +
        '<span style="font-size:11px;font-weight:700;color:'+(f.active?'#22c55e':'var(--text-faint)')+';">'+(f.active?'Activo':'Inactivo')+'</span>' +
      '</div>' +
    '</div>';
  }).join('');
}

window.prodToggleAuto = function(id, val) {
  var f = prodAutoFlows.find(function(x) { return x.id === id; });
  if (f) f.active = val;
  showToast(f.name + (val ? ' activado' : ' desactivado'));
  prodRenderAutopilot();
};

window.prodToggleSection = function(id) {
  var el = document.getElementById(id);
  if (el) el.style.display = el.style.display === 'none' ? '' : 'none';
};

// ═══════ HELP BANNERS ═══════
window.prodDismissHelp = function(tab) {
  var el = document.getElementById('prod-help-' + tab);
  if (el) {
    el.style.transition = 'opacity 0.3s, transform 0.3s';
    el.style.opacity = '0';
    el.style.transform = 'translateY(-10px)';
    setTimeout(function() { el.style.display = 'none'; }, 300);
  }
  try { localStorage.setItem('prod_help_' + tab, 'dismissed'); } catch(e) {}
};

function prodRestoreHelp() {
  ['catalog','add','categories','inventory','analytics'].forEach(function(tab) {
    try {
      if (localStorage.getItem('prod_help_' + tab) === 'dismissed') {
        var el = document.getElementById('prod-help-' + tab);
        if (el) el.style.display = 'none';
      }
    } catch(e) {}
  });
}

// ═══════ MORE MENU ═══════
window.prodToggleMore = function() {
  var m = document.getElementById('prod-more-menu');
  if (m) m.style.display = m.style.display === 'none' ? '' : 'none';
};
document.addEventListener('click', function(e) {
  var wrap = document.getElementById('prod-more-wrap');
  var menu = document.getElementById('prod-more-menu');
  if (wrap && menu && !wrap.contains(e.target)) menu.style.display = 'none';
});

// ═══════ CUSTOM FIELDS ═══════
var prodCustomFields = [];

function prodAddCustomField() {
  var name = prompt('Nombre del campo:', '');
  if (!name) return;
  prodCustomFields.push({ name: name, type: 'text', value: '' });
  prodRenderCustomFields();
}

function prodRemoveCustomField(idx) {
  prodCustomFields.splice(idx, 1);
  prodRenderCustomFields();
}

function prodRenderCustomFields() {
  var el = document.getElementById('prod-custom-fields');
  if (!prodCustomFields.length) {
    el.innerHTML = '<p style="font-size:11px;color:var(--text-faintest);text-align:center;padding:12px;">Sin campos personalizados.</p>';
    return;
  }
  el.innerHTML = prodCustomFields.map(function(f, i) {
    return '<div style="display:flex;gap:8px;align-items:end;">' +
      '<div style="flex:1;"><label class="prod-label">' + f.name + '</label><input type="text" placeholder="Valor..." class="prod-input" style="font-size:12px;" value="' + (f.value || '') + '" onchange="prodCustomFields[' + i + '].value=this.value"/></div>' +
      '<button onclick="prodRemoveCustomField(' + i + ')" style="width:32px;height:38px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text-faint);cursor:pointer;font-size:14px;">✕</button>' +
    '</div>';
  }).join('');
}

var presetFields = {
  restaurant: [{ name: 'Ingredientes', type: 'text' }, { name: 'Alérgenos', type: 'text' }, { name: 'Tiempo de preparación', type: 'text' }, { name: 'Calorías', type: 'text' }, { name: 'Tipo (Entrada/Plato fuerte/Postre/Bebida)', type: 'text' }],
  health: [{ name: 'Duración de consulta', type: 'text' }, { name: 'Especialidad', type: 'text' }, { name: 'Requiere receta', type: 'text' }, { name: 'Contraindicaciones', type: 'text' }],
  beauty: [{ name: 'Duración del servicio', type: 'text' }, { name: 'Tipo de cabello/piel', type: 'text' }, { name: 'Productos utilizados', type: 'text' }, { name: 'Nivel (Básico/Premium)', type: 'text' }],
  fitness: [{ name: 'Duración de clase', type: 'text' }, { name: 'Nivel (Principiante/Intermedio/Avanzado)', type: 'text' }, { name: 'Cupo máximo', type: 'text' }, { name: 'Instructor', type: 'text' }, { name: 'Equipo necesario', type: 'text' }],
  education: [{ name: 'Duración del curso', type: 'text' }, { name: 'Nivel', type: 'text' }, { name: 'Formato (Presencial/Online/Híbrido)', type: 'text' }, { name: 'Certificado incluido', type: 'text' }, { name: 'Requisitos previos', type: 'text' }],
  realestate: [{ name: 'Metros cuadrados', type: 'text' }, { name: 'Recámaras', type: 'text' }, { name: 'Baños', type: 'text' }, { name: 'Estacionamientos', type: 'text' }, { name: 'Zona/Colonia', type: 'text' }, { name: 'Tipo (Venta/Renta)', type: 'text' }],
};

function prodAddPresetFields(sector) {
  var fields = presetFields[sector] || [];
  fields.forEach(function(f) {
    if (!prodCustomFields.find(function(x) { return x.name === f.name; })) {
      prodCustomFields.push({ name: f.name, type: f.type, value: '' });
    }
  });
  prodRenderCustomFields();
  showToast('Campos de ' + sector + ' agregados');
}

// ═══════ INIT ═══════
(function() {
  prodUpdateStats();
  prodLoadRecs();
  prodRenderCatalog();
  prodRenderAutopilot();
  prodRestoreHelp();
})();
</script>
