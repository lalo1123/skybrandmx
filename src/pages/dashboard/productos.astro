---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:6100';
---

<DashboardLayout title="Productos">
  <!-- Smart Recommendations -->
  <div id="prod-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="prod-stat-label">Total productos</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="prod-stat-total" class="prod-stat-val">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="prod-stat-label">Valor del inventario <span class="prod-tip" data-tip="Suma del costo de todos los productos multiplicado por su stock actual">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="prod-stat-value" class="prod-stat-val" style="color:#22c55e;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="prod-stat-label">Agotados</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="prod-stat-outofstock" class="prod-stat-val" style="color:#ef4444;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="prod-stat-label">Bajo stock <span class="prod-tip" data-tip="Productos con menos de 5 unidades disponibles que necesitan reabastecimiento pronto">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="prod-stat-lowstock" class="prod-stat-val" style="color:#f97316;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="prod-stat-label">Categorias</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="prod-stat-cats" class="prod-stat-val" style="color:var(--accent);">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="prod-stat-label">Margen promedio <span class="prod-tip" data-tip="Porcentaje de ganancia promedio entre el precio de venta y el costo de cada producto">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="prod-stat-margin" class="prod-stat-val" style="color:#8b5cf6;">--</p></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="prod-tab-catalog" class="prod-tab active" onclick="switchProdTab('catalog')">Catalogo</button>
    <button id="prod-tab-add" class="prod-tab" onclick="switchProdTab('add')">Agregar producto</button>
    <button id="prod-tab-categories" class="prod-tab" onclick="switchProdTab('categories')">Categorias</button>
    <button id="prod-tab-inventory" class="prod-tab" onclick="switchProdTab('inventory')">Inventario</button>
    <button id="prod-tab-analytics" class="prod-tab" onclick="switchProdTab('analytics')">Analitica</button>
  </div>

  <!-- ══════════ Tab: Catalogo ══════════ -->
  <div id="prod-panel-catalog">
    <div id="prod-help-catalog" class="prod-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aqui ves todos tus productos. Usa los filtros para buscar por nombre, categoria o estado. Haz clic en un producto para ver sus detalles.</p>
      <button onclick="prodDismissHelp('catalog')" class="prod-help-close">&times;</button>
    </div>
    <div id="prod-empty-catalog" style="display:none;" class="prod-empty-state">
      <svg style="width:56px;height:56px;color:var(--accent);opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">Aun no tienes productos</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:360px;line-height:1.5;">Agrega tu primer producto para empezar a vender en tu tienda.</p>
      <button onclick="switchProdTab('add')" class="prod-btn-primary" style="margin-top:16px;padding:12px 28px;">Agregar mi primer producto</button>
    </div>
    <!-- Toolbar -->
    <div id="prod-toolbar" class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="prod-search" type="text" placeholder="Buscar por nombre, SKU..." oninput="prodFilterCatalog()" class="prod-input" style="padding-left:38px;"/>
      </div>
      <select id="prod-filter-cat" onchange="prodFilterCatalog()" class="prod-input" style="width:auto;cursor:pointer;">
        <option value="">Todas las categorias</option>
        <option value="Ropa">Ropa</option>
        <option value="Accesorios">Accesorios</option>
        <option value="Artesanias">Artesanias</option>
        <option value="Bebidas">Bebidas</option>
        <option value="Hogar">Hogar</option>
      </select>
      <select id="prod-filter-status" onchange="prodFilterCatalog()" class="prod-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="activo">Activo</option>
        <option value="agotado">Agotado</option>
        <option value="borrador">Borrador</option>
      </select>
      <button onclick="switchProdTab('add')" class="prod-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Agregar producto
      </button>
      <div style="position:relative;" id="prod-more-wrap">
        <button onclick="prodToggleMore()" class="prod-btn-secondary" style="padding:10px 14px;display:flex;align-items:center;gap:4px;">Mas <svg style="width:12px;height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></button>
        <div id="prod-more-menu" style="display:none;position:absolute;top:100%;right:0;margin-top:4px;background:var(--bg-sidebar);border:1px solid var(--border);border-radius:10px;padding:6px;min-width:160px;z-index:50;box-shadow:0 4px 20px rgba(0,0,0,0.3);">
          <button onclick="showToast('CSV exportado');prodToggleMore()" class="prod-dropdown-item">Exportar CSV</button>
          <button onclick="showToast('Importacion iniciada');prodToggleMore()" class="prod-dropdown-item">Importar productos</button>
        </div>
      </div>
    </div>
    <!-- Product grid -->
    <div id="prod-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;"></div>
  </div>

  <!-- ══════════ Tab: Agregar producto ══════════ -->
  <div id="prod-panel-add" style="display:none;">
    <div id="prod-help-add" class="prod-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Llena la informacion de tu producto. Los campos con * son obligatorios. La IA te ayuda a generar descripciones y titulos SEO.</p>
      <button onclick="prodDismissHelp('add')" class="prod-help-close">&times;</button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <!-- Left column: basic info -->
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Informacion basica</h4>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div><label class="prod-label">Nombre del producto *</label><input id="prod-add-name" type="text" placeholder="Ej: Blusa bordada Oaxaca" class="prod-input"/></div>
            <div><label class="prod-label">Descripcion</label><textarea id="prod-add-desc" rows="4" placeholder="Describe tu producto con detalle..." class="prod-input" style="resize:vertical;"></textarea></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div><label class="prod-label">Categoria *</label>
                <select id="prod-add-cat" class="prod-input" style="cursor:pointer;">
                  <option value="">Seleccionar...</option>
                  <option value="Ropa">Ropa</option>
                  <option value="Accesorios">Accesorios</option>
                  <option value="Artesanias">Artesanias</option>
                  <option value="Bebidas">Bebidas</option>
                  <option value="Hogar">Hogar</option>
                </select>
              </div>
              <div><label class="prod-label">Peso (kg)</label><input id="prod-add-weight" type="number" step="0.1" placeholder="0.5" class="prod-input"/></div>
            </div>
          </div>
        </div>
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Precios</h4>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
              <div><label class="prod-label">Precio de venta * <span class="prod-tip" data-tip="El precio que ve tu cliente en la tienda">?</span></label><input id="prod-add-price" type="number" step="0.01" placeholder="450.00" class="prod-input" oninput="prodCalcMargin()"/></div>
              <div><label class="prod-label">Precio comparar <span class="prod-tip" data-tip="Se muestra tachado junto al precio real para dar sensacion de descuento">?</span></label><input id="prod-add-compare" type="number" step="0.01" placeholder="600.00" class="prod-input"/></div>
              <div><label class="prod-label">Costo <span class="prod-tip" data-tip="Lo que te cuesta a ti. Se usa para calcular tu margen de ganancia">?</span></label><input id="prod-add-cost" type="number" step="0.01" placeholder="180.00" class="prod-input" oninput="prodCalcMargin()"/></div>
            </div>
            <div style="padding:12px 16px;border-radius:10px;background:var(--accent-bg);border:1px solid rgba(111,207,245,0.15);display:flex;align-items:center;gap:10px;">
              <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <p style="font-size:12px;color:var(--text-secondary);">Margen de ganancia: <strong id="prod-add-margin" style="color:var(--accent);">--%</strong></p>
            </div>
          </div>
        </div>
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Inventario</h4>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div><label class="prod-label">SKU <span class="prod-tip" data-tip="Codigo unico para identificar este producto en tu sistema">?</span></label><input id="prod-add-sku" type="text" placeholder="BLU-OAX-001" class="prod-input"/></div>
              <div><label class="prod-label">Codigo de barras</label><input id="prod-add-barcode" type="text" placeholder="7501234567890" class="prod-input"/></div>
            </div>
            <div><label class="prod-label">Stock disponible *</label><input id="prod-add-stock" type="number" placeholder="25" class="prod-input"/></div>
          </div>
        </div>
      </div>
      <!-- Right column: media, variants, SEO -->
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Fotos del producto</h4>
          <div id="prod-add-photos" style="border:2px dashed var(--border);border-radius:12px;padding:32px;text-align:center;cursor:pointer;transition:all 0.2s;" onclick="showToast('Subida de fotos disponible pronto')" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
            <svg style="width:40px;height:40px;color:var(--text-faint);margin:0 auto 10px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <p style="font-size:13px;font-weight:700;color:var(--text-muted);margin-bottom:4px;">Arrastra fotos aqui o haz clic</p>
            <p style="font-size:11px;color:var(--text-faint);">PNG, JPG hasta 5MB. Recomendado: 800x800px</p>
          </div>
        </div>
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Variantes</h4>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div><label class="prod-label">Tallas (separadas por coma)</label><input id="prod-add-sizes" type="text" placeholder="CH, M, G, XG" class="prod-input"/></div>
            <div><label class="prod-label">Colores (separados por coma)</label><input id="prod-add-colors" type="text" placeholder="Rojo, Azul, Negro" class="prod-input"/></div>
          </div>
        </div>
        <!-- Custom fields -->
        <div class="stat-card animate-in" style="padding:20px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
            <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);">Campos personalizados <span class="prod-tip" data-tip="Agrega cualquier información extra que necesites para tu tipo de negocio. Ejemplo: ingredientes, materiales, tiempo de preparación, nivel de dificultad, etc.">?</span></h4>
            <button onclick="prodAddCustomField()" style="padding:5px 12px;border-radius:6px;border:1px dashed var(--border);background:transparent;color:var(--text-muted);font-size:11px;font-weight:600;cursor:pointer;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">+ Agregar campo</button>
          </div>
          <div id="prod-custom-fields" style="display:flex;flex-direction:column;gap:10px;">
            <p style="font-size:11px;color:var(--text-faintest);text-align:center;padding:12px;">Sin campos personalizados. Agrega los que necesites para tu tipo de negocio.</p>
          </div>
          <div style="margin-top:12px;padding:10px;border-radius:8px;background:var(--input-bg);">
            <p style="font-size:11px;font-weight:700;color:var(--text-faint);margin-bottom:6px;">Ejemplos por sector:</p>
            <div style="display:flex;flex-wrap:wrap;gap:6px;">
              <button onclick="prodAddPresetFields('restaurant')" style="padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:10px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">🍽 Restaurante</button>
              <button onclick="prodAddPresetFields('health')" style="padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:10px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">🏥 Salud</button>
              <button onclick="prodAddPresetFields('beauty')" style="padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:10px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">💇 Belleza</button>
              <button onclick="prodAddPresetFields('fitness')" style="padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:10px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">🏋 Fitness</button>
              <button onclick="prodAddPresetFields('education')" style="padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:10px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">📚 Educación</button>
              <button onclick="prodAddPresetFields('realestate')" style="padding:4px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:10px;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">🏠 Inmobiliaria</button>
            </div>
          </div>
        </div>
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">SEO <span class="prod-tip" data-tip="Optimizacion para que tu producto aparezca en Google cuando lo busquen">?</span></h4>
          <div style="display:flex;flex-direction:column;gap:14px;">
            <div><label class="prod-label">Meta titulo</label><input id="prod-add-metatitle" type="text" placeholder="Blusa bordada Oaxaca - Artesanal mexicana" class="prod-input" maxlength="70" oninput="prodUpdateSeoCount('title')"/><p id="prod-seo-title-count" style="font-size:10px;color:var(--text-faint);text-align:right;margin-top:2px;">0/70</p></div>
            <div><label class="prod-label">Meta descripcion</label><textarea id="prod-add-metadesc" rows="3" placeholder="Hermosa blusa bordada a mano por artesanas oaxaquenas..." class="prod-input" style="resize:vertical;" maxlength="160" oninput="prodUpdateSeoCount('desc')"></textarea><p id="prod-seo-desc-count" style="font-size:10px;color:var(--text-faint);text-align:right;margin-top:2px;">0/160</p></div>
          </div>
        </div>
        <button onclick="prodSaveProduct()" class="prod-btn-primary" style="padding:14px;font-size:14px;width:100%;display:flex;align-items:center;justify-content:center;gap:8px;">
          <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Guardar producto
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Categorias ══════════ -->
  <div id="prod-panel-categories" style="display:none;">
    <div id="prod-help-categories" class="prod-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Organiza tus productos en categorias. Puedes crear, editar o eliminar categorias. Los productos se agrupan automaticamente.</p>
      <button onclick="prodDismissHelp('categories')" class="prod-help-close">&times;</button>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
      <button onclick="prodOpenCatModal()" class="prod-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva categoria
      </button>
    </div>
    <div id="prod-categories-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;"></div>
  </div>

  <!-- ══════════ Tab: Inventario ══════════ -->
  <div id="prod-panel-inventory" style="display:none;">
    <div id="prod-help-inventory" class="prod-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Controla el stock de tus productos. Las alertas en rojo indican productos agotados y las naranjas bajo stock. Puedes ajustar cantidades en lote.</p>
      <button onclick="prodDismissHelp('inventory')" class="prod-help-close">&times;</button>
    </div>
    <!-- Low stock alerts -->
    <div id="prod-low-stock-alerts" style="margin-bottom:16px;"></div>
    <div style="display:flex;justify-content:flex-end;gap:10px;margin-bottom:16px;">
      <button onclick="prodBulkUpdate()" class="prod-btn-secondary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        Actualizar stock en lote
      </button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
