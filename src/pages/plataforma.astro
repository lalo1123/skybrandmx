---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const whatsappPhone = '5525582310';

const modules = [
  {
    id: 'pedidos',
    name: 'Gestión de Pedidos',
    tagline: 'Todos tus canales, un solo lugar',
    description: 'Centraliza pedidos de Shopify, WooCommerce, Mercado Libre y Amazon en un dashboard unificado. Status en tiempo real, reglas automáticas y notificaciones.',
    features: ['Multi-canal sincronizado', 'Status en tiempo real', 'Reglas automáticas', 'Notificaciones a clientes', 'Historial completo'],
    icon: '📦',
    gradient: 'from-orange-500 to-amber-500',
    bgLight: 'bg-orange-50',
    accent: 'text-orange-600',
  },
  {
    id: 'crm',
    name: 'CRM',
    tagline: 'Conoce a cada cliente',
    description: 'Base de datos de contactos con historial completo de interacciones, compras y comunicaciones. Scoring automático y segmentación inteligente.',
    features: ['Contactos ilimitados (Growth+)', 'Scoring automático', 'Segmentación inteligente', 'Historial de interacciones', 'Integración con WhatsApp'],
    icon: '👥',
    gradient: 'from-blue-500 to-indigo-500',
    bgLight: 'bg-blue-50',
    accent: 'text-blue-600',
  },
  {
    id: 'facturacion',
    name: 'Facturación SAT',
    tagline: 'CFDI 4.0 automatizado',
    description: 'Genera facturas automáticamente desde cada pedido. Complementos de pago, notas de crédito y facturación masiva. 100% compatible con el SAT.',
    features: ['CFDI 4.0 automático', 'Complementos de pago', 'Notas de crédito', 'Facturación masiva', 'Reportes fiscales'],
    icon: '🧾',
    gradient: 'from-emerald-500 to-green-500',
    bgLight: 'bg-emerald-50',
    accent: 'text-emerald-600',
  },
  {
    id: 'envios',
    name: 'Guías de Envío',
    tagline: 'Multi-paquetería, tarifas preferenciales',
    description: 'Genera guías de DHL, Estafeta, FedEx y Redpack desde el panel. Reglas automáticas por peso, zona y costo. Tracking integrado para tus clientes.',
    features: ['DHL, Estafeta, FedEx, Redpack', 'Tarifas preferenciales', 'Reglas automáticas', 'Tracking integrado', 'Etiquetas de envío'],
    icon: '🚚',
    gradient: 'from-brand-primary to-cyan-500',
    bgLight: 'bg-sky-50',
    accent: 'text-brand-primary',
  },
  {
    id: 'ads',
    name: 'Ads con IA',
    tagline: 'Publicidad que se optimiza sola',
    description: 'Conecta tus cuentas de Meta Ads y Google Ads. Nuestra IA optimiza tu presupuesto automáticamente para maximizar conversiones y reducir CPA.',
    features: ['Meta Ads + Google Ads', 'Optimización automática', 'Reportes de ROAS', 'Audiencias sugeridas', 'A/B testing automático'],
    icon: '🤖',
    gradient: 'from-purple-500 to-pink-500',
    bgLight: 'bg-purple-50',
    accent: 'text-purple-600',
  },
  {
    id: 'email',
    name: 'Email Marketing',
    tagline: 'Campañas que convierten',
    description: 'Diseña campañas con plantillas profesionales, crea automations basadas en comportamiento y segmenta tu audiencia para envíos personalizados.',
    features: ['Plantillas drag & drop', 'Automations avanzados', 'Segmentación por comportamiento', 'A/B testing', 'Reportes de apertura/clic'],
    icon: '📧',
    gradient: 'from-rose-500 to-red-500',
    bgLight: 'bg-rose-50',
    accent: 'text-rose-600',
  },
  {
    id: 'reportes',
    name: 'Reportes y Analytics',
    tagline: 'Datos para tomar decisiones',
    description: 'Dashboard unificado con métricas de ventas, ads, logística y finanzas. Reportes automáticos semanales y mensuales para tu equipo.',
    features: ['Dashboard en tiempo real', 'Métricas multi-canal', 'Reportes automáticos', 'Exportación a Excel/PDF', 'KPIs personalizables'],
    icon: '📊',
    gradient: 'from-teal-500 to-emerald-500',
    bgLight: 'bg-teal-50',
    accent: 'text-teal-600',
  },
  {
    id: 'integraciones',
    name: 'Integraciones',
    tagline: '+50 herramientas conectadas',
    description: 'Conecta con Shopify, WooCommerce, Mercado Libre, Stripe, Mercado Pago, WhatsApp, Slack, Zapier y más. API REST para integraciones custom.',
    features: ['Shopify, WooCommerce, ML', 'Stripe, Mercado Pago', 'WhatsApp, Slack, Gmail', 'Zapier (2,000+ apps)', 'API REST documentada'],
    icon: '🔌',
    gradient: 'from-slate-600 to-slate-800',
    bgLight: 'bg-slate-50',
    accent: 'text-slate-600',
  },
];
---

<Layout title="Plataforma — SkyBrandMX | CRM, Facturación, Envíos, Ads y Email Marketing">
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="pt-36 pb-20 bg-gradient-to-b from-slate-900 via-brand-dark to-slate-900 text-white">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-teal/10 border border-brand-teal/20 text-brand-teal text-xs font-bold mb-8">
          Una plataforma, todo integrado
        </div>
        <h1 class="text-4xl md:text-7xl font-black tracking-tighter mb-6">
          Todo lo que necesitas <span class="text-brand-teal">en un solo lugar.</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-400 font-medium max-w-2xl mx-auto mb-12">
          CRM, facturación SAT, guías de envío, ads con IA, email marketing y gestión de pedidos — integrados y automatizados.
        </p>

        <!-- Quick nav -->
        <div class="flex flex-wrap justify-center gap-2">
          {modules.map((mod) => (
            <a href={`#${mod.id}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-sm font-medium text-slate-300 hover:bg-white/10 hover:text-white transition-all">
              <span>{mod.icon}</span>
              {mod.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-20 bg-white">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-5xl font-black tracking-tighter mb-6 text-slate-900">¿Cómo funciona?</h2>
        <p class="text-lg text-slate-500 font-medium mb-16 max-w-2xl mx-auto">Tres pasos para transformar tu operación.</p>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="relative">
            <div class="w-16 h-16 rounded-2xl bg-brand-primary/10 flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-black text-brand-primary">1</span>
            </div>
            <h3 class="text-lg font-black text-slate-900 mb-2">Conecta tus herramientas</h3>
            <p class="text-sm text-slate-500">Vincula tu tienda en línea, pasarelas de pago y cuentas de ads en minutos.</p>
          </div>
          <div class="relative">
            <div class="w-16 h-16 rounded-2xl bg-brand-teal/10 flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-black text-brand-teal">2</span>
            </div>
            <h3 class="text-lg font-black text-slate-900 mb-2">Configura tu operación</h3>
            <p class="text-sm text-slate-500">Define reglas de envío, plantillas de facturación y automations de email.</p>
          </div>
          <div class="relative">
            <div class="w-16 h-16 rounded-2xl bg-emerald-500/10 flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-black text-emerald-500">3</span>
            </div>
            <h3 class="text-lg font-black text-slate-900 mb-2">Automatiza y escala</h3>
            <p class="text-sm text-slate-500">Todo corre automáticamente. Tú te enfocas en crecer tu negocio.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Modules -->
    {modules.map((mod, idx) => (
      <section id={mod.id} class={`py-20 ${idx % 2 === 0 ? 'bg-slate-50' : 'bg-white'}`}>
        <div class="max-w-6xl mx-auto px-6">
          <div class="grid lg:grid-cols-2 gap-12 items-center">
            {/* Info */}
            <div class={idx % 2 !== 0 ? 'lg:order-2' : ''}>
              <div class={`inline-flex items-center gap-2 px-3 py-1 rounded-full ${mod.bgLight} ${mod.accent} text-xs font-bold mb-4`}>
                <span>{mod.icon}</span> {mod.tagline}
              </div>
              <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-slate-900 mb-4">{mod.name}</h2>
              <p class="text-slate-500 text-lg leading-relaxed mb-8">{mod.description}</p>
              <ul class="space-y-3">
                {mod.features.map((feat) => (
                  <li class="flex items-center gap-3">
                    <svg class={`w-5 h-5 ${mod.accent} shrink-0`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-sm font-medium text-slate-700">{feat}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Visual card */}
            <div class={idx % 2 !== 0 ? 'lg:order-1' : ''}>
              <div class={`rounded-3xl bg-gradient-to-br ${mod.gradient} p-10 md:p-14 text-white shadow-2xl`}>
                <span class="text-6xl mb-6 block">{mod.icon}</span>
                <h3 class="text-2xl font-black mb-3">{mod.name}</h3>
                <p class="text-white/80 text-sm leading-relaxed">{mod.tagline}</p>
                <div class="mt-8 grid grid-cols-2 gap-4">
                  {mod.features.slice(0, 4).map((feat) => (
                    <div class="flex items-center gap-2">
                      <div class="w-1.5 h-1.5 rounded-full bg-white/60"></div>
                      <span class="text-xs font-medium text-white/80">{feat}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- CTA -->
    <section class="py-24 bg-gradient-to-r from-brand-primary to-slate-800 text-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-5xl font-black tracking-tighter mb-6">¿Listo para automatizar tu negocio?</h2>
        <p class="text-lg text-slate-300 font-medium mb-10">Empieza con una prueba gratis de 14 días. Sin tarjeta de crédito.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={`https://wa.me/${whatsappPhone}?text=${encodeURIComponent('Hola, me interesa conocer más sobre la plataforma SkyBrandMX')}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-brand-teal text-slate-900 font-black text-base hover:-translate-y-0.5 transition-all shadow-lg shadow-brand-teal/20"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Hablar con un asesor
          </a>
          <a
            href="/precios"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-white/10 border border-white/20 text-white font-bold text-base hover:bg-white/20 transition-all"
          >
            Ver precios
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
