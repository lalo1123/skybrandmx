---
import AuthLayout from '../layouts/AuthLayout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:6100';
---

<AuthLayout title="Iniciar sesión — SkyBrandMX">
  <div class="glass-card p-8 md:p-10 bg-slate-900/50 border border-white/5">
    <!-- Step 1: Email + Password -->
    <div id="step-1">
      <h1 class="text-2xl font-black mb-2">Iniciar sesión</h1>
      <p class="text-slate-400 text-sm mb-8">Ingresa tus credenciales para acceder al panel.</p>

      <form id="login-form" class="space-y-5">
        <div>
          <label for="email" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="username"
            required
            placeholder="tu@empresa.com"
            class="w-full px-4 py-3 rounded-xl bg-slate-800/80 border border-white/10 text-white font-medium placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal transition-all"
          />
        </div>
        <div>
          <label for="password" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            placeholder="••••••••"
            class="w-full px-4 py-3 rounded-xl bg-slate-800/80 border border-white/10 text-white font-medium placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal transition-all"
          />
        </div>
        <div id="error-1" class="hidden text-red-400 text-sm font-medium p-3 rounded-lg bg-red-500/10 border border-red-500/20"></div>
        <button type="submit" id="btn-1" class="w-full py-3.5 rounded-xl bg-brand-teal text-slate-900 font-black text-sm hover:-translate-y-0.5 transition-all active:scale-[0.98]">
          Continuar
        </button>
      </form>
    </div>

    <!-- Step 2: 2FA Code -->
    <div id="step-2" class="hidden">
      <button id="back-btn" class="flex items-center gap-2 text-slate-400 text-sm font-medium mb-6 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Volver
      </button>
      <h1 class="text-2xl font-black mb-2">Verificación</h1>
      <p class="text-slate-400 text-sm mb-8">Ingresa el código de 6 dígitos que enviamos a tu email.</p>

      <form id="twofa-form" class="space-y-5">
        <div>
          <label for="code" class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Código de verificación</label>
          <input
            type="text"
            id="code"
            maxlength="6"
            pattern="[0-9]{6}"
            required
            placeholder="000000"
            class="w-full px-4 py-3 rounded-xl bg-slate-800/80 border border-white/10 text-white font-black text-2xl text-center tracking-[0.5em] placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-brand-teal/30 focus:border-brand-teal transition-all"
          />
        </div>
        <div id="error-2" class="hidden text-red-400 text-sm font-medium p-3 rounded-lg bg-red-500/10 border border-red-500/20"></div>
        <button type="submit" id="btn-2" class="w-full py-3.5 rounded-xl bg-brand-teal text-slate-900 font-black text-sm hover:-translate-y-0.5 transition-all active:scale-[0.98]">
          Verificar
        </button>
        <button type="button" id="resend-btn" class="w-full py-2 text-slate-500 text-xs font-bold hover:text-brand-teal transition-colors">
          ¿No recibiste el código? Reenviar
        </button>
      </form>
    </div>
  </div>

  <p class="text-center text-slate-600 text-xs mt-6">
    <a href="/" class="hover:text-slate-400 transition-colors">← Volver al inicio</a>
  </p>
</AuthLayout>

<script define:vars={{ API_URL }}>
  const step1 = document.getElementById('step-1');
  const step2 = document.getElementById('step-2');
  const loginForm = document.getElementById('login-form');
  const twofaForm = document.getElementById('twofa-form');
  const error1 = document.getElementById('error-1');
  const error2 = document.getElementById('error-2');
  const btn1 = document.getElementById('btn-1');
  const btn2 = document.getElementById('btn-2');
  const backBtn = document.getElementById('back-btn');
  const resendBtn = document.getElementById('resend-btn');

  let currentUserId = null;
  let currentEmail = '';
  let currentPassword = '';

  // Check if already logged in
  if (localStorage.getItem('skybrand_token')) {
    window.location.href = '/dashboard';
  }

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    error1.classList.add('hidden');
    btn1.textContent = 'Verificando...';
    btn1.disabled = true;

    const formData = new FormData();
    currentEmail = document.getElementById('email').value;
    currentPassword = document.getElementById('password').value;
    formData.append('username', currentEmail);
    formData.append('password', currentPassword);

    try {
      const res = await fetch(`${API_URL}/api/v1/auth/login`, {
        method: 'POST',
        body: formData,
      });
      const data = await res.json();

      if (!res.ok) {
        error1.textContent = data.detail || 'Error al iniciar sesión.';
        error1.classList.remove('hidden');
        btn1.textContent = 'Continuar';
        btn1.disabled = false;
        return;
      }

      if (data.requires_2fa) {
        currentUserId = data.user_id;
        step1.classList.add('hidden');
        step2.classList.remove('hidden');
        document.getElementById('code').focus();
      }
    } catch (err) {
      error1.textContent = 'Error de conexión con el servidor.';
      error1.classList.remove('hidden');
      btn1.textContent = 'Continuar';
      btn1.disabled = false;
    }
  });

  twofaForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    error2.classList.add('hidden');
    btn2.textContent = 'Verificando...';
    btn2.disabled = true;

    const code = document.getElementById('code').value;

    try {
      const res = await fetch(`${API_URL}/api/v1/auth/verify-2fa`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: currentUserId, code }),
      });
      const data = await res.json();

      if (!res.ok) {
        error2.textContent = data.detail || 'Código incorrecto.';
        error2.classList.remove('hidden');
        btn2.textContent = 'Verificar';
        btn2.disabled = false;
        return;
      }

      localStorage.setItem('skybrand_token', data.access_token);
      window.location.href = '/dashboard';
    } catch (err) {
      error2.textContent = 'Error de conexión.';
      error2.classList.remove('hidden');
      btn2.textContent = 'Verificar';
      btn2.disabled = false;
    }
  });

  backBtn?.addEventListener('click', () => {
    step2.classList.add('hidden');
    step1.classList.remove('hidden');
    btn1.textContent = 'Continuar';
    btn1.disabled = false;
  });

  resendBtn?.addEventListener('click', async () => {
    resendBtn.textContent = 'Reenviando...';
    const formData = new FormData();
    formData.append('username', currentEmail);
    formData.append('password', currentPassword);
    try {
      await fetch(`${API_URL}/api/v1/auth/login`, { method: 'POST', body: formData });
      resendBtn.textContent = 'Código reenviado ✓';
    } catch {
      resendBtn.textContent = 'Error al reenviar';
    }
    setTimeout(() => { resendBtn.textContent = '¿No recibiste el código? Reenviar'; }, 3000);
  });
</script>
