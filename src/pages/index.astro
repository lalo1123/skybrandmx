---
import Layout from '../layouts/Layout.astro';
import SegmentationTabs from '../components/SegmentationTabs.astro';
---

<style>
	@keyframes float {
		0% { transform: translateY(0px); }
		50% { transform: translateY(-10px); }
		100% { transform: translateY(0px); }
	}
	.animate-float {
		animation: float 6s ease-in-out infinite;
	}
	.animate-float-delayed {
		animation: float 8s ease-in-out infinite -2s;
	}
</style>

<Layout title="Panel Todo en Uno para PYMES | CRM, Facturación y Envíos — SkyBrandMX">
	<nav class="py-6 sticky top-0 z-50 shadow-md" style="background-color: #084d6e;">
		<div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
			<a href="/" class="block">
                <div class="group relative" aria-label="SkybrandMX">
                    <h1 class="font-bold text-2xl tracking-tight transition-colors duration-300 text-white"><span>SKYBR</span><span class="bg-gradient-to-br from-[#6fcff5] to-white bg-clip-text text-transparent">A</span><span class="bg-gradient-to-br from-[#6fcff5] to-white bg-clip-text text-transparent">N</span><span>DM</span><span class="bg-gradient-to-br from-[#6fcff5] to-white bg-clip-text text-transparent">X</span></h1>
                    <div class="absolute -bottom-1 left-0 h-[3px] w-1/3 rounded-full bg-gradient-to-r from-brand-cyan to-brand-teal transition-all duration-500 ease-out group-hover:w-full" style="filter: saturate(1.2);"></div>
                </div>
			</a>
			<div class="hidden md:flex gap-8 items-center text-sm font-bold tracking-wider">
				<a href="#inicio" class="text-brand-secondary border-b-2 border-brand-secondary pb-1">INICIO</a>
				<a href="#nosotros" class="text-white hover:text-brand-accent transition-colors">SOBRE NOSOTROS</a>
				<a href="#servicios" class="text-white hover:text-brand-accent transition-colors">SERVICIOS</a>
				<a href="#clientes" class="text-white hover:text-brand-accent transition-colors">CLIENTES</a>
				<a href="#contacto" class="text-white hover:text-brand-accent transition-colors">CONTACTO</a>
				<a href="#blog" class="text-white hover:text-brand-accent transition-colors">BLOG</a>
			</div>
		</div>
	</nav>

	<main>
		<!-- HERO SECTION -->
		<section class="relative pt-32 pb-24 overflow-hidden bg-white">
			<!-- Background subtle light gradient -->
			<div class="absolute inset-0 bg-gradient-to-b from-slate-50/80 to-white pointer-events-none"></div>

			<div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-20 items-center relative z-10">
				<div class="flex flex-col items-start">
					<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#EBFDFA] border border-[#D1F9F1] text-[#0d9488] text-xs font-bold mb-10">
						<span class="flex h-2 w-2 rounded-full bg-[#14b8a6]"></span>
                        Nuevo: Panel Todo-en-Uno para México
					</div>
					<h1 class="text-7xl lg:text-[90px] font-black tracking-tight mb-8 leading-[0.9] text-slate-900">
						Toda tu empresa <br/><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#2dd4bf] to-[#0d9488]">bajo control.</span>
					</h1>
					<p class="text-xl text-slate-500 mb-12 max-w-xl leading-relaxed font-semibold">
						CRM, facturación SAT, guías de envío y automatización — integrados en una sola plataforma Enterprise diseñada para escalar tu negocio.
					</p>
					<div class="flex flex-col sm:flex-row gap-5 mb-14 w-full sm:w-auto">
						<a href="#pricing" class="px-10 py-5 bg-[#084d6e] text-white rounded-2xl text-lg font-black shadow-[0_20px_40px_rgba(8,77,110,0.3)] hover:bg-[#063d58] transition-all transform hover:-translate-y-1 active:scale-95 text-center">Prueba 14 Días Gratis</a>
						<a href="#demo" class="px-10 py-5 bg-slate-50 text-slate-900 rounded-2xl text-lg font-black border border-slate-200 hover:bg-slate-100 transition-all transform hover:-translate-y-1 active:scale-95 text-center">Agendar Demo</a>
					</div>
					<div class="flex items-center gap-4 text-sm font-bold">
						<div class="flex -space-x-3">
							<div class="w-10 h-10 rounded-full border-2 border-white bg-slate-100 shadow-sm overflow-hidden flex items-center justify-center text-lg">🧔🏻</div>
							<div class="w-10 h-10 rounded-full border-2 border-white bg-slate-100 shadow-sm overflow-hidden flex items-center justify-center text-lg">👩🏼‍💻</div>
							<div class="w-10 h-10 rounded-full border-2 border-white bg-slate-100 shadow-sm overflow-hidden flex items-center justify-center text-sm">📦</div>
						</div>
						<span class="text-slate-400">Confiado por <strong class="text-slate-900">+150 PYMES</strong> en México</span>
					</div>
				</div>

				<!-- Dashboard Visual / App Mockup -->
				<div class="relative w-full max-w-2xl mx-auto lg:ml-auto">
					<!-- Floating Elements matching Reference (Refined) -->
					<div class="absolute -right-16 top-[15%] z-20 animate-float">
						<div class="bg-white rounded-[1.75rem] p-5 shadow-[0_40px_80px_-15px_rgba(0,0,0,0.15)] flex items-center gap-5 border border-slate-50">
							<div class="w-14 h-14 rounded-3xl bg-[#3b82f6] text-white flex items-center justify-center shadow-lg shadow-blue-500/20">
                                <span class="text-xl">📈</span>
							</div>
							<div>
								<p class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Conversión</p>
								<p class="text-2xl font-black text-slate-900 leading-none tracking-tight">+18.4%</p>
							</div>
						</div>
					</div>

					<div class="absolute -left-20 top-[45%] z-20 animate-float-delayed">
						<div class="bg-white rounded-[1.75rem] p-5 shadow-[0_40px_80px_-15px_rgba(0,0,0,0.15)] flex items-center gap-5 border border-slate-50">
							<div class="w-14 h-14 rounded-3xl bg-[#a855f7] text-white flex items-center justify-center shadow-lg shadow-purple-500/20">
                                <span class="text-2xl">🔔</span>
							</div>
							<div>
								<p class="text-[11px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Nuevos Leads</p>
								<p class="text-2xl font-black text-slate-900 leading-none tracking-tight">24 Hoy</p>
							</div>
						</div>
					</div>

					<div class="glass-card w-full aspect-[16/11] relative overflow-hidden flex flex-col bg-white border-slate-100 shadow-[0_100px_200px_-40px_rgba(0,0,0,0.12)]">
						<div class="h-20 border-b border-slate-50 px-10 flex items-center justify-between bg-white text-slate-400">
							<div class="flex gap-3">
								<div class="w-3.5 h-3.5 rounded-full bg-[#FF5F57]"></div>
								<div class="w-3.5 h-3.5 rounded-full bg-[#FEBC2E]"></div>
								<div class="w-3.5 h-3.5 rounded-full bg-[#28C840]"></div>
							</div>
							<div class="flex-1 max-w-sm mx-auto">
                                <div class="bg-slate-50 rounded-2xl h-10 flex items-center px-5 gap-3 border border-slate-100/50">
                                    <span class="text-[12px] text-slate-400 font-semibold tracking-tight">app.skybrandmx.mx</span>
                                </div>
                            </div>
							<div class="w-20 flex justify-end">
                                <div class="w-11 h-11 rounded-full bg-slate-50 flex items-center justify-center text-[12px] font-black italic border border-slate-100 text-[#1e293b]">SJ</div>
                            </div>
						</div>
						
						<div class="flex-1 flex overflow-hidden">
							<div class="w-24 flex flex-col items-center py-10 border-r border-slate-50 gap-10 bg-white">
								<div class="w-12 h-12 rounded-2xl text-white flex items-center justify-center shadow-lg shadow-[#1e293b]/20 bg-[#1e293b]">🚀</div>
								<div class="w-10 h-10 rounded-xl bg-slate-50 text-slate-300 flex items-center justify-center border border-slate-100/50">💼</div>
								<div class="w-10 h-10 rounded-xl bg-slate-50 text-slate-300 flex items-center justify-center border border-slate-100/50">📄</div>
								<div class="w-10 h-10 rounded-xl bg-slate-50 text-slate-300 flex items-center justify-center border border-slate-100/50">⚙️</div>
							</div>
							<div class="flex-1 p-8 flex flex-col gap-6 bg-white/50 backdrop-blur-3xl">
								<div class="flex items-end justify-between">
									<div class="space-y-1">
										<h3 class="text-2xl font-black text-[#1e293b] tracking-tighter leading-tight">Visión Operativa</h3>
										<p class="text-[9px] text-slate-400 font-black uppercase tracking-[0.3em] opacity-80">Métricas en tiempo real</p>
									</div>
									<div class="bg-white border border-slate-200/60 rounded-xl px-4 py-2 shadow-sm text-[8px] font-black text-slate-400 tracking-wider">MARZO 2026</div>
								</div>
								
								<div class="grid grid-cols-2 gap-5">
									<div class="bg-white border border-slate-100 rounded-[1.75rem] p-6 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.03)]">
										<div class="flex justify-between items-start mb-5">
                                            <div class="w-10 h-10 rounded-xl bg-[#EBFDFA] text-[#0d9488] flex items-center justify-center text-xl border border-[#D1F9F1]">💵</div>
                                            <span class="text-[9px] font-black text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full">+24.5%</span>
                                        </div>
										<p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.15em] mb-1.5 font-black">Ingresos Netos</p>
										<span class="text-3xl font-black text-[#1e293b] tracking-tighter leading-none">$842.2k</span>
									</div>
									<div class="bg-white border border-slate-100 rounded-[1.75rem] p-6 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.03)]">
                                        <div class="flex justify-between items-start mb-5">
                                            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center text-xl border border-blue-100">📦</div>
                                            <span class="text-[9px] font-black text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full">+12%</span>
                                        </div>
										<p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.15em] mb-1.5 font-black">Envíos Exitosos</p>
										<span class="text-3xl font-black text-[#1e293b] tracking-tighter leading-none">3,128</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTEGRATIONS MARQUEE -->
		<section class="py-24 bg-white border-y border-slate-50 overflow-hidden relative">
            <div class="max-w-7xl mx-auto px-6 text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-black text-[#105971] tracking-tighter mb-4">
                    Se integra a la perfección con el ecosistema que ya usas
                </h2>
                <p class="text-slate-500 font-bold max-w-2xl mx-auto text-lg leading-relaxed">
                    Conecta tus tiendas, paqueterías y pasarelas de pago en un par de clics.
                </p>
            </div>

            <div class="relative w-full">
                <!-- Fade gradients -->
                <div class="absolute inset-y-0 left-0 w-40 bg-gradient-to-r from-white to-transparent z-20 pointer-events-none"></div>
                <div class="absolute inset-y-0 right-0 w-40 bg-gradient-to-l from-white to-transparent z-20 pointer-events-none"></div>
                
