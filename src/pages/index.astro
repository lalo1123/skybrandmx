                                <svg class="h-6 w-auto" viewBox="0 0 100 40" xmlns="http://www.w3.org/2000/svg"><path d="M42.2 12.1h-4V25h3.9v-12.9zM53.1 16.6c-1.4 0-2.3.8-2.3 1.9 0 1.2 1.1 1.7 2.4 2l1.9.5c.7.2 1.1.5 1.1 1.1 0 .7-.7 1.3-1.8 1.3-1.3 0-2.4-.6-2.8-1.5l-3.3 2c.8 1.9 2.9 3 5.9 3 3.6 0 5.8-1.7 5.8-4.5 0-2.6-2.4-3.5-4.4-4.1l-1.6-.4c-.6-.2-1-.4-1-.9 0-.5.6-1.1 1.5-1.1s1.9.4 2.3 1.1l3.3-2c-.9-1.3-2.5-2.1-4.7-2.1v.2zM75.3 16.6c-1.8 0-3.3 1-4 2.6v-2.3H68V34.5h3.9v-6.6c.7 1.4 2.1 2.3 3.8 2.3 3.5 0 5.9-2.9 5.9-6.9.1-3.8-2.3-6.7-5.9-6.7zm-1 10.3c-1.5 0-2.5-.9-2.8-2v-2.6c0-1.1 1-1.9 2.5-1.9 1.7 0 2.9 1.4 2.9 3.3.1 1.8-1.1 3.2-2.6 3.2zM86.1 16.6c-3.6 0-6.1 2.8-6.1 6.8s2.5 6.9 6.2 6.9c2.3 0 4.1-1.1 5.1-3.2l-3.4-1.8c-.4.7-1 .9-1.8.9-1.2 0-2-.8-2.2-2h7.6c.1-.4.1-.9.1-1.4 0-3.8-2.2-6.2-5.5-6.2zm-2.2 4.6c.2-1.1 1.1-1.8 2.2-1.8s1.9.7 2.1 1.8h-4.3v-.offsetzM32.8 12.1h-4.2V27h4V12.1h.2zM21.5 16.6c-1.4 0-2.5.7-3.1 1.8v-1.5h-4.2V27h4v-5.2c0-1.5 1.1-2.4 2.4-2.4h.9v-3.7l-.1-.offseth-.1z" fill="#635bff"/><path d="M12.2 26.5c-1.8 0-3.6-.5-5.2-1.3l-1.3 3.1c2 1.1 4.5 1.6 6.8 1.6 5 0 8-2.8 8-6.5 0-4.4-4-5.3-6.2-5.8-1.5-.4-2-.8-2-1.5 0-.7.8-1.2 1.8-1.2 1.4 0 2.9.5 4.1 1.3l1.1-3.2c-1.5-1-3.3-1.4-5.2-1.4-4.8 0-7.7 2.6-7.7 6.1s3.7 5.2 6 5.8c1.6.4 2.3.9 2.3 1.6 0 .7-.8 1.3-2 1.3h-.5z" fill="#635bff"/></svg>
                            </div>
