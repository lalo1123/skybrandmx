                <span style="font-size:11px;font-weight:800;color:#22c55e;background:rgba(34,197,94,0.1);padding:4px 10px;border-radius:6px;">Activo</span>
              </div>
              <button style="padding:12px 20px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:800;cursor:pointer;width:fit-content;">Actualizar contraseña</button>
            </div>
          </div>

          <!-- Danger zone -->
          <div class="stat-card animate-in" style="border-color:rgba(239,68,68,0.2);">
            <h3 style="font-size:16px;font-weight:900;color:#ef4444;margin-bottom:8px;">Zona de peligro</h3>
            <p style="font-size:12px;color:var(--text-faint);margin-bottom:16px;">Estas acciones son irreversibles. Ten cuidado.</p>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button onclick="localStorage.removeItem('skybrand_token');window.location.href='/login';" style="padding:10px 20px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;">Cerrar sesión</button>
              <button style="padding:10px 20px;border-radius:10px;border:1px solid #ef4444;background:transparent;color:#ef4444;font-size:12px;font-weight:700;cursor:pointer;" onclick="if(confirm('¿Estás seguro que quieres eliminar tu cuenta? Esta acción no se puede deshacer.'))alert('Funcionalidad en desarrollo. Contacta a soporte.')">Eliminar mi cuenta</button>
            </div>
          </div>
        </div>

        <!-- ===== SECTION: Automations ===== -->
        <div id="section-automations" class="dashboard-section" style="display:none;">
          <!-- Header -->
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
            <div>
              <h2 style="font-size:20px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Automatizaciones</h2>
              <p style="font-size:13px;color:var(--text-faint);">Crea reglas que ejecutan acciones cuando ocurren eventos en tu negocio.</p>
            </div>
            <div style="display:flex;gap:8px;">
              <button onclick="testAutomation()" style="padding:10px 20px;border-radius:12px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
                <svg style="width:14px;height:14px;display:inline;vertical-align:-2px;margin-right:4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Probar evento
              </button>
              <button onclick="openAutomationModal()" style="padding:10px 20px;border-radius:12px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:800;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.opacity='0.9';this.style.transform='translateY(-1px)'" onmouseout="this.style.opacity='1';this.style.transform='none'">+ Nueva regla</button>
            </div>
          </div>

          <!-- Empty state -->
          <div id="automations-empty" class="stat-card animate-in" style="text-align:center;padding:60px 24px;">
            <div style="width:64px;height:64px;border-radius:20px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
              <svg style="width:32px;height:32px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 style="font-size:18px;font-weight:900;color:var(--text-primary);margin-bottom:8px;">Crea tu primera automatización</h3>
            <p style="font-size:13px;color:var(--text-faint);max-width:400px;margin:0 auto 20px;line-height:1.6;">Define reglas para automatizar acciones cuando ocurran ciertos eventos, como enviar un email al recibir un pedido.</p>
            <button onclick="openAutomationModal()" style="padding:10px 24px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:700;cursor:pointer;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">+ Nueva regla</button>
          </div>

          <!-- Rules list -->
          <div id="automations-rules-list" style="display:none;flex-direction:column;gap:12px;margin-bottom:32px;"></div>

          <!-- Logs section -->
          <div id="automations-logs-section" style="display:none;margin-top:32px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
              <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);">Historial de ejecuciones</h3>
              <button onclick="loadAutomationLogs()" style="padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;font-weight:700;cursor:pointer;">Actualizar</button>
            </div>
            <div id="automations-logs-list" style="display:flex;flex-direction:column;gap:8px;"></div>
          </div>
        </div>

        <!-- Automation Modal -->
        <div id="automation-modal" style="display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;">
          <div style="background:var(--bg-sidebar);border:1px solid var(--border);border-radius:20px;width:100%;max-width:640px;max-height:80vh;overflow-y:auto;padding:32px;position:relative;">
            <!-- Close -->
            <button onclick="closeAutomationModal()" style="position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:8px;border:none;background:transparent;cursor:pointer;color:var(--text-muted);display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='var(--nav-hover)'" onmouseout="this.style.background='transparent'">
              <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <!-- Step indicators -->
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:24px;">
              <div id="auto-step-1-dot" style="width:28px;height:28px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;">1</div>
              <div style="flex:1;height:2px;background:var(--border);border-radius:2px;"><div id="auto-step-bar-1" style="height:100%;width:0%;background:var(--accent);border-radius:2px;transition:width 0.3s;"></div></div>
              <div id="auto-step-2-dot" style="width:28px;height:28px;border-radius:50%;background:var(--input-bg);border:1px solid var(--border);color:var(--text-faint);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;">2</div>
              <div style="flex:1;height:2px;background:var(--border);border-radius:2px;"><div id="auto-step-bar-2" style="height:100%;width:0%;background:var(--accent);border-radius:2px;transition:width 0.3s;"></div></div>
              <div id="auto-step-3-dot" style="width:28px;height:28px;border-radius:50%;background:var(--input-bg);border:1px solid var(--border);color:var(--text-faint);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;">3</div>
            </div>

            <!-- Step 1: Select trigger -->
            <div id="auto-step-1" style="">
              <h3 style="font-size:18px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Selecciona un disparador</h3>
              <p style="font-size:13px;color:var(--text-faint);margin-bottom:20px;">¿Cuándo quieres que se ejecute esta regla?</p>
              <div id="auto-trigger-list" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;"></div>
            </div>

            <!-- Step 2: Add actions -->
            <div id="auto-step-2" style="display:none;">
              <h3 style="font-size:18px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Agrega acciones</h3>
              <p style="font-size:13px;color:var(--text-faint);margin-bottom:20px;">¿Qué debe hacer esta regla cuando se dispare?</p>
              <div id="auto-selected-actions" style="margin-bottom:20px;display:flex;flex-direction:column;gap:8px;"></div>
              <p style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:10px;">Acciones disponibles</p>
              <div id="auto-action-list" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;"></div>
              <div style="display:flex;gap:8px;margin-top:20px;">
                <button onclick="goToAutoStep(1)" style="padding:10px 20px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;">Atrás</button>
                <button id="auto-next-step-2" onclick="goToAutoStep(3)" disabled style="padding:10px 20px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:800;cursor:pointer;opacity:0.5;">Siguiente</button>
              </div>
            </div>

            <!-- Step 3: Name & save -->
            <div id="auto-step-3" style="display:none;">
              <h3 style="font-size:18px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Nombra tu regla</h3>
              <p style="font-size:13px;color:var(--text-faint);margin-bottom:20px;">Dale un nombre descriptivo a esta automatización.</p>
              <div style="margin-bottom:16px;">
                <label style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px;">Nombre de la regla</label>
                <input id="auto-rule-name" type="text" placeholder="Ej: Enviar email de bienvenida" style="width:100%;padding:12px 16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:14px;font-weight:600;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='var(--border)'" />
              </div>
              <div id="auto-rule-summary" style="padding:16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);margin-bottom:20px;">
                <p style="font-size:12px;font-weight:700;color:var(--text-muted);margin-bottom:8px;">Resumen</p>
                <p id="auto-summary-trigger" style="font-size:13px;color:var(--text-secondary);margin-bottom:4px;"></p>
                <p id="auto-summary-actions" style="font-size:13px;color:var(--text-secondary);"></p>
              </div>
              <div style="display:flex;gap:8px;">
                <button onclick="goToAutoStep(2)" style="padding:10px 20px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;">Atrás</button>
                <button onclick="saveAutomationRule()" style="padding:10px 24px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:800;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">Guardar regla</button>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Theme customization panel -->
  <div id="theme-panel-overlay" class="theme-panel-overlay" onclick="closeThemePanel()"></div>
  <div id="theme-panel" class="theme-panel">
    <div style="padding:24px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
        <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);">Personalizar</h3>
        <button onclick="closeThemePanel()" style="width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:8px;border:none;background:transparent;cursor:pointer;color:var(--text-muted);">
          <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Mode -->
      <div style="margin-bottom:28px;">
        <p style="font-size:11px;font-weight:800;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px;">Modo</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
          <button id="mode-dark" onclick="setThemeMode('dark')" style="padding:12px;border-radius:12px;border:2px solid var(--border);background:var(--bg-card);cursor:pointer;transition:all 0.2s;text-align:center;">
            <svg style="width:24px;height:24px;color:var(--text-muted);margin:0 auto 6px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            <p style="font-size:12px;font-weight:700;color:var(--text-secondary);">Oscuro</p>
          </button>
          <button id="mode-light" onclick="setThemeMode('light')" style="padding:12px;border-radius:12px;border:2px solid var(--border);background:var(--bg-card);cursor:pointer;transition:all 0.2s;text-align:center;">
            <svg style="width:24px;height:24px;color:var(--text-muted);margin:0 auto 6px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            <p style="font-size:12px;font-weight:700;color:var(--text-secondary);">Claro</p>
          </button>
        </div>
      </div>

      <!-- Accent color -->
      <div style="margin-bottom:28px;">
        <p style="font-size:11px;font-weight:800;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px;">Color de acento</p>
        <div style="display:flex;flex-wrap:wrap;gap:8px;">
          <button class="color-swatch" style="background:#6fcff5;" onclick="setAccentColor('#6fcff5','#084D6E')" title="Cyan (default)"></button>
          <button class="color-swatch" style="background:#22c55e;" onclick="setAccentColor('#22c55e','#166534')" title="Verde"></button>
          <button class="color-swatch" style="background:#3b82f6;" onclick="setAccentColor('#3b82f6','#1e40af')" title="Azul"></button>
          <button class="color-swatch" style="background:#8b5cf6;" onclick="setAccentColor('#8b5cf6','#5b21b6')" title="Morado"></button>
          <button class="color-swatch" style="background:#ec4899;" onclick="setAccentColor('#ec4899','#9d174d')" title="Rosa"></button>
          <button class="color-swatch" style="background:#f97316;" onclick="setAccentColor('#f97316','#9a3412')" title="Naranja"></button>
          <button class="color-swatch" style="background:#eab308;" onclick="setAccentColor('#eab308','#854d0e')" title="Amarillo"></button>
          <button class="color-swatch" style="background:#ef4444;" onclick="setAccentColor('#ef4444','#991b1b')" title="Rojo"></button>
        </div>
      </div>

      <!-- Custom brand color -->
      <div style="margin-bottom:28px;">
        <p style="font-size:11px;font-weight:800;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:12px;">Color personalizado de tu marca</p>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="color" id="custom-color" value="#6fcff5" style="width:44px;height:44px;border:none;border-radius:10px;cursor:pointer;background:transparent;padding:0;" />
          <div style="flex:1;">
            <input type="text" id="custom-color-hex" value="#6fcff5" placeholder="#hex" style="width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:600;font-family:monospace;" />
          </div>
          <button onclick="applyCustomColor()" style="padding:10px 16px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:12px;font-weight:800;cursor:pointer;">Aplicar</button>
        </div>
      </div>

      <!-- Reset -->
      <button onclick="resetTheme()" style="width:100%;padding:12px;border-radius:12px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
        Restaurar valores predeterminados
      </button>
    </div>
  </div>

  <script define:vars={{ API_URL }}>
    // ===== THEME SYSTEM =====
    function loadTheme() {
      const mode = localStorage.getItem('skybrand_theme_mode') || 'dark';
      const accent = localStorage.getItem('skybrand_accent') || '#6fcff5';
      const accentDark = localStorage.getItem('skybrand_accent_dark') || '#084D6E';
      setThemeMode(mode, false);
      if (accent !== '#6fcff5') setAccentColor(accent, accentDark, false);
    }

    window.setThemeMode = function(mode, save = true) {
      document.documentElement.setAttribute('data-theme', mode);
      const sun = document.getElementById('icon-sun');
      const moon = document.getElementById('icon-moon');
      const modeDark = document.getElementById('mode-dark');
      const modeLight = document.getElementById('mode-light');
      if (mode === 'light') {
        sun.style.display = 'block'; moon.style.display = 'none';
        if (modeDark) { modeDark.style.borderColor = 'var(--border)'; modeLight.style.borderColor = 'var(--accent)'; }
      } else {
        sun.style.display = 'none'; moon.style.display = 'block';
        if (modeDark) { modeDark.style.borderColor = 'var(--accent)'; modeLight.style.borderColor = 'var(--border)'; }
      }
      if (save) localStorage.setItem('skybrand_theme_mode', mode);
    };

    window.setAccentColor = function(color, darkColor, save = true) {
      const r = document.documentElement;
      r.style.setProperty('--accent', color);
      r.style.setProperty('--accent-bg', color + '14');
      r.style.setProperty('--accent-bg2', color + '26');
      r.style.setProperty('--accent-gradient-start', darkColor || color);
      r.style.setProperty('--accent-gradient-end', color);
      // Update swatches
      document.querySelectorAll('.color-swatch').forEach(s => {
        s.classList.toggle('selected', s.style.background === color || s.style.backgroundColor === color);
      });
      if (save) {
        localStorage.setItem('skybrand_accent', color);
        localStorage.setItem('skybrand_accent_dark', darkColor || color);
      }
    };

    window.applyCustomColor = function() {
      const hex = document.getElementById('custom-color-hex')?.value || document.getElementById('custom-color')?.value;
      if (hex && /^#[0-9a-fA-F]{6}$/.test(hex)) {
        setAccentColor(hex, hex);
      }
    };

    document.getElementById('custom-color')?.addEventListener('input', (e) => {
      document.getElementById('custom-color-hex').value = e.target.value;
    });
    document.getElementById('custom-color-hex')?.addEventListener('change', (e) => {
      if (/^#[0-9a-fA-F]{6}$/.test(e.target.value)) {
        document.getElementById('custom-color').value = e.target.value;
      }
    });
    // Logo upload preview
    document.getElementById('logo-upload')?.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      if (file.size > 2 * 1024 * 1024) { alert('El archivo es muy grande. Máximo 2MB.'); return; }
      const reader = new FileReader();
      reader.onload = (ev) => {
        const img = document.getElementById('company-logo-img');
        const initials = document.getElementById('company-logo-initials');
        const removeBtn = document.getElementById('remove-logo-btn');
        img.src = ev.target.result;
        img.style.display = 'block';
        initials.style.display = 'none';
        removeBtn.style.display = 'inline-block';
        localStorage.setItem('skybrand_company_logo', ev.target.result);
      };
      reader.readAsDataURL(file);
    });
    window.removeLogo = function() {
      document.getElementById('company-logo-img').style.display = 'none';
      document.getElementById('company-logo-initials').style.display = 'block';
      document.getElementById('remove-logo-btn').style.display = 'none';
      document.getElementById('logo-upload').value = '';
      localStorage.removeItem('skybrand_company_logo');
    };
    // Load saved logo
    const savedLogo = localStorage.getItem('skybrand_company_logo');
    if (savedLogo) {
      const img = document.getElementById('company-logo-img');
      if (img) { img.src = savedLogo; img.style.display = 'block'; }
      const initials = document.getElementById('company-logo-initials');
      if (initials) initials.style.display = 'none';
      const removeBtn = document.getElementById('remove-logo-btn');
      if (removeBtn) removeBtn.style.display = 'inline-block';
    }

    // Sync settings page color picker too
    document.getElementById('settings-custom-color')?.addEventListener('input', (e) => {
      document.getElementById('settings-custom-hex').value = e.target.value;
    });

    window.resetTheme = function() {
      localStorage.removeItem('skybrand_theme_mode');
      localStorage.removeItem('skybrand_accent');
      localStorage.removeItem('skybrand_accent_dark');
      document.documentElement.removeAttribute('data-theme');
      document.documentElement.style.removeProperty('--accent');
      document.documentElement.style.removeProperty('--accent-bg');
      document.documentElement.style.removeProperty('--accent-bg2');
      document.documentElement.style.removeProperty('--accent-gradient-start');
      document.documentElement.style.removeProperty('--accent-gradient-end');
      setThemeMode('dark', false);
      document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('selected'));
    };

    // Theme panel toggle
    document.getElementById('theme-panel-btn')?.addEventListener('click', () => {
      document.getElementById('theme-panel')?.classList.add('open');
      document.getElementById('theme-panel-overlay')?.classList.add('active');
    });
    window.closeThemePanel = function() {
      document.getElementById('theme-panel')?.classList.remove('open');
      document.getElementById('theme-panel-overlay')?.classList.remove('active');
    };

    // Theme mode quick toggle
    document.getElementById('theme-mode-btn')?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      setThemeMode(current === 'light' ? 'dark' : 'light');
    });

    // Load saved theme
    loadTheme();

    // Set date
    const dateEl = document.getElementById('page-date');
    if (dateEl) {
      dateEl.textContent = new Date().toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }

    // Mobile sidebar
    window.toggleSidebar = function() {
      document.getElementById('sidebar')?.classList.toggle('open');
      document.getElementById('mobile-overlay')?.classList.toggle('active');
    };

    // Auth check
    const token = localStorage.getItem('skybrand_token');
    if (!token) {
      window.location.href = '/login';
    } else {
      fetch(`${API_URL}/api/v1/auth/me`, {
        headers: { 'Authorization': `Bearer ${token}` },
      })
        .then(res => {
          if (!res.ok) throw new Error('Unauthorized');
          return res.json();
        })
        .then(user => {
          document.getElementById('loading').style.display = 'none';
          document.getElementById('dashboard').style.display = 'block';

          const name = user.full_name || user.email.split('@')[0];
          const initials = name.charAt(0).toUpperCase();

          document.getElementById('sidebar-name').textContent = name;
          document.getElementById('sidebar-email').textContent = user.email;
          document.getElementById('user-avatar').textContent = initials;

          // Fill settings inputs
          const settingsName = document.getElementById('settings-name');
          const settingsEmail = document.getElementById('settings-email');
          if (settingsName) settingsName.value = user.full_name || '';
          if (settingsEmail) settingsEmail.value = user.email || '';

          if (user.is_admin) {
            document.getElementById('admin-nav').style.display = 'block';
          }
        })
        .catch(() => {
          localStorage.removeItem('skybrand_token');
          window.location.href = '/login';
        });
    }

    // Logout
    document.getElementById('logout-btn')?.addEventListener('click', () => {
      localStorage.removeItem('skybrand_token');
      window.location.href = '/login';
    });

    // ===== SECTION NAVIGATION =====
    window.showSection = function(sectionName) {
      // Hide all sections
      document.querySelectorAll('.dashboard-section').forEach(s => {
        s.style.display = 'none';
      });
      // Show target section
      const target = document.getElementById('section-' + sectionName);
      if (target) {
        target.style.display = 'block';
      }
      // Update nav active state
      document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
      const navItem = document.querySelector(`.nav-item[data-section="${sectionName}"]`);
      if (navItem) {
        navItem.classList.add('active');
        document.getElementById('page-title').textContent = navItem.textContent.trim();
      }
      // Close mobile sidebar
      document.getElementById('sidebar')?.classList.remove('open');
      document.getElementById('mobile-overlay')?.classList.remove('active');
    };

    // ===== ONBOARDING =====
    window.dismissOnboarding = function() {
      const banner = document.getElementById('onboarding-banner');
      if (banner) {
        banner.style.transition = 'opacity 0.3s, transform 0.3s';
        banner.style.opacity = '0';
        banner.style.transform = 'translateY(-10px)';
        setTimeout(() => { banner.style.display = 'none'; }, 300);
      }
      localStorage.setItem('skybrand_onboarding_dismissed', 'true');
    };

    // Check if onboarding was dismissed
    if (localStorage.getItem('skybrand_onboarding_dismissed') === 'true') {
      const banner = document.getElementById('onboarding-banner');
      if (banner) banner.style.display = 'none';
    }

    // Nav click handler
    document.querySelectorAll('.nav-item[data-section]').forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const section = item.getAttribute('data-section');
        if (section === 'users') return; // Let admin link navigate normally
        showSection(section);
      });
    });

    // ===== AUTOMATIONS =====
    let _autoCatalog = null;
    let _autoSelectedTrigger = null;
    let _autoSelectedActions = [];

    const _autoHeaders = () => ({
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + localStorage.getItem('skybrand_token')
    });

    const _triggerIcons = {
      'order.created': '🛒',
      'order.paid': '💳',
      'order.shipped': '📦',
      'order.delivered': '✅',
      'order.cancelled': '❌',
      'customer.created': '👤',
      'lead.created': '🎯',
      'invoice.created': '🧾',
    };

    const _actionIcons = {
      'send_email': '✉️',
      'send_whatsapp': '💬',
      'create_task': '📋',
      'update_crm': '🔄',
      'webhook': '🔗',
      'wait': '⏱️',
    };

    async function loadAutomationCatalog() {
      if (_autoCatalog) return _autoCatalog;
      try {
        const res = await fetch(API_URL + '/api/v1/automations/catalog', { headers: _autoHeaders() });
        if (!res.ok) throw new Error('Error cargando catálogo');
        _autoCatalog = await res.json();
        return _autoCatalog;
      } catch(e) {
        console.error('loadAutomationCatalog:', e);
        return null;
      }
    }

    async function loadAutomationRules() {
      try {
        const res = await fetch(API_URL + '/api/v1/automations/rules', { headers: _autoHeaders() });
        if (!res.ok) throw new Error('Error cargando reglas');
        const rules = await res.json();
        const list = document.getElementById('automations-rules-list');
        const empty = document.getElementById('automations-empty');
        const logsSection = document.getElementById('automations-logs-section');

        if (!rules || rules.length === 0) {
          list.style.display = 'none';
          empty.style.display = 'block';
          logsSection.style.display = 'none';
          return;
        }

        empty.style.display = 'none';
        list.style.display = 'flex';
        logsSection.style.display = 'block';

        list.innerHTML = rules.map(r => `
          <div class="stat-card" style="padding:16px 20px;">
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:12px;flex:1;min-width:0;">
                <div style="width:40px;height:40px;border-radius:12px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">
                  ${_triggerIcons[r.trigger_event] || '⚡'}
                </div>
                <div style="min-width:0;">
                  <p style="font-size:14px;font-weight:800;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${r.name}</p>
                  <p style="font-size:11px;color:var(--text-faint);">Trigger: ${r.trigger_event} · ${r.actions ? r.actions.length : 0} acción(es)</p>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
                <span style="font-size:10px;font-weight:800;padding:3px 10px;border-radius:999px;${r.active ? 'background:rgba(34,197,94,0.1);color:#22c55e;' : 'background:var(--input-bg);color:var(--text-faint);'}">${r.active ? 'Activa' : 'Inactiva'}</span>
                <button onclick="toggleRule('${r.id}')" title="${r.active ? 'Desactivar' : 'Activar'}" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-muted);transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
                  <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${r.active ? 'M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z' : 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z'}"/></svg>
                </button>
                <button onclick="deleteRule('${r.id}')" title="Eliminar" style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-muted);transition:all 0.2s;" onmouseover="this.style.borderColor='#ef4444';this.style.color='#ef4444'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
                  <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
              </div>
            </div>
          </div>
        `).join('');

        loadAutomationLogs();
      } catch(e) {
        console.error('loadAutomationRules:', e);
      }
    }

    async function openAutomationModal() {
      _autoSelectedTrigger = null;
      _autoSelectedActions = [];
      document.getElementById('auto-rule-name').value = '';
      goToAutoStep(1);

      const modal = document.getElementById('automation-modal');
      modal.style.display = 'flex';

      const catalog = await loadAutomationCatalog();
      if (!catalog) return;

      // Render triggers
      const triggerList = document.getElementById('auto-trigger-list');
      triggerList.innerHTML = Object.entries(catalog.triggers || {}).map(([key, t]) => `
        <div onclick="selectTrigger('${key}')" class="stat-card" style="padding:16px;cursor:pointer;text-align:center;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor=this.dataset.selected==='true'?'var(--accent)':'var(--border)'" data-trigger="${key}">
          <div style="font-size:28px;margin-bottom:8px;">${_triggerIcons[key] || '⚡'}</div>
          <p style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:4px;">${t.label || key}</p>
          <p style="font-size:11px;color:var(--text-faint);line-height:1.4;">${t.description || ''}</p>
        </div>
      `).join('');

      // Render actions
      const actionList = document.getElementById('auto-action-list');
      actionList.innerHTML = Object.entries(catalog.actions || {}).map(([key, a]) => `
        <div onclick="addAction('${key}')" class="stat-card" style="padding:14px;cursor:pointer;text-align:center;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
          <div style="font-size:24px;margin-bottom:6px;">${_actionIcons[key] || '⚙️'}</div>
          <p style="font-size:12px;font-weight:800;color:var(--text-primary);">${a.label || key}</p>
        </div>
      `).join('');
    }

    function closeAutomationModal() {
      document.getElementById('automation-modal').style.display = 'none';
      _autoSelectedTrigger = null;
      _autoSelectedActions = [];
    }

    function goToAutoStep(step) {
      document.getElementById('auto-step-1').style.display = step === 1 ? '' : 'none';
      document.getElementById('auto-step-2').style.display = step === 2 ? '' : 'none';
      document.getElementById('auto-step-3').style.display = step === 3 ? '' : 'none';

      // Update step dots
      for (let i = 1; i <= 3; i++) {
        const dot = document.getElementById('auto-step-' + i + '-dot');
        if (i < step) {
          dot.style.background = 'var(--accent)'; dot.style.color = '#fff'; dot.style.border = 'none';
        } else if (i === step) {
          dot.style.background = 'var(--accent)'; dot.style.color = '#fff'; dot.style.border = 'none';
        } else {
          dot.style.background = 'var(--input-bg)'; dot.style.color = 'var(--text-faint)'; dot.style.border = '1px solid var(--border)';
        }
      }
      // Update progress bars
      document.getElementById('auto-step-bar-1').style.width = step > 1 ? '100%' : '0%';
      document.getElementById('auto-step-bar-2').style.width = step > 2 ? '100%' : '0%';

      // Step 3 summary
      if (step === 3) {
        const catalog = _autoCatalog || {};
        const tLabel = (catalog.triggers && catalog.triggers[_autoSelectedTrigger]) ? catalog.triggers[_autoSelectedTrigger].label : _autoSelectedTrigger;
        document.getElementById('auto-summary-trigger').textContent = 'Cuando: ' + tLabel;
        const actLabels = _autoSelectedActions.map(a => {
          const info = catalog.actions && catalog.actions[a.type];
          return info ? info.label : a.type;
        });
        document.getElementById('auto-summary-actions').textContent = 'Acciones: ' + actLabels.join(', ');
      }
    }

    window.selectTrigger = function(triggerKey) {
      _autoSelectedTrigger = triggerKey;
      // Highlight selected
      document.querySelectorAll('#auto-trigger-list .stat-card').forEach(c => {
        const isSel = c.dataset.trigger === triggerKey;
        c.dataset.selected = isSel;
        c.style.borderColor = isSel ? 'var(--accent)' : 'var(--border)';
        c.style.background = isSel ? 'var(--accent-bg)' : 'var(--bg-card)';
      });
      // Auto-advance to step 2
      setTimeout(() => goToAutoStep(2), 300);
    };

    window.addAction = function(actionType) {
      _autoSelectedActions.push({ type: actionType, config: {} });
      _renderSelectedActions();
    };

    window.removeAction = function(index) {
      _autoSelectedActions.splice(index, 1);
      _renderSelectedActions();
    };

    function _renderSelectedActions() {
      const catalog = _autoCatalog || {};
      const container = document.getElementById('auto-selected-actions');
      const btn = document.getElementById('auto-next-step-2');

      if (_autoSelectedActions.length === 0) {
        container.innerHTML = '<p style="font-size:12px;color:var(--text-faintest);text-align:center;padding:12px;">Aún no has agregado acciones.</p>';
        btn.disabled = true;
        btn.style.opacity = '0.5';
        return;
      }

      btn.disabled = false;
      btn.style.opacity = '1';

      container.innerHTML = _autoSelectedActions.map((a, i) => {
        const info = catalog.actions && catalog.actions[a.type];
        const label = info ? info.label : a.type;
        return `
          <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);">
            <span style="width:22px;height:22px;border-radius:6px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;color:var(--accent);flex-shrink:0;">${i + 1}</span>
            <span style="font-size:16px;flex-shrink:0;">${_actionIcons[a.type] || '⚙️'}</span>
            <span style="font-size:13px;font-weight:700;color:var(--text-primary);flex:1;">${label}</span>
            <button onclick="removeAction(${i})" style="width:24px;height:24px;border-radius:6px;border:none;background:transparent;cursor:pointer;color:var(--text-faint);display:flex;align-items:center;justify-content:center;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='var(--text-faint)'">
              <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        `;
      }).join('');
    }

    async function saveAutomationRule() {
      const name = document.getElementById('auto-rule-name').value.trim();
      if (!name) { alert('Escribe un nombre para la regla.'); return; }
      if (!_autoSelectedTrigger) { alert('Selecciona un disparador.'); return; }
      if (_autoSelectedActions.length === 0) { alert('Agrega al menos una acción.'); return; }

      try {
        const res = await fetch(API_URL + '/api/v1/automations/rules', {
          method: 'POST',
          headers: _autoHeaders(),
          body: JSON.stringify({
            name: name,
            trigger_event: _autoSelectedTrigger,
            actions: _autoSelectedActions
          })
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error || 'Error creando regla');
        }
        closeAutomationModal();
        loadAutomationRules();
      } catch(e) {
        alert('Error: ' + e.message);
      }
    }
    window.saveAutomationRule = saveAutomationRule;

    window.toggleRule = async function(id) {
      try {
        const res = await fetch(API_URL + '/api/v1/automations/rules/' + id + '/toggle', {
          method: 'PATCH',
          headers: _autoHeaders()
        });
        if (!res.ok) throw new Error('Error toggling rule');
        loadAutomationRules();
      } catch(e) {
        console.error('toggleRule:', e);
      }
    };

    window.deleteRule = async function(id) {
      if (!confirm('¿Estás seguro de eliminar esta regla?')) return;
      try {
        const res = await fetch(API_URL + '/api/v1/automations/rules/' + id, {
          method: 'DELETE',
          headers: _autoHeaders()
        });
        if (!res.ok) throw new Error('Error deleting rule');
        loadAutomationRules();
      } catch(e) {
        console.error('deleteRule:', e);
      }
    };

    async function loadAutomationLogs() {
      try {
        const res = await fetch(API_URL + '/api/v1/automations/logs', { headers: _autoHeaders() });
        if (!res.ok) throw new Error('Error cargando logs');
        const logs = await res.json();
        const container = document.getElementById('automations-logs-list');

        if (!logs || logs.length === 0) {
          container.innerHTML = '<p style="font-size:12px;color:var(--text-faintest);text-align:center;padding:16px;">Sin ejecuciones recientes.</p>';
          return;
        }

        container.innerHTML = logs.slice(0, 20).map(log => {
          const statusColor = log.status === 'success' ? '#22c55e' : log.status === 'error' ? '#ef4444' : 'var(--text-faint)';
          const statusLabel = log.status === 'success' ? 'OK' : log.status === 'error' ? 'Error' : log.status;
          const date = new Date(log.created_at || log.fired_at).toLocaleString('es-MX', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
          return `
            <div style="display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);">
              <div style="width:8px;height:8px;border-radius:50%;background:${statusColor};flex-shrink:0;"></div>
              <div style="flex:1;min-width:0;">
                <p style="font-size:12px;font-weight:700;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${log.rule_name || log.trigger_event || 'Regla'}</p>
                <p style="font-size:10px;color:var(--text-faintest);">${log.trigger_event || ''} · ${log.steps ? log.steps.length + ' pasos' : ''}</p>
              </div>
              <span style="font-size:10px;font-weight:800;padding:3px 8px;border-radius:6px;background:${log.status === 'success' ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)'};color:${statusColor};">${statusLabel}</span>
              <span style="font-size:10px;color:var(--text-faintest);flex-shrink:0;">${date}</span>
            </div>
          `;
        }).join('');
      } catch(e) {
        console.error('loadAutomationLogs:', e);
      }
    }

    async function testAutomation() {
      try {
        const res = await fetch(API_URL + '/api/v1/automations/test?event_type=order.created', {
          method: 'POST',
          headers: _autoHeaders()
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          alert('Evento de prueba disparado correctamente. ' + (data.rules_matched ? data.rules_matched + ' regla(s) ejecutada(s).' : ''));
          loadAutomationRules();
        } else {
          alert('Error: ' + (data.error || 'No se pudo disparar el evento de prueba.'));
        }
      } catch(e) {
        alert('Error de conexión al probar evento.');
      }
    }
    window.testAutomation = testAutomation;

    // Hook into showSection to load automations data when section is shown
    const _origShowSection = window.showSection;
    window.showSection = function(sectionName) {
      _origShowSection(sectionName);
      if (sectionName === 'automations') {
        loadAutomationRules();
      }
    };

    // ===== DEMO & SIMULATOR =====
    let demoData = null;

    async function loadDemoData() {
      const btn = document.getElementById('demo-load-btn');
      btn.textContent = 'Cargando...';
      btn.disabled = true;
      try {
        const res = await fetch(`${API_URL}/api/v1/demo/seed`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${localStorage.getItem('skybrand_token')}` },
        });
        demoData = await res.json();
        if (demoData.success) {
          // Update stats in overview
          const s = demoData.stats;
          const statValues = document.querySelectorAll('#section-overview .stat-value');
          if (statValues[0]) statValues[0].textContent = '$' + s.revenue.toLocaleString();
          if (statValues[1]) statValues[1].textContent = s.orders;
          if (statValues[2]) statValues[2].textContent = s.customers;
          if (statValues[3]) statValues[3].textContent = s.invoices;

          btn.textContent = '\u2713 Datos cargados';
          btn.style.background = '#22c55e';

          // Reload automation rules if they were created
          if (typeof loadAutomationRules === 'function') loadAutomationRules();
        }
      } catch(e) {
        btn.textContent = 'Error - Reintentar';
        btn.style.background = '#ef4444';
      }
      setTimeout(() => {
        btn.textContent = 'Cargar datos demo';
        btn.style.background = '#6fcff5';
        btn.disabled = false;
      }, 3000);
    }

