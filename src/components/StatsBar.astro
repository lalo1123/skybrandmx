---
const stats = [
  { value: '+150', label: 'Empresas activas', suffix: '' },
  { value: '$24M', label: 'Facturado por clientes', suffix: 'MXN' },
  { value: '50k+', label: 'Guías de envío generadas', suffix: '' },
  { value: '99.9%', label: 'Uptime garantizado', suffix: '' },
];
---

<section class="relative -mt-16 z-20 max-w-6xl mx-auto px-6">
  <div class="bg-white rounded-3xl shadow-[0_40px_80px_-20px_rgba(0,0,0,0.1)] border border-slate-100 p-8 md:p-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      {stats.map((stat, i) => (
        <div class={`text-center ${i < stats.length - 1 ? 'md:border-r md:border-slate-100' : ''}`}>
          <p class="text-3xl md:text-4xl font-black text-brand-primary tracking-tight mb-1">
            {stat.value} <span class="text-sm text-slate-400 font-bold">{stat.suffix}</span>
          </p>
          <p class="text-sm text-slate-500 font-bold">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
