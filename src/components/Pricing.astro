---
const whatsappPhone = '5525582310';

const plans = [
  {
    name: 'Solo Herramientas',
    audience: 'Conecta tu tienda',
    price: '399',
    period: '/mes',
    description: 'Panel + tienda conectada. Paga solo por lo que uses.',
    features: [
      'Panel de control con métricas',
      'Conexión a Shopify / WooCommerce / ML',
      'Gestión de pedidos centralizada',
      'Guías de envío como add-on',
      'Facturación SAT como add-on',
      'Email marketing como add-on',
    ],
    cta: 'Ver detalles',
    ctaHref: '/precios#herramientas',
    popular: false,
    gradient: '',
    badge: 'Paga por uso',
    badgeColor: 'bg-amber-500/10 border-amber-500/20 text-amber-600',
  },
  {
    name: 'Starter',
    audience: 'Para PYMES',
    price: '899',
    period: '/mes',
    description: 'Todo lo esencial para empezar a automatizar tu negocio.',
    features: [
      'CRM hasta 500 contactos',
      'Facturación SAT 4.0 (50/mes)',
      'Guías de envío preferencial',
      'Email marketing (1,000 envíos)',
      'Gestión de pedidos básica',
      '1 usuario incluido',
      'Soporte por WhatsApp',
    ],
    cta: 'Ver detalles',
    ctaHref: '/precios#starter',
    popular: false,
    gradient: '',
    badge: null,
    badgeColor: '',
  },
  {
    name: 'Growth',
    audience: 'Para empresas en crecimiento',
    price: '1,999',
    period: '/mes',
    description: 'Escala tu operación con automatización avanzada e IA.',
    features: [
      'CRM contactos ilimitados',
      'Facturación SAT ilimitada',
      'Guías multi-paquetería',
      'Ads con IA (Meta + Google)',
      'Email marketing (10,000 envíos)',
      'Gestión multi-canal',
      'Hasta 5 usuarios',
      'Soporte prioritario',
      'Reportes avanzados',
    ],
    cta: 'Ver detalles',
    ctaHref: '/precios#growth',
    popular: true,
    gradient: 'from-brand-primary to-slate-800',
    badge: null,
    badgeColor: '',
  },
  {
    name: 'Enterprise',
    audience: 'Para grandes empresas',
    price: 'Personalizado',
    period: '',
    description: 'Solución a la medida con APIs e integraciones custom.',
    features: [
      'Todo lo de Growth, más:',
      'API completa',
      'Usuarios ilimitados',
      'Multi-sucursal / multi-bodega',
      'Facturación masiva',
      'Ads con presupuesto gestionado',
      'Onboarding personalizado',
      'Account manager dedicado',
      'SLA 99.99%',
    ],
    cta: 'Hablar con ventas',
    ctaHref: '/precios#enterprise',
    popular: false,
    gradient: '',
    badge: null,
    badgeColor: '',
  },
];
---

<section id="pricing" class="py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/5 border border-emerald-500/10 text-emerald-600 text-xs font-bold mb-8">
        Precios transparentes
      </div>
      <h2 class="text-4xl md:text-6xl font-black tracking-tighter mb-6 text-slate-900">
        Un plan para cada <span class="text-gradient">etapa de tu negocio.</span>
      </h2>
      <p class="text-lg text-slate-500 font-medium">
        Desde herramientas individuales hasta soluciones enterprise. Sin costos ocultos.
      </p>
    </div>

    <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6 items-start">
      {plans.map((plan) => (
        <div class={`relative rounded-3xl p-8 transition-all duration-300 ${
          plan.popular
            ? 'bg-gradient-to-br from-brand-primary to-slate-800 text-white shadow-[0_40px_80px_-20px_rgba(8,77,110,0.4)] md:scale-105 border-0'
            : 'bg-white border border-slate-200 hover:border-slate-300 hover:shadow-xl'
        }`}>
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="px-5 py-2 rounded-full bg-brand-teal text-slate-900 text-xs font-black uppercase tracking-wider shadow-lg">
                Más popular
              </span>
            </div>
          )}

          {plan.badge && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class={`px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-wider border ${plan.badgeColor}`}>
                {plan.badge}
              </span>
            </div>
          )}

          <div class="mb-6">
            <p class={`text-xs font-bold mb-2 ${plan.popular ? 'text-brand-cyan' : 'text-brand-primary'}`}>{plan.audience}</p>
            <h3 class={`text-xl font-black mb-2 ${plan.popular ? 'text-white' : 'text-slate-900'}`}>{plan.name}</h3>
            <p class={`text-xs font-medium leading-relaxed ${plan.popular ? 'text-slate-300' : 'text-slate-500'}`}>{plan.description}</p>
          </div>

          <div class="mb-6">
            {plan.price === 'Personalizado' ? (
              <p class={`text-2xl font-black ${plan.popular ? 'text-white' : 'text-slate-900'}`}>Personalizado</p>
            ) : (
              <div class="flex items-baseline gap-1">
                <span class={`text-4xl font-black tracking-tight ${plan.popular ? 'text-white' : 'text-slate-900'}`}>${plan.price}</span>
                <span class={`text-sm font-bold ${plan.popular ? 'text-slate-300' : 'text-slate-400'}`}>MXN{plan.period}</span>
              </div>
            )}
          </div>

          <ul class="space-y-3 mb-8">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2.5">
                <svg class={`w-4 h-4 shrink-0 mt-0.5 ${plan.popular ? 'text-brand-teal' : 'text-brand-teal'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class={`text-xs font-medium ${plan.popular ? 'text-slate-200' : 'text-slate-600'}`}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={plan.ctaHref}
            class={`block w-full py-3.5 rounded-xl text-center font-black text-sm transition-all hover:-translate-y-0.5 active:scale-95 ${
              plan.popular
                ? 'bg-brand-teal text-slate-900 shadow-lg shadow-brand-teal/20 hover:bg-brand-teal/90'
                : 'bg-brand-primary text-white shadow-lg shadow-brand-primary/20 hover:bg-brand-primary/90'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/precios" class="inline-flex items-center gap-2 text-brand-primary font-bold text-sm hover:underline">
        Ver comparación detallada de todos los planes
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>

    <p class="text-center text-slate-400 text-sm font-medium mt-4">
      Todos los planes incluyen 14 días de prueba gratis. Precios en pesos mexicanos + IVA.
    </p>
  </div>
</section>
