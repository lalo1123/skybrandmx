---
const plans = [
  {
    name: 'Starter',
    audience: 'Para PYMES',
    price: '499',
    period: '/mes',
    description: 'Todo lo esencial para empezar a automatizar tu negocio.',
    features: [
      'CRM hasta 500 contactos',
      'Facturación SAT 4.0 (50 facturas/mes)',
      'Guías de envío con tarifa preferencial',
      'Email marketing (1,000 envíos/mes)',
      'Gestión de pedidos básica',
      '1 usuario incluido',
      'Soporte por WhatsApp',
    ],
    cta: 'Empieza gratis 14 días',
    popular: false,
    gradient: '',
  },
  {
    name: 'Growth',
    audience: 'Para empresas en crecimiento',
    price: '1,499',
    period: '/mes',
    description: 'Escala tu operación con automatización avanzada e IA.',
    features: [
      'CRM contactos ilimitados',
      'Facturación SAT 4.0 ilimitada',
      'Guías de envío multi-paquetería',
      'Ads con IA (Meta + Google)',
      'Email marketing (10,000 envíos/mes)',
      'Gestión de pedidos multi-canal',
      'Hasta 5 usuarios',
      'Soporte prioritario',
      'Reportes avanzados',
    ],
    cta: 'Empieza gratis 14 días',
    popular: true,
    gradient: 'from-brand-primary to-slate-800',
  },
  {
    name: 'Enterprise',
    audience: 'Para grandes empresas',
    price: 'Personalizado',
    period: '',
    description: 'Solución a la medida con APIs, integraciones custom y SLA dedicado.',
    features: [
      'Todo lo de Growth, más:',
      'API completa para integraciones',
      'Usuarios ilimitados',
      'Multi-sucursal / multi-bodega',
      'Facturación masiva automatizada',
      'Ads con presupuesto gestionado',
      'Onboarding personalizado',
      'Account manager dedicado',
      'SLA 99.99% garantizado',
    ],
    cta: 'Hablar con ventas',
    popular: false,
    gradient: '',
  },
];
---

<section id="pricing" class="py-32 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/5 border border-emerald-500/10 text-emerald-600 text-xs font-bold mb-8">
        Precios transparentes
      </div>
      <h2 class="text-4xl md:text-6xl font-black tracking-tighter mb-6 text-slate-900">
        Un plan para cada <span class="text-gradient">etapa de tu negocio.</span>
      </h2>
      <p class="text-lg text-slate-500 font-medium">
        Sin costos ocultos. Sin contratos forzosos. Cancela cuando quieras.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8 items-start">
      {plans.map((plan) => (
        <div class={`relative rounded-3xl p-10 transition-all duration-300 ${
          plan.popular
            ? 'bg-gradient-to-br from-brand-primary to-slate-800 text-white shadow-[0_40px_80px_-20px_rgba(8,77,110,0.4)] scale-105 border-0'
            : 'bg-white border border-slate-200 hover:border-slate-300 hover:shadow-xl'
        }`}>
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
              <span class="px-5 py-2 rounded-full bg-brand-teal text-slate-900 text-xs font-black uppercase tracking-wider shadow-lg">
                Más popular
              </span>
            </div>
          )}

          <div class="mb-8">
            <p class={`text-sm font-bold mb-2 ${plan.popular ? 'text-brand-cyan' : 'text-brand-primary'}`}>{plan.audience}</p>
            <h3 class={`text-2xl font-black mb-2 ${plan.popular ? 'text-white' : 'text-slate-900'}`}>{plan.name}</h3>
            <p class={`text-sm font-medium ${plan.popular ? 'text-slate-300' : 'text-slate-500'}`}>{plan.description}</p>
          </div>

          <div class="mb-8">
            {plan.price === 'Personalizado' ? (
              <p class={`text-3xl font-black ${plan.popular ? 'text-white' : 'text-slate-900'}`}>Personalizado</p>
            ) : (
              <div class="flex items-baseline gap-1">
                <span class={`text-5xl font-black tracking-tight ${plan.popular ? 'text-white' : 'text-slate-900'}`}>${plan.price}</span>
                <span class={`text-lg font-bold ${plan.popular ? 'text-slate-300' : 'text-slate-400'}`}>MXN{plan.period}</span>
              </div>
            )}
          </div>

          <ul class="space-y-4 mb-10">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class={`w-5 h-5 shrink-0 mt-0.5 ${plan.popular ? 'text-brand-teal' : 'text-brand-teal'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class={`text-sm font-medium ${plan.popular ? 'text-slate-200' : 'text-slate-600'}`}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href={plan.price === 'Personalizado' ? '#contacto' : '#demo'}
            class={`block w-full py-4 rounded-2xl text-center font-black text-base transition-all hover:-translate-y-0.5 active:scale-95 ${
              plan.popular
                ? 'bg-brand-teal text-slate-900 shadow-lg shadow-brand-teal/20 hover:bg-brand-teal/90'
                : 'bg-brand-primary text-white shadow-lg shadow-brand-primary/20 hover:bg-brand-primary/90'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-slate-400 text-sm font-medium mt-12">
      Todos los planes incluyen 14 días de prueba gratis. Precios en pesos mexicanos + IVA.
    </p>
  </div>
</section>
