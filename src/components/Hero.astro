---
---

<section id="inicio" class="relative pt-28 pb-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-brand-primary to-slate-900"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_20%,rgba(111,207,245,0.15),transparent_60%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_80%_80%,rgba(45,212,191,0.1),transparent_50%)]"></div>
  <!-- Grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;><g fill=&quot;none&quot; stroke=&quot;white&quot; stroke-width=&quot;1&quot;><path d=&quot;M60 0H0v60&quot;/></g></svg>');"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Top badge -->
    <div class="flex justify-center mb-12">
      <div class="inline-flex items-center gap-3 px-5 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-sm">
        <span class="flex h-2 w-2 rounded-full bg-brand-teal animate-pulse"></span>
        <span class="text-brand-cyan text-sm font-bold">Plataforma Todo-en-Uno para empresas en México</span>
      </div>
    </div>

    <!-- Main headline -->
    <div class="text-center max-w-5xl mx-auto mb-16">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tight mb-8 leading-[0.95] text-white">
        Automatiza tu negocio.
        <br />
        <span class="text-gradient">Escala sin límites.</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed font-medium">
        CRM, facturación SAT, guías de envío, ads con IA, email marketing y gestión de pedidos
        — todo integrado en una sola plataforma diseñada para empresas mexicanas.
      </p>
    </div>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row justify-center gap-5 mb-16">
      <a href="#pricing" class="px-10 py-5 bg-brand-teal text-slate-900 rounded-2xl text-lg font-black shadow-[0_20px_50px_rgba(45,212,191,0.3)] hover:bg-brand-teal/90 transition-all transform hover:-translate-y-1 active:scale-95 text-center">
        Empieza 14 días gratis
      </a>
      <a href="#demo" class="px-10 py-5 bg-white/5 text-white rounded-2xl text-lg font-black border border-white/10 hover:bg-white/10 backdrop-blur-sm transition-all transform hover:-translate-y-1 active:scale-95 text-center">
        Ver demo en vivo
      </a>
    </div>

    <!-- Social proof -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-8 mb-20">
      <div class="flex -space-x-3">
        <div class="w-10 h-10 rounded-full border-2 border-slate-800 bg-slate-700 shadow-sm flex items-center justify-center text-lg">🧔🏻</div>
        <div class="w-10 h-10 rounded-full border-2 border-slate-800 bg-slate-700 shadow-sm flex items-center justify-center text-lg">👩🏼‍💻</div>
        <div class="w-10 h-10 rounded-full border-2 border-slate-800 bg-slate-700 shadow-sm flex items-center justify-center text-lg">👨🏽‍💼</div>
        <div class="w-10 h-10 rounded-full border-2 border-slate-800 bg-slate-700 shadow-sm flex items-center justify-center text-sm font-black text-white">+</div>
      </div>
      <div class="flex items-center gap-6 text-sm">
        <span class="text-slate-400">Utilizado por <strong class="text-white">+150 empresas</strong> en México</span>
        <div class="hidden sm:block w-px h-5 bg-slate-700"></div>
        <div class="flex items-center gap-1">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
          <span class="text-slate-400 ml-1">4.9/5</span>
        </div>
      </div>
    </div>

    <!-- Dashboard mockup -->
    <div class="relative max-w-5xl mx-auto">
      <!-- Glow effect behind -->
      <div class="absolute -inset-4 bg-gradient-to-r from-brand-teal/20 via-brand-cyan/20 to-brand-teal/20 rounded-[2.5rem] blur-3xl"></div>

      <div class="relative rounded-[2rem] border border-white/10 bg-slate-900/80 backdrop-blur-xl shadow-[0_60px_120px_-20px_rgba(0,0,0,0.7)] overflow-hidden">
        <!-- Browser chrome -->
        <div class="h-14 border-b border-white/5 px-6 flex items-center gap-4 bg-slate-900/50">
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#FEBC2E]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28C840]"></div>
          </div>
          <div class="flex-1 max-w-md mx-auto">
            <div class="bg-white/5 rounded-xl h-8 flex items-center px-4 gap-2 border border-white/5">
              <svg class="w-3 h-3 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg>
              <span class="text-[11px] text-slate-500 font-medium">app.skybrandmx.com</span>
            </div>
          </div>
        </div>

        <!-- Dashboard content -->
        <div class="flex">
          <!-- Sidebar -->
          <div class="hidden md:flex w-16 flex-col items-center py-6 border-r border-white/5 gap-6 bg-slate-900/30">
            <div class="w-10 h-10 rounded-xl bg-brand-teal/20 text-brand-teal flex items-center justify-center text-sm">📊</div>
            <div class="w-9 h-9 rounded-lg bg-white/5 text-slate-500 flex items-center justify-center text-sm">💼</div>
            <div class="w-9 h-9 rounded-lg bg-white/5 text-slate-500 flex items-center justify-center text-sm">🧾</div>
            <div class="w-9 h-9 rounded-lg bg-white/5 text-slate-500 flex items-center justify-center text-sm">📦</div>
            <div class="w-9 h-9 rounded-lg bg-white/5 text-slate-500 flex items-center justify-center text-sm">📧</div>
          </div>

          <!-- Main content -->
          <div class="flex-1 p-6 md:p-8">
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class="text-lg font-black text-white tracking-tight">Dashboard Principal</h3>
                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Métricas en tiempo real</p>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-xl px-4 py-2 text-[10px] font-bold text-slate-400">Marzo 2026</div>
            </div>

            <!-- Metric cards -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
              <div class="bg-white/5 border border-white/5 rounded-2xl p-4">
                <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-2">Ingresos</p>
                <p class="text-xl md:text-2xl font-black text-white tracking-tight">$842k</p>
                <span class="text-[9px] font-bold text-emerald-400">+24.5%</span>
              </div>
              <div class="bg-white/5 border border-white/5 rounded-2xl p-4">
                <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-2">Envíos</p>
                <p class="text-xl md:text-2xl font-black text-white tracking-tight">3,128</p>
                <span class="text-[9px] font-bold text-emerald-400">+12%</span>
              </div>
              <div class="bg-white/5 border border-white/5 rounded-2xl p-4">
                <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-2">Leads</p>
                <p class="text-xl md:text-2xl font-black text-white tracking-tight">847</p>
                <span class="text-[9px] font-bold text-emerald-400">+31%</span>
              </div>
              <div class="bg-white/5 border border-white/5 rounded-2xl p-4">
                <p class="text-[9px] font-bold text-slate-500 uppercase tracking-wider mb-2">Facturas</p>
                <p class="text-xl md:text-2xl font-black text-white tracking-tight">1,204</p>
                <span class="text-[9px] font-bold text-emerald-400">+18%</span>
              </div>
            </div>

            <!-- Chart placeholder -->
            <div class="bg-white/5 border border-white/5 rounded-2xl p-5 h-32 md:h-40 flex items-end gap-1.5">
              {[35,45,30,55,40,65,50,70,60,80,55,75,90,70,85,95,80,100,85,95].map((h) => (
                <div class="flex-1 rounded-t-sm bg-gradient-to-t from-brand-teal/60 to-brand-cyan/40" style={`height: ${h}%`}></div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Floating cards -->
      <div class="absolute -right-4 md:-right-12 top-[20%] z-30 animate-float">
        <div class="bg-white rounded-2xl p-4 shadow-[0_30px_60px_-10px_rgba(0,0,0,0.4)] flex items-center gap-4 border border-slate-100">
          <div class="w-11 h-11 rounded-xl bg-blue-500 text-white flex items-center justify-center shadow-lg shadow-blue-500/30 text-lg">📈</div>
          <div>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider">Conversión</p>
            <p class="text-xl font-black text-slate-900 tracking-tight">+18.4%</p>
          </div>
        </div>
      </div>

      <div class="absolute -left-4 md:-left-12 bottom-[25%] z-30 animate-float-delayed">
        <div class="bg-white rounded-2xl p-4 shadow-[0_30px_60px_-10px_rgba(0,0,0,0.4)] flex items-center gap-4 border border-slate-100">
          <div class="w-11 h-11 rounded-xl bg-purple-500 text-white flex items-center justify-center shadow-lg shadow-purple-500/30 text-lg">🔔</div>
          <div>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-wider">Nuevos Leads</p>
            <p class="text-xl font-black text-slate-900 tracking-tight">24 Hoy</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
