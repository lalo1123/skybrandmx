---
// HelpCenter.astro — Floating help center widget for dashboard pages
---

<div id="help-center-widget">
  <!-- Floating trigger button -->
  <button id="help-trigger" class="help-trigger" aria-label="Centro de ayuda" title="Centro de ayuda">
    <span class="help-trigger-icon">?</span>
  </button>

  <!-- Panel backdrop -->
  <div id="help-backdrop" class="help-backdrop"></div>

  <!-- Slide-up panel -->
  <div id="help-panel" class="help-panel">
    <!-- Header -->
    <div class="help-header">
      <div class="help-header-left">
        <button id="help-back" class="help-back" aria-label="Volver" style="display:none;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <span class="help-header-title" id="help-title">Centro de Ayuda</span>
      </div>
      <button id="help-close" class="help-close" aria-label="Cerrar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Search -->
    <div class="help-search-wrap">
      <svg class="help-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input id="help-search" class="help-search" type="text" placeholder="¿Qué necesitas ayuda con?" autocomplete="off" />
    </div>

    <!-- Article list -->
    <div id="help-list" class="help-list"></div>

    <!-- Article detail -->
    <div id="help-detail" class="help-detail" style="display:none;"></div>

    <!-- Footer -->
    <div class="help-footer">
      <span>¿No encontraste lo que buscas?</span>
      <a href="https://wa.me/5525582310?text=Hola%2C%20necesito%20ayuda%20con%20SkyBrandMX" target="_blank" rel="noopener noreferrer" class="help-wa-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Escríbenos por WhatsApp
      </a>
    </div>
  </div>
</div>

<style>
  /* --- Trigger button --- */
  .help-trigger {
    position: fixed;
    bottom: 6.5rem;
    right: 1.5rem;
    z-index: 9998;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    font-size: 1.35rem;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .help-trigger:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 28px rgba(99, 102, 241, 0.55);
  }
  .help-trigger:active {
    transform: scale(0.95);
  }
  .help-trigger-icon {
    line-height: 1;
    margin-top: -1px;
  }

  /* --- Backdrop --- */
  .help-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: rgba(0,0,0,0.25);
    backdrop-filter: blur(2px);
  }
  .help-backdrop.active {
    display: block;
  }

  /* --- Panel --- */
  .help-panel {
    position: fixed;
    bottom: 7rem;
    right: 1.5rem;
    z-index: 9999;
    width: 350px;
    max-height: 500px;
    background: var(--help-bg, #ffffff);
    color: var(--help-text, #1e293b);
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.18), 0 0 0 1px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .help-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* --- Header --- */
  .help-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--help-border, #e2e8f0);
    flex-shrink: 0;
  }
  .help-header-left {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .help-header-title {
    font-weight: 700;
    font-size: 0.95rem;
  }
  .help-back, .help-close {
    background: none;
    border: none;
    color: var(--help-muted, #64748b);
    cursor: pointer;
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
  }
  .help-back:hover, .help-close:hover {
    background: var(--help-hover, #f1f5f9);
    color: var(--help-text, #1e293b);
  }

  /* --- Search --- */
  .help-search-wrap {
    position: relative;
    padding: 10px 16px;
    flex-shrink: 0;
  }
  .help-search-icon {
    position: absolute;
    left: 28px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--help-muted, #94a3b8);
    pointer-events: none;
  }
  .help-search {
    width: 100%;
    padding: 9px 12px 9px 36px;
    border-radius: 10px;
    border: 1px solid var(--help-border, #e2e8f0);
    background: var(--help-input-bg, #f8fafc);
    color: var(--help-text, #1e293b);
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .help-search:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
  }
  .help-search::placeholder {
    color: var(--help-muted, #94a3b8);
  }

  /* --- Article list --- */
  .help-list {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 4px 8px 8px;
  }
  .help-list::-webkit-scrollbar {
    width: 4px;
  }
  .help-list::-webkit-scrollbar-thumb {
    background: var(--help-border, #cbd5e1);
    border-radius: 4px;
  }

  .help-article-btn {
    width: 100%;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: none;
    background: none;
    border-radius: 10px;
    cursor: pointer;
    font-size: 0.84rem;
    color: var(--help-text, #1e293b);
    transition: background 0.15s;
  }
  .help-article-btn:hover {
    background: var(--help-hover, #f1f5f9);
  }
  .help-article-btn .help-emoji {
    font-size: 1.15rem;
    flex-shrink: 0;
    width: 28px;
    text-align: center;
  }
  .help-article-btn .help-label {
    line-height: 1.35;
  }

  .help-no-results {
    text-align: center;
    padding: 24px 16px;
    color: var(--help-muted, #94a3b8);
    font-size: 0.84rem;
  }

  /* --- Article detail --- */
  .help-detail {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 12px 16px 16px;
  }
  .help-detail::-webkit-scrollbar {
    width: 4px;
  }
  .help-detail::-webkit-scrollbar-thumb {
    background: var(--help-border, #cbd5e1);
    border-radius: 4px;
  }
  .help-detail-title {
    font-weight: 700;
    font-size: 0.92rem;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .help-step {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
    font-size: 0.84rem;
    line-height: 1.5;
  }
  .help-step-num {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }
  .help-step-text {
    color: var(--help-text, #1e293b);
  }
  .help-tip {
    margin-top: 8px;
    padding: 10px 12px;
    border-radius: 10px;
    background: var(--help-tip-bg, #f0f0ff);
    font-size: 0.8rem;
    color: var(--help-tip-text, #4338ca);
    line-height: 1.45;
  }

  /* --- Footer --- */
  .help-footer {
    padding: 12px 16px;
    border-top: 1px solid var(--help-border, #e2e8f0);
    text-align: center;
    font-size: 0.78rem;
    color: var(--help-muted, #94a3b8);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .help-wa-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: #25d366;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.8rem;
    transition: opacity 0.15s;
  }
  .help-wa-link:hover {
    opacity: 0.8;
  }

  /* --- Dark theme --- */
  :global(.dark) #help-center-widget,
  :global([data-theme="dark"]) #help-center-widget {
    --help-bg: #1e1e2e;
    --help-text: #e2e8f0;
    --help-muted: #94a3b8;
    --help-border: #334155;
    --help-hover: #2a2a3e;
    --help-input-bg: #262638;
    --help-tip-bg: #2e2b5a;
    --help-tip-text: #a5b4fc;
  }

  /* Responsive: smaller screens */
  @media (max-width: 480px) {
    .help-panel {
      width: calc(100vw - 2rem);
      right: 1rem;
      bottom: 6rem;
      max-height: 70vh;
    }
  }
</style>

<script is:inline>
(function() {
  // ---- Article data ----
  const articles = [
    {
      id: 'pedido',
      emoji: '\uD83D\uDCE6',
      title: '¿Cómo creo un pedido?',
      steps: [
        'Ve a la sección <b>Pedidos</b> en el menú lateral.',
        'Haz clic en el botón <b>"+ Nuevo Pedido"</b> arriba a la derecha.',
        'Selecciona al cliente o crea uno nuevo. Agrega los productos deseados.',
        'Revisa el resumen, ajusta cantidades o descuentos si aplica.',
        'Haz clic en <b>"Crear Pedido"</b> para confirmarlo.'
      ],
      tip: '¡Tip! Puedes duplicar pedidos anteriores para ahorrar tiempo.'
    },
    {
      id: 'factura',
      emoji: '\uD83E\uDDFE',
      title: '¿Cómo facturo?',
      steps: [
        'Abre la sección <b>Facturación</b> desde el menú.',
        'Haz clic en <b>"+ Nueva Factura"</b>.',
        'Ingresa los datos fiscales del cliente (RFC, razón social, uso de CFDI).',
        'Agrega los conceptos de la factura con sus importes.',
        'Haz clic en <b>"Timbrar"</b> para generar el CFDI ante el SAT.'
      ],
      tip: 'Puedes facturar directamente desde un pedido ya existente con un solo clic.'
    },
    {
      id: 'envio',
      emoji: '\uD83D\uDCE6',
      title: '¿Cómo genero una guía de envío?',
      steps: [
        'Ve a la sección <b>Envíos</b> en el menú.',
        'Selecciona el pedido que deseas enviar o crea uno nuevo.',
        'Elige la paquetería y el tipo de servicio (económico, express, etc.).',
        'Confirma las direcciones de origen y destino.',
        'Haz clic en <b>"Generar Guía"</b> para obtener la etiqueta de envío.'
      ],
      tip: 'Las guías se generan con tarifas preferenciales. ¡Puedes comparar precios entre paqueterías!'
    },
    {
      id: 'email',
      emoji: '\uD83D\uDCE7',
      title: '¿Cómo envío una campaña de email?',
      steps: [
        'Abre <b>Email Marketing</b> desde el menú lateral.',
        'Haz clic en <b>"+ Nueva Campaña"</b>.',
        'Elige una plantilla o crea tu diseño desde cero con el editor visual.',
        'Selecciona la lista de contactos o segmento a quien enviar.',
        'Revisa el preview y haz clic en <b>"Enviar"</b> o programa la hora de envío.'
      ],
      tip: 'Envía primero un correo de prueba a ti mismo para asegurarte de que se vea bien.'
    },
    {
      id: 'crm',
      emoji: '\uD83D\uDC64',
      title: '¿Cómo agrego un contacto al CRM?',
      steps: [
        'Ve a la sección <b>CRM</b> en el menú.',
        'Haz clic en <b>"+ Nuevo Contacto"</b>.',
        'Llena los datos básicos: nombre, email, teléfono y empresa.',
        'Asigna una etiqueta o segmento para organizarlo.',
        'Guarda el contacto. ¡Listo! Ya puedes hacerle seguimiento.'
      ],
      tip: 'También puedes importar contactos en bloque desde un archivo CSV.'
    },
    {
      id: 'tienda',
      emoji: '\uD83C\uDFEA',
      title: '¿Cómo creo mi tienda online?',
      steps: [
        'Abre <b>Tienda Online</b> desde el menú.',
        'Haz clic en <b>"Configurar Tienda"</b> y elige tu dominio o subdominio.',
        'Personaliza el diseño: colores, logo y banner principal.',
        'Agrega tus productos con fotos, precios y descripciones.',
        'Activa los métodos de pago y envío, y haz clic en <b>"Publicar"</b>.'
      ],
      tip: 'Tu tienda se ve increíble en celular automáticamente. ¡Compártela en redes!'
    },
    {
      id: 'cita',
      emoji: '\uD83D\uDCC5',
      title: '¿Cómo agendo una cita?',
      steps: [
        'Ve a la sección <b>Reservaciones</b> en el menú.',
        'Haz clic en <b>"+ Nueva Cita"</b>.',
        'Selecciona el servicio, la fecha y el horario disponible.',
        'Asigna un cliente existente o ingresa los datos de uno nuevo.',
        'Confirma la cita. El cliente recibirá una notificación automática.'
      ],
      tip: 'Puedes compartir tu link de reservaciones para que los clientes agenden solos.'
    },
    {
      id: 'automatizacion',
      emoji: '\u26A1',
      title: '¿Cómo creo una automatización?',
      steps: [
        'Abre <b>Automatizaciones</b> desde el menú.',
        'Haz clic en <b>"+ Nueva Automatización"</b>.',
        'Elige un disparador: nuevo pedido, nuevo contacto, fecha, etc.',
        'Configura la acción: enviar email, crear tarea, notificar por WhatsApp, etc.',
        'Activa la automatización con el switch y listo. ¡Trabaja mientras duermes!'
      ],
      tip: 'Empieza con las plantillas prediseñadas — son un excelente punto de partida.'
    }
  ];

  // ---- DOM refs ----
  var trigger = document.getElementById('help-trigger');
  var backdrop = document.getElementById('help-backdrop');
  var panel = document.getElementById('help-panel');
  var closeBtn = document.getElementById('help-close');
  var backBtn = document.getElementById('help-back');
  var searchInput = document.getElementById('help-search');
  var listEl = document.getElementById('help-list');
  var detailEl = document.getElementById('help-detail');
  var titleEl = document.getElementById('help-title');

  var isOpen = false;
  var currentArticle = null;

  // ---- Render list ----
  function renderList(filter) {
    var q = (filter || '').toLowerCase().trim();
    var filtered = articles.filter(function(a) {
      return !q || a.title.toLowerCase().indexOf(q) !== -1;
    });
    if (filtered.length === 0) {
      listEl.innerHTML = '<div class="help-no-results">No encontramos artículos con ese término. Intenta con otra búsqueda.</div>';
      return;
    }
    listEl.innerHTML = filtered.map(function(a) {
      return '<button class="help-article-btn" data-id="' + a.id + '">' +
        '<span class="help-emoji">' + a.emoji + '</span>' +
        '<span class="help-label">' + a.title + '</span>' +
        '</button>';
    }).join('');
  }

  // ---- Render detail ----
  function renderDetail(article) {
    var html = '<div class="help-detail-title">' +
      '<span>' + article.emoji + '</span> ' + article.title +
      '</div>';
    article.steps.forEach(function(step, i) {
      html += '<div class="help-step">' +
        '<span class="help-step-num">' + (i + 1) + '</span>' +
        '<span class="help-step-text">' + step + '</span>' +
        '</div>';
    });
    if (article.tip) {
      html += '<div class="help-tip">💡 ' + article.tip + '</div>';
    }
    detailEl.innerHTML = html;
  }

  // ---- Show / Hide ----
  function openPanel() {
    isOpen = true;
    panel.classList.add('open');
    backdrop.classList.add('active');
    trigger.style.display = 'none';
    showList();
    searchInput.value = '';
    renderList('');
    setTimeout(function() { searchInput.focus(); }, 200);
  }

  function closePanel() {
    isOpen = false;
    panel.classList.remove('open');
    backdrop.classList.remove('active');
    trigger.style.display = '';
    currentArticle = null;
  }

  function showList() {
    currentArticle = null;
    listEl.style.display = '';
    detailEl.style.display = 'none';
    backBtn.style.display = 'none';
    titleEl.textContent = 'Centro de Ayuda';
  }

  function showDetail(id) {
    var article = articles.find(function(a) { return a.id === id; });
    if (!article) return;
    currentArticle = article;
    renderDetail(article);
    listEl.style.display = 'none';
    detailEl.style.display = '';
    backBtn.style.display = '';
    titleEl.textContent = '';
  }

  // ---- Events ----
  trigger.addEventListener('click', function(e) {
    e.stopPropagation();
    openPanel();
  });

  closeBtn.addEventListener('click', closePanel);
  backdrop.addEventListener('click', closePanel);

  backBtn.addEventListener('click', function() {
    showList();
    renderList(searchInput.value);
  });

  listEl.addEventListener('click', function(e) {
    var btn = e.target.closest('.help-article-btn');
    if (btn) showDetail(btn.dataset.id);
  });

  searchInput.addEventListener('input', function() {
    if (currentArticle) showList();
    renderList(searchInput.value);
  });

  // Escape key closes
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && isOpen) closePanel();
  });

  // Initial render
  renderList('');

  // ---- Dark mode detection ----
  // Auto-detect from html class or data attribute
  function applyThemeVars() {
    var root = document.documentElement;
    var isDark = root.classList.contains('dark') || root.getAttribute('data-theme') === 'dark';
    var widget = document.getElementById('help-center-widget');
    if (!widget) return;
    if (isDark) {
      widget.style.setProperty('--help-bg', '#1e1e2e');
      widget.style.setProperty('--help-text', '#e2e8f0');
      widget.style.setProperty('--help-muted', '#94a3b8');
      widget.style.setProperty('--help-border', '#334155');
      widget.style.setProperty('--help-hover', '#2a2a3e');
      widget.style.setProperty('--help-input-bg', '#262638');
      widget.style.setProperty('--help-tip-bg', '#2e2b5a');
      widget.style.setProperty('--help-tip-text', '#a5b4fc');
    }
  }
  applyThemeVars();

  // Observe theme changes
  var observer = new MutationObserver(applyThemeVars);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme'] });
})();
</script>
