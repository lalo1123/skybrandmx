---
// SkyBot — AI Assistant for SkyBrandMX Dashboard
---

<div id="skybot-widget">
  <!-- Floating trigger — SkyBrand rocket -->
  <button id="skybot-trigger" class="skybot-trigger" aria-label="Asistente SkyBot" title="Asistente SkyBot">
    <svg class="skybot-rocket" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="26" height="26">
      <g stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2L15 6V14C15 14 15 17 12 17C9 17 9 14 9 14V6L12 2Z"/>
        <path d="M9 11L6 14H9V11Z" fill="#fff"/>
        <path d="M15 11L18 14H15V11Z" fill="#fff"/>
      </g>
      <path d="M9 17C10.5 20 12 22 12 22C12 22 13.5 20 15 17H9Z" fill="#ff6600" class="skybot-flame"/>
    </svg>
    <span class="skybot-pulse"></span>
  </button>

  <!-- Chat panel -->
  <div id="skybot-panel" class="skybot-panel" style="display:none;">
    <!-- Header -->
    <div class="skybot-header">
      <div style="display:flex;align-items:center;gap:10px;">
        <div style="width:36px;height:36px;border-radius:12px;background:linear-gradient(135deg,var(--accent-gradient-start,#084D6E),var(--accent,#6fcff5));display:flex;align-items:center;justify-content:center;position:relative;">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="20" height="20">
            <g stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L15 6V14C15 14 15 17 12 17C9 17 9 14 9 14V6L12 2Z"/>
              <path d="M9 11L6 14H9V11Z" fill="#fff"/><path d="M15 11L18 14H15V11Z" fill="#fff"/>
            </g>
            <path d="M9 17C10.5 20 12 22 12 22C12 22 13.5 20 15 17H9Z" fill="#ff6600"/>
          </svg>
          <div style="position:absolute;bottom:-1px;right:-1px;width:10px;height:10px;border-radius:50%;background:#22c55e;border:2px solid var(--bg-sidebar);"></div>
        </div>
        <div>
          <p style="font-size:14px;font-weight:900;color:var(--text-primary);letter-spacing:-0.02em;">Sky<span style="color:var(--accent,#6fcff5);">Bot</span></p>
          <p style="font-size:10px;color:#22c55e;font-weight:600;">Asistente inteligente</p>
        </div>
      </div>
      <button onclick="toggleSkybot()" style="width:28px;height:28px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="skybot-messages" class="skybot-messages">
      <!-- Welcome message -->
      <div class="skybot-msg skybot-msg-bot">
        <div class="skybot-avatar">🚀</div>
        <div class="skybot-bubble skybot-bubble-bot">
          <p>¡Hola! Soy <strong>Sky<span style="color:var(--accent,#6fcff5);">Bot</span></strong> 🚀 Tu asistente personal de SkyBrandMX.</p>
          <p style="margin-top:8px;">Dime qué necesitas y yo lo hago por ti:</p>
          <div style="display:flex;flex-direction:column;gap:4px;margin-top:8px;">
            <button onclick="skybotQuick('¿Cómo creo una factura?')" class="skybot-quick">🧾 Crear una factura</button>
            <button onclick="skybotQuick('Genera una guía de envío para mi último pedido')" class="skybot-quick">📦 Generar guía de envío</button>
            <button onclick="skybotQuick('Crea una automatización: cuando paguen, facturar y enviar WhatsApp')" class="skybot-quick">⚡ Crear automatización</button>
            <button onclick="skybotQuick('¿Cómo puedo vender más?')" class="skybot-quick">📈 Consejos para vender más</button>
            <button onclick="skybotQuick('¿Qué módulos tengo disponibles?')" class="skybot-quick">🔍 Ver mis módulos</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="skybot-input-wrap">
      <input id="skybot-input" type="text" placeholder="Escribe algo... Ej: Factura para público en general" class="skybot-input" onkeydown="if(event.key==='Enter')skybotSend()"/>
      <button onclick="skybotSend()" class="skybot-send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </button>
    </div>
  </div>
</div>

<style>
  .skybot-trigger {
    position:fixed;bottom:1.5rem;right:1.5rem;z-index:9998;
    width:56px;height:56px;border-radius:50%;border:none;
    background:linear-gradient(135deg,var(--accent-gradient-start,#084D6E),var(--accent,#6fcff5));
    color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;
    box-shadow:0 4px 24px rgba(0,0,0,0.3);
    transition:transform 0.3s,box-shadow 0.3s;
    overflow:visible;
  }
  .skybot-trigger:hover { transform:scale(1.1) rotate(5deg);box-shadow:0 6px 30px rgba(0,0,0,0.4); }
  .skybot-rocket { animation:skybot-float 3s ease-in-out infinite; }
  .skybot-flame { animation:skybot-flicker 0.3s ease-in-out infinite alternate; }
  @keyframes skybot-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-3px)} }
  @keyframes skybot-flicker { from{opacity:0.7;transform:scaleY(0.9)} to{opacity:1;transform:scaleY(1.1)} }
  .skybot-pulse {
    position:absolute;inset:-4px;border-radius:50%;
    border:2px solid var(--accent,#6fcff5);opacity:0;
    animation:skybot-ring 2s ease-out infinite;
  }
  @keyframes skybot-ring { 0%{transform:scale(1);opacity:0.6} 100%{transform:scale(1.4);opacity:0} }

  .skybot-panel {
    position:fixed;bottom:5rem;right:1.5rem;z-index:9999;
    width:380px;max-height:550px;
    background:var(--bg-sidebar,#0F172A);
    border:1px solid var(--border,rgba(255,255,255,0.06));
    border-radius:16px;overflow:hidden;
    display:flex;flex-direction:column;
    box-shadow:0 8px 40px rgba(0,0,0,0.4);
    animation:skybot-slide-up 0.3s ease;
  }
  @keyframes skybot-slide-up { from { opacity:0;transform:translateY(20px); } to { opacity:1;transform:translateY(0); } }

  .skybot-header {
    padding:14px 16px;border-bottom:1px solid var(--border);
    display:flex;align-items:center;justify-content:space-between;
    background:var(--bg-card,rgba(255,255,255,0.02));
  }

  .skybot-messages {
    flex:1;overflow-y:auto;padding:16px;
    display:flex;flex-direction:column;gap:12px;
    max-height:380px;min-height:200px;
  }

  .skybot-msg { display:flex;gap:8px;align-items:flex-start; }
  .skybot-msg-user { flex-direction:row-reverse; }
  .skybot-avatar { width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0; }

  .skybot-bubble {
    max-width:85%;padding:10px 14px;border-radius:12px;font-size:13px;line-height:1.5;
    color:var(--text-primary,#fff);
  }
  .skybot-bubble-bot {
    background:var(--input-bg,rgba(255,255,255,0.05));
    border:1px solid var(--border);border-radius:4px 12px 12px 12px;
  }
  .skybot-bubble-user {
    background:linear-gradient(135deg,var(--accent-gradient-start,#084D6E),var(--accent,#6fcff5));
    color:#fff;border-radius:12px 4px 12px 12px;
  }
  .skybot-bubble p { margin:0; }
  .skybot-bubble strong { color:var(--accent,#6fcff5);font-weight:800; }

  .skybot-quick {
    width:100%;padding:8px 12px;border-radius:8px;
    border:1px solid var(--border);background:transparent;
    color:var(--text-secondary,#e2e8f0);font-size:12px;font-weight:600;
    cursor:pointer;text-align:left;transition:all 0.15s;
  }
  .skybot-quick:hover { border-color:var(--accent,#6fcff5);color:var(--accent,#6fcff5);background:var(--accent-bg,rgba(111,207,245,0.08)); }

  .skybot-input-wrap {
    padding:12px 14px;border-top:1px solid var(--border);
    display:flex;gap:8px;align-items:center;
    background:var(--bg-card,rgba(255,255,255,0.02));
  }
  .skybot-input {
    flex:1;padding:10px 14px;border-radius:10px;
    border:1px solid var(--border);background:var(--input-bg);
    color:var(--text-primary);font-size:13px;outline:none;
    transition:border-color 0.2s;
  }
  .skybot-input:focus { border-color:var(--accent,#6fcff5); }
  .skybot-send {
    width:38px;height:38px;border-radius:10px;border:none;
    background:linear-gradient(135deg,var(--accent-gradient-start,#084D6E),var(--accent,#6fcff5));
    color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;
    transition:opacity 0.2s;flex-shrink:0;
  }
  .skybot-send:hover { opacity:0.85; }

  .skybot-typing { display:flex;gap:4px;padding:4px 0; }
  .skybot-typing span { width:6px;height:6px;border-radius:50%;background:var(--text-faint);animation:skybot-dot 1.4s infinite; }
  .skybot-typing span:nth-child(2) { animation-delay:0.2s; }
  .skybot-typing span:nth-child(3) { animation-delay:0.4s; }
  @keyframes skybot-dot { 0%,80%,100%{opacity:0.3;transform:scale(0.8)} 40%{opacity:1;transform:scale(1.2)} }

  .skybot-action {
    display:inline-flex;align-items:center;gap:4px;
    padding:6px 12px;border-radius:8px;border:none;
    background:linear-gradient(135deg,var(--accent-gradient-start,#084D6E),var(--accent,#6fcff5));color:#fff;
    font-size:11px;font-weight:700;cursor:pointer;
    margin-top:8px;transition:opacity 0.2s;
  }
  .skybot-action:hover { opacity:0.85; }

  @media (max-width:480px) {
    .skybot-panel { width:calc(100vw - 2rem);right:1rem;bottom:4.5rem; }
  }
</style>

<script is:inline>
// ═══════ SKYBOT AI ASSISTANT ═══════
function toggleSkybot() {
  const panel = document.getElementById('skybot-panel');
  panel.style.display = panel.style.display === 'none' ? 'flex' : 'none';
  if (panel.style.display === 'flex') {
    document.getElementById('skybot-input').focus();
    scrollBot();
  }
}

document.getElementById('skybot-trigger')?.addEventListener('click', toggleSkybot);

function scrollBot() {
  const el = document.getElementById('skybot-messages');
  if (el) el.scrollTop = el.scrollHeight;
}

function addBotMsg(html, actions) {
  const el = document.getElementById('skybot-messages');
  const msg = document.createElement('div');
  msg.className = 'skybot-msg skybot-msg-bot';
  let actionsHtml = '';
  if (actions && actions.length) {
    actionsHtml = '<div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">' +
      actions.map(a => `<button class="skybot-action" onclick="${a.action}">${a.icon || ''} ${a.label}</button>`).join('') +
    '</div>';
  }
  msg.innerHTML = `<div class="skybot-avatar">🚀</div><div class="skybot-bubble skybot-bubble-bot">${html}${actionsHtml}</div>`;
  el.appendChild(msg);
  scrollBot();
}

function addUserMsg(text) {
  const el = document.getElementById('skybot-messages');
  const msg = document.createElement('div');
  msg.className = 'skybot-msg skybot-msg-user';
  msg.innerHTML = `<div class="skybot-bubble skybot-bubble-user"><p>${text}</p></div>`;
  el.appendChild(msg);
  scrollBot();
}

function showTyping() {
  const el = document.getElementById('skybot-messages');
  const typing = document.createElement('div');
  typing.className = 'skybot-msg skybot-msg-bot';
  typing.id = 'skybot-typing';
  typing.innerHTML = '<div class="skybot-avatar">🚀</div><div class="skybot-bubble skybot-bubble-bot"><div class="skybot-typing"><span></span><span></span><span></span></div></div>';
  el.appendChild(typing);
  scrollBot();
}

function hideTyping() {
  document.getElementById('skybot-typing')?.remove();
}

function skybotQuick(text) {
  addUserMsg(text);
  processMessage(text);
}

function skybotSend() {
  const input = document.getElementById('skybot-input');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';
  addUserMsg(text);
  processMessage(text);
}

function processMessage(text) {
  showTyping();
  const lower = text.toLowerCase();

  setTimeout(() => {
    hideTyping();

    // ═══════ FACTURACIÓN ═══════
    if (lower.includes('factura') && (lower.includes('crear') || lower.includes('crea') || lower.includes('generar') || lower.includes('cómo'))) {
      if (lower.includes('público') || lower.includes('general')) {
        addBotMsg('<p>¡Claro! Para facturar a <strong>público en general</strong>:</p><p style="margin-top:6px;">Solo ve a Facturación → haz clic en <strong>"Público en general"</strong> y se llenan los datos automáticamente (RFC genérico XAXX010101000). Solo agrega los conceptos y dale "Timbrar".</p>', [
          { label: 'Ir a Facturación', icon: '🧾', action: "window.location.href='/dashboard/facturacion'" },
        ]);
      } else {
        addBotMsg('<p>Para crear una factura CFDI 4.0:</p><ol style="margin:8px 0 0 16px;font-size:12px;"><li>Ve a <strong>Facturación → Nueva factura</strong></li><li>Llena los datos del cliente (nombre, RFC, régimen fiscal)</li><li>Agrega los conceptos con cantidad y precio</li><li>El IVA se calcula automáticamente</li><li>Dale clic en <strong>"Timbrar ante SAT"</strong></li></ol><p style="margin-top:8px;">También puedes facturar rápido a público en general o desde un pedido existente.</p>', [
          { label: 'Ir a Facturación', icon: '🧾', action: "window.location.href='/dashboard/facturacion'" },
          { label: 'Factura rápida', icon: '⚡', action: "window.location.href='/dashboard/facturacion';setTimeout(()=>switchFacTab&&switchFacTab('create'),500)" },
        ]);
      }
    }
    // ═══════ ENVÍOS / GUÍA ═══════
    else if (lower.includes('guía') || lower.includes('envío') || lower.includes('enviar') || lower.includes('paquete')) {
      addBotMsg('<p>Para generar una guía de envío:</p><ol style="margin:8px 0 0 16px;font-size:12px;"><li>Ve a <strong>Envíos → Cotizar envío</strong></li><li>Pon el código postal de origen y destino</li><li>Ingresa peso y medidas del paquete</li><li>Comparo precios de 5 paqueterías al instante</li><li>Elige la que más te convenga y se genera la guía</li></ol><p style="margin-top:8px;">También puedo generar guías masivas desde un CSV.</p>', [
          { label: 'Ir a Envíos', icon: '📦', action: "window.location.href='/dashboard/envios'" },
        ]);
    }
    // ═══════ AUTOMATIZACIÓN ═══════
    else if (lower.includes('automatiz') || lower.includes('automátic') || lower.includes('regla') || lower.includes('cuando')) {
      addBotMsg('<p>¡Las automatizaciones son lo más poderoso de SkyBrandMX! 🚀</p><p style="margin-top:6px;">Puedes crear reglas como:</p><ul style="margin:8px 0 0 16px;font-size:12px;"><li><strong>Cuando paguen</strong> → facturar + generar guía + WhatsApp</li><li><strong>Carrito abandonado</strong> → email en 1h + WhatsApp en 24h</li><li><strong>Nuevo cliente</strong> → email bienvenida + cupón</li></ul><p style="margin-top:8px;">Tienes 12 disparadores y 10 acciones disponibles. También hay plantillas listas que activas con un clic.</p>', [
          { label: 'Ir a Automatizaciones', icon: '⚡', action: "window.location.href='/dashboard/automatizaciones'" },
          { label: 'Ver plantillas listas', icon: '📋', action: "window.location.href='/dashboard/automatizaciones';setTimeout(()=>switchAutoTab&&switchAutoTab('templates'),500)" },
        ]);
    }
    // ═══════ VENDER MÁS ═══════
    else if (lower.includes('vender más') || lower.includes('ventas') || lower.includes('mejorar') || lower.includes('consejos') || lower.includes('crecer')) {
      addBotMsg('<p>Aquí van mis <strong>5 recomendaciones</strong> para vender más:</p><ol style="margin:8px 0 0 16px;font-size:12px;line-height:1.6;"><li>🛒 <strong>Recupera carritos abandonados</strong> — activa la secuencia automática en Email Marketing</li><li>📢 <strong>Invierte en ads</strong> — tu ROAS es 4.3x, por cada $1 ganas $4.30. Escala las campañas que funcionan</li><li>⭐ <strong>Pide reseñas</strong> — activa el email post-compra en Automatizaciones</li><li>💬 <strong>Responde rápido en el chat</strong> — tienes mensajes sin contestar</li><li>📧 <strong>Envía newsletter semanal</strong> — tus emails tienen 47% de apertura, aprovéchalo</li></ol>', [
          { label: 'Email Marketing', icon: '✉️', action: "window.location.href='/dashboard/email-marketing'" },
          { label: 'Publicidad', icon: '📢', action: "window.location.href='/dashboard/ads'" },
          { label: 'Automatizaciones', icon: '⚡', action: "window.location.href='/dashboard/automatizaciones'" },
        ]);
    }
    // ═══════ MÓDULOS ═══════
    else if (lower.includes('módulo') || lower.includes('herramienta') || lower.includes('disponible') || lower.includes('qué puedo') || lower.includes('funciones')) {
      addBotMsg('<p>Tienes <strong>14 módulos</strong> disponibles:</p><div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:8px;font-size:11px;"><span>🛒 Pedidos</span><span>🛍 Productos</span><span>👤 CRM</span><span>🧾 Facturación</span><span>📦 Envíos</span><span>✉️ Email Marketing</span><span>📢 Publicidad + IA</span><span>💬 Chat unificado</span><span>🏪 Tienda Online</span><span>⚡ Automatizaciones</span><span>📅 Reservaciones</span><span>📋 Cotizaciones</span><span>📊 Reportes</span><span>⚙ Configuración</span></div><p style="margin-top:8px;font-size:12px;">¿Sobre cuál quieres saber más?</p>');
    }
    // ═══════ PEDIDOS ═══════
    else if (lower.includes('pedido') && (lower.includes('crear') || lower.includes('nuevo') || lower.includes('cómo'))) {
      addBotMsg('<p>Para crear un pedido manual:</p><ol style="margin:8px 0 0 16px;font-size:12px;"><li>Ve a <strong>Pedidos → Crear pedido</strong></li><li>Ingresa datos del cliente</li><li>Agrega productos con cantidad y precio</li><li>Confirma y listo</li></ol><p style="margin-top:8px;">Los pedidos de tu tienda online (Shopify/WooCommerce) llegan automáticamente.</p>', [
          { label: 'Ir a Pedidos', icon: '🛒', action: "window.location.href='/dashboard/pedidos'" },
        ]);
    }
    // ═══════ CRM ═══════
    else if (lower.includes('crm') || lower.includes('contacto') || lower.includes('cliente') && lower.includes('agregar')) {
      addBotMsg('<p>El CRM te ayuda a organizar tus clientes:</p><ul style="margin:8px 0 0 16px;font-size:12px;"><li>Agrega contactos manualmente o impórtalos desde CSV</li><li>Usa el <strong>Pipeline</strong> para ver en qué etapa están (Lead → Prospecto → Cliente)</li><li>Crea <strong>tareas</strong> para dar seguimiento</li><li>Detecta <strong>duplicados</strong> para limpiar tu base</li></ul>', [
          { label: 'Ir al CRM', icon: '👤', action: "window.location.href='/dashboard/crm'" },
        ]);
    }
    // ═══════ EMAIL ═══════
    else if (lower.includes('email') || lower.includes('campaña') || lower.includes('newsletter')) {
      addBotMsg('<p>En Email Marketing puedes:</p><ul style="margin:8px 0 0 16px;font-size:12px;"><li>Crear campañas con un <strong>wizard paso a paso</strong></li><li>Usar la <strong>IA para generar asuntos</strong></li><li>Diseñar emails con el <strong>editor visual</strong> (drag & drop)</li><li>Activar <strong>secuencias automáticas</strong> (bienvenida, carrito abandonado, etc.)</li><li>Hacer <strong>pruebas A/B</strong></li></ul>', [
          { label: 'Ir a Email Marketing', icon: '✉️', action: "window.location.href='/dashboard/email-marketing'" },
        ]);
    }
    // ═══════ AYUDA GENERAL ═══════
    else if (lower.includes('ayuda') || lower.includes('help') || lower.includes('no sé') || lower.includes('cómo funciona')) {
      addBotMsg('<p>¡Estoy aquí para ayudarte! 😊 Puedes preguntarme cosas como:</p><ul style="margin:8px 0 0 16px;font-size:12px;line-height:1.6;"><li>"¿Cómo creo una factura?"</li><li>"Genera una guía de envío"</li><li>"Crea una automatización para mis pedidos"</li><li>"¿Cómo puedo vender más?"</li><li>"¿Qué módulos tengo?"</li></ul><p style="margin-top:8px;">O si prefieres hablar con una persona, escríbenos por WhatsApp.</p>', [
          { label: 'WhatsApp soporte', icon: '💬', action: "window.open('https://wa.me/5525582310?text=Hola,%20necesito%20ayuda%20con%20SkyBrandMX','_blank')" },
        ]);
    }
    // ═══════ SALUDO ═══════
    else if (lower.includes('hola') || lower.includes('hey') || lower.includes('buenos') || lower.includes('buenas')) {
      addBotMsg('<p>¡Hola! 👋 ¿En qué te puedo ayudar hoy?</p><p style="margin-top:6px;font-size:12px;">Puedes pedirme que haga cosas como crear facturas, generar guías, configurar automatizaciones, o darte consejos para tu negocio.</p>');
    }
    // ═══════ GRACIAS ═══════
    else if (lower.includes('gracias') || lower.includes('thanks')) {
      addBotMsg('<p>¡De nada! 😊 Aquí estoy siempre que me necesites. ¡Mucho éxito con tu negocio! 🚀</p>');
    }
    // ═══════ TIENDA ═══════
    else if (lower.includes('tienda') && (lower.includes('crear') || lower.includes('online') || lower.includes('cómo'))) {
      addBotMsg('<p>¡Puedes crear tu tienda online directamente aquí! 🏪</p><p style="margin-top:6px;">No necesitas Shopify ni WordPress. En el módulo <strong>Tienda Online</strong> puedes:</p><ul style="margin:8px 0 0 16px;font-size:12px;"><li>Elegir un diseño (4 temas disponibles)</li><li>Agregar tus productos</li><li>Configurar tu dominio</li><li>¡Publicar!</li></ul>', [
          { label: 'Crear mi tienda', icon: '🏪', action: "window.location.href='/dashboard/tienda'" },
        ]);
    }
    // ═══════ RESERVACIONES ═══════
    else if (lower.includes('cita') || lower.includes('reserv') || lower.includes('agenda') || lower.includes('mesa')) {
      addBotMsg('<p>El módulo de Reservaciones funciona para cualquier negocio que necesite agendar:</p><ul style="margin:8px 0 0 16px;font-size:12px;"><li>🍽 Restaurantes (mesas)</li><li>💇 Salones de belleza (citas)</li><li>🏥 Consultorios (consultas)</li><li>🏋 Gyms (clases)</li><li>💼 Servicios profesionales (reuniones)</li></ul>', [
          { label: 'Ir a Reservaciones', icon: '📅', action: "window.location.href='/dashboard/reservaciones'" },
        ]);
    }
    // ═══════ DEFAULT ═══════
    else {
      addBotMsg('<p>Entiendo que quieres saber sobre: <strong>"' + text.substring(0, 50) + '"</strong></p><p style="margin-top:6px;">Todavía estoy aprendiendo, pero puedo ayudarte con facturación, envíos, automatizaciones, email marketing, CRM, y más. ¿Puedes reformular tu pregunta?</p><p style="margin-top:6px;font-size:12px;">También puedes hablar con nuestro equipo por WhatsApp para ayuda personalizada.</p>', [
          { label: 'WhatsApp soporte', icon: '💬', action: "window.open('https://wa.me/5525582310?text=Hola,%20necesito%20ayuda%20con%20SkyBrandMX','_blank')" },
        ]);
    }
  }, 800 + Math.random() * 600); // Random delay 0.8-1.4s for realism
}

// Close on Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('skybot-panel').style.display = 'none';
});
</script>
