---
const navLinks = [
  { href: '/', label: 'INICIO' },
  { href: '/plataforma', label: 'PLATAFORMA' },
  { href: '/modulos', label: 'MÓDULOS' },
  { href: '/precios', label: 'PRECIOS' },
  { href: '/#contacto', label: 'CONTACTO' },
];
---

<nav class="py-4 sticky top-0 z-50 bg-slate-950/80 backdrop-blur-xl border-b border-white/5">
  <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
    <a href="/" class="block group" aria-label="SkyBrandMX">
      <div class="flex items-center space-x-2">
        <!-- Rocket logo -->
        <div class="relative w-10 h-10 flex items-center justify-center logo-fade-in">
          <div class="absolute inset-0 rounded-full logo-glow"></div>
          <svg class="h-7 w-7 text-brand-cyan relative" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g class="rocket-shake">
              <g stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L15 6V14C15 14 15 17 12 17C9 17 9 14 9 14V6L12 2Z" />
                <path d="M9 11L6 14H9V11Z" fill="currentColor" />
                <path d="M15 11L18 14H15V11Z" fill="currentColor" />
              </g>
              <g>
                <path d="M9 17C10.5 20 12 22 12 22C12 22 13.5 20 15 17H9Z" fill="#ff6600" class="flame flame-1" />
                <path d="M10 17.5C11 19.5 12 21 12 21C12 21 13 19.5 14 17.5H10Z" fill="#ef6f6f" class="flame flame-2" />
              </g>
            </g>
          </svg>
        </div>
        <!-- Text -->
        <div class="relative inline-flex flex-col">
          <div class="font-bold text-2xl tracking-tight flex items-center text-white">
            <span>SKYBR</span>
            <span class="bg-gradient-to-br from-[#70D1C6] from-[45%] to-white to-[55%] bg-clip-text text-transparent">A</span>
            <span class="bg-gradient-to-br from-[#70D1C6] from-[45%] to-white to-[55%] bg-clip-text text-transparent">N</span>
            <span>DM</span>
            <span class="bg-gradient-to-br from-[#70D1C6] from-[45%] to-white to-[55%] bg-clip-text text-transparent">X</span>
          </div>
          <div class="absolute -bottom-1 left-0 h-[3px] w-[55%] rounded-full bg-gradient-to-r from-[#70D1C6] to-[#105971] opacity-90" style="filter: saturate(1.2);"></div>
        </div>
      </div>
    </a>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-btn" class="md:hidden text-white p-2" aria-label="Abrir menú">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Desktop nav -->
    <div class="hidden md:flex gap-1 items-center">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="px-4 py-2 text-[13px] font-bold text-brand-cyan hover:text-white transition-colors rounded-lg hover:bg-white/5"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/precios"
        class="ml-4 px-6 py-2.5 bg-brand-teal text-slate-900 rounded-xl text-[13px] font-black hover:bg-brand-teal/90 transition-all active:scale-95"
      >
        Prueba gratis
      </a>
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pt-4 pb-6 space-y-1 border-t border-white/5 mt-4">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block px-4 py-3 text-sm font-bold text-brand-cyan hover:text-white hover:bg-white/5 rounded-lg transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/precios"
      class="block mt-4 px-6 py-3 bg-brand-teal text-slate-900 rounded-xl text-sm font-black text-center"
    >
      Prueba gratis
    </a>
  </div>
</nav>

<style>
  .logo-fade-in {
    animation: logo-fade 0.3s ease-out;
  }

  .logo-glow {
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes logo-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 8px rgba(112, 209, 198, 0.15); }
    50% { box-shadow: 0 0 16px rgba(112, 209, 198, 0.3); }
  }

  .rocket-shake {
    transform-origin: center bottom;
    animation: shake 2.5s ease-in-out infinite;
  }

  @keyframes shake {
    0%, 100% { transform: rotate(0deg) translateY(0); }
    15% { transform: rotate(-1.5deg) translateY(-1px); }
    30% { transform: rotate(1deg) translateY(0); }
    45% { transform: rotate(-0.5deg) translateY(-1px); }
    60% { transform: rotate(0.5deg) translateY(0); }
    75% { transform: rotate(-1deg) translateY(-1px); }
  }

  .flame {
    transform-origin: center top;
    animation: flame-dance 0.4s ease-in-out infinite alternate;
  }

  .flame-1 {
    animation-delay: 0s;
  }

  .flame-2 {
    animation-delay: 0.2s;
  }

  @keyframes flame-dance {
    0% { transform: scaleY(0.85) scaleX(0.95); opacity: 0.8; }
    100% { transform: scaleY(1.15) scaleX(1.05); opacity: 1; }
  }

  .group:hover .rocket-shake {
    animation: shake-boost 0.5s ease-out;
  }

  @keyframes shake-boost {
    0% { transform: translateY(0); }
    30% { transform: translateY(-4px) scale(1.05); }
    60% { transform: translateY(-2px) scale(1.02); }
    100% { transform: translateY(0) scale(1); }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
