---
const productLinks = [
  { href: '/plataforma#crm', label: 'CRM' },
  { href: '/plataforma#facturacion', label: 'Facturación SAT' },
  { href: '/plataforma#envios', label: 'Guías de envío' },
  { href: '/plataforma#ads', label: 'Ads con IA' },
  { href: '/plataforma#email', label: 'Email Marketing' },
  { href: '/plataforma#pedidos', label: 'Gestión de pedidos' },
];

const companyLinks = [
  { href: '/soluciones', label: 'Soluciones' },
  { href: '/soluciones#pymes', label: 'Para PYMES' },
  { href: '/soluciones#medianas', label: 'Para Medianas' },
  { href: '/soluciones#grandes', label: 'Para Grandes' },
  { href: '/precios', label: 'Precios' },
  { href: '/#contacto', label: 'Contacto' },
];

const legalLinks = [
  { href: '/privacidad', label: 'Privacidad' },
  { href: '/cookies', label: 'Cookies' },
  { href: '/terminos', label: 'Términos' },
];
---

<footer class="bg-slate-950 pt-20 pb-10 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="text-2xl font-black tracking-tight text-white mb-4 block">
          SKYBR<span class="text-brand-teal">AN</span>DM<span class="text-brand-teal">X</span>
        </a>
        <p class="text-slate-500 text-sm font-medium leading-relaxed mb-6">
          La plataforma de automatización empresarial diseñada para escalar negocios en México.
        </p>
        <div class="flex items-center gap-2">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
          <span class="text-slate-500 text-xs font-bold ml-1">4.9/5</span>
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Producto</h4>
        <ul class="space-y-3">
          {productLinks.map((link) => (
            <li><a href={link.href} class="text-slate-500 hover:text-white text-sm font-medium transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Empresa</h4>
        <ul class="space-y-3">
          {companyLinks.map((link) => (
            <li><a href={link.href} class="text-slate-500 hover:text-white text-sm font-medium transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Legal</h4>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li><a href={link.href} class="text-slate-500 hover:text-white text-sm font-medium transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-600 text-xs font-medium">
        &copy; 2026 SkyBrandMX. Todos los derechos reservados.
      </p>
      <p class="text-slate-700 text-xs font-medium">
        Hecho con orgullo en México 🇲🇽
      </p>
    </div>
  </div>
</footer>
