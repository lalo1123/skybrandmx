---
const features = [
  {
    icon: '📈',
    title: 'CRM Inteligente',
    description: 'Pipelines visuales de ventas, scoring de leads y embudos automatizados que convierten prospectos en clientes 24/7.',
    highlights: ['Pipeline drag & drop', 'Lead scoring con IA', 'Seguimiento automático'],
    gradient: 'from-blue-500 to-indigo-600',
    bg: 'bg-blue-500/5',
  },
  {
    icon: '🧾',
    title: 'Facturación SAT 4.0',
    description: 'Emite comprobantes CFDI válidos ante el SAT en segundos. Complementos de pago, notas de crédito y cancelaciones incluidas.',
    highlights: ['CFDI 4.0 validado', 'Complementos de pago', 'Timbrado automático'],
    gradient: 'from-brand-cyan to-blue-500',
    bg: 'bg-brand-cyan/5',
  },
  {
    icon: '📦',
    title: 'Guías de Envío Premium',
    description: 'Las mejores tarifas de México negociadas por volumen. DHL, FedEx, Estafeta, Redpack y más desde un solo panel.',
    highlights: ['Tarifas preferenciales', 'Rastreo centralizado', 'Multi-paquetería'],
    gradient: 'from-brand-teal to-emerald-600',
    bg: 'bg-brand-teal/5',
  },
  {
    icon: '🤖',
    title: 'Ads con IA',
    description: 'Lanza campañas en Meta y Google Ads optimizadas automáticamente según tu rendimiento real y tu presupuesto.',
    highlights: ['Optimización automática', 'Reportes ROAS', 'Audiencias inteligentes'],
    gradient: 'from-purple-500 to-pink-500',
    bg: 'bg-purple-500/5',
  },
  {
    icon: '📧',
    title: 'Email Marketing',
    description: 'Secuencias de bienvenida, recuperación de carrito abandonado y fidelización que se ejecutan solas.',
    highlights: ['Flujos automatizados', 'Templates profesionales', 'A/B testing'],
    gradient: 'from-orange-500 to-red-500',
    bg: 'bg-orange-500/5',
  },
  {
    icon: '🛒',
    title: 'Gestión de Pedidos',
    description: 'Tus ventas de Shopify, WooCommerce y Mercado Libre consolidadas en un solo flujo maestro con estatus en tiempo real.',
    highlights: ['Multi-canal unificado', 'Estatus en tiempo real', 'Inventario sincronizado'],
    gradient: 'from-brand-primary to-slate-700',
    bg: 'bg-brand-primary/5',
  },
];
---

<section id="servicios" class="py-32 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-orange/5 border border-brand-orange/10 text-brand-orange text-xs font-bold mb-8">
        Módulos
      </div>
      <h2 class="text-4xl md:text-6xl font-black tracking-tighter mb-6 text-slate-900">
        6 herramientas. <span class="text-brand-orange">1 plataforma.</span>
      </h2>
      <p class="text-lg text-slate-500 font-medium">
        Cada módulo funciona solo o en conjunto. Tú decides cómo armar tu stack operativo.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 hover:border-slate-200 hover:shadow-2xl hover:shadow-slate-100 transition-all duration-500">
          <!-- Icon -->
          <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${feature.gradient} flex items-center justify-center text-2xl mb-6 shadow-lg group-hover:scale-110 transition-transform duration-300`}>
            {feature.icon}
          </div>

          <h3 class="text-xl font-black text-slate-900 mb-3 tracking-tight">{feature.title}</h3>
          <p class="text-slate-500 text-sm font-medium leading-relaxed mb-6">{feature.description}</p>

          <!-- Highlights -->
          <div class="flex flex-wrap gap-2">
            {feature.highlights.map((h) => (
              <span class={`px-3 py-1.5 rounded-lg ${feature.bg} text-xs font-bold text-slate-700`}>{h}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
