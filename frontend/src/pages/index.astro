						<div>
                            <div class="flex items-center gap-5 mb-10">
                                <span class="w-16 h-16 rounded-2xl bg-red-100/50 text-red-500 flex items-center justify-center text-3xl shadow-sm border border-red-200/50">✕</span> 
                                <h3 class="text-3xl font-black text-slate-800 tracking-tight">Caos Fragmentado</h3>
                            </div>
                            <ul id="chaos-list" class="space-y-6">
                                <!-- Dynamic Content -->
                            </ul>
                        </div>
                        <div class="mt-12 pt-8 border-t border-slate-200 opacity-50">
