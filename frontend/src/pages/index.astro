---
import Layout from '../layouts/Layout.astro';
import SegmentationTabs from '../components/SegmentationTabs.astro';
import { Icon } from 'astro-icon/components';
---

<style>
	@keyframes float {
		0% { transform: translateY(0px); }
		50% { transform: translateY(-10px); }
		100% { transform: translateY(0px); }
	}
	.animate-float {
		animation: float 6s ease-in-out infinite;
	}
	.animate-float-delayed {
		animation: float 8s ease-in-out infinite -2s;
	}
</style>

<Layout title="Panel Todo en Uno para PYMES | CRM, Facturación y Envíos — SkyBrandMX">


	<main>
		<!-- HERO SECTION -->
		<section class="relative pt-40 pb-32 overflow-hidden bg-[#081014]">
			<!-- Background subtle technological light gradient -->
			<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(16,89,113,0.3),transparent_50%)] pointer-events-none"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(112,209,198,0.05),transparent_40%)] pointer-events-none"></div>

			<div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-20 items-center relative z-10">
				<div class="flex flex-col items-start">
					<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#105971]/30 border border-[#70D1C6]/30 text-[#70D1C6] text-xs font-bold mb-10 shadow-[0_0_15px_rgba(112,209,198,0.1)]">
						<span class="flex h-2 w-2 rounded-full bg-[#70D1C6] shadow-[0_0_5px_#70D1C6]"></span>
                        Nuevo: Panel Todo-en-Uno para México
					</div>
					<h1 class="text-7xl lg:text-[90px] font-black tracking-tight mb-8 leading-[0.9] text-white">
						Todo tu negocio en <br/><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#105971] via-[#3a96a6] to-[#70D1C6]">un solo panel.</span>
					</h1>
					<p class="text-xl text-slate-400 mb-12 max-w-xl leading-relaxed font-semibold">
						CRM, facturación SAT, guías de envío y automatización — integrados en una sola plataforma Enterprise diseñada para escalar tu negocio.
