                                        </div>
										<p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.15em] mb-1.5 font-black">Ingresos Netos</p>
										<span class="text-3xl font-black text-white tracking-tighter leading-none">$842.2k</span>
									</div>
									<div class="bg-[#081014]/60 backdrop-blur-md border border-white/5 rounded-[1.75rem] p-6 shadow-xl">
                                        <div class="flex justify-between items-start mb-5">
                                            <div class="w-10 h-10 rounded-xl bg-[#105971]/30 text-[#70D1C6] flex items-center justify-center text-xl border border-[#105971]/50 shadow-inner">📦</div>
                                            <span class="text-[9px] font-black text-[#70D1C6] bg-[#70D1C6]/10 px-2.5 py-1 rounded-full border border-[#70D1C6]/20">+12%</span>
                                        </div>
										<p class="text-[9px] font-black text-slate-400 uppercase tracking-[0.15em] mb-1.5 font-black">Envíos Exitosos</p>
										<span class="text-3xl font-black text-white tracking-tighter leading-none">3,128</span>
									</div>
								</div>

                                <!-- Progress Bar Mockup Element -->
