                            </div>
                            <div class="logo-card">
                                <div class="bg-[#1D2A4F] text-white text-[10px] font-black px-2 py-1 rounded">SAT</div>
                                <span class="logo-text">SAT (4.0)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
		</section>

		<!-- PROBLEM / SOLUTION REDESIGN -->
		<section id="solucion" class="py-32 bg-white relative overflow-hidden">
            <div class="absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[#F8FAFC] to-transparent pointer-events-none"></div>
			<div class="max-w-7xl mx-auto px-6 text-center relative z-10">
                <h2 class="text-4xl md:text-7xl font-black mb-12 tracking-tighter text-[#105971] leading-tight transition-all duration-700">
                    ¿Cansado de pagar por <br/><span class="text-[#FF6B00]">6 herramientas</span> que no se hablan?
                </h2>

                <!-- Tab Selector Segmented B2B -->
                <div class="flex justify-center mb-16">
                    <div class="inline-flex p-1.5 bg-[#F1F5F9] border border-slate-200 rounded-2xl shadow-inner relative overflow-hidden group">
                        <button 
                            class="solucion-tab active px-8 py-3 rounded-xl text-xs font-black uppercase tracking-widest transition-all duration-500 relative z-10"
                            data-segment="pymes"
                        >
                            PYMES
                        </button>
                        <button 
                            class="solucion-tab px-8 py-3 rounded-xl text-xs font-black uppercase tracking-widest text-slate-500 hover:text-[#105971] transition-all duration-500 relative z-10"
                            data-segment="medianas"
