                        <div class="absolute inset-0 bg-gradient-to-br from-white via-white to-[#70D1C6]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-1000"></div>
                        
                        <div class="relative z-10">
                            <div class="flex items-center gap-5 mb-10">
                                <span class="w-16 h-16 rounded-2xl bg-[#70D1C6]/10 text-[#70D1C6] flex items-center justify-center text-3xl shadow-sm border border-[#70D1C6]/20">✓</span> 
                                <h3 class="text-3xl font-black text-[#105971] tracking-tight">La Solución SkyBrand</h3>
                            </div>
                            <ul id="solution-list" class="space-y-6">
                                <!-- Dynamic Content -->
                            </ul>
                        </div>

                        <div class="mt-12 pt-8 border-t border-slate-50 relative z-10">
                            <p class="text-[10px] font-black uppercase tracking-[0.2em] text-[#70D1C6] leading-relaxed italic">Tecnología Enterprise que trabaja por ti.</p>
                        </div>
					</div>
				</div>
			</div>

            <!-- Client-side logic for the solution cards -->
            <script is:inline>
                const segmentData = {
                    pymes: {
                        chaos: [
                            "Pagas suscripciones separadas para web, email y CRM.",
                            "Copias y pegas a mano los datos para generar una guía de envío.",
                            "Pierdes ventas porque los mensajes de WhatsApp e Instagram se mezclan.",
                            "Hacer una factura en el portal del SAT te toma demasiado tiempo.",
                            "No tienes claridad de qué anuncios de Meta o Google realmente venden."
                        ],
                        solution: [
                            "Una sola suscripción que reemplaza más de 5 herramientas.",
                            "Generación masiva de guías multi-paquetería con 1 solo clic.",
                            "Bandeja omnicanal: Todo tu chat en un solo embudo ordenado.",
                            "Facturación SAT 4.0 automatizada directamente desde el pedido.",
                            "Dashboards de marketing que miden el ROI de cada centavo invertido."
                        ]
                    },
                    medianas: {
                        chaos: [
                            "Tu equipo de ventas choca entre sí y los leads se enfrían.",
                            "El inventario físico de tu almacén no cuadra con tu tienda online.",
                            "Dependes de Excel para intentar cruzar reportes de diferentes áreas.",
                            "Cuellos de botella en atención al cliente fuera de horario laboral.",
                            "El seguimiento de carritos abandonados se hace manual o no se hace."
                        ],
                        solution: [
                            "Pipelines inteligentes que asignan leads a tus vendedores automáticamente.",
                            "Sincronización de inventario en tiempo real en todos tus canales.",
                            "Analítica centralizada con reportes visuales al instante.",
                            "Chatbots con IA que atienden y califican prospectos 24/7.",
                            "Flujos de Email y SMS Marketing automatizados que venden por ti."
                        ]
                    },
                    enterprise: {
                        chaos: [
                            "Tu sistema legacy (AS400/ERP) está totalmente aislado del e-commerce.",
                            "Los pedidos de mayoreo (B2B) requieren llamadas, correos y procesos manuales.",
                            "Falta de gobernanza: todos los empleados tienen el mismo nivel de acceso.",
                            "Rupturas de stock por no tener alertas tempranas para resurtir.",
                            "Soporte técnico saturado sin medición de tiempos de respuesta."
                        ],
                        solution: [
                            "Integración API bidireccional nativa con tu ERP y bases de datos actuales.",
                            "Portal B2B de auto-servicio con precios ocultos y reglas de volumen.",
                            "Workspaces con permisos granulares y registro de auditoría.",
                            "Órdenes de compra automatizadas a proveedores basadas en stock mínimo.",
                            "Sistema Helpdesk Pro con SLAs y asignación de tickets automatizada."
                        ]
                    }
                };

                function updateSolucionTabs() {
                    const tabs = document.querySelectorAll('.solucion-tab');
                    const chaosList = document.getElementById('chaos-list');
                    const solutionList = document.getElementById('solution-list');
                    const cards = [document.getElementById('chaos-card'), document.getElementById('solution-card')];

                    tabs.forEach(tab => {
                        tab.addEventListener('click', () => {
                            const segment = tab.getAttribute('data-segment');
                            
                            // UI Update
