                <h2 class="text-3xl md:text-5xl font-black text-[#105971] tracking-tighter mb-4">
                    Conectado con el ecosistema que impulsas
                </h2>
                <a href="/integraciones" class="text-[#70D1C6] font-black uppercase text-[10px] tracking-[0.2em] hover:text-[#105971] transition-colors">Ver todas las integraciones →</a>
            </div>

            <div class="relative w-full">
                <!-- Fade gradients -->
