								<div class="w-3 h-3 rounded-full bg-slate-700"></div>
								<div class="w-3 h-3 rounded-full bg-slate-700"></div>
							</div>
							<div class="flex-1 max-w-sm mx-auto">
                                <div class="bg-white/5 rounded-xl h-8 flex items-center px-4 gap-3 border border-white/5">
                                    <span class="text-[11px] text-slate-500 font-semibold tracking-tight mx-auto flex gap-2 items-center"><span class="w-2 h-2 rounded-full bg-[#70D1C6]"></span> app.skybrandmx.mx</span>
