                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:whatsapp" class="h-6 w-auto" />
                                <span class="logo-text">WhatsApp</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:amazon" class="h-6 w-auto" />
                                <span class="logo-text">Amazon</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:dhl" class="h-6 w-auto" />
                                <span class="logo-text">DHL</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:meta" class="h-6 w-auto" />
                                <span class="logo-text">Meta</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:mercadopago" class="h-6 w-auto" />
                                <span class="logo-text">Mercado Libre</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:gmail" class="h-6 w-auto" />
                                <span class="logo-text">Gmail</span>
                            </div>
                            <div class="logo-card">
                                <div class="bg-[#1D2A4F] text-white text-[10px] font-black px-2 py-1 rounded">SAT</div>
                                <span class="logo-text">SAT (4.0)</span>
                            </div>
                        </div>
                        <!-- Group 2 (Duplicate for seamless loop) -->
                        <div class="logo-group flex gap-12 items-center">
                            <div class="logo-card">
                                <Icon name="simple-icons:shopify" class="h-6 w-auto" />
                                <span class="logo-text">Shopify</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:stripe" class="h-6 w-auto" />
                                <span class="logo-text">Stripe</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:mercadopago" class="h-6 w-auto" />
                                <span class="logo-text">Mercado Pago</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:whatsapp" class="h-6 w-auto" />
                                <span class="logo-text">WhatsApp</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:amazon" class="h-6 w-auto" />
                                <span class="logo-text">Amazon</span>
                            </div>
                            <div class="logo-card">
                                <Icon name="simple-icons:dhl" class="h-6 w-auto" />
