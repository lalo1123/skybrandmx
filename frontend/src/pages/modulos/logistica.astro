---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Módulo de Logística y Envíos — SkyBrandMX">
    <main>
        <!-- HERO LOGÍSTICA -->
        <section class="relative pt-40 pb-20 overflow-hidden bg-white">
            <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center relative z-10">
                <div>
                    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#105971]/10 border border-[#105971]/20 text-[#105971] text-xs font-black mb-8">
                        Módulo Especializado
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black text-[#081014] tracking-tighter mb-6 leading-tight">
                        Despacha en <span class="text-[#FF6B00]">minutos</span>, no en horas.
                    </h1>
                    <p class="text-lg text-slate-500 font-bold mb-10 leading-relaxed">
                        Automatiza la cotización, generación y monitoreo de guías con las mejores paqueterías de México. Todo sincronizado en tiempo real con tu tienda online.
                    </p>
                    <div class="flex gap-4">
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="px-8 py-4 bg-[#FF6B00] text-white rounded-2xl text-sm font-black uppercase tracking-widest hover:bg-[#E66000] transition-all shadow-xl shadow-orange-200 hover:-translate-y-1">Ver Demo Logística</a>
                    </div>
                </div>
                <div class="relative">
                    <div class="absolute inset-0 bg-gradient-to-tr from-[#70D1C6]/30 to-[#FF6B00]/20 rounded-full blur-[100px] -z-10"></div>
                    <div class="bg-white border-2 border-slate-100 rounded-[2.5rem] shadow-2xl p-8 relative">
                        <div class="flex items-center justify-between mb-8 pb-6 border-b border-slate-100">
                            <div>
                                <h3 class="font-black text-xl text-[#081014]">Lote de Envíos del Día</h3>
                                <p class="text-xs font-bold text-slate-400">142 Pedidos sincronizados (Shopify)</p>
                            </div>
                            <button class="px-4 py-2 bg-[#105971] text-white text-xs font-black rounded-lg">Generar Lote (1 clic)</button>
                        </div>
                        <div class="space-y-4">
                            <!-- Mock Row 1 -->
                            <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-black text-[#FF6B00]">FX</div>
                                    <div>
                                        <p class="font-bold text-sm text-[#081014]">Roberto Sánchez</p>
                                        <p class="text-[10px] font-black tracking-wider uppercase text-slate-400">Monterrey, NL</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="font-black text-[#105971]">$145.00</p>
                                    <span class="inline-block px-2 py-1 bg-[#70D1C6]/20 text-[#105971] text-[10px] font-black rounded">Express</span>
                                </div>
                            </div>
                            <!-- Mock Row 2 -->
                            <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl">
                                <div class="flex items-center gap-4">
                                    <div class="w-10 h-10 rounded-full bg-white border border-slate-200 flex items-center justify-center font-black text-yellow-500">DHL</div>
                                    <div>
                                        <p class="font-bold text-sm text-[#081014]">Ana Gabriela Solís</p>
                                        <p class="text-[10px] font-black tracking-wider uppercase text-slate-400">Guadalajara, JAL</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="font-black text-[#105971]">$168.50</p>
                                    <span class="inline-block px-2 py-1 bg-slate-200 text-slate-500 text-[10px] font-black rounded">Estándar</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CARACTERISTICAS LOGISTICA -->
        <section class="py-24 bg-[#F8FAFC]">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-16">
                    <h2 class="text-4xl font-black text-[#105971] tracking-tighter mb-4">
                        Poder logístico a tu alcance
                    </h2>
                    <p class="text-slate-500 font-bold max-w-2xl mx-auto">
                        Todo lo que necesitas para asegurar que tus productos lleguen a tiempo, sin dolores de cabeza.
                    </p>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Cotizador -->
                    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all">
                        <div class="w-12 h-12 bg-[#FF6B00]/10 rounded-xl flex items-center justify-center text-2xl mb-6">💰</div>
                        <h4 class="text-xl font-black text-[#081014] mb-3">Cotizador Inteligente</h4>
                        <p class="text-slate-500 text-sm font-bold">Compara tarifas de más de 10 paqueterías en tiempo real y elige siempre la opción más rentable.</p>
                    </div>

                    <!-- Generación Masiva -->
                    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all">
                        <div class="w-12 h-12 bg-[#105971]/10 rounded-xl flex items-center justify-center text-2xl mb-6">🖨️</div>
                        <h4 class="text-xl font-black text-[#081014] mb-3">Guías en Batch</h4>
                        <p class="text-slate-500 text-sm font-bold">Imprime hasta 100 guías con un solo clic, sin copiar y pegar direcciones. Sincronización 100% nativa.</p>
                    </div>

                    <!-- Rastreo Activo -->
                    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all">
                        <div class="w-12 h-12 bg-[#70D1C6]/20 rounded-xl flex items-center justify-center text-2xl mb-6">📍</div>
                        <h4 class="text-xl font-black text-[#081014] mb-3">Rastreo Proactivo</h4>
                        <p class="text-slate-500 text-sm font-bold">Tus clientes reciben notificaciones automáticas vía WhatsApp o Email sobre el estado de su envío.</p>
                    </div>

                    <!-- Reportística -->
                    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 hover:shadow-xl hover:-translate-y-1 transition-all">
                        <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center text-2xl mb-6">📊</div>
                        <h4 class="text-xl font-black text-[#081014] mb-3">Métricas de Envío</h4>
                        <p class="text-slate-500 text-sm font-bold">Analiza tus costos de distribución, tiempos promedio de entrega y rendimiento por paquetería.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA FINAL -->
        <section class="py-24 bg-[#081014]">
            <div class="max-w-4xl mx-auto px-6 text-center">
                <h2 class="text-4xl md:text-5xl font-black text-white tracking-tighter mb-8">
                    Deja de perder dinero en guías sobre-cotizadas.
                </h2>
                <p class="text-xl text-[#70D1C6] font-bold mb-10">
                    Nuestros clientes reducen sus costos operativos de logística hasta en un 30% en el primer mes.
                </p>
                <a href="/planes" class="inline-block px-10 py-5 bg-[#FF6B00] text-white rounded-2xl text-sm font-black uppercase tracking-widest hover:bg-[#E66000] transition-all shadow-[0_0_20px_rgba(255,107,0,0.4)]">Comenzar Período de Prueba</a>
            </div>
        </section>
    </main>
</Layout>
