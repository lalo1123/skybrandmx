---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="CRM y Gestión de Ventas — SkyBrandMX">
    <main>
        <!-- HERO CRM -->
        <section class="relative pt-40 pb-20 overflow-hidden bg-[#F8FAFC]">
            <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[#FF6B00]/20 to-transparent"></div>
            <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center relative z-10">
                <div class="order-2 md:order-1 relative">
                    <div class="absolute inset-0 bg-gradient-to-tr from-[#105971]/20 to-[#FF6B00]/10 rounded-full blur-[100px] -z-10"></div>
                    <div class="bg-white border-2 border-[#105971]/10 rounded-[2.5rem] shadow-2xl p-6 relative">
                        <!-- Mock Pipeline -->
                        <div class="flex gap-4 overflow-x-auto pb-4">
                            <!-- Col 1 -->
                            <div class="min-w-[250px] bg-slate-50 rounded-2xl p-4">
                                <h4 class="font-black text-[#105971] text-xs uppercase tracking-widest mb-4 flex justify-between">
                                    Nuevos Leads <span class="bg-white text-slate-500 px-2 rounded-full">3</span>
                                </h4>
                                <div class="space-y-3">
                                    <div class="bg-white p-3 rounded-xl border border-slate-100 shadow-sm cursor-grab">
                                        <p class="font-bold text-sm text-[#081014] mb-1">Cotización B2B - Grupo ACME</p>
                                        <p class="text-xl font-black text-[#105971] mb-2">$45,000</p>
                                        <span class="inline-flex bg-[#FF6B00]/10 text-[#FF6B00] text-[10px] font-black uppercase rounded px-2 py-0.5">High Priority</span>
                                    </div>
                                    <div class="bg-white p-3 rounded-xl border border-slate-100 shadow-sm cursor-grab opacity-70">
                                        <p class="font-bold text-sm text-slate-600 mb-1">Duda sobre envíos MX</p>
                                        <p class="text-sm font-black text-[#70D1C6]">$--</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Col 2 -->
                            <div class="min-w-[250px] bg-[#105971]/5 rounded-2xl p-4 border border-[#105971]/20">
                                <h4 class="font-black text-[#105971] text-xs uppercase tracking-widest mb-4 flex justify-between">
                                    En Negociación <span class="bg-white text-slate-500 px-2 rounded-full">1</span>
                                </h4>
                                <div class="space-y-3">
                                    <div class="bg-white p-3 rounded-xl border-2 border-[#70D1C6] shadow-sm cursor-grab relative overflow-hidden">
                                        <div class="absolute right-0 top-0 bottom-0 w-1 bg-[#70D1C6]"></div>
                                        <p class="font-bold text-sm text-[#081014] mb-1">Suscripción Anual Plata</p>
                                        <p class="text-xl font-black text-[#105971] mb-2">$18,500</p>
                                        <span class="text-xs text-slate-400 font-bold block mb-2">Vendedor: Luis M.</span>
                                        <div class="w-full bg-slate-100 h-1.5 rounded-full"><div class="bg-[#70D1C6] h-1.5 rounded-full w-[80%]"></div></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="order-1 md:order-2">
                    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#FF6B00]/10 border border-[#FF6B00]/20 text-[#FF6B00] text-xs font-black mb-8">
                        Ventas Inteligentes
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black text-[#081014] tracking-tighter mb-6 leading-tight">
                        Cierra tratos <br/><span class="text-[#105971]">automáticamente.</span>
                    </h1>
                    <p class="text-lg text-slate-500 font-bold mb-10 leading-relaxed">
                        Reemplaza tus hojas de cálculo con un embudo visual en tiempo real. Asigna prospectos a tus asesores y monitorea los ratios de conversión segundo a segundo.
                    </p>
                    <div class="flex gap-4">
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="px-8 py-4 bg-[#105971] text-white rounded-2xl text-sm font-black uppercase tracking-widest hover:bg-[#084d6e] transition-all shadow-xl shadow-cyan-900/20 hover:-translate-y-1">Agendar Demostración CRM</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- CARACTERISTICAS CRM -->
        <section class="py-24 bg-white">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-16">
                    <h2 class="text-4xl font-black text-[#105971] tracking-tighter mb-4">
                        Visión 360° de cada cliente
                    </h2>
                    <p class="text-slate-500 font-bold max-w-2xl mx-auto">
                        Tus equipos de ventas, soporte y finanzas compartiendo la misma pantalla de verdad.
                    </p>
                </div>

                <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
                    <!-- Feature -->
                    <div class="flex gap-6 p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 hover:border-[#105971]/30 transition-all group">
                        <div class="w-16 h-16 shrink-0 bg-[#FF6B00]/10 rounded-2xl flex items-center justify-center text-3xl group-hover:bg-[#FF6B00] group-hover:text-white transition-colors duration-300">📱</div>
                        <div>
                            <h4 class="text-xl font-black text-[#105971] mb-2">WhatsApp Omnicanal</h4>
                            <p class="text-slate-600 focus font-bold text-sm leading-relaxed">Atiende a tus clientes desde múltiples líneas con bots de pre-calificación que derivan los leads calientes a humanos en tu CRM.</p>
                        </div>
                    </div>

                    <!-- Feature -->
                    <div class="flex gap-6 p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 hover:border-[#105971]/30 transition-all group">
                        <div class="w-16 h-16 shrink-0 bg-[#70D1C6]/20 rounded-2xl flex items-center justify-center text-3xl group-hover:bg-[#70D1C6] group-hover:text-white transition-colors duration-300">📊</div>
                        <div>
                            <h4 class="text-xl font-black text-[#105971] mb-2">Embudo Personalizable</h4>
                            <p class="text-slate-600 font-bold text-sm leading-relaxed">Crea pipelines Drag and Drop (Kanban) ilimitados. Adapta las etapas a tus procesos y ciclo de venta, no al revés.</p>
                        </div>
                    </div>

                    <!-- Feature -->
                    <div class="flex gap-6 p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 hover:border-[#105971]/30 transition-all group">
                        <div class="w-16 h-16 shrink-0 bg-blue-100 rounded-2xl flex items-center justify-center text-3xl group-hover:bg-blue-500 group-hover:text-white transition-colors duration-300">📩</div>
                        <div>
                            <h4 class="text-xl font-black text-[#105971] mb-2">Automatización (Email & SMS)</h4>
                            <p class="text-slate-600 font-bold text-sm leading-relaxed">Recupera carritos abandonados o lanza on-boardings en base al comportamiento que el cliente tiene en tu web.</p>
                        </div>
                    </div>

                    <!-- Feature -->
                    <div class="flex gap-6 p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 hover:border-[#105971]/30 transition-all group">
                        <div class="w-16 h-16 shrink-0 bg-purple-100 rounded-2xl flex items-center justify-center text-3xl group-hover:bg-purple-500 group-hover:text-white transition-colors duration-300">🎯</div>
                        <div>
                            <h4 class="text-xl font-black text-[#105971] mb-2">Asignación Inteligente (Round Robin)</h4>
                            <p class="text-slate-600 font-bold text-sm leading-relaxed">Distribuye los leads entrantes de manera equitativa entre tus asesores según volumen, especialidad de industria o desempeño.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA FINAL CRM -->
        <section class="py-24 bg-[#081014] text-center">
            <div class="max-w-4xl mx-auto px-6">
                <h2 class="text-4xl md:text-5xl font-black text-white tracking-tighter mb-8">
                    Tus vendedores deberían estar vendiendo, no tecleando en Excel.
                </h2>
                <a href="/planes" class="inline-block px-10 py-5 bg-[#FF6B00] text-white rounded-2xl text-sm font-black uppercase tracking-widest hover:bg-[#E66000] transition-all shadow-[0_0_20px_rgba(255,107,0,0.4)] hover:-translate-y-1">Aumentar mis Conversiones</a>
            </div>
        </section>
    </main>
</Layout>
