---
import AppLayout from '../../layouts/AppLayout.astro';
import { Icon } from 'astro-icon/components';
---

<AppLayout title="CRM y Gestión de Ventas">
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 rounded-full bg-[#FF6B00] shadow-[0_0_10px_#FF6B00]"></span>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Gestión Comercial</p>
            </div>
            <h1 class="text-4xl font-black text-slate-950 tracking-tighter">CRM Inteligente</h1>
            <p class="text-slate-500 font-bold mt-1 text-lg">Centraliza tus prospectos y <span class="text-[#105971]">acelera el cierre</span> de ventas.</p>
        </div>
        <div class="flex items-center gap-3">
            <button class="px-5 py-3 bg-white border border-slate-200 rounded-2xl text-sm font-black text-slate-700 hover:bg-slate-50 transition-all flex items-center gap-2 shadow-sm">
                <Icon name="lucide:filter" class="w-4 h-4" />
                Filtrar Segmentos
            </button>
            <button class="px-5 py-3 bg-[#105971] text-white rounded-2xl text-sm font-black hover:shadow-xl transition-all flex items-center gap-2">
                <Icon name="lucide:user-plus" class="w-4 h-4" />
                Nuevo Prospecto
            </button>
        </div>
    </div>

    <!-- PIPELINE METRICS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm transition-all hover:shadow-md">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-orange-50 text-[#FF6B00] flex items-center justify-center">
                    <Icon name="lucide:zap" class="w-6 h-6" />
                </div>
                <h3 class="font-black text-slate-900">Leads este mes</h3>
            </div>
            <p class="text-3xl font-black text-slate-900">142</p>
            <p class="text-xs font-bold text-emerald-600 mt-2">+24% vs anterior</p>
        </div>
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm transition-all hover:shadow-md">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-blue-50 text-[#105971] flex items-center justify-center">
                    <Icon name="lucide:bar-chart-3" class="w-6 h-6" />
                </div>
                <h3 class="font-black text-slate-900">Tasa de Conversión</h3>
            </div>
            <p class="text-3xl font-black text-slate-900">18.5%</p>
            <p class="text-xs font-bold text-slate-400 mt-2">Promedio industria: 12%</p>
        </div>
        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm transition-all hover:shadow-md">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
                    <Icon name="lucide:trending-up" class="w-6 h-6" />
                </div>
                <h3 class="font-black text-slate-900">Valor Proyectado</h3>
            </div>
            <p class="text-3xl font-black text-slate-900">$2.4M</p>
            <p class="text-xs font-bold text-emerald-600 mt-2">Embudo en expansión</p>
        </div>
    </div>

    <!-- CUSTOMER TABLE -->
    <div class="bg-white rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-8 border-b border-slate-50 flex justify-between items-center">
            <h2 class="text-xl font-black text-slate-900">Prospectos Activos</h2>
            <div class="flex gap-2">
                <button class="px-4 py-2 text-xs font-black bg-slate-100 text-slate-600 rounded-lg hover:bg-slate-200 transition-colors">Todos</button>
                <button class="px-4 py-2 text-xs font-black bg-[#105971]/10 text-[#105971] rounded-lg">Negociación</button>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-8 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Contacto</th>
                        <th class="px-8 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Etapa</th>
                        <th class="px-8 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Interés</th>
                        <th class="px-8 py-5 text-right text-[10px] font-black text-slate-400 uppercase tracking-widest">Valor Est.</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-8 py-6">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-bold text-xs">AM</div>
                                <div>
                                    <p class="text-sm font-black text-slate-900">Andrea Morán</p>
                                    <p class="text-[10px] text-slate-400 font-bold">Distribuidora Textil del Bajío</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <span class="px-3 py-1 bg-amber-50 text-amber-700 text-[10px] font-black rounded-full border border-amber-100 uppercase tracking-widest">Negociación</span>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex gap-1">
                                <span class="bg-slate-100 px-2 py-0.5 rounded text-[9px] font-black text-slate-500 uppercase">LOGÍSTICA</span>
                                <span class="bg-slate-100 px-2 py-0.5 rounded text-[9px] font-black text-slate-500 uppercase">SAT</span>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-right font-black text-slate-900">$45,000</td>
                    </tr>
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="px-8 py-6">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center font-bold text-xs">CL</div>
                                <div>
                                    <p class="text-sm font-black text-slate-900">Carlos Lopez</p>
                                    <p class="text-[10px] text-slate-400 font-bold">Alimentos Procesados MX</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-6">
                            <span class="px-3 py-1 bg-blue-50 text-blue-700 text-[10px] font-black rounded-full border border-blue-100 uppercase tracking-widest">Contacto Inicial</span>
                        </td>
                        <td class="px-8 py-6">
                            <div class="flex gap-1">
                                <span class="bg-slate-100 px-2 py-0.5 rounded text-[9px] font-black text-slate-500 uppercase">ULTRA PLAN</span>
                            </div>
                        </td>
                        <td class="px-8 py-6 text-right font-black text-slate-900">$12,800</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</AppLayout>
