---
import AppLayout from '../../layouts/AppLayout.astro';
import { Icon } from 'astro-icon/components';
---

<AppLayout title="Panel Principal">
	<div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
		<div>
            <div class="flex items-center gap-2 mb-2">
			    <span class="w-2 h-2 rounded-full bg-[#70D1C6] shadow-[0_0_10px_#70D1C6]"></span>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]">Operativa General</p>
            </div>
			<h1 class="text-4xl font-black text-slate-950 tracking-tighter">Bienvenido, Santiago</h1>
			<p class="text-slate-500 font-bold mt-1 text-lg">Tu empresa ha crecido un <span class="text-emerald-600">12.4%</span> esta semana. 🚀</p>
		</div>
        <div class="flex items-center gap-3">
            <button class="px-5 py-3 bg-white border border-slate-200 rounded-2xl text-sm font-black text-slate-700 hover:bg-slate-50 transition-all flex items-center gap-2 shadow-sm">
                <Icon name="lucide:calendar" class="w-4 h-4" />
                Últimos 30 días
            </button>
            <button class="px-5 py-3 bg-[#FF6B00] text-white rounded-2xl text-sm font-black hover:shadow-xl hover:shadow-orange-200 hover:-translate-y-0.5 transition-all flex items-center gap-2 shadow-[0_10px_20px_-5px_rgba(255,107,0,0.3)]">
                <Icon name="lucide:plus" class="w-4 h-4" />
                Nueva Orden
            </button>
        </div>
	</div>

	<!-- METRICS BENTO BOX -->
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
		<!-- Card 1: Ventas -->
		<div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.03)] hover:shadow-2xl transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-emerald-500/5 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
			<div class="flex justify-between items-start mb-6">
				<div class="w-14 h-14 rounded-2xl bg-emerald-50 text-emerald-600 flex items-center justify-center text-xl border border-emerald-100 group-hover:bg-emerald-600 group-hover:text-white transition-all duration-500 shadow-sm">
					<Icon name="lucide:shopping-bag" class="w-6 h-6" />
				</div>
				<div class="text-right">
                    <span class="text-[10px] font-black text-emerald-600 bg-emerald-50 px-3 py-1.5 rounded-full border border-emerald-100">+18%</span>
                </div>
			</div>
			<p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 font-black">Ventas del Mes</p>
			<div class="flex items-baseline gap-1">
                <h3 class="text-3xl font-black text-slate-900 tracking-tight">$84,230</h3>
                <span class="text-xs font-bold text-slate-400">MXN</span>
            </div>
		</div>

		<!-- Card 2: Pedidos -->
		<div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.03)] hover:shadow-2xl transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#FF6B00]/5 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
			<div class="flex justify-between items-start mb-6">
				<div class="w-14 h-14 rounded-2xl bg-[#FF6B00]/10 text-[#FF6B00] flex items-center justify-center text-xl border border-[#FF6B00]/20 group-hover:bg-[#FF6B00] group-hover:text-white transition-all duration-500 shadow-sm">
					<Icon name="lucide:clock" class="w-6 h-6" />
				</div>
                <div class="text-right">
				    <span class="text-[10px] font-black text-[#FF6B00] bg-orange-50 px-3 py-1.5 rounded-full border border-orange-100">8 Urgentes</span>
                </div>
			</div>
			<p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 font-black">Pedidos Pendientes</p>
			<div class="flex items-baseline gap-1">
                <h3 class="text-3xl font-black text-slate-900 tracking-tight">24</h3>
                <span class="text-xs font-bold text-slate-400">órdenes</span>
            </div>
		</div>

		<!-- Card 3: Guías -->
		<div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.03)] hover:shadow-2xl transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#105971]/5 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
			<div class="flex justify-between items-start mb-6">
				<div class="w-14 h-14 rounded-2xl bg-[#105971]/10 text-[#105971] flex items-center justify-center text-xl border border-[#105971]/20 group-hover:bg-[#105971] group-hover:text-white transition-all duration-500 shadow-sm">
					<Icon name="lucide:truck" class="w-6 h-6" />
				</div>
                <div class="text-right">
				    <span class="text-[10px] font-black text-[#105971] bg-blue-50 px-3 py-1.5 rounded-full border border-blue-100">98% Éxito</span>
                </div>
			</div>
			<p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 font-black">Guías Generadas</p>
			<div class="flex items-baseline gap-1">
                <h3 class="text-3xl font-black text-slate-900 tracking-tight">1,120</h3>
                <span class="text-xs font-bold text-slate-400">logística</span>
            </div>
		</div>

		<!-- Card 4: Ticket -->
		<div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.03)] hover:shadow-2xl transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#70D1C6]/5 to-transparent rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
			<div class="flex justify-between items-start mb-6">
				<div class="w-14 h-14 rounded-2xl bg-[#70D1C6]/10 text-[#105971] flex items-center justify-center text-xl border border-[#70D1C6]/20 group-hover:bg-[#70D1C6] group-hover:text-[#081014] transition-all duration-500 shadow-sm">
					<Icon name="lucide:credit-card" class="w-6 h-6" />
				</div>
                <div class="text-right">
				    <span class="text-[10px] font-black text-[#105971] bg-[#70D1C6]/20 px-3 py-1.5 rounded-full border border-[#70D1C6]/30">+5% avg</span>
                </div>
			</div>
			<p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1 font-black">Ticket Promedio</p>
			<div class="flex items-baseline gap-1">
                <h3 class="text-3xl font-black text-slate-900 tracking-tight">$1,250</h3>
                <span class="text-xs font-bold text-slate-400">ticket</span>
            </div>
		</div>
	</div>

	<!-- TWO COLUMN CONTENT -->
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
		<!-- Left: Recent Activity -->
		<div class="lg:col-span-2 bg-white rounded-[3rem] border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] overflow-hidden">
			<div class="p-10 border-b border-slate-50 flex justify-between items-center bg-slate-50/30">
				<div>
					<h3 class="text-2xl font-black text-slate-900 tracking-tight">Órdenes a Procesar</h3>
					<p class="text-[10px] text-slate-400 font-bold uppercase tracking-[0.2em] mt-1">Tiempo real integrado con Shopify</p>
				</div>
				<button class="text-xs font-black text-[#105971] bg-[#105971]/5 px-5 py-2.5 rounded-xl hover:bg-[#105971] hover:text-white transition-all">Exportar Datos</button>
			</div>
			<div class="overflow-x-auto">
				<table class="w-full">
					<thead>
						<tr class="bg-slate-50 border-b border-slate-100">
							<th class="px-10 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">ID Orden</th>
							<th class="px-10 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Cliente</th>
							<th class="px-10 py-5 text-left text-[10px] font-black text-slate-400 uppercase tracking-widest">Estado Sist.</th>
							<th class="px-10 py-5 text-right text-[10px] font-black text-slate-400 uppercase tracking-widest">Valor</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-slate-50">
						<tr class="hover:bg-slate-50/50 transition-colors group">
							<td class="px-10 py-7">
								<span class="px-4 py-2 bg-slate-100 rounded-xl text-xs font-black text-[#081014] border border-slate-200 group-hover:border-[#105971]/30 transition-colors">#SB-9421</span>
							</td>
							<td class="px-10 py-7">
								<div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center font-bold text-xs">RM</div>
                                    <div>
									    <p class="text-sm font-black text-slate-900">Roberto Mendez</p>
									    <p class="text-[10px] text-slate-400 font-bold tracking-tight">roberto.m@gmail.com</p>
                                    </div>
								</div>
							</td>
							<td class="px-10 py-7">
								<span class="inline-flex items-center gap-2 px-4 py-1.5 bg-emerald-50 text-emerald-600 rounded-full text-[10px] font-black border border-emerald-100">
									<span class="w-1.5 h-1.5 rounded-full bg-emerald-600"></span>
									Guía Generada
								</span>
							</td>
							<td class="px-10 py-7 text-right font-black text-slate-900 text-lg">$2,450.00</td>
						</tr>
						<tr class="hover:bg-slate-50/50 transition-colors group">
							<td class="px-10 py-7">
								<span class="px-4 py-2 bg-slate-100 rounded-xl text-xs font-black text-[#081014] border border-slate-200 group-hover:border-[#105971]/30 transition-colors">#SB-9420</span>
							</td>
							<td class="px-10 py-7">
								<div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center font-bold text-xs">SG</div>
                                    <div>
									    <p class="text-sm font-black text-slate-900">Sonia Gutierrez</p>
									    <p class="text-[10px] text-slate-400 font-bold tracking-tight">soniaG@outlook.com</p>
                                    </div>
								</div>
							</td>
							<td class="px-10 py-7">
								<span class="inline-flex items-center gap-2 px-4 py-1.5 bg-amber-50 text-amber-600 rounded-full text-[10px] font-black border border-amber-100">
									<span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span>
									Pendiente SAT
								</span>
							</td>
							<td class="px-10 py-7 text-right font-black text-slate-900 text-lg">$840.00</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>

		<!-- Right: Quick Stats/Integrations Status -->
		<div class="space-y-6">
			<div class="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)]">
				<h4 class="text-xl font-black text-slate-900 mb-8 flex items-center gap-2">
                    <Icon name="lucide:cpu" class="w-5 h-5 text-[#105971]" />
                    Salud del Motor
                </h4>
				<div class="space-y-8">
					<div class="space-y-3 font-bold text-sm">
						<div class="flex justify-between items-end">
							<span class="text-slate-500">Shopify API</span>
							<span class="text-emerald-600 font-black">99.9% Online</span>
						</div>
						<div class="h-2 bg-slate-50 rounded-full overflow-hidden border border-slate-100">
							<div class="h-full bg-emerald-500 w-[99.9%] rounded-full shadow-[0_0_10px_rgba(16,185,129,0.3)]"></div>
						</div>
					</div>
					<div class="space-y-3 font-bold text-sm">
						<div class="flex justify-between items-end">
							<span class="text-slate-500">Facturapi Node</span>
							<span class="text-[#70D1C6] font-black">Latencia: 42ms</span>
						</div>
						<div class="h-2 bg-slate-50 rounded-full overflow-hidden border border-slate-100">
							<div class="h-full bg-[#70D1C6] w-[85%] rounded-full shadow-[0_0_10px_rgba(112,209,198,0.3)]"></div>
						</div>
					</div>
				</div>
                <div class="mt-10 p-5 bg-[#081014] rounded-2xl border border-white/5">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                            <Icon name="lucide:shield-check" class="w-6 h-6 text-[#70D1C6]" />
                        </div>
                        <div>
                            <p class="text-[10px] font-black text-white leading-tight uppercase tracking-widest">Seguridad ACTIVA</p>
                            <p class="text-[10px] text-slate-500 font-bold mt-0.5">AES-256 bits Encryption</p>
                        </div>
                    </div>
                </div>
			</div>

            <!-- Promotion/CTA -->
            <div class="bg-gradient-to-br from-[#105971] to-[#081014] p-10 rounded-[3rem] text-white relative overflow-hidden group shadow-2xl">
                <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-bl-full translate-x-10 -translate-y-10 group-hover:translate-x-5 group-hover:-translate-y-5 transition-transform duration-700"></div>
                <h4 class="text-xl font-black mb-4 relative z-10 leading-tight">¿Necesitas automatizar marketing?</h4>
                <p class="text-slate-300 text-sm font-medium mb-8 relative z-10 leading-relaxed">Configura flujos de abandono de carrito con un par de clics.</p>
                <button class="w-full py-4 bg-[#70D1C6] text-[#081014] rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-white transition-all relative z-10">Explorar Módulos</button>
            </div>
		</div>
	</div>
</AppLayout>
