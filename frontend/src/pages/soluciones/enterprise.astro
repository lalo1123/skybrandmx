---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Soluciones Enterprise — SkyBrandMX">
    <main>
        <!-- HERO ENTERPRISE -->
        <section class="relative pt-40 pb-20 overflow-hidden bg-[#081014]">
            <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
            <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-slate-300 text-xs font-black mb-8">
                    Corporativos & Enterprise
                </div>
                <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter mb-8 leading-none">
                    Infraestructura B2B <br/><span class="bg-gradient-to-r from-white to-slate-500 bg-clip-text text-transparent">sin límites.</span>
                </h1>
                <p class="text-xl text-slate-400 max-w-2xl mx-auto font-bold mb-12">
                    Soluciones a la medida para operaciones de alto desempeño. Sincroniza desde tu ERP hasta tu fuerza de ventas en campo con latencia cero.
                </p>
                
                <div class="flex justify-center gap-4 mb-20">
                    <a href="#planes-enterprise" class="px-8 py-4 border border-white/20 text-white rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-white/10 transition-all">Desarrollo a la Medida</a>
                </div>
            </div>
        </section>

        <!-- COMO FUNCIONA PARA ENTERPRISE -->
        <section class="py-24 bg-white">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-20">
                    <h2 class="text-4xl md:text-5xl font-black text-[#105971] tracking-tighter mb-4">
                        Arquitectura que soporta tu crecimiento
                    </h2>
                    <p class="text-slate-500 font-bold max-w-2xl mx-auto text-lg">
                        Garantizamos un uptime del 99.9% para tus operaciones críticas.
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-8">
                    <!-- Feature 1 -->
                    <div class="p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 transition-all">
                        <div class="w-14 h-14 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl mb-8">🔒</div>
                        <h3 class="text-2xl font-black text-[#105971] mb-4">Seguridad Bancaria</h3>
                        <p class="text-slate-600 font-bold leading-relaxed text-sm">Cifrado de extremo a extremo, servidores dedicados y cumplimiento con normativas mexicanas de protección de datos.</p>
                    </div>

                    <!-- Feature 2 -->
                    <div class="p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 transition-all">
                        <div class="w-14 h-14 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl mb-8">🔗</div>
                        <h3 class="text-2xl font-black text-[#105971] mb-4">Integración ERP</h3>
                        <p class="text-slate-600 font-bold leading-relaxed text-sm">Conectamos SkyBrandMX directamente con SAP, Oracle, Intelisis o tu desarrollo in-house a través de protocolos seguros.</p>
                    </div>

                    <!-- Feature 3 -->
                    <div class="p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 transition-all">
                        <div class="w-14 h-14 rounded-2xl bg-slate-200 flex items-center justify-center text-3xl mb-8">👨‍💻</div>
                        <h3 class="text-2xl font-black text-[#105971] mb-4">Soporte Dedicado</h3>
                        <p class="text-slate-600 font-bold leading-relaxed text-sm">Acceso 24/7 a un equipo de ingenieros locales para monitorear, auditar y resolver cuellos de botella al instante.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PRICING DEDICADO A ENTERPRISE -->
        <section id="planes-enterprise" class="py-24 bg-[#081014] border-t border-white/5">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-16">
                    <h2 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 text-white">
                        Soluciones a la Medida
                    </h2>
                    <p class="text-slate-400 font-bold text-lg">Desarrollo personalizado según la escala de tus requerimientos.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center max-w-6xl mx-auto">
                    <!-- Plan Core -->
                    <div class="p-10 bg-[#0a151b] border border-white/10 rounded-[2.5rem] flex flex-col h-full">
                        <div class="mb-8">
                            <h5 class="text-xl font-black text-white mb-2">Custom Core</h5>
                            <p class="text-sm text-slate-400 font-bold leading-relaxed mb-6">Instalación en servidor privado.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-4xl font-black text-white">Contactar</span>
                            </div>
                        </div>
                        <ul class="space-y-4 mb-10 flex-1">
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Hardware Dedicado
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> VPN Site-to-Site
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Bases de Datos Aisladas
                            </li>
                        </ul>
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="w-full text-center px-6 py-4 border border-white/20 text-white rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-white/10 transition-all">Hablar con un Experto</a>
                    </div>
                    
                    <!-- Plan Transformación -->
                    <div class="p-10 bg-[#0a151b] border border-[#70D1C6]/30 rounded-[2.5rem] flex flex-col relative scale-[1.02] z-10 shadow-[0_0_50px_rgba(112,209,198,0.1)] h-full">
                        <div class="absolute top-0 right-0 bg-[#70D1C6] text-[#081014] text-[10px] font-black px-4 py-2 rounded-bl-2xl uppercase tracking-widest">Recomendado</div>
                        <div class="mb-8">
                            <h5 class="text-xl font-black text-white mb-2">Transformación</h5>
                            <p class="text-sm text-slate-400 font-bold leading-relaxed mb-6">Desarrollo Multi-Módulo.</p>
                            <div class="flex items-baseline gap-2">
                                <span class="text-5xl font-black text-white">A medida</span>
                            </div>
                        </div>
                        <ul class="space-y-4 mb-10 flex-1">
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Implementación ERP/SAP
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Capacitación On-Site
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Soluciones de IA Custom
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> SLAs por Contrato
                            </li>
                        </ul>
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="w-full text-center px-6 py-4 bg-[#70D1C6] text-[#081014] rounded-2xl text-sm font-black uppercase tracking-widest hover:bg-[#5cbdab] transition-all shadow-[0_0_20px_rgba(112,209,198,0.3)]">Iniciar Transformación</a>
                    </div>
                    
                    <!-- Plan API Infra -->
                    <div class="p-10 bg-[#0a151b] border border-white/10 rounded-[2.5rem] flex flex-col h-full">
                        <div class="mb-8">
                            <h5 class="text-xl font-black text-white mb-2">API Infra</h5>
                            <p class="text-sm text-slate-400 font-bold leading-relaxed mb-6">Módulos "Headless" Integrados.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-4xl font-black text-white">Desde $8k</span>
                                <span class="text-slate-500 font-bold">/mes</span>
                            </div>
                        </div>
                        <ul class="space-y-4 mb-10 flex-1">
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Rate limits de alto volumen
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> GraphQL & REST
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-300">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Canal Slack 24/7
                            </li>
                        </ul>
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="w-full text-center px-6 py-4 border border-white/20 text-white rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-white/10 transition-all">Activar Infraestructura</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
