---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Soluciones para Medianas Empresas — SkyBrandMX">
    <main>
        <!-- HERO MEDIANAS -->
        <section class="relative pt-40 pb-20 overflow-hidden bg-[#081014]">
            <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
            <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#70D1C6]/10 border border-[#70D1C6]/20 text-[#70D1C6] text-xs font-black mb-8">
                    Medianas Empresas
                </div>
                <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter mb-8 leading-none">
                    Rompe el techo <br/><span class="text-[#FF6B00]">de crecimiento.</span>
                </h1>
                <p class="text-xl text-slate-400 max-w-2xl mx-auto font-bold mb-12">
                    Sincroniza tus almacenes, automatiza tu fuerza de ventas y delega la facturación masiva. Diseñado para altos volúmenes de operación.
                </p>
                
                <div class="flex justify-center gap-4 mb-20">
                    <a href="#planes-medianas" class="px-8 py-4 bg-[#FF6B00] text-white rounded-2xl text-xs font-black uppercase tracking-widest hover:-translate-y-1 transition-all shadow-[0_0_20px_rgba(255,107,0,0.3)]">Ver Planes Corporate</a>
                </div>
            </div>
        </section>

        <!-- COMO FUNCIONA PARA MEDIANAS -->
        <section class="py-24 bg-white">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-20">
                    <h2 class="text-4xl md:text-5xl font-black text-[#105971] tracking-tighter mb-4">
                        Operaciones sincronizadas al 100%
                    </h2>
                    <p class="text-slate-500 font-bold max-w-2xl mx-auto text-lg">
                        Destruye los silos de información entre tus departamentos.
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-8">
                    <!-- Feature 1 -->
                    <div class="p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 hover:border-[#FF6B00]/30 transition-all">
                        <div class="w-14 h-14 rounded-2xl bg-[#FF6B00]/5 flex items-center justify-center text-3xl mb-8">📈</div>
                        <h3 class="text-2xl font-black text-[#105971] mb-4">Multicanal Real</h3>
                        <p class="text-slate-600 font-bold leading-relaxed text-sm">Vende en Shopify, Mercado Libre y Amazon con el inventario sincronizado en un solo lugar en tiempo real.</p>
                    </div>

                    <!-- Feature 2 -->
                    <div class="p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 hover:border-[#FF6B00]/30 transition-all">
                        <div class="w-14 h-14 rounded-2xl bg-[#FF6B00]/5 flex items-center justify-center text-3xl mb-8">👥</div>
                        <h3 class="text-2xl font-black text-[#105971] mb-4">CRM Colaborativo</h3>
                        <p class="text-slate-600 font-bold leading-relaxed text-sm">Pipelines avanzados con métricas de rendimiento por vendedor. Automatización de seguimientos vía WhatsApp.</p>
                    </div>

                    <!-- Feature 3 -->
                    <div class="p-8 bg-[#F8FAFC] rounded-[2.5rem] border border-slate-100 hover:border-[#FF6B00]/30 transition-all">
                        <div class="w-14 h-14 rounded-2xl bg-[#FF6B00]/5 flex items-center justify-center text-3xl mb-8">⚡</div>
                        <h3 class="text-2xl font-black text-[#105971] mb-4">Escalabilidad API</h3>
                        <p class="text-slate-600 font-bold leading-relaxed text-sm">Conecta tu infraestructura actual a nuestro motor. Webhooks y APIs listas para integraciones complejas.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PRICING DEDICADO A MEDIANAS -->
        <section id="planes-medianas" class="py-24 bg-[#F8FAFC] border-t border-slate-100">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center mb-16">
                    <h2 class="text-4xl md:text-5xl font-black tracking-tighter mb-4 text-[#105971]">
                        Poder para equipos en expansión
                    </h2>
                    <p class="text-slate-600 font-bold text-lg">Plataforma robusta para altos volúmenes de ventas y envíos.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center max-w-6xl mx-auto">
                    <!-- Plan Impulso -->
                    <div class="p-10 bg-white border border-slate-100 rounded-[2.5rem] shadow-sm flex flex-col hover:shadow-xl transition-all h-full">
                        <div class="mb-8">
                            <h5 class="text-xl font-black text-[#105971] mb-2">Plan Impulso</h5>
                            <p class="text-sm text-slate-500 font-bold leading-relaxed mb-6">Equipos de hasta 15 personas.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-4xl font-black text-[#105971]">$5,500</span>
                                <span class="text-slate-500 font-bold">MXN/mes</span>
                            </div>
                        </div>
                        <ul class="space-y-4 mb-10 flex-1">
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-600">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Hasta 15 Usuarios CRM
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-600">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Multi-almacén (2 ubicaciones)
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-600">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Reportes Avanzados
                            </li>
                        </ul>
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="w-full text-center px-6 py-4 border-2 border-[#105971] text-[#105971] rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-[#105971] hover:text-white transition-all">Solicitar Información</a>
                    </div>
                    
                    <!-- Plan Escalabilidad -->
                    <div class="p-10 bg-white border-2 border-[#FF6B00] rounded-[2.5rem] shadow-[0_25px_60px_-15px_rgba(255,107,0,0.15)] flex flex-col relative scale-[1.02] z-10 hover:scale-105 transition-all h-full">
                        <div class="absolute top-0 right-0 bg-[#FF6B00] text-white text-[10px] font-black px-4 py-2 rounded-bl-2xl uppercase tracking-widest">Favorito de Agencias</div>
                        <div class="mb-8">
                            <h5 class="text-xl font-black text-[#105971] mb-2">Escalabilidad</h5>
                            <p class="text-sm text-slate-500 font-bold leading-relaxed mb-6">Operación masiva sin contratiempos.</p>
                            <div class="flex items-baseline gap-2">
                                <span class="text-5xl font-black text-[#105971]">$9,500</span>
                                <span class="text-slate-500 font-bold">MXN/mes</span>
                            </div>
                        </div>
                        <ul class="space-y-4 mb-10 flex-1">
                            <li class="flex items-center gap-3 text-sm font-black text-[#105971]">
                                <span class="text-[#FF6B00] text-lg font-black italic">✔️</span> Usuarios Ilimitados
                            </li>
                            <li class="flex items-center gap-3 text-sm font-black text-[#105971]">
                                <span class="text-[#FF6B00] text-lg font-black italic">✔️</span> 1,000 Guías incluidas
                            </li>
                            <li class="flex items-center gap-3 text-sm font-black text-[#105971]">
                                <span class="text-[#FF6B00] text-lg font-black italic">✔️</span> Marketplace Sync (Meli/Amazon)
                            </li>
                            <li class="flex items-center gap-3 text-sm font-black text-[#105971]">
                                <span class="text-[#FF6B00] text-lg font-black italic">✔️</span> Account Manager Dedicado
                            </li>
                        </ul>
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="w-full text-center px-6 py-4 bg-[#FF6B00] text-white rounded-2xl text-sm font-black uppercase tracking-widest hover:bg-[#E66000] transition-all shadow-xl shadow-orange-200">Impulsar Ahora</a>
                    </div>
                    
                    <!-- Plan Connect -->
                    <div class="p-10 bg-white border border-slate-100 rounded-[2.5rem] shadow-sm flex flex-col hover:shadow-xl transition-all h-full">
                        <div class="mb-8">
                            <h5 class="text-xl font-black text-[#105971] mb-2">Connect</h5>
                            <p class="text-sm text-slate-500 font-bold leading-relaxed mb-6">Integra nuestras APIs a tu ERP.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-4xl font-black text-[#105971]">$3,500</span>
                                <span class="text-slate-500 font-bold">MXN/mes</span>
                            </div>
                        </div>
                        <ul class="space-y-4 mb-10 flex-1">
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-600">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> APIs y Webhooks Premium
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-600">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Módulo de Logística Externo
                            </li>
                            <li class="flex items-center gap-3 text-sm font-bold text-slate-600">
                                <span class="text-[#70D1C6] text-lg font-black italic">✔️</span> Soporte Técnico Avanzado
                            </li>
                        </ul>
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="w-full text-center px-6 py-4 border-2 border-[#105971] text-[#105971] rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-[#105971] hover:text-white transition-all">Activar Conexión</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
