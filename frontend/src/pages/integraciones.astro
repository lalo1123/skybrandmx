---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Integraciones y Ecosistema — SkyBrandMX">
    <main>
        <!-- HERO INTEGRATIONS -->
        <section class="relative pt-40 pb-20 overflow-hidden bg-[#081014]">
            <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
            <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
                <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter mb-8 leading-none">
                    Un solo panel, <br/><span class="text-[#70D1C6]">todo tu ecosistema.</span>
                </h1>
                <p class="text-xl text-slate-400 max-w-2xl mx-auto font-bold mb-12">
                    Conexiones nativas y seguras con las herramientas que ya impulsan tu negocio. Sin configuraciones complejas.
                </p>
                
                <div class="flex justify-center flex-wrap gap-4 mb-20">
                    <span class="px-5 py-2 bg-white/5 border border-white/10 rounded-full text-xs font-black text-white uppercase tracking-widest">E-commerce</span>
                    <span class="px-5 py-2 bg-white/5 border border-white/10 rounded-full text-xs font-black text-white uppercase tracking-widest">Paquetería</span>
                    <span class="px-5 py-2 bg-white/5 border border-white/10 rounded-full text-xs font-black text-white uppercase tracking-widest">Pagos</span>
                    <span class="px-5 py-2 bg-white/5 border border-white/10 rounded-full text-xs font-black text-white uppercase tracking-widest">Marketing</span>
                </div>
            </div>
        </section>

        <!-- INTEGRATIONS GRID -->
        <section class="py-24 bg-white">
            <div class="max-w-7xl mx-auto px-6">
                <!-- E-commerce category -->
                <div class="mb-24">
                    <div class="flex items-center gap-4 mb-10">
                        <h2 class="text-2xl font-black text-[#105971] tracking-tight">Ventas y E-commerce</h2>
                        <div class="h-px flex-1 bg-slate-100"></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        <!-- Shopify -->
                        <div class="group p-8 bg-[#F8FAFC] border border-slate-100 rounded-[2.5rem] hover:bg-white hover:shadow-2xl transition-all duration-500">
                            <div class="flex justify-between items-start mb-8">
                                <div class="w-16 h-16 rounded-2xl bg-white border border-slate-100 flex items-center justify-center text-3xl shadow-sm group-hover:scale-110 transition-transform">
                                    <Icon name="simple-icons:shopify" class="text-[#95BF47] w-10 h-10" />
                                </div>
                                <span class="bg-emerald-100 text-emerald-700 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest border border-emerald-200">Activo</span>
                            </div>
                            <h3 class="text-xl font-black text-[#105971] mb-2">Shopify</h3>
                            <p class="text-slate-500 font-bold text-sm leading-relaxed">Sincroniza pedidos, inventario y clientes en tiempo real.</p>
                        </div>
                        <!-- Mercado Libre -->
                        <div class="group p-8 bg-[#F8FAFC] border border-slate-100 rounded-[2.5rem] hover:bg-white hover:shadow-2xl transition-all duration-500">
                            <div class="flex justify-between items-start mb-8">
                                <div class="w-16 h-16 rounded-2xl bg-white border border-slate-100 flex items-center justify-center text-3xl shadow-sm group-hover:scale-110 transition-transform text-[#FFE600] font-black">M</div>
                                <span class="bg-emerald-100 text-emerald-700 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest border border-emerald-200">Activo</span>
                            </div>
                            <h3 class="text-xl font-black text-[#105971] mb-2">Mercado Libre</h3>
                            <p class="text-slate-500 font-bold text-sm leading-relaxed">Gestión de publicaciones y mensajería centralizada.</p>
                        </div>
                        <!-- Amazon -->
                        <div class="group p-8 bg-[#F8FAFC] border border-slate-100 rounded-[2.5rem] hover:bg-white hover:shadow-2xl transition-all duration-500">
                            <div class="flex justify-between items-start mb-8">
                                <div class="w-16 h-16 rounded-2xl bg-white border border-slate-100 flex items-center justify-center text-3xl shadow-sm group-hover:scale-110 transition-transform">
                                     <Icon name="simple-icons:amazon" class="text-black w-10 h-10" />
                                </div>
                                <span class="bg-blue-100 text-blue-700 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest border border-blue-200">Próximamente</span>
                            </div>
                            <h3 class="text-xl font-black text-[#105971] mb-2">Amazon</h3>
                            <p class="text-slate-500 font-bold text-sm leading-relaxed">Automatización de FBA y reportes de rentabilidad.</p>
                        </div>
                    </div>
                </div>

                <!-- Shipping category -->
                <div class="mb-24">
                    <div class="flex items-center gap-4 mb-10">
                        <h2 class="text-2xl font-black text-[#105971] tracking-tight">Logística y Envíos</h2>
                        <div class="h-px flex-1 bg-slate-100"></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- Skydropx -->
                        <div class="group p-8 bg-[#F8FAFC] border border-slate-100 rounded-[2.5rem] hover:bg-white hover:shadow-2xl transition-all duration-500">
                            <div class="w-12 h-12 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-xl shadow-sm mb-6 group-hover:bg-[#105971] group-hover:text-white transition-colors duration-500">📦</div>
                            <h4 class="text-lg font-black text-[#105971] mb-1">SkydropX</h4>
                            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest italic">Multi-paquetería</p>
                        </div>
                        <!-- FedEx -->
                        <div class="group p-8 bg-[#F8FAFC] border border-slate-100 rounded-[2.5rem] hover:bg-white hover:shadow-2xl transition-all duration-500">
                            <div class="w-12 h-12 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-xl shadow-sm mb-6 group-hover:bg-[#4D148C] transition-colors duration-500">
                                <Icon name="simple-icons:fedex" class="w-8 h-8 group-hover:text-white" />
                            </div>
                            <h4 class="text-lg font-black text-[#105971] mb-1">FedEx</h4>
                            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest italic">Nativo</p>
                        </div>
                        <!-- DHL -->
                        <div class="group p-8 bg-[#F8FAFC] border border-slate-100 rounded-[2.5rem] hover:bg-white hover:shadow-2xl transition-all duration-500">
                            <div class="w-12 h-12 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-xl shadow-sm mb-6 group-hover:bg-[#D40511] transition-colors duration-500">
                                <Icon name="simple-icons:dhl" class="w-8 h-8 group-hover:text-white" />
                            </div>
                            <h4 class="text-lg font-black text-[#105971] mb-1">DHL</h4>
                            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest italic">Global Express</p>
                        </div>
                         <!-- Envia.com -->
                        <div class="group p-8 bg-[#F8FAFC] border border-slate-100 rounded-[2.5rem] hover:bg-white hover:shadow-2xl transition-all duration-500">
                            <div class="w-12 h-12 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-xl shadow-sm mb-6 group-hover:bg-[#FF6B00] group-hover:text-white transition-colors duration-500">⚡</div>
                            <h4 class="text-lg font-black text-[#105971] mb-1">Envia.com</h4>
                            <p class="text-slate-400 text-xs font-bold uppercase tracking-widest italic">Directo</p>
                        </div>
                    </div>
                </div>

                <!-- Marketing & Social category -->
                <div class="mb-24">
                    <div class="flex items-center gap-4 mb-10">
                        <h2 class="text-2xl font-black text-[#105971] tracking-tight">Marketing y Omnicanalidad</h2>
                        <div class="h-px flex-1 bg-slate-100"></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <!-- WhatsApp -->
                        <div class="group p-10 bg-white border border-slate-100 rounded-[3rem] hover:shadow-2xl transition-all duration-500 relative overflow-hidden">
                            <div class="absolute top-0 right-0 w-24 h-24 bg-emerald-500/5 rounded-bl-full translate-x-4 -translate-y-4 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
                            <div class="flex items-center gap-5 mb-8">
                                <div class="w-14 h-14 rounded-2xl bg-[#25D366]/10 flex items-center justify-center shadow-sm">
                                    <Icon name="simple-icons:whatsapp" class="text-[#25D366] w-9 h-9" />
                                </div>
                                <h4 class="text-xl font-black text-[#105971]">WhatsApp Business</h4>
                            </div>
                            <p class="text-slate-500 font-bold text-sm leading-relaxed">Centraliza tus chats, envía catálogos y automatiza respuestas de venta.</p>
                        </div>
                        <!-- Facebook & Instagram -->
                        <div class="group p-10 bg-white border border-slate-100 rounded-[3rem] hover:shadow-2xl transition-all duration-500 relative overflow-hidden">
                            <div class="flex items-center gap-5 mb-8">
                                <div class="flex -space-x-4">
                                    <div class="w-14 h-14 rounded-2xl bg-[#1877F2]/10 border-2 border-white flex items-center justify-center shadow-sm relative z-10">
                                        <Icon name="simple-icons:facebook" class="text-[#1877F2] w-8 h-8" />
                                    </div>
                                    <div class="w-14 h-14 rounded-2xl bg-gradient-to-tr from-[#F58529] via-[#D62976] to-[#962FBF] opacity-20 border-2 border-white flex items-center justify-center shadow-sm">
                                        <Icon name="simple-icons:instagram" class="text-white w-8 h-8" />
                                    </div>
                                </div>
                                <h4 class="text-xl font-black text-[#105971] ml-4">Meta Ads & Shop</h4>
                            </div>
                            <p class="text-slate-500 font-bold text-sm leading-relaxed">Sincroniza tu catálogo con Instagram Shopping y trackea ROI de campañas.</p>
                        </div>
                        <!-- Email Marketing -->
                        <div class="group p-10 bg-white border border-slate-100 rounded-[3rem] hover:shadow-2xl transition-all duration-500">
                            <div class="flex items-center gap-5 mb-8">
                                <div class="w-14 h-14 rounded-xl bg-slate-900 flex items-center justify-center shadow-sm">
                                    <Icon name="lucide:mail" class="text-white w-8 h-8" />
                                </div>
                                <h4 class="text-xl font-black text-[#105971]">Email Automation</h4>
                            </div>
                            <p class="text-slate-500 font-bold text-sm leading-relaxed">Flujos de recuperación de carrito y newsletters personalizados.</p>
                        </div>
                        <!-- Google Ads -->
                        <div class="group p-10 bg-white border border-slate-100 rounded-[3rem] hover:shadow-2xl transition-all duration-500 relative overflow-hidden">
                            <div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/5 rounded-bl-full translate-x-4 -translate-y-4 group-hover:translate-x-0 group-hover:translate-y-0 transition-transform"></div>
                            <div class="flex items-center gap-5 mb-8">
                                <div class="w-14 h-14 rounded-2xl bg-[#4285F4]/10 flex items-center justify-center shadow-sm">
                                    <Icon name="simple-icons:googleads" class="text-[#4285F4] w-9 h-9" />
                                </div>
                                <h4 class="text-xl font-black text-[#105971]">Google Ads</h4>
                            </div>
                            <p class="text-slate-500 font-bold text-sm leading-relaxed">Sincroniza tus conversiones y crea audiencias automáticas desde tus clientes.</p>
                        </div>
                        <!-- Automated Ads AI -->
                        <div class="group p-10 bg-gradient-to-br from-[#105971] to-[#081014] rounded-[3rem] hover:shadow-2xl transition-all duration-500 relative overflow-hidden border border-[#70D1C6]/30">
                            <div class="absolute top-0 right-0 w-32 h-32 bg-[#70D1C6]/10 rounded-bl-full pointer-events-none"></div>
                            <div class="flex items-center gap-5 mb-8">
                                <div class="w-14 h-14 rounded-2xl bg-[#70D1C6]/10 flex items-center justify-center shadow-sm">
                                    <Icon name="lucide:sparkles" class="text-[#70D1C6] w-8 h-8" />
                                </div>
                                <h4 class="text-xl font-black text-white">Anuncios IA</h4>
                            </div>
                            <p class="text-slate-400 font-bold text-sm leading-relaxed mb-4">Generación automática de creativos y optimización de puja con Inteligencia Artificial.</p>
                            <span class="inline-block px-3 py-1 bg-[#70D1C6]/20 text-[#70D1C6] text-[10px] font-black rounded-full border border-[#70D1C6]/30 uppercase tracking-widest">Nativo SkyBrand</span>
                        </div>
                    </div>
                </div>

                 <!-- Payments & SAT -->
                <div class="mb-24">
                    <div class="flex items-center gap-4 mb-10">
                        <h2 class="text-2xl font-black text-[#105971] tracking-tight">Finanzas y Cumplimiento</h2>
                        <div class="h-px flex-1 bg-slate-100"></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        <!-- Facturapi -->
                        <div class="bg-gradient-to-br from-[#105971] to-[#081014] p-10 rounded-[3rem] text-white overflow-hidden relative group">
                            <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-bl-full pointer-events-none"></div>
                            <div class="flex items-center gap-4 mb-8">
                                <div class="bg-white/10 px-3 py-1.5 rounded-xl border border-white/10 font-black text-[10px] tracking-widest">CERTIFICADO SAT</div>
                                <span class="w-2 h-2 rounded-full bg-[#70D1C6] animate-pulse"></span>
                            </div>
                            <h3 class="text-2xl font-black mb-4">Facturación CFDI 4.0</h3>
                            <p class="text-slate-400 font-bold text-sm mb-8 leading-relaxed">Conexión nativa con Facturapi para timbrado inmediato desde tus pedidos de Shopify.</p>
                            <div class="text-[10px] font-black uppercase tracking-[0.2em] text-[#70D1C6]">Powered by Facturapi API</div>
                        </div>
                        <!-- Stripe -->
                        <div class="group p-10 bg-[#F1F5F9] border border-slate-200 rounded-[3rem] hover:shadow-xl transition-all">
                             <div class="flex items-center gap-5 mb-8">
                                <Icon name="simple-icons:stripe" class="text-[#635BFF] w-12 h-10" />
                                <h4 class="text-xl font-black text-[#105971]">Stripe Payments</h4>
                             </div>
                             <p class="text-slate-500 font-bold text-sm leading-relaxed mb-6">Conciliación automática de pagos internacionales directamente en tu flujo de caja.</p>
                             <div class="flex flex-wrap gap-2">
                                <span class="bg-white px-3 py-1 rounded-full text-[9px] font-black text-slate-400 border border-slate-200">SUSCRIPCIONES</span>
                                <span class="bg-white px-3 py-1 rounded-full text-[9px] font-black text-slate-400 border border-slate-200">VIRTUAL TERMINAL</span>
                             </div>
                        </div>
                        <!-- Mercado Pago -->
                        <div class="group p-10 bg-[#F1F5F9] border border-slate-200 rounded-[3rem] hover:shadow-xl transition-all">
                             <div class="flex items-center gap-5 mb-8">
                                <Icon name="simple-icons:mercadopago" class="text-[#009EE3] w-12 h-10" />
                                <h4 class="text-xl font-black text-[#105971]">Mercado Pago</h4>
                             </div>
                             <p class="text-slate-500 font-bold text-sm leading-relaxed mb-6">La solución líder en Latam integrada para liquidaciones inmediatas.</p>
                             <div class="flex flex-wrap gap-2">
                                <span class="bg-white px-3 py-1 rounded-full text-[9px] font-black text-slate-400 border border-slate-200">POINT</span>
                                <span class="bg-white px-3 py-1 rounded-full text-[9px] font-black text-slate-400 border border-slate-200">LINK DE PAGO</span>
                             </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA FINAL -->
        <section class="py-24 bg-[#081014] text-white relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 pointer-events-none">
                 <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:50px_50px]"></div>
            </div>
            <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
                <h2 class="text-4xl md:text-6xl font-black mb-8 leading-tight text-white drop-shadow-2xl">¿No ves tu herramienta favorita?</h2>
                <p class="text-xl text-slate-300 mb-12 font-bold max-w-2xl mx-auto">Nuestro equipo puede construir integraciones a la medida mediante Webhooks y API REST para potenciar tu SaaS.</p>
                <a href="https://web.whatsapp.com/send?phone=5525582310" class="px-10 py-5 bg-[#70D1C6] text-[#081014] rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-white hover:scale-105 transition-all inline-block shadow-[0_20px_40px_-10px_rgba(112,209,198,0.4)]">Hablar con expertos en API</a>
            </div>
        </section>
    </main>
</Layout>
