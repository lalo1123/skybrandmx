---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="Planes y Precios — SkyBrandMX">
    <main>
        <!-- HERO PRICING -->
        <section class="relative pt-40 pb-20 overflow-hidden bg-[#081014]">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(16,89,113,0.3),transparent_50%)] pointer-events-none"></div>
            <div class="max-w-7xl mx-auto px-6 text-center relative z-10">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#FF6B00]/10 border border-[#FF6B00]/20 text-[#FF6B00] text-xs font-black mb-8">
                    <span class="flex h-2 w-2 rounded-full bg-[#FF6B00] shadow-[0_0_8px_#FF6B00]"></span>
                    Precios Transparentes
                </div>
                <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter mb-8 leading-none">
                    Escala tu negocio <br/><span class="bg-clip-text text-transparent bg-gradient-to-r from-[#105971] to-[#70D1C6]">a tu propio ritmo.</span>
                </h1>
                <p class="text-xl text-slate-400 max-w-2xl mx-auto font-bold mb-12">
                    Sin costos ocultos. Sin contratos forzosos. Elige el motor que mejor se adapte a tu operativa actual.
                </p>

                <!-- Toggle Mensual/Anual Funcional -->
                <div class="flex items-center justify-center gap-6 mb-16">
                    <span id="label-monthly" class="text-sm font-black text-white transition-colors duration-300">Mensual</span>
                    <button id="price-toggle" class="w-16 h-8 bg-white/10 border border-white/20 rounded-full p-1 relative transition-all duration-300 hover:bg-white/20" aria-label="Cambiar entre pago mensual y anual">
                        <div id="toggle-knob" class="w-6 h-6 bg-[#70D1C6] rounded-full shadow-[0_0_15px_rgba(112,209,198,0.5)] transition-transform duration-300"></div>
                    </button>
                    <div class="flex items-center gap-3">
                        <span id="label-annual" class="text-sm font-black text-slate-500 transition-colors duration-300">Anual</span>
                        <span class="bg-[#70D1C6]/10 text-[#70D1C6] text-[10px] px-3 py-1 rounded-full border border-[#70D1C6]/20 font-black tracking-widest uppercase">Ahorra 20%</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- PRICING GRIDS -->
        <section class="py-24 bg-[#F8FAFC]">
            <div class="max-w-7xl mx-auto px-6">
                <div class="grid lg:grid-cols-4 gap-6 items-stretch">
                    <!-- Plan Start -->
                    <div class="pricing-card p-8 bg-white border border-slate-100 rounded-[2.5rem] shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col group relative overflow-hidden">
                        <div class="mb-8">
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 block">Ideal para: Emprendedores</span>
                            <h3 class="text-xl font-black text-[#105971] mb-2 uppercase tracking-tight">Plan Start</h3>
                            <p class="text-slate-500 font-bold text-xs mb-6 leading-relaxed">Inicia tu digitalización con las herramientas esenciales.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-slate-400 font-bold text-lg">$</span>
                                <span id="price-start" class="text-4xl font-black text-[#105971] tracking-tighter" data-monthly="2,500" data-annual="24,000">2,500</span>
                                <span class="price-period text-slate-400 font-bold text-xs leading-none ml-1">MXN/mes</span>
                            </div>
                        </div>
                        <ul class="space-y-3 mb-8 flex-1">
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:check" class="w-4 h-4 text-[#70D1C6]" />
                                CRM: 500 Contactos
                            </li>
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:check" class="w-4 h-4 text-[#70D1C6]" />
                                SAT: 50 Folios
                            </li>
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:check" class="w-4 h-4 text-[#70D1C6]" />
                                1 Conector E-commerce
                            </li>
                        </ul>
                        <button class="w-full py-3 bg-slate-50 text-[#105971] border border-slate-200 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-[#105971] hover:text-white transition-all">Empezar</button>
                    </div>

                    <!-- Plan Pro [NUEVO] -->
                    <div class="pricing-card p-8 bg-white border border-[#105971]/20 rounded-[2.5rem] shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col group relative overflow-hidden ring-1 ring-inset ring-[#105971]/10">
                        <div class="mb-8">
                            <span class="text-[10px] font-black text-[#70D1C6] uppercase tracking-widest mb-4 block">Ideal para: Pequeños Equipos</span>
                            <h3 class="text-xl font-black text-[#105971] mb-2 uppercase tracking-tight">Plan Pro</h3>
                            <p class="text-slate-500 font-bold text-xs mb-6 leading-relaxed">Automatización avanzada para marcas en crecimiento constante.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-slate-400 font-bold text-lg">$</span>
                                <span id="price-pro" class="text-4xl font-black text-[#105971] tracking-tighter" data-monthly="3,900" data-annual="37,440">3,900</span>
                                <span class="price-period text-slate-400 font-bold text-xs leading-none ml-1">MXN/mes</span>
                            </div>
                        </div>
                        <ul class="space-y-3 mb-8 flex-1">
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:check" class="w-4 h-4 text-[#70D1C6]" />
                                CRM: 2,500 Contactos
                            </li>
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:check" class="w-4 h-4 text-[#70D1C6]" />
                                SAT: 200 Folios
                            </li>
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:check" class="w-4 h-4 text-[#70D1C6]" />
                                3 Conectores E-commerce
                            </li>
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:check" class="w-4 h-4 text-[#70D1C6]" />
                                Dashboards de Venta
                            </li>
                        </ul>
                        <button class="w-full py-3 bg-[#105971] text-white rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-[#084d6e] transition-all">Elegir Pro</button>
                    </div>

                    <!-- Plan Scale -->
                    <div class="pricing-card p-8 bg-white border-2 border-[#FF6B00] rounded-[2.5rem] shadow-xl shadow-orange-100 hover:-translate-y-2 transition-all duration-500 flex flex-col relative scale-[1.02] z-10 group">
                        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#FF6B00] text-white text-[9px] font-black px-6 py-2 rounded-full uppercase tracking-[0.2em] shadow-lg whitespace-nowrap">Ideal para: Empresas Logísticas</div>
                        <div class="mb-8">
                            <h3 class="text-xl font-black text-[#105971] mb-2 uppercase tracking-tight">Plan Scale</h3>
                            <p class="text-slate-500 font-bold text-xs mb-6 leading-relaxed">Poder operativo total para infraestructuras masivas.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-slate-400 font-bold text-lg">$</span>
                                <span id="price-scale" class="text-4xl font-black text-[#105971] tracking-tighter" data-monthly="5,800" data-annual="55,680">5,800</span>
                                <span class="price-period text-slate-400 font-bold text-xs leading-none ml-1">MXN/mes</span>
                            </div>
                        </div>
                        <ul class="space-y-3 mb-8 flex-1">
                            <li class="flex items-center gap-3 text-xs font-black text-[#105971]">
                                <Icon name="lucide:check-circle" class="w-4 h-4 text-[#FF6B00]" />
                                CRM Ilimitado + Predictivo
                            </li>
                            <li class="flex items-center gap-3 text-xs font-black text-[#105971]">
                                <Icon name="lucide:check-circle" class="w-4 h-4 text-[#FF6B00]" />
                                SAT Ilimitado (CFDI 4.0)
                            </li>
                            <li class="flex items-center gap-3 text-xs font-black text-[#105971]">
                                <Icon name="lucide:check-circle" class="w-4 h-4 text-[#FF6B00]" />
                                API de Envíos Masivos
                            </li>
                            <li class="flex items-center gap-3 text-xs font-black text-[#105971]">
                                <Icon name="lucide:check-circle" class="w-4 h-4 text-[#FF6B00]" />
                                Soporte VIP WhatsApp
                            </li>
                        </ul>
                        <button class="w-full py-4 bg-[#FF6B00] text-white rounded-xl font-black text-[10px] uppercase tracking-widest shadow-xl shadow-orange-200 hover:shadow-2xl hover:bg-[#E66000] transition-all">Elegir Scale</button>
                    </div>

                    <!-- Plan Enterprise -->
                    <div class="pricing-card p-8 bg-white border border-slate-100 rounded-[2.5rem] shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 flex flex-col group relative overflow-hidden">
                        <div class="mb-8">
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 block">Ideal para: Corporativos</span>
                            <h3 class="text-xl font-black text-[#105971] mb-2 uppercase tracking-tight">Enterprise</h3>
                            <p class="text-slate-500 font-bold text-xs mb-6 leading-relaxed">Soluciones a medida para alto volumen y seguridad extrema.</p>
                            <div class="flex items-baseline gap-1">
                                <span class="text-2xl font-black text-[#105971] tracking-tighter italic">Personalizado</span>
                            </div>
                        </div>
                        <ul class="space-y-3 mb-8 flex-1">
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:cpu" class="w-4 h-4 text-[#70D1C6]" />
                                Integraciones ERP/SAP
                            </li>
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:shield-alert" class="w-4 h-4 text-[#70D1C6]" />
                                SLA de 99.9% Garantizado
                            </li>
                            <li class="flex items-center gap-3 text-xs font-bold text-slate-600">
                                <Icon name="lucide:headset" class="w-4 h-4 text-[#70D1C6]" />
                                Manager de Cuenta Dedicado
                            </li>
                        </ul>
                        <button class="w-full py-3 bg-slate-900 text-white rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-[#105971] transition-all">Contactar</button>
                    </div>
                </div>

                <!-- TABLA COMPARATIVA DETALLADA -->
                <div class="mt-32">
                    <h2 class="text-3xl font-black text-[#105971] text-center mb-16 tracking-tight">Comparativa de Poder Operativo</h2>
                    <div class="bg-white rounded-[3rem] border border-slate-100 shadow-xl overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead>
                                    <tr class="bg-[#F1F5F9]/50">
                                        <th class="p-8 text-sm font-black text-[#105971] border-b border-slate-100 bg-white sticky left-0 z-10 w-1/4">Funcionalidad</th>
                                        <th class="p-8 text-center text-sm font-black text-[#105971] border-b border-slate-100">Start</th>
                                        <th class="p-8 text-center text-sm font-black text-[#105971] border-b border-slate-100 bg-[#70D1C6]/5">Pro</th>
                                        <th class="p-8 text-center text-sm font-black text-[#105971] border-b border-slate-100">Scale</th>
                                        <th class="p-8 text-center text-sm font-black text-[#105971] border-b border-slate-100">Enterprise</th>
                                    </tr>
                                </thead>
                                <tbody class="text-sm font-bold text-slate-500">
                                    <!-- CRM -->
                                    <tr class="bg-white group">
                                        <td class="p-8 border-b border-slate-100 sticky left-0 z-10 bg-white group-hover:bg-slate-50 transition-colors">CRM: Gestión de Clientes</td>
                                        <td class="p-8 text-center border-b border-slate-100 italic">Básico</td>
                                        <td class="p-8 text-center border-b border-slate-100 bg-[#70D1C6]/5 text-[#105971]">Avanzado</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-[#FF6B00]">Predictivo</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-slate-900">Custom Neural</td>
                                    </tr>
                                    <tr class="bg-[#F8FAFC]/30 group">
                                        <td class="p-8 border-b border-slate-100 sticky left-0 z-10 bg-[#F8FAFC]/30 group-hover:bg-slate-50 transition-colors">Automatización de Marketing</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-slate-300">—</td>
                                        <td class="p-8 text-center border-b border-slate-100 bg-[#70D1C6]/5 text-[#70D1C6]"><Icon name="lucide:check" class="w-5 h-5 mx-auto" /></td>
                                        <td class="p-8 text-center border-b border-slate-100 text-[#FF6B00]"><Icon name="lucide:check" class="w-5 h-5 mx-auto" /></td>
                                        <td class="p-8 text-center border-b border-slate-100 text-slate-900">Omnicanal Full</td>
                                    </tr>
                                    <!-- LOGISTICA -->
                                    <tr class="bg-white group">
                                        <td class="p-8 border-b border-slate-100 sticky left-0 z-10 bg-white group-hover:bg-slate-50 transition-colors">Generación de Guías</td>
                                        <td class="p-8 text-center border-b border-slate-100">Manual</td>
                                        <td class="p-8 text-center border-b border-slate-100 bg-[#70D1C6]/5">Lotes (Batch)</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-[#FF6B00]">Masiva / API</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-slate-900">Infra Directa</td>
                                    </tr>
                                    <tr class="bg-[#F8FAFC]/30 group">
                                        <td class="p-8 border-b border-slate-100 sticky left-0 z-10 bg-[#F8FAFC]/30 group-hover:bg-slate-50 transition-colors">Conectores Marketplace</td>
                                        <td class="p-8 text-center border-b border-slate-100">1</td>
                                        <td class="p-8 text-center border-b border-slate-100 bg-[#70D1C6]/5">3</td>
                                        <td class="p-8 text-center border-b border-slate-100">Ilimitados</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-slate-900">Nativos Custom</td>
                                    </tr>
                                    <!-- SAT -->
                                    <tr class="bg-white group">
                                        <td class="p-8 border-b border-slate-100 sticky left-0 z-10 bg-white group-hover:bg-slate-50 transition-colors">Facturación SAT 4.0</td>
                                        <td class="p-8 text-center border-b border-slate-100">50 folios</td>
                                        <td class="p-8 text-center border-b border-slate-100 bg-[#70D1C6]/5">200 folios</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-[#FF6B00]">Ilimitada</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-slate-900">Ilimitada</td>
                                    </tr>
                                    <!-- SOPORTE -->
                                    <tr class="bg-[#F8FAFC]/30 group">
                                        <td class="p-8 border-b border-slate-100 sticky left-0 z-10 bg-[#F8FAFC]/30 group-hover:bg-slate-50 transition-colors">Soporte Técnico</td>
                                        <td class="p-8 text-center border-b border-slate-100">Correo</td>
                                        <td class="p-8 text-center border-b border-slate-100 bg-[#70D1C6]/5">WhatsApp</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-[#FF6B00]">WhatsApp VIP</td>
                                        <td class="p-8 text-center border-b border-slate-100 text-slate-900">Account Manager</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- NOTA DE INTEGRACIÓN GRATUITA -->
                <div class="mt-20 p-10 bg-gradient-to-br from-[#105971] to-[#081014] rounded-[3rem] border border-[#70D1C6]/20 text-center relative overflow-hidden group">
                    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#70D1C6]/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                    <div class="relative z-10 flex flex-col md:flex-row items-center justify-center gap-8">
                        <div class="w-16 h-16 rounded-2xl bg-[#70D1C6]/10 flex items-center justify-center">
                            <Icon name="lucide:plug-zap" class="text-[#70D1C6] w-9 h-9" />
                        </div>
                        <div class="max-w-2xl text-left">
                            <h4 class="text-2xl font-black text-white mb-2 tracking-tight">¿No ves tu herramienta favorita?</h4>
                            <p class="text-slate-400 font-bold leading-relaxed">
                                Si necesitas conectar una plataforma de envíos, ERP o eCommerce que no está en nuestro catálogo, <span class="text-[#70D1C6]">la integramos sin ningún costo adicional</span> a tu plan contratado.
                            </p>
                        </div>
                        <a href="https://web.whatsapp.com/send?phone=5525582310" class="px-8 py-4 bg-white/5 border border-white/10 rounded-2xl text-white text-xs font-black uppercase tracking-widest hover:bg-white/10 transition-all shrink-0">Solicitar Integración</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ SECTION PREVIEW -->
        <section class="py-24 bg-white border-t border-slate-100">
            <div class="max-w-4xl mx-auto px-6 text-center">
                <h2 class="text-4xl font-black text-[#105971] mb-8 tracking-tight">¿Tienes dudas?</h2>
                <p class="text-slate-500 font-bold mb-12">Todas tus preguntas sobre facturación, envíos y contratos resueltas.</p>
                <a href="/#faq" class="inline-flex items-center gap-3 text-[#105971] font-black uppercase text-xs tracking-widest hover:gap-5 transition-all">
                    Ver todas las preguntas frecuentes
                    <span>→</span>
                </a>
            </div>
        </section>
    </main>
</Layout>

<style>
    .pricing-card {
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
</style>

<script>
    const priceToggle = document.getElementById('price-toggle');
    const toggleKnob = document.getElementById('toggle-knob');
    const labelMonthly = document.getElementById('label-monthly');
    const labelAnnual = document.getElementById('label-annual');
    
    const priceElements = {
        start: document.getElementById('price-start'),
        pro: document.getElementById('price-pro'),
        scale: document.getElementById('price-scale')
    };
    
    const periodLabels = document.querySelectorAll('.price-period');
    
    let isAnnual = false;

    priceToggle?.addEventListener('click', () => {
        isAnnual = !isAnnual;
        
        // Update Toggle UI
        if (isAnnual) {
            toggleKnob?.classList.add('translate-x-8');
            labelAnnual?.classList.add('text-white');
            labelAnnual?.classList.remove('text-slate-500');
            labelMonthly?.classList.add('text-slate-500');
            labelMonthly?.classList.remove('text-white');
        } else {
            toggleKnob?.classList.remove('translate-x-8');
            labelAnnual?.classList.remove('text-white');
            labelAnnual?.classList.add('text-slate-500');
            labelMonthly?.classList.remove('text-slate-500');
            labelMonthly?.classList.add('text-white');
        }
        
        // Update Prices
        Object.entries(priceElements).forEach(([id, el]) => {
            if (el) {
                const price = isAnnual ? el.getAttribute('data-annual') : el.getAttribute('data-monthly');
                el.innerText = price || '';
                
                // Animate change
                el.animate([
                    { transform: 'translateY(-10px)', opacity: 0 },
                    { transform: 'translateY(0)', opacity: 1 }
                ], { duration: 300, easing: 'ease-out' });
            }
        });
        
        // Update Period Labels
        periodLabels.forEach(label => {
            (label as HTMLElement).innerText = isAnnual ? 'MXN/año' : 'MXN/mes';
        });
    });
</script>
