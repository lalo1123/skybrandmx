  if(!name){alert('Ingresa un nombre');return;}
  const audId=document.getElementById('em-wiz-audience').value;
  const aud=demoAudiences.find(a=>a.id==audId);
  demoCampaigns.unshift({id:Date.now(),name,subject:subject||'Sin asunto',previewText:document.getElementById('em-wiz-preview').value,status:'draft',audience:aud?aud.name:'',audienceId:audId?parseInt(audId):null,sent:0,opened:0,clicked:0,bounced:0,spam:0,unsubs:0,date:'',templateId:document.getElementById('em-wiz-template').value||null});
  closeWizard();renderCampaigns();renderStats();showToast('Borrador guardado');
}
function wizSend(){
  const name=document.getElementById('em-wiz-name').value.trim();
  const subject=document.getElementById('em-wiz-subject').value.trim();
  if(!name||!subject){alert('Completa nombre y asunto');return;}
  const schedule=document.getElementById('em-wiz-schedule').value;
