// AI Subject generator (reused in wizard)
function wizGenerateAI(){
  const box=document.getElementById('em-wiz-ai-suggestions');
  box.style.display='block';box.innerHTML='<p style="color:var(--text-muted);font-size:12px;padding:4px;">Generando...</p>';
  setTimeout(()=>{
    const cn=document.getElementById('em-wiz-name').value.toLowerCase();
    let pool=aiSubjects.promotional;
    if(/bienven|welcome/.test(cn))pool=aiSubjects.welcome;
    else if(/carrito|abandon/.test(cn))pool=aiSubjects.abandoned;
    else if(/re-engagement|extrañ/.test(cn))pool=aiSubjects.reengagement;
    else if(/newsletter/.test(cn))pool=aiSubjects.newsletter;
    box.innerHTML=`<p style="font-size:11px;font-weight:700;color:#8b5cf6;margin-bottom:6px;">Sugerencias de IA:</p>`+pool.map(s=>`<button onclick="document.getElementById('em-wiz-subject').value='${s.replace(/'/g,"\\'")}';document.getElementById('em-wiz-ai-suggestions').style.display='none';showToast('Asunto aplicado')" style="display:block;width:100%;text-align:left;padding:8px 12px;border-radius:8px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-secondary);font-size:12px;cursor:pointer;margin-bottom:4px;transition:all 0.15s;" onmouseover="this.style.borderColor='#8b5cf6'" onmouseout="this.style.borderColor='var(--border)'">${s}</button>`).join('');
  },600);
}

// Spam score in wizard
function wizAnalyzeSpam(){
  const result=document.getElementById('em-wiz-spam-result');
  result.innerHTML='<p style="color:var(--text-muted);font-size:12px;">Analizando...</p>';
  setTimeout(()=>{
    const subject=document.getElementById('em-wiz-subject').value||'';
    let score=2;const warnings=[];const tips=[];
    if(/gratis|free|ganar|winner|prize/i.test(subject)){score+=3;warnings.push('Palabras como "gratis" o "ganar" activan filtros');}
    if(/!!!|¡¡¡|\$\$|URGENTE|IMPORTANTE/i.test(subject)){score+=2;warnings.push('Signos de exclamación o mayúsculas excesivas');}
    if(/100%|garantizado|sin riesgo/i.test(subject)){score+=2;warnings.push('Frases como "100% garantizado" son señales de spam');}
    if(subject.length>60){score+=1;warnings.push('Asunto muy largo (más de 60 caracteres)');}
    if(subject===subject.toUpperCase()&&subject.length>3){score+=3;warnings.push('Todo en mayúsculas');}
    if(!subject){score+=1;warnings.push('No hay asunto');}
    if(/\{\{nombre\}\}/i.test(subject)){score-=1;tips.push('Personalización con nombre del contacto');}
    if(subject.length>=20&&subject.length<=50)tips.push('Longitud de asunto ideal');
    score=Math.max(0,Math.min(10,score));
    let color,label;
    if(score<=3){color='#22c55e';label='Excelente';}else if(score<=5){color='#eab308';label='Aceptable';}else{color='#ef4444';label='Riesgo alto';}
    result.innerHTML=`<div style="display:flex;align-items:center;gap:12px;"><div style="width:40px;height:40px;border-radius:10px;background:${color}15;display:flex;align-items:center;justify-content:center;"><span style="font-size:16px;font-weight:900;color:${color};">${score}/10</span></div><div><p style="font-size:13px;font-weight:800;color:${color};">${label}</p><p style="font-size:10px;color:var(--text-muted);">0 = excelente, 10 = muy probable spam</p></div></div>${warnings.length?'<div style="margin-top:8px;">'+warnings.map(w=>`<p style="font-size:11px;color:var(--text-secondary);padding:2px 0;">⚠ ${w}</p>`).join('')+'</div>':''}${tips.length?'<div style="margin-top:4px;">'+tips.map(t=>`<p style="font-size:11px;color:#22c55e;padding:2px 0;">✓ ${t}</p>`).join('')+'</div>':''}`;
  },500);
}

