---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Email Marketing">
  <!-- ══════════ Smart Recommendations ══════════ -->
  <div id="em-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- ══════════ AI Campaign Generator (prominent) ══════════ -->
  <div id="em-ai-generator" class="stat-card animate-in" style="padding:0;margin-bottom:20px;overflow:hidden;background:linear-gradient(135deg,rgba(139,92,246,0.08),rgba(111,207,245,0.08));border:1px solid rgba(139,92,246,0.15);">
    <div style="display:flex;align-items:center;gap:16px;padding:20px;flex-wrap:wrap;">
      <div style="width:48px;height:48px;border-radius:14px;background:linear-gradient(135deg,#8b5cf6,#6fcff5);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg style="width:24px;height:24px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <div style="flex:1;min-width:200px;">
        <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);margin-bottom:2px;">Crear campaña con IA</h3>
        <p style="font-size:12px;color:var(--text-muted);">Dile a la IA qué quieres promocionar y ella arma todo: asunto, contenido, audiencia y horario.</p>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex:1;min-width:280px;">
        <input id="em-ai-prompt" type="text" placeholder="Ej: Quiero promocionar mi nueva colección de verano..." class="em-input" style="flex:1;border-color:rgba(139,92,246,0.3);"/>
        <button onclick="generateAICampaign()" class="em-btn-primary" style="background:linear-gradient(135deg,#8b5cf6,#6fcff5);padding:10px 20px;white-space:nowrap;display:flex;align-items:center;gap:6px;">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Generar
        </button>
      </div>
    </div>
    <div id="em-ai-gen-result" style="display:none;"></div>
  </div>

  <!-- Stats bar with tooltips + trends -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Campañas enviadas</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="em-stat-sent" style="font-size:28px;font-weight:900;color:var(--text-primary);">--</p><span id="em-trend-sent" class="em-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Tasa de apertura <span class="em-tip" data-tip="De cada 100 personas que recibieron tu email, ¿cuántas lo abrieron?">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="em-stat-open" style="font-size:28px;font-weight:900;color:#22c55e;">--</p><span id="em-trend-open" class="em-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Tasa de clics <span class="em-tip" data-tip="De cada 100 personas que recibieron tu email, ¿cuántas hicieron clic en algún link?">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="em-stat-clicks" style="font-size:28px;font-weight:900;color:var(--accent);">--</p><span id="em-trend-clicks" class="em-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Suscriptores</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="em-stat-subs" style="font-size:28px;font-weight:900;color:var(--text-primary);">--</p><span id="em-trend-subs" class="em-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Rebotes <span class="em-tip" data-tip="Emails que no pudieron entregarse porque el buzón no existe o está lleno">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="em-stat-bounces" style="font-size:28px;font-weight:900;color:#f97316;">--</p><span id="em-trend-bounces" class="em-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px;">Bajas <span class="em-tip" data-tip="Personas que pidieron no recibir más emails tuyos">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="em-stat-unsubs" style="font-size:28px;font-weight:900;color:#ef4444;">--</p><span id="em-trend-unsubs" class="em-trend"></span></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="em-tab-campaigns" class="em-tab active" onclick="switchEMTab('campaigns')">Campañas</button>
    <button id="em-tab-templates" class="em-tab" onclick="switchEMTab('templates')">Plantillas</button>
    <button id="em-tab-sequences" class="em-tab" onclick="switchEMTab('sequences')">Secuencias</button>
    <button id="em-tab-audiences" class="em-tab" onclick="switchEMTab('audiences')">Audiencias</button>
    <button id="em-tab-forms" class="em-tab" onclick="switchEMTab('forms')">Formularios</button>
    <button id="em-tab-analytics" class="em-tab" onclick="switchEMTab('analytics')">Analítica</button>
  </div>

  <!-- ══════════ Tab: Campaigns ══════════ -->
  <div id="em-panel-campaigns">
    <!-- Help banner -->
    <div id="em-help-campaigns" class="em-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aquí creas y envías emails a tus clientes. Crea una campaña, elige a quién enviarla y programa la fecha.</p>
      <button onclick="dismissHelp('campaigns')" class="em-help-close">&times;</button>
    </div>
    <!-- Empty state -->
    <div id="em-empty-campaigns" style="display:none;" class="em-empty-state">
      <svg style="width:56px;height:56px;color:var(--accent);opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">Aún no has enviado emails</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:360px;line-height:1.5;">¡Crea tu primera campaña y conecta con tus clientes! Es más fácil de lo que crees.</p>
      <button onclick="openCampaignWizard()" class="em-btn-primary" style="margin-top:16px;padding:12px 28px;">Crear mi primera campaña</button>
    </div>
    <!-- Toolbar (simplified) -->
    <div id="em-toolbar-campaigns" class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="em-search" type="text" placeholder="Buscar campañas..." oninput="emFilterCampaigns()" class="em-input" style="padding-left:38px;"/>
      </div>
      <select id="em-filter-status" onchange="emFilterCampaigns()" class="em-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="sent">Enviada</option>
        <option value="draft">Borrador</option>
        <option value="scheduled">Programada</option>
        <option value="ab_test">Prueba A/B</option>
      </select>
      <button onclick="openCampaignWizard()" class="em-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Crear campaña
      </button>
      <!-- More options dropdown -->
      <div style="position:relative;" id="em-more-wrap">
        <button onclick="toggleMoreMenu()" class="em-btn-secondary" style="padding:10px 14px;display:flex;align-items:center;gap:4px;">
          Más opciones <svg style="width:12px;height:12px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="em-more-menu" style="display:none;position:absolute;top:100%;right:0;margin-top:4px;background:var(--bg-sidebar);border:1px solid var(--border);border-radius:10px;padding:6px;min-width:180px;z-index:50;box-shadow:0 4px 20px rgba(0,0,0,0.3);">
          <button onclick="openABTestModal();toggleMoreMenu()" class="em-dropdown-item">
            <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            Prueba A/B
          </button>
          <button onclick="openCompareModal();toggleMoreMenu()" class="em-dropdown-item">
            <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            Comparar campañas
          </button>
        </div>
      </div>
    </div>

    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid var(--border);">
              <th class="em-th">Campaña</th>
              <th class="em-th">Estado</th>
              <th class="em-th">Audiencia</th>
              <th class="em-th" style="text-align:right;">Enviados</th>
              <th class="em-th" style="text-align:right;">Apertura</th>
              <th class="em-th" style="text-align:right;">Clics</th>
              <th class="em-th" style="text-align:right;">Rebote</th>
              <th class="em-th" style="text-align:right;">Bajas</th>
              <th class="em-th">Fecha</th>
              <th class="em-th" style="text-align:center;">Acciones</th>
            </tr>
          </thead>
          <tbody id="em-campaigns-tbody">
            <tr><td colspan="10" style="padding:40px;text-align:center;color:var(--text-faint);font-size:13px;">Cargando campañas...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Templates ══════════ -->
  <div id="em-panel-templates" style="display:none;">
    <div id="em-help-templates" class="em-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Los diseños que puedes reutilizar. Crea uno bonito y úsalo en muchas campañas.</p>
      <button onclick="dismissHelp('templates')" class="em-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <h3 style="font-size:15px;font-weight:800;color:var(--text-primary);margin:0;">Plantillas de email</h3>
        <div style="display:flex;gap:4px;flex-wrap:wrap;">
          <button onclick="filterTemplates('')" class="em-tpl-filter active" data-cat="">Todas</button>
          <button onclick="filterTemplates('promotional')" class="em-tpl-filter" data-cat="promotional">Promocional</button>
          <button onclick="filterTemplates('welcome')" class="em-tpl-filter" data-cat="welcome">Bienvenida</button>
          <button onclick="filterTemplates('newsletter')" class="em-tpl-filter" data-cat="newsletter">Newsletter</button>
          <button onclick="filterTemplates('abandoned')" class="em-tpl-filter" data-cat="abandoned">Carrito</button>
          <button onclick="filterTemplates('transactional')" class="em-tpl-filter" data-cat="transactional">Transaccional</button>
        </div>
      </div>
      <button onclick="openEditorModal(null)" class="em-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Crear plantilla
      </button>
    </div>
    <div id="em-empty-templates" style="display:none;" class="em-empty-state">
      <svg style="width:56px;height:56px;color:#8b5cf6;opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">Diseña tu primera plantilla</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:360px;line-height:1.5;">Crea un diseño profesional para tus emails. Arrastra bloques, personaliza colores y listo.</p>
      <button onclick="openEditorModal(null)" class="em-btn-primary" style="margin-top:16px;padding:12px 28px;">Crear plantilla</button>
    </div>
    <div id="em-templates-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;"></div>
  </div>

  <!-- ══════════ Tab: Sequences ══════════ -->
  <div id="em-panel-sequences" style="display:none;">
    <div id="em-help-sequences" class="em-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Emails que se envían solos cuando algo pasa. Ejemplo: alguien se registra y recibe un email de bienvenida automático, y 2 días después otro con tips.</p>
      <button onclick="dismissHelp('sequences')" class="em-help-close">&times;</button>
    </div>
    <!-- Autopilot -->
    <div class="stat-card animate-in" style="padding:20px;margin-bottom:20px;background:linear-gradient(135deg,rgba(34,197,94,0.06),rgba(111,207,245,0.06));border:1px solid rgba(34,197,94,0.15);">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
        <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#22c55e,#6fcff5);display:flex;align-items:center;justify-content:center;">
          <svg style="width:18px;height:18px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div>
          <h3 style="font-size:15px;font-weight:900;color:var(--text-primary);">Piloto automático</h3>
          <p style="font-size:11px;color:var(--text-muted);">Activa estos flujos y se envían solos. Sin que hagas nada.</p>
        </div>
      </div>
      <div id="em-autopilot-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;"></div>
    </div>

    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <h3 style="font-size:15px;font-weight:800;color:var(--text-primary);margin:0;">Secuencias personalizadas</h3>
      <button onclick="openSequenceModal()" class="em-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva secuencia
      </button>
    </div>
    <div id="em-empty-sequences" style="display:none;" class="em-empty-state">
      <svg style="width:56px;height:56px;color:#f97316;opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">Automatiza tus emails</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:400px;line-height:1.5;">Las secuencias envían emails automáticos. Por ejemplo: un cliente nuevo recibe bienvenida, y 2 días después tips para usar tu producto.</p>
      <button onclick="openSequenceModal()" class="em-btn-primary" style="margin-top:16px;padding:12px 28px;">Crear mi primera secuencia</button>
    </div>
    <div id="em-sequences-list" style="display:flex;flex-direction:column;gap:16px;"></div>
  </div>

  <!-- ══════════ Tab: Audiences ══════════ -->
  <div id="em-panel-audiences" style="display:none;">
    <div id="em-help-audiences" class="em-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Tus listas de contactos organizadas por tipo. Puedes importarlos desde un archivo o traerlos del CRM.</p>
      <button onclick="dismissHelp('audiences')" class="em-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
      <h3 style="font-size:15px;font-weight:800;color:var(--text-primary);margin:0;">Listas de audiencia</h3>
      <button onclick="openAudienceModal()" class="em-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva lista
      </button>
    </div>
    <div id="em-empty-audiences" style="display:none;" class="em-empty-state">
      <svg style="width:56px;height:56px;color:#22c55e;opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">Importa tus contactos</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:360px;line-height:1.5;">Organiza a tus clientes en listas para enviarles campañas específicas. Importa desde CSV o conecta tu CRM.</p>
      <button onclick="openAudienceModal()" class="em-btn-primary" style="margin-top:16px;padding:12px 28px;">Crear mi primera lista</button>
    </div>
    <div id="em-audiences-list" style="display:flex;flex-direction:column;gap:12px;"></div>

    <!-- Emails bloqueados (collapsed by default) -->
