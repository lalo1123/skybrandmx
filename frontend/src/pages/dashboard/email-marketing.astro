        <div class="stat-card animate-in" style="padding:16px 18px;">
          <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;display:flex;align-items:center;gap:4px;">Tasa de entrega <span class="em-tip" data-tip="De todos los emails enviados, ¿cuántos llegaron al buzón del destinatario?">?</span></p>
          <p id="em-an-delivery" style="font-size:24px;font-weight:900;color:#22c55e;">--</p>
          <div style="height:4px;border-radius:2px;background:var(--input-bg);margin-top:8px;"><div id="em-an-delivery-bar" style="height:100%;border-radius:2px;background:#22c55e;transition:width 0.6s;width:0%;"></div></div>
        </div>
