// ═══════ SMART RECOMMENDATIONS ═══════
function renderSmartRecs() {
  const el = document.getElementById('em-smart-recs');
  if (!el) return;
  const recs = [];

  // Check abandoned carts
  const cartSeq = demoSequences.find(s => s.trigger === 'abandoned');
  if (cartSeq && cartSeq.status !== 'active') {
    recs.push({ icon: '🛒', color: '#f97316', title: `Tienes ${demoAudiences.find(a=>a.name.includes('Carrito'))?.count || 0} carritos abandonados`, desc: 'Activa la recuperación automática y recupera ventas perdidas.', btn: 'Activar ahora', action: "toggleAutopilot('abandoned',true)" });
  }

  // Check inactivity
  const lastSent = demoCampaigns.filter(c => c.status === 'sent').sort((a, b) => b.date.localeCompare(a.date))[0];
  if (!lastSent || daysSince(lastSent.date) > 10) {
    recs.push({ icon: '📬', color: '#8b5cf6', title: 'Llevas tiempo sin enviar emails', desc: 'Tus contactos podrían olvidarte. ¿Enviamos un newsletter automático?', btn: 'Crear con IA', action: "document.getElementById('em-ai-prompt').value='Newsletter con novedades del mes';generateAICampaign()" });
  }

  // Check VIP customers
  const vipAud = demoAudiences.find(a => a.name.includes('VIP'));
  if (vipAud && vipAud.count > 0) {
    recs.push({ icon: '⭐', color: '#eab308', title: `${vipAud.count} clientes VIP sin actividad reciente`, desc: 'Envíales una promoción exclusiva para mantenerlos comprando.', btn: 'Enviar promo VIP', action: "document.getElementById('em-ai-prompt').value='Promoción exclusiva para clientes VIP con descuento especial';generateAICampaign()" });
  }

  // Check welcome sequence
  const welcomeSeq = demoSequences.find(s => s.trigger === 'signup');
  if (welcomeSeq && welcomeSeq.status !== 'active') {
    recs.push({ icon: '👋', color: '#22c55e', title: 'No tienes bienvenida automática', desc: 'Los clientes nuevos no reciben un email de bienvenida. Actívalo con un clic.', btn: 'Activar', action: "toggleAutopilot('signup',true)" });
  }

  if (!recs.length) { el.style.display = 'none'; return; }
  el.style.display = 'flex';
  el.innerHTML = recs.slice(0, 3).map(r => `
    <div style="display:flex;align-items:center;gap:14px;padding:14px 18px;border-radius:12px;background:${r.color}08;border:1px solid ${r.color}20;">
      <span style="font-size:24px;flex-shrink:0;">${r.icon}</span>
      <div style="flex:1;min-width:0;">
        <p style="font-size:13px;font-weight:700;color:var(--text-primary);">${r.title}</p>
        <p style="font-size:11px;color:var(--text-muted);margin-top:2px;">${r.desc}</p>
      </div>
      <button onclick="${r.action}" style="padding:8px 16px;border-radius:8px;border:none;background:${r.color};color:#fff;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">${r.btn}</button>
      <button onclick="this.closest('div[style]').remove()" style="border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:14px;padding:0 4px;">✕</button>
    </div>
  `).join('');
}

function daysSince(dateStr) {
  if (!dateStr) return 999;
  const d = new Date(dateStr);
  const now = new Date();
  return Math.floor((now - d) / (1000 * 60 * 60 * 24));
}

// ═══════ AI CAMPAIGN GENERATOR ═══════
function generateAICampaign() {
  const prompt = document.getElementById('em-ai-prompt').value.trim();
