function openSuppressionModal(){document.getElementById('em-modal-suppression').style.display='flex';}
function addToSuppression(){
  const raw=document.getElementById('em-suppress-emails').value.trim();
  if(!raw){alert('Ingresa al menos un email');return;}
  const emails=raw.split(/[,\n]+/).map(e=>e.trim()).filter(e=>e);
  const reason=document.getElementById('em-suppress-reason').value;
  const date=new Date().toISOString().split('T')[0];
  emails.forEach(email=>{if(!demoSuppression.find(s=>s.email===email))demoSuppression.unshift({email,reason,date});});
  document.getElementById('em-modal-suppression').style.display='none';
  document.getElementById('em-suppress-emails').value='';
  renderSuppression();showToast(emails.length+' email(s) bloqueados');
}
function removeSuppression(idx){demoSuppression.splice(idx,1);renderSuppression();showToast('Email desbloqueado');}

// ═══════ ANALYTICS ═══════
function renderAnalytics() {
  const sent=demoCampaigns.filter(c=>c.status==='sent'||c.status==='ab_test');
  const ts=sent.reduce((s,c)=>s+c.sent,0),tb=sent.reduce((s,c)=>s+c.bounced,0);
  const tsp=sent.reduce((s,c)=>s+c.spam,0),tu=sent.reduce((s,c)=>s+c.unsubs,0);
  const delivR=ts>0?(((ts-tb)/ts)*100).toFixed(1):0, bounceR=ts>0?((tb/ts)*100).toFixed(2):0;
  const spamR=ts>0?((tsp/ts)*100).toFixed(3):0, unsubR=ts>0?((tu/ts)*100).toFixed(2):0;

  document.getElementById('em-an-delivery').textContent=delivR+'%';
  document.getElementById('em-an-delivery-bar').style.width=delivR+'%';
  document.getElementById('em-an-bounce').textContent=bounceR+'%';
  document.getElementById('em-an-bounce-bar').style.width=Math.min(bounceR*10,100)+'%';
  document.getElementById('em-an-spam').textContent=spamR+'%';
  document.getElementById('em-an-spam-bar').style.width=Math.min(spamR*100,100)+'%';
  document.getElementById('em-an-unsub').textContent=unsubR+'%';
  document.getElementById('em-an-unsub-bar').style.width=Math.min(unsubR*10,100)+'%';

  // Monthly chart
  const months=['Oct','Nov','Dic','Ene','Feb','Mar'],openR=[38,42,36,44,41,47],clickR=[12,14,11,16,15,16],bounceRm=[3.2,2.8,3.5,2.1,1.9,1.7];
  document.getElementById('em-chart-monthly').innerHTML=months.map((m,i)=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;"><div style="width:100%;display:flex;gap:2px;align-items:flex-end;height:160px;"><div style="flex:1;background:var(--accent);border-radius:3px 3px 0 0;height:${openR[i]*3}px;opacity:0.8;" title="Apertura: ${openR[i]}%"></div><div style="flex:1;background:#f97316;border-radius:3px 3px 0 0;height:${clickR[i]*3}px;opacity:0.8;" title="Clics: ${clickR[i]}%"></div><div style="flex:1;background:#ef4444;border-radius:3px 3px 0 0;height:${bounceRm[i]*20}px;opacity:0.8;" title="Rebote: ${bounceRm[i]}%"></div></div><span style="font-size:10px;color:var(--text-faint);font-weight:600;">${m}</span></div>`).join('');

  // Top campaigns
  const sortedC=sent.filter(c=>c.sent>0).sort((a,b)=>(b.opened/b.sent)-(a.opened/a.sent));
  document.getElementById('em-top-campaigns').innerHTML=sortedC.slice(0,4).map((c,i)=>{
    const rate=((c.opened/c.sent)*100).toFixed(1);
    return`<div style="display:flex;align-items:center;gap:12px;padding:10px;border-radius:10px;background:var(--input-bg);"><span style="width:24px;height:24px;border-radius:6px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--accent);">${i+1}</span><div style="flex:1;min-width:0;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${c.name}</p><p style="font-size:11px;color:var(--text-faint);">${c.sent.toLocaleString()} env.</p></div><span style="font-size:14px;font-weight:800;color:#22c55e;">${rate}%</span></div>`;
  }).join('');

  // Growth
  const gD=[3200,3450,3680,3900,4350,4820,5380,5700,5950,6100,6230,6430],mG=Math.max(...gD);
  document.getElementById('em-chart-growth').innerHTML=gD.map(v=>`<div style="flex:1;background:linear-gradient(to top,var(--accent),var(--accent)88);border-radius:3px 3px 0 0;height:${(v/mG)*160}px;opacity:0.7;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.7'"></div>`).join('');

  // Engagement by day
  const days=['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'],dayR=[45,52,48,55,42,28,22],mD=Math.max(...dayR);
  document.getElementById('em-chart-days').innerHTML=days.map((d,i)=>{const int=dayR[i]/mD;return`<div style="text-align:center;"><div style="width:100%;aspect-ratio:1;border-radius:8px;background:rgba(111,207,245,${0.15+int*0.85});display:flex;align-items:center;justify-content:center;margin-bottom:6px;"><span style="font-size:14px;font-weight:800;color:${int>0.5?'#fff':'var(--text-muted)'};">${dayR[i]}%</span></div><span style="font-size:10px;color:var(--text-faint);font-weight:600;">${d}</span></div>`;}).join('');

  // Device stats
  const devices=[{l:'Celular',pct:58,icon:'📱',c:'var(--accent)'},{l:'Escritorio',pct:32,icon:'💻',c:'#f97316'},{l:'Tableta',pct:7,icon:'📟',c:'#8b5cf6'},{l:'Otros',pct:3,icon:'🔗',c:'#64748b'}];
  document.getElementById('em-chart-devices').innerHTML=devices.map(d=>`<div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;"><span style="font-size:12px;color:var(--text-secondary);display:flex;align-items:center;gap:6px;"><span style="font-size:14px;">${d.icon}</span>${d.l}</span><span style="font-size:13px;font-weight:800;color:var(--text-primary);">${d.pct}%</span></div><div style="height:8px;border-radius:4px;background:var(--input-bg);overflow:hidden;"><div style="height:100%;width:${d.pct}%;background:${d.c};border-radius:4px;"></div></div></div>`).join('');

  // Click heatmap
  const links=[{l:'Logo',cl:45,p:5.2},{l:'Banner imagen',cl:89,p:10.3},{l:'Botón principal "Ver ofertas"',cl:312,p:36.1},{l:'Producto 1',cl:156,p:18.1},{l:'Producto 2',cl:98,p:11.4},{l:'Link "Ver todos"',cl:67,p:7.8},{l:'Redes sociales',cl:34,p:3.9},{l:'Link de baja',cl:62,p:7.2}];
  const maxCl=Math.max(...links.map(l=>l.cl));
  document.getElementById('em-click-heatmap').innerHTML=`<div style="border:1px solid var(--border);border-radius:8px;overflow:hidden;">${links.map(l=>{const int=l.cl/maxCl;const hC=int>0.7?'#ef4444':int>0.4?'#f97316':int>0.2?'#eab308':'#22c55e';return`<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid var(--border);background:${hC}0d;"><div style="width:8px;height:8px;border-radius:50%;background:${hC};flex-shrink:0;"></div><span style="flex:1;font-size:11px;color:var(--text-secondary);font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${l.l}</span><span style="font-size:11px;color:var(--text-muted);white-space:nowrap;">${l.cl} clics</span><span style="font-size:11px;font-weight:800;color:${hC};min-width:40px;text-align:right;">${l.p}%</span></div>`;}).join('')}</div><div style="display:flex;justify-content:center;gap:16px;margin-top:10px;"><div style="display:flex;align-items:center;gap:4px;"><div style="width:8px;height:8px;border-radius:50%;background:#ef4444;"></div><span style="font-size:10px;color:var(--text-faint);">Alto</span></div><div style="display:flex;align-items:center;gap:4px;"><div style="width:8px;height:8px;border-radius:50%;background:#f97316;"></div><span style="font-size:10px;color:var(--text-faint);">Medio</span></div><div style="display:flex;align-items:center;gap:4px;"><div style="width:8px;height:8px;border-radius:50%;background:#eab308;"></div><span style="font-size:10px;color:var(--text-faint);">Bajo</span></div></div>`;

  // Optimal time
  const timeSlots=[{h:'8:00',l:'Temprano',r:38,d:'Mar-Jue'},{h:'10:00',l:'Media mañana',r:55,d:'Jue',best:true},{h:'13:00',l:'Hora de comida',r:42,d:'Mar-Mié'},{h:'18:00',l:'Fin de jornada',r:48,d:'Lun-Mar'},{h:'20:00',l:'Noche',r:35,d:'Vie'}];
  const maxR=Math.max(...timeSlots.map(t=>t.r));
  document.getElementById('em-optimal-time').innerHTML=timeSlots.map(t=>`<div style="display:flex;align-items:center;gap:10px;padding:10px;border-radius:8px;${t.best?'background:rgba(139,92,246,0.08);border:1px solid rgba(139,92,246,0.2);':'background:var(--input-bg);'}"><div style="min-width:48px;text-align:center;"><p style="font-size:14px;font-weight:900;color:${t.best?'#8b5cf6':'var(--text-primary)'};">${t.h}</p><p style="font-size:9px;color:var(--text-faint);">${t.d}</p></div><div style="flex:1;"><div style="display:flex;justify-content:space-between;margin-bottom:3px;"><span style="font-size:11px;color:var(--text-muted);">${t.l}</span><span style="font-size:11px;font-weight:800;color:${t.best?'#8b5cf6':'var(--text-secondary)'};">${t.r}%</span></div><div style="height:6px;border-radius:3px;background:var(--border);overflow:hidden;"><div style="height:100%;width:${(t.r/maxR)*100}%;background:${t.best?'#8b5cf6':'var(--accent)'};border-radius:3px;"></div></div></div>${t.best?'<span style="font-size:10px;font-weight:800;color:#8b5cf6;white-space:nowrap;">⭐ MEJOR</span>':''}</div>`).join('');
}

// ═══════ WIZARD ═══════
function openCampaignWizard(){
  wizStep=1;updateWizUI();
  document.getElementById('em-modal-wizard').style.display='flex';
  const as=document.getElementById('em-wiz-audience');
  as.innerHTML='<option value="">Seleccionar lista...</option>'+demoAudiences.map(a=>`<option value="${a.id}">${a.name} (${a.count.toLocaleString()} contactos)</option>`).join('');
  const ts=document.getElementById('em-wiz-template');
  ts.innerHTML='<option value="">Sin plantilla (empezar vacío)</option>'+demoTemplates.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  document.getElementById('em-wiz-ai-suggestions').style.display='none';
  ['em-wiz-name','em-wiz-subject','em-wiz-preview','em-wiz-schedule'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});
}
function closeWizard(){document.getElementById('em-modal-wizard').style.display='none';}

function updateWizUI(){
  for(let i=1;i<=4;i++){
    const s=document.getElementById('em-wiz-step-'+i);
    s.classList.remove('active','done');
    if(i<wizStep)s.classList.add('done');
    if(i===wizStep)s.classList.add('active');
    const p=document.getElementById('em-wiz-panel-'+i);
    p.style.display=i===wizStep?'':'none';
    if(i<4){const c=document.getElementById('em-wiz-conn-'+i);c.classList.toggle('done',i<wizStep);}
  }
  document.getElementById('em-wiz-back').style.display=wizStep>1?'':'none';
  document.getElementById('em-wiz-next').style.display=wizStep<4?'':'none';
  document.getElementById('em-wiz-send').style.display=wizStep===4?'':'none';
  document.getElementById('em-wiz-draft').style.display=wizStep===4?'':'none';
  document.getElementById('em-wiz-send-test').style.display=wizStep===4?'':'none';
  if(wizStep===4)renderWizSummary();
}
let _emWizValidator=null;
function _emInitWizValidator(){
  if(_emWizValidator||typeof SkyValidator==='undefined')return;
  _emWizValidator=SkyValidator.create('em-wiz-form',{
    'em-wiz-name':{rules:['required','min:3'],label:'Nombre de la campaña'},
    'em-wiz-subject':{rules:['required','min:5'],label:'Asunto del correo'},
    'em-wiz-from-email':{rules:['email'],label:'Email de remitente',optional:true},
  },{submitBtnId:'em-wiz-next'});
}
function wizNext(){
  _emInitWizValidator();
  if(wizStep===1 && _emWizValidator){
    _emWizValidator.touchAll();
    if(!_emWizValidator.validate())return;
  } else if(wizStep===1 && !document.getElementById('em-wiz-name').value.trim()){
    return;
  }
  if(wizStep<4){wizStep++;updateWizUI();}
}
function wizBack(){if(wizStep>1){wizStep--;updateWizUI();}}

function renderWizSummary(){
  const name=document.getElementById('em-wiz-name').value||'Sin nombre';
  const subject=document.getElementById('em-wiz-subject').value||'Sin asunto';
  const preview=document.getElementById('em-wiz-preview').value||'Sin texto de vista previa';
  const audSel=document.getElementById('em-wiz-audience');
  const aud=audSel.options[audSel.selectedIndex]?.text||'Sin seleccionar';
  const fromName=document.getElementById('em-wiz-from-name').value||'--';
  const fromEmail=document.getElementById('em-wiz-from-email').value||'--';
  document.getElementById('em-wiz-summary').innerHTML=`
    <div style="display:grid;grid-template-columns:100px 1fr;gap:8px;font-size:12px;">
      <span style="color:var(--text-faint);font-weight:700;">Campaña:</span><span style="color:var(--text-primary);font-weight:600;">${name}</span>
      <span style="color:var(--text-faint);font-weight:700;">Asunto:</span><span style="color:var(--text-primary);">${subject}</span>
      <span style="color:var(--text-faint);font-weight:700;">Vista previa:</span><span style="color:var(--text-muted);">${preview}</span>
      <span style="color:var(--text-faint);font-weight:700;">Audiencia:</span><span style="color:var(--text-primary);">${aud}</span>
      <span style="color:var(--text-faint);font-weight:700;">Remitente:</span><span style="color:var(--text-primary);">${fromName} &lt;${fromEmail}&gt;</span>
    </div>`;
}

function wizSaveDraft(){
  const name=document.getElementById('em-wiz-name').value.trim();
