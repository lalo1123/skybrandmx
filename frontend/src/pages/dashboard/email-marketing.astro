        </div>
      </div>

      <!-- Step 4: Review & Send -->
      <div id="em-wiz-panel-4" class="em-wiz-panel" style="display:none;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">¡Revisa antes de enviar!</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Verifica que todo esté correcto.</p>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <!-- Summary -->
          <div id="em-wiz-summary" style="border:1px solid var(--border);border-radius:10px;padding:16px;background:var(--input-bg);"></div>
          <!-- Spam score -->
          <div style="border:1px solid var(--border);border-radius:10px;padding:14px;background:var(--input-bg);">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
              <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;display:flex;align-items:center;gap:4px;">Revisión anti-spam <span class="em-tip" data-tip="Analizamos tu asunto para predecir si podría caer en la carpeta de correo no deseado">?</span></p>
              <button onclick="wizAnalyzeSpam()" style="padding:4px 12px;border-radius:6px;border:1px solid var(--accent);background:transparent;color:var(--accent);font-size:11px;font-weight:600;cursor:pointer;">Analizar</button>
            </div>
            <div id="em-wiz-spam-result"></div>
          </div>
          <!-- Optimal time -->
          <div id="em-wiz-optimal-hint" style="padding:10px 14px;border-radius:10px;background:rgba(139,92,246,0.06);border:1px solid rgba(139,92,246,0.15);display:flex;align-items:center;gap:10px;">
            <svg style="width:16px;height:16px;color:#8b5cf6;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <div style="flex:1;">
              <p style="font-size:11px;color:#8b5cf6;font-weight:700;">Sugerencia de IA: envía el Jueves a las 10:00 AM</p>
              <p style="font-size:11px;color:var(--text-muted);">Tus contactos abren más emails a esa hora (55% apertura)</p>
            </div>
            <button onclick="wizApplyOptimalTime()" style="padding:4px 12px;border-radius:6px;border:1px solid #8b5cf6;background:transparent;color:#8b5cf6;font-size:10px;font-weight:700;cursor:pointer;white-space:nowrap;">Aplicar</button>
          </div>
          <!-- Schedule -->
          <div>
            <label class="em-label">¿Cuándo quieres enviarlo?</label>
            <input id="em-wiz-schedule" type="datetime-local" class="em-input"/>
            <div style="display:flex;align-items:center;gap:8px;margin-top:8px;">
              <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
                <input type="checkbox" id="em-wiz-timezone" style="accent-color:var(--accent);"/>
                <span style="font-size:11px;color:var(--text-muted);font-weight:600;">Enviar a la hora local de cada contacto <span class="em-tip" data-tip="En vez de enviar todo a las 10am hora CDMX, cada contacto recibe el email a las 10am de SU zona horaria. Ideal si tienes clientes en diferentes estados o países.">?</span></span>
              </label>
            </div>
            <p style="font-size:11px;color:var(--text-faint);margin-top:4px;">Deja vacío para guardar como borrador</p>
          </div>
          <!-- Collapsed advanced: UTM -->
          <button onclick="toggleSection('em-wiz-advanced-utm')" class="em-collapse-toggle">Configuración avanzada (rastreo de enlaces) ▾</button>
          <div id="em-wiz-advanced-utm" style="display:none;border:1px solid var(--border);border-radius:10px;padding:14px;background:var(--input-bg);">
            <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;display:flex;align-items:center;gap:4px;">Rastreo de enlaces (UTM) <span class="em-tip" data-tip="Agrega etiquetas invisibles a los links de tu email para saber en Google Analytics de dónde vienen tus visitas">?</span></p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
              <div><label class="em-label">Fuente</label><input id="em-wiz-utm-source" type="text" value="email" class="em-input" style="font-size:11px;padding:6px 10px;"/></div>
              <div><label class="em-label">Medio</label><input id="em-wiz-utm-medium" type="text" value="campaign" class="em-input" style="font-size:11px;padding:6px 10px;"/></div>
              <div><label class="em-label">Campaña</label><input id="em-wiz-utm-campaign" type="text" placeholder="auto del nombre" class="em-input" style="font-size:11px;padding:6px 10px;"/></div>
              <div><label class="em-label">Contenido</label><input id="em-wiz-utm-content" type="text" placeholder="(opcional)" class="em-input" style="font-size:11px;padding:6px 10px;"/></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Wizard navigation -->
      <div style="display:flex;gap:10px;margin-top:20px;">
        <button id="em-wiz-back" onclick="wizBack()" class="em-btn-secondary" style="flex:1;display:none;">← Anterior</button>
        <button id="em-wiz-send-test" onclick="wizSendTest()" class="em-btn-secondary" style="flex:0;border-color:#22c55e;color:#22c55e;padding:12px 16px;display:none;">
          <span style="display:flex;align-items:center;gap:4px;"><svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8"/></svg>Enviar prueba</span>
        </button>
        <button id="em-wiz-draft" onclick="wizSaveDraft()" class="em-btn-secondary" style="flex:1;display:none;">Guardar borrador</button>
        <button id="em-wiz-next" onclick="wizNext()" class="em-btn-primary" style="flex:1;">Siguiente →</button>
        <button id="em-wiz-send" onclick="wizSend()" class="em-btn-primary" style="flex:1;display:none;">Programar envío</button>
        <button onclick="closeWizard()" style="position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text-muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;">&times;</button>
      </div>
    </div>
  </div>

  <!-- ══════════ Modal: A/B Test ══════════ -->
  <div id="em-modal-abtest" class="em-modal-overlay" style="display:none;">
    <div class="em-modal-box" style="max-width:640px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);">Crear Prueba A/B <span class="em-tip" data-tip="Envía 2 versiones diferentes de tu email a un grupo pequeño. La que funcione mejor se envía al resto automáticamente.">?</span></h3>
        <button onclick="closeABTestModal()" class="em-modal-close">&times;</button>
      </div>
      <div style="display:flex;flex-direction:column;gap:14px;">
        <div>
          <label class="em-label">Nombre del test</label>
          <input id="em-ab-name" type="text" placeholder="Ej: Test asunto promo abril" class="em-input"/>
        </div>
        <div>
          <label class="em-label">¿Qué quieres probar?</label>
          <div style="display:flex;gap:8px;">
            <button onclick="setABType('subject')" id="em-ab-type-subject" class="em-chip active" style="flex:1;">Asunto</button>
            <button onclick="setABType('content')" id="em-ab-type-content" class="em-chip" style="flex:1;">Contenido</button>
            <button onclick="setABType('sendtime')" id="em-ab-type-sendtime" class="em-chip" style="flex:1;">Hora de envío</button>
          </div>
        </div>
        <div id="em-ab-variants">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div><label class="em-label">Versión A</label><input id="em-ab-var-a" type="text" placeholder="Asunto versión A" class="em-input"/></div>
            <div><label class="em-label">Versión B</label><input id="em-ab-var-b" type="text" placeholder="Asunto versión B" class="em-input"/></div>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div><label class="em-label">Audiencia</label><select id="em-ab-audience" class="em-input" style="cursor:pointer;"><option value="">Seleccionar...</option></select></div>
          <div>
            <label class="em-label" style="display:flex;align-items:center;gap:4px;">Muestra del test <span class="em-tip" data-tip="¿A qué porcentaje de tu lista le envías las 2 versiones? El resto recibe la ganadora.">?</span></label>
            <select id="em-ab-sample" class="em-input" style="cursor:pointer;">
              <option value="20">20% (10% cada versión)</option>
              <option value="30">30% (15% cada versión)</option>
              <option value="50" selected>50% (25% cada versión)</option>
            </select>
          </div>
        </div>
        <div>
          <label class="em-label">¿Cómo se elige la ganadora?</label>
          <div style="display:flex;gap:8px;">
            <button onclick="setABWinner('open')" id="em-ab-win-open" class="em-chip active" style="flex:1;">Más aperturas</button>
            <button onclick="setABWinner('click')" id="em-ab-win-click" class="em-chip" style="flex:1;">Más clics</button>
          </div>
          <p style="font-size:11px;color:var(--text-faint);margin-top:6px;">La versión ganadora se envía automáticamente al resto de la lista después de 4 horas.</p>
        </div>
        <button onclick="saveABTest()" class="em-btn-primary">Crear Prueba A/B</button>
      </div>
    </div>
  </div>

  <!-- ══════════ Modal: Email Editor (full-screen) ══════════ -->
  <div id="em-modal-editor" style="display:none;position:fixed;inset:0;background:var(--bg-main);z-index:1100;overflow:hidden;">
