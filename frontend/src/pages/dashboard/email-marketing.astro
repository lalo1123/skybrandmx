function showEditorGuide(){
  const guide=document.getElementById('em-editor-guide');guide.style.display='block';
  const content=document.getElementById('em-guide-content');
  let step=0;const steps=[
    {text:'<h4 style="font-size:15px;font-weight:800;color:var(--text-primary);margin-bottom:8px;">1. Arrastra bloques</h4><p style="font-size:13px;color:var(--text-muted);line-height:1.5;">Desde este panel izquierdo, arrastra los bloques que necesites: texto, imágenes, botones, etc.</p>',left:'260px',top:'200px'},
    {text:'<h4 style="font-size:15px;font-weight:800;color:var(--text-primary);margin-bottom:8px;">2. Tu email se arma aquí</h4><p style="font-size:13px;color:var(--text-muted);line-height:1.5;">En el centro ves cómo va quedando tu email. Haz clic en cualquier bloque para editarlo.</p>',left:'50%',top:'200px',transform:'translateX(-50%)'},
    {text:'<h4 style="font-size:15px;font-weight:800;color:var(--text-primary);margin-bottom:8px;">3. Personaliza aquí</h4><p style="font-size:13px;color:var(--text-muted);line-height:1.5;">Cuando seleccionas un bloque, aquí cambias colores, tamaños, textos y más.</p>',right:'20px',top:'200px'},
  ];
  function showStep(i){
    if(i>=steps.length){guide.style.display='none';localStorage.setItem('em_editor_guide_seen','1');return;}
    const s=steps[i];content.innerHTML=s.text+`<button onclick="document.getElementById('em-guide-step').click()" class="em-btn-primary" style="margin-top:12px;padding:8px 20px;font-size:12px;">${i<steps.length-1?'Siguiente →':'¡Entendido!'}</button>`;
    content.style.cssText='position:absolute;background:var(--bg-sidebar);border:1px solid var(--accent);border-radius:16px;padding:24px;max-width:320px;box-shadow:0 4px 30px rgba(111,207,245,0.2);'+(s.left?'left:'+s.left+';':'')+(s.right?'right:'+s.right+';':'')+(s.top?'top:'+s.top+';':'')+(s.transform?'transform:'+s.transform+';':'');
  }
  showStep(step);
  const btn=document.createElement('button');btn.id='em-guide-step';btn.style.display='none';
  btn.onclick=()=>{step++;showStep(step);};document.body.appendChild(btn);
  guide.onclick=e=>{if(e.target===guide){guide.style.display='none';localStorage.setItem('em_editor_guide_seen','1');btn.remove();}};
}

function setPreviewMode(mode){
  document.getElementById('em-prev-desktop').classList.toggle('active',mode==='desktop');
