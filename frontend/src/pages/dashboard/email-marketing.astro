  document.getElementById('em-prev-desktop').style.background=mode==='desktop'?'var(--accent-bg)':'transparent';
  document.getElementById('em-prev-desktop').style.color=mode==='desktop'?'var(--accent)':'var(--text-muted)';
  document.getElementById('em-prev-mobile').style.background=mode==='mobile'?'var(--accent-bg)':'transparent';
  document.getElementById('em-prev-mobile').style.color=mode==='mobile'?'var(--accent)':'var(--text-muted)';
