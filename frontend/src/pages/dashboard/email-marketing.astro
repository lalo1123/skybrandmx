    // Generate campaign based on prompt
    const subjects = [
      `¡${prompt.includes('colección') ? 'Nueva colección' : 'Oferta especial'}! Solo por tiempo limitado`,
      `{{nombre}}, ${prompt.includes('descuento') ? 'tu descuento exclusivo te espera' : 'tenemos algo nuevo para ti'}`,
      `¡No te lo pierdas! ${prompt.substring(0, 40)}...`,
    ];
    const bestAudience = prompt.includes('VIP') ? 'Clientes VIP' : prompt.includes('nuevo') ? 'Nuevos registros' : 'Todos los clientes';
    const bestTime = 'Jueves 10:00 AM';

    result.innerHTML = `
