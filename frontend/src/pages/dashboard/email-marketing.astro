function renderBlockPalette(){document.getElementById('em-block-palette').innerHTML=editorBlocks.map(b=>`<div class="em-block-item" draggable="true" ondragstart="event.dataTransfer.setData('blockType','${b.type}')" onclick="addBlock('${b.type}')"><span style="width:24px;text-align:center;font-size:14px;">${b.icon}</span>${b.label}</div>`).join('');}
function renderMergeTags(){document.getElementById('em-merge-tags').innerHTML=mergeTags.map(mt=>`<button class="em-merge-tag" onclick="insertMergeTag('${mt.tag}')" title="Copiar ${mt.tag}">${mt.tag} <span style="color:var(--text-faint);font-weight:400;">${mt.label}</span></button>`).join('');}
function insertMergeTag(tag){navigator.clipboard.writeText(tag).then(()=>showToast('Variable '+tag+' copiada'));}

function addBlock(type){
  const defaults={header:{content:'Encabezado',styles:{bg:'#6fcff5',color:'#ffffff',padding:'32px',align:'center',fontSize:'28px'}},text:{content:'Escribe tu texto aquí...',styles:{padding:'20px 32px',color:'#333333',fontSize:'15px'}},image:{content:'https://placehold.co/600x200/e2e8f0/64748b?text=Tu+Imagen',styles:{padding:'0',width:'100%'}},button:{content:'Botón',styles:{bg:'#6fcff5',color:'#ffffff',padding:'14px 32px',align:'center',borderRadius:'8px',margin:'24px auto'}},divider:{content:'',styles:{padding:'0 32px',color:'#e2e8f0'}},columns:{content:'Col 1|Col 2',styles:{padding:'20px 32px'}},social:{content:'Facebook|Instagram|Twitter',styles:{padding:'20px 32px',align:'center'}},footer:{content:'Tu empresa · {{unsubscribe}}',styles:{padding:'20px 32px',color:'#94a3b8',fontSize:'11px',align:'center'}},spacer:{content:'',styles:{height:'32px'}},product:{content:'Nombre del producto',styles:{padding:'20px 32px'}}};
  editorBlockList.push({type,...defaults[type]});renderEditorBlocks();selectBlock(editorBlockList.length-1);
}
function handleBlockDrop(e){e.preventDefault();const t=e.dataTransfer.getData('blockType');if(t)addBlock(t);}
function selectBlock(idx){selectedBlockIdx=idx;renderEditorBlocks();updateBlockSettings();}
function moveBlock(idx,dir){const ni=idx+dir;if(ni<0||ni>=editorBlockList.length)return;[editorBlockList[idx],editorBlockList[ni]]=[editorBlockList[ni],editorBlockList[idx]];selectedBlockIdx=ni;renderEditorBlocks();updateBlockSettings();}
function deleteBlock(idx){editorBlockList.splice(idx,1);selectedBlockIdx=null;renderEditorBlocks();updateBlockSettings();}

function renderEditorBlocks(){
  const el=document.getElementById('em-editor-blocks');if(!editorBlockList.length){el.innerHTML='';return;}
  const dark=emailDarkMode;
  el.innerHTML=editorBlockList.map((b,i)=>{
    const sel=i===selectedBlockIdx?'selected':'';let html='';const s=b.styles||{};
    const txtColor=dark&&(s.color==='#333333'||s.color==='#333')? '#e0e0e0':s.color;
    const footColor=dark&&s.color==='#94a3b8'?'#888':s.color;
    switch(b.type){
      case'header':html=`<div style="background:${s.bg||'#6fcff5'};color:${s.color||'#fff'};padding:${s.padding||'32px'};text-align:${s.align||'center'};font-size:${s.fontSize||'28px'};font-weight:800;">${b.content}</div>`;break;
      case'text':html=`<div style="padding:${s.padding||'20px 32px'};color:${txtColor||'#333'};font-size:${s.fontSize||'15px'};line-height:1.6;white-space:pre-wrap;">${b.content}</div>`;break;
      case'image':html=`<div style="padding:${s.padding||'0'};text-align:center;"><img src="${b.content}" style="max-width:100%;width:${s.width||'100%'};display:block;" alt=""/></div>`;break;
      case'button':html=`<div style="text-align:${s.align||'center'};padding:16px 32px;"><table cellpadding="0" cellspacing="0" style="margin:0 auto;"><tr><td style="background:${s.bg||'#6fcff5'};color:${s.color||'#fff'};padding:${s.padding||'14px 32px'};border-radius:${s.borderRadius||'8px'};font-weight:700;font-size:15px;">${b.content}</td></tr></table></div>`;break;
      case'divider':html=`<div style="padding:${s.padding||'0 32px'};"><hr style="border:none;border-top:1px solid ${dark?'#444':s.color||'#e2e8f0'};"/></div>`;break;
      case'columns':{const cols=b.content.split('|');html=`<div style="padding:${s.padding||'20px 32px'};display:flex;gap:16px;">${cols.map(c=>`<div style="flex:1;padding:12px;background:${dark?'#2a2a3e':'#f8fafc'};border-radius:6px;color:${dark?'#ccc':'#333'};font-size:13px;">${c.trim()}</div>`).join('')}</div>`;break;}
      case'social':html=`<div style="padding:${s.padding||'20px 32px'};text-align:${s.align||'center'};display:flex;gap:12px;justify-content:center;">${b.content.split('|').map(n=>`<span style="display:inline-block;width:36px;height:36px;border-radius:50%;background:${dark?'#444':'#e2e8f0'};line-height:36px;text-align:center;font-size:12px;color:${dark?'#aaa':'#64748b'};">${n.trim().charAt(0)}</span>`).join('')}</div>`;break;
      case'footer':html=`<div style="padding:${s.padding||'20px 32px'};color:${footColor||'#94a3b8'};font-size:${s.fontSize||'11px'};text-align:${s.align||'center'};line-height:1.5;">${b.content}</div>`;break;
      case'spacer':html=`<div style="height:${s.height||'32px'};"></div>`;break;
      case'product':html=`<div style="padding:${s.padding||'20px 32px'};display:flex;gap:16px;align-items:center;"><div style="width:80px;height:80px;border-radius:8px;background:${dark?'#2a2a3e':'#e2e8f0'};display:flex;align-items:center;justify-content:center;font-size:24px;">🛍</div><div><p style="font-weight:700;color:${dark?'#e0e0e0':'#333'};font-size:15px;">${b.content}</p><p style="color:${dark?'#888':'#64748b'};font-size:13px;">$0.00 MXN</p></div></div>`;break;
    }
    return`<div class="editor-block ${sel}" onclick="selectBlock(${i})"><div class="editor-block-actions"><button class="editor-block-btn" onclick="event.stopPropagation();moveBlock(${i},-1)">↑</button><button class="editor-block-btn" onclick="event.stopPropagation();moveBlock(${i},1)">↓</button><button class="editor-block-btn" onclick="event.stopPropagation();deleteBlock(${i})" style="color:#ef4444;">✕</button></div>${html}</div>`;
  }).join('');
}

function updateBlockSettings(){
  const el=document.getElementById('em-block-settings-content');
  if(selectedBlockIdx===null||!editorBlockList[selectedBlockIdx]){el.innerHTML='<p style="color:var(--text-muted);font-size:12px;">Selecciona un bloque para editar</p>';return;}
  const b=editorBlockList[selectedBlockIdx],s=b.styles||{};
  const tL={header:'Encabezado',text:'Texto',image:'Imagen',button:'Botón',divider:'Separador',columns:'Columnas',social:'Redes',footer:'Pie',spacer:'Espacio',product:'Producto'};
  let html=`<p style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">${tL[b.type]||b.type}</p>`;
  if(b.type!=='divider'&&b.type!=='spacer'){
    html+=`<label class="em-label">Contenido</label>`;
    if(b.type==='text'||b.type==='footer')html+=`<textarea onchange="updateBlockProp(${selectedBlockIdx},'content',this.value)" style="width:100%;padding:8px;border-radius:8px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:12px;outline:none;resize:vertical;min-height:80px;">${b.content}</textarea>`;
    else html+=`<input type="text" value="${b.content}" onchange="updateBlockProp(${selectedBlockIdx},'content',this.value)" class="em-input" style="font-size:12px;margin-bottom:8px;"/>`;
  }
  if(s.bg!==undefined)html+=`<label class="em-label" style="margin-top:8px;">Color fondo</label><input type="color" value="${s.bg}" onchange="updateBlockStyle(${selectedBlockIdx},'bg',this.value)" style="width:100%;height:32px;border:none;border-radius:6px;cursor:pointer;"/>`;
  if(s.color!==undefined)html+=`<label class="em-label" style="margin-top:8px;">Color texto</label><input type="color" value="${s.color}" onchange="updateBlockStyle(${selectedBlockIdx},'color',this.value)" style="width:100%;height:32px;border:none;border-radius:6px;cursor:pointer;"/>`;
  if(s.fontSize!==undefined)html+=`<label class="em-label" style="margin-top:8px;">Tamaño</label><select onchange="updateBlockStyle(${selectedBlockIdx},'fontSize',this.value)" class="em-input" style="font-size:12px;">${['11px','13px','15px','18px','22px','28px','36px'].map(v=>`<option ${s.fontSize===v?'selected':''}>${v}</option>`).join('')}</select>`;
  if(s.align!==undefined)html+=`<label class="em-label" style="margin-top:8px;">Alineación</label><div style="display:flex;gap:4px;"><button onclick="updateBlockStyle(${selectedBlockIdx},'align','left')" class="em-chip ${s.align==='left'?'active':''}" style="flex:1;padding:6px;">Izq</button><button onclick="updateBlockStyle(${selectedBlockIdx},'align','center')" class="em-chip ${s.align==='center'?'active':''}" style="flex:1;padding:6px;">Centro</button><button onclick="updateBlockStyle(${selectedBlockIdx},'align','right')" class="em-chip ${s.align==='right'?'active':''}" style="flex:1;padding:6px;">Der</button></div>`;
  if(s.borderRadius!==undefined)html+=`<label class="em-label" style="margin-top:8px;">Bordes</label><select onchange="updateBlockStyle(${selectedBlockIdx},'borderRadius',this.value)" class="em-input" style="font-size:12px;"><option ${s.borderRadius==='0'?'selected':''}>0</option><option ${s.borderRadius==='4px'?'selected':''}>4px</option><option ${s.borderRadius==='8px'?'selected':''}>8px</option><option ${s.borderRadius==='20px'?'selected':''}>20px</option></select>`;
  if(b.type==='spacer')html+=`<label class="em-label">Altura</label><select onchange="updateBlockStyle(${selectedBlockIdx},'height',this.value)" class="em-input" style="font-size:12px;">${['16px','24px','32px','48px','64px'].map(v=>`<option ${s.height===v?'selected':''}>${v}</option>`).join('')}</select>`;
  el.innerHTML=html;
}
function updateBlockProp(idx,prop,val){editorBlockList[idx][prop]=val;renderEditorBlocks();}
function updateBlockStyle(idx,prop,val){editorBlockList[idx].styles[prop]=val;renderEditorBlocks();updateBlockSettings();}
