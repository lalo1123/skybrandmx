  <!-- ══════════ Modal: Campaign Wizard (4 steps) ══════════ -->
  <div id="em-modal-wizard" class="em-modal-overlay" style="display:none;">
    <div class="em-modal-box" style="max-width:600px;">
      <!-- Progress bar -->
      <div style="display:flex;align-items:center;gap:0;margin-bottom:24px;">
        <div id="em-wiz-step-1" class="em-wiz-step active"><span class="em-wiz-num">1</span><span class="em-wiz-label">Lo básico</span></div>
        <div class="em-wiz-connector" id="em-wiz-conn-1"></div>
        <div id="em-wiz-step-2" class="em-wiz-step"><span class="em-wiz-num">2</span><span class="em-wiz-label">Diseño</span></div>
        <div class="em-wiz-connector" id="em-wiz-conn-2"></div>
        <div id="em-wiz-step-3" class="em-wiz-step"><span class="em-wiz-num">3</span><span class="em-wiz-label">Audiencia</span></div>
        <div class="em-wiz-connector" id="em-wiz-conn-3"></div>
        <div id="em-wiz-step-4" class="em-wiz-step"><span class="em-wiz-num">4</span><span class="em-wiz-label">Revisar</span></div>
      </div>

      <!-- Step 1: Basics -->
      <div id="em-wiz-panel-1" class="em-wiz-panel">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">¿Cómo se llamará tu campaña?</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">El nombre es solo para ti, tus contactos no lo ven.</p>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div>
            <label class="em-label">Nombre de campaña</label>
            <input id="em-wiz-name" type="text" placeholder="Ej: Promo verano 2026" class="em-input"/>
          </div>
          <div>
            <label class="em-label" style="display:flex;align-items:center;gap:4px;">Asunto del email <span class="em-tip" data-tip="Es lo primero que ven tus contactos en su bandeja de entrada. Un buen asunto = más aperturas.">?</span></label>
            <div style="display:flex;gap:8px;">
              <input id="em-wiz-subject" type="text" placeholder="Lo que verán en su bandeja de entrada" class="em-input" style="flex:1;"/>
              <button onclick="wizGenerateAI()" class="em-ai-btn">
                <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Sugerir con IA
              </button>
            </div>
            <div id="em-wiz-ai-suggestions" style="display:none;margin-top:8px;"></div>
          </div>
          <div>
            <label class="em-label" style="display:flex;align-items:center;gap:4px;">Texto de vista previa <span class="em-tip" data-tip="Es el texto que aparece después del asunto en la bandeja de entrada. Ayuda a que la gente decida abrir tu email.">?</span></label>
            <input id="em-wiz-preview" type="text" placeholder="Lo que ven junto al asunto antes de abrir" class="em-input"/>
          </div>
        </div>
      </div>

      <!-- Step 2: Design -->
      <div id="em-wiz-panel-2" class="em-wiz-panel" style="display:none;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">¿Cómo se verá tu email?</h3>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Elige una plantilla existente o crea una desde cero.</p>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div>
            <label class="em-label">Elegir plantilla</label>
            <select id="em-wiz-template" class="em-input" style="cursor:pointer;"><option value="">Sin plantilla (empezar vacío)</option></select>
          </div>
          <div style="text-align:center;padding:20px;border:2px dashed var(--border);border-radius:12px;">
            <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px;">¿Quieres personalizar el diseño?</p>
            <button onclick="openEditorModal('campaign')" class="em-btn-secondary" style="border-color:#8b5cf6;color:#8b5cf6;">
              <span style="display:flex;align-items:center;justify-content:center;gap:6px;">
                <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
