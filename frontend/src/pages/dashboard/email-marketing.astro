        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Actividad por día</h4>
          <div id="em-chart-days" style="display:grid;grid-template-columns:repeat(7,1fr);gap:8px;"></div>
        </div>
