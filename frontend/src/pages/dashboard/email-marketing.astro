  document.getElementById('em-compare-a').innerHTML='<option value="">Seleccionar...</option>'+opts;
  document.getElementById('em-compare-b').innerHTML='<option value="">Seleccionar...</option>'+opts;
  document.getElementById('em-compare-result').innerHTML='<p style="text-align:center;color:var(--text-faintest);font-size:13px;padding:24px;">Selecciona dos campañas</p>';
}
function closeCompareModal(){document.getElementById('em-modal-compare').style.display='none';}
function renderComparison(){
  const aId=parseInt(document.getElementById('em-compare-a').value),bId=parseInt(document.getElementById('em-compare-b').value);
  const box=document.getElementById('em-compare-result');
  if(!aId||!bId){box.innerHTML='<p style="text-align:center;color:var(--text-faintest);font-size:13px;padding:24px;">Selecciona dos campañas</p>';return;}
  if(aId===bId){box.innerHTML='<p style="text-align:center;color:#f97316;font-size:13px;padding:24px;">Elige campañas diferentes</p>';return;}
  const a=demoCampaigns.find(c=>c.id===aId),b=demoCampaigns.find(c=>c.id===bId);if(!a||!b)return;
  const pct=(v,t)=>t>0?((v/t)*100).toFixed(1):0;
  const metrics=[{l:'Enviados',aV:a.sent,bV:b.sent,f:v=>v.toLocaleString(),hi:true},{l:'Apertura',aV:pct(a.opened,a.sent),bV:pct(b.opened,b.sent),f:v=>v+'%',hi:true},{l:'Clics',aV:pct(a.clicked,a.sent),bV:pct(b.clicked,b.sent),f:v=>v+'%',hi:true},{l:'Rebote',aV:pct(a.bounced,a.sent),bV:pct(b.bounced,b.sent),f:v=>v+'%',hi:false},{l:'Bajas',aV:a.unsubs,bV:b.unsubs,f:v=>v,hi:false}];
  box.innerHTML=`<div style="display:grid;grid-template-columns:1fr 60px 1fr;gap:8px;align-items:center;"><div style="text-align:center;padding:10px;"><p style="font-size:14px;font-weight:800;color:var(--accent);">${a.name}</p></div><div style="text-align:center;font-size:12px;font-weight:800;color:var(--text-faint);">VS</div><div style="text-align:center;padding:10px;"><p style="font-size:14px;font-weight:800;color:#f97316;">${b.name}</p></div></div>${metrics.map(m=>{const aN=parseFloat(m.aV),bN=parseFloat(m.bV);const aW=m.hi?aN>bN:aN<bN;const bW=m.hi?bN>aN:bN<aN;return`<div style="display:grid;grid-template-columns:1fr 60px 1fr;gap:8px;margin-top:8px;"><div class="em-compare-metric ${aW?'em-compare-winner':''}"><span class="em-compare-metric-label">${m.l}</span><span class="em-compare-metric-val" style="color:${aW?'#22c55e':'var(--text-primary)'};">${m.f(m.aV)}</span></div><div style="text-align:center;">${aW?'<span style="color:#22c55e;">←</span>':bW?'<span style="color:#22c55e;">→</span>':'='}</div><div class="em-compare-metric ${bW?'em-compare-winner':''}"><span class="em-compare-metric-label">${m.l}</span><span class="em-compare-metric-val" style="color:${bW?'#22c55e':'var(--text-primary)'};">${m.f(m.bV)}</span></div></div>`;}).join('')}`;
}

