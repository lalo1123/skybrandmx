          <svg style="width:16px;height:16px;color:#8b5cf6;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <p style="font-size:13px;font-weight:800;color:#8b5cf6;">Campaña generada por IA</p>
        </div>
        <div style="display:grid;grid-template-columns:100px 1fr;gap:8px;font-size:12px;margin-bottom:16px;">
          <span style="color:var(--text-faint);font-weight:700;">Asunto:</span><span style="color:var(--text-primary);font-weight:600;">${subjects[0]}</span>
          <span style="color:var(--text-faint);font-weight:700;">Audiencia:</span><span style="color:var(--text-primary);">${bestAudience} (${(demoAudiences.find(a=>a.name===bestAudience)||{count:2450}).count.toLocaleString()} contactos)</span>
          <span style="color:var(--text-faint);font-weight:700;">Horario:</span><span style="color:var(--text-primary);">${bestTime} (mejor tasa de apertura)</span>
          <span style="color:var(--text-faint);font-weight:700;">Plantilla:</span><span style="color:var(--text-primary);">Promoción general</span>
        </div>
        <p style="font-size:11px;color:var(--text-faint);margin-bottom:12px;">Alternativas de asunto:</p>
        <div style="display:flex;flex-direction:column;gap:4px;margin-bottom:16px;">
          ${subjects.map((s,i) => `<div style="display:flex;align-items:center;gap:8px;padding:6px 10px;border-radius:6px;background:var(--input-bg);"><span style="font-size:10px;color:var(--text-faint);">${i+1}.</span><span style="font-size:12px;color:var(--text-secondary);flex:1;">${s}</span></div>`).join('')}
        </div>
        <div style="display:flex;gap:10px;">
          <button onclick="aiCampaignApply('${subjects[0].replace(/'/g,"\\'")}','${bestAudience}')" class="em-btn-primary" style="flex:1;background:linear-gradient(135deg,#8b5cf6,#6fcff5);display:flex;align-items:center;justify-content:center;gap:6px;">
            <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Crear esta campaña
          </button>
          <button onclick="document.getElementById('em-ai-gen-result').style.display='none'" class="em-btn-secondary" style="flex:0;padding:12px 16px;">Cerrar</button>
        </div>
      </div>`;
  }, 1200);
}

function aiCampaignApply(subject, audience) {
  const name = document.getElementById('em-ai-prompt').value.substring(0, 50);
  const audId = demoAudiences.find(a => a.name === audience)?.id || 1;
  const aud = demoAudiences.find(a => a.id === audId);

  // Create the campaign directly
  const now = new Date();
  const d = (4 - now.getDay() + 7) % 7 || 7;
  const t = new Date(now); t.setDate(now.getDate() + d); t.setHours(10, 0, 0, 0);

  demoCampaigns.unshift({
    id: Date.now(), name: 'IA: ' + name, subject, previewText: '', status: 'scheduled',
    audience: aud ? aud.name : '', audienceId: audId, sent: 0, opened: 0, clicked: 0,
    bounced: 0, spam: 0, unsubs: 0, date: t.toISOString().split('T')[0], templateId: 1, autoResend: true
  });

  document.getElementById('em-ai-gen-result').style.display = 'none';
  document.getElementById('em-ai-prompt').value = '';
  renderCampaigns(); renderStats();
  showToast('Campaña creada por IA y programada para ' + t.toLocaleDateString('es-MX', { weekday: 'long', hour: '2-digit', minute: '2-digit' }));
}

