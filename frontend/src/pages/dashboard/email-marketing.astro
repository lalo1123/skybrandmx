function handleCSVDrop(e){e.preventDefault();document.getElementById('em-csv-dropzone').style.borderColor='var(--border)';document.getElementById('em-csv-dropzone').style.background='transparent';if(e.dataTransfer.files[0])processCSVFile(e.dataTransfer.files[0]);}
function handleCSVSelect(input){if(input.files[0])processCSVFile(input.files[0]);}
function processCSVFile(file){
  if(file.size>10*1024*1024){alert('Archivo muy grande (máx 10MB)');return;}
  const reader=new FileReader();reader.onload=function(e){
    const lines=e.target.result.split('\n').filter(l=>l.trim());const headers=lines[0].split(',').map(h=>h.trim());const rows=lines.slice(1,6);const total=lines.length-1;
    document.getElementById('em-csv-preview').style.display='block';
    document.getElementById('em-csv-preview').innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;"><p style="font-size:12px;font-weight:700;color:var(--text-primary);">${file.name}</p><span style="font-size:11px;color:var(--accent);font-weight:600;">${total} contactos</span></div><div style="overflow-x:auto;border:1px solid var(--border);border-radius:8px;"><table style="width:100%;border-collapse:collapse;font-size:11px;"><thead><tr>${headers.map(h=>`<th style="padding:6px 10px;text-align:left;font-weight:700;color:var(--text-faint);text-transform:uppercase;font-size:10px;border-bottom:1px solid var(--border);">${h}</th>`).join('')}</tr></thead><tbody>${rows.map(r=>`<tr style="border-bottom:1px solid var(--border);">${r.split(',').map(c=>`<td style="padding:6px 10px;color:var(--text-secondary);">${c.trim()}</td>`).join('')}</tr>`).join('')}</tbody></table></div>`;
    document.getElementById('em-csv-dropzone').innerHTML=`<p style="font-size:13px;color:#22c55e;font-weight:700;">✓ ${file.name}</p><p style="font-size:11px;color:var(--text-faint);">${total} contactos</p>`;
  };reader.readAsText(file);
}

