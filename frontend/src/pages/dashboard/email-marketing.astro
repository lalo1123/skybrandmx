// ═══════ STATS WITH TRENDS ═══════
function renderStats() {
  const sent=demoCampaigns.filter(c=>c.status==='sent'||c.status==='ab_test');
  const ts=sent.reduce((s,c)=>s+c.sent,0), to=sent.reduce((s,c)=>s+c.opened,0);
  const tc=sent.reduce((s,c)=>s+c.clicked,0), tb=sent.reduce((s,c)=>s+c.bounced,0);
  const tu=sent.reduce((s,c)=>s+c.unsubs,0), totalSubs=demoAudiences.reduce((s,a)=>s+a.count,0);

  document.getElementById('em-stat-sent').textContent = sent.length;
  document.getElementById('em-stat-open').textContent = ts>0?((to/ts)*100).toFixed(1)+'%':'0%';
  document.getElementById('em-stat-clicks').textContent = ts>0?((tc/ts)*100).toFixed(1)+'%':'0%';
  document.getElementById('em-stat-subs').textContent = totalSubs.toLocaleString();
  document.getElementById('em-stat-bounces').textContent = ts>0?((tb/ts)*100).toFixed(1)+'%':'0%';
  document.getElementById('em-stat-unsubs').textContent = tu;

  // Trends
  setTrend('em-trend-sent','+2','vs mes pasado',true);
  setTrend('em-trend-open','+5.3%','vs mes pasado',true);
  setTrend('em-trend-clicks','+2.1%','vs mes pasado',true);
  setTrend('em-trend-subs','+385','vs mes pasado',true);
  setTrend('em-trend-bounces','-0.3%','vs mes pasado',true);
  setTrend('em-trend-unsubs','-2','vs mes pasado',true);
}
function setTrend(id,val,label,good) {
  const el=document.getElementById(id);
  if (!el) return;
  const isUp = val.startsWith('+');
  const isGood = (good && isUp) || (!good && !isUp);
  // For bounces and unsubs, down is good
  const color = id.includes('bounces')||id.includes('unsubs') ? (isUp?'#ef4444':'#22c55e') : (isUp?'#22c55e':'#ef4444');
  el.innerHTML = `<span style="color:${color};">${isUp?'▲':'▼'} ${val}</span>`;
  el.title = label;
}

