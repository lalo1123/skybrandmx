            <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:2px;background:var(--accent);"></div><span style="font-size:11px;color:var(--text-muted);">Apertura</span></div>
            <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:2px;background:#f97316;"></div><span style="font-size:11px;color:var(--text-muted);">Clics</span></div>
            <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:2px;background:#ef4444;"></div><span style="font-size:11px;color:var(--text-muted);">Rebotes</span></div>
          </div>
