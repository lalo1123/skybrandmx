function wizApplyOptimalTime(){
  const now=new Date();const d=(4-now.getDay()+7)%7||7;const t=new Date(now);t.setDate(now.getDate()+d);t.setHours(10,0,0,0);
  document.getElementById('em-wiz-schedule').value=t.toISOString().slice(0,16);showToast('Horario óptimo aplicado: Jueves 10:00 AM');
