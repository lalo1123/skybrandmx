        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Top campañas</h4>
          <div id="em-top-campaigns" style="display:flex;flex-direction:column;gap:10px;"></div>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:20px;">
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Crecimiento de suscriptores</h4>
          <div id="em-chart-growth" style="height:180px;display:flex;align-items:flex-end;gap:4px;"></div>
