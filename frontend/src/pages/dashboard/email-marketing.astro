  const name = prompt(type === 'embed' ? '¿Cómo se llamará tu formulario?' : '¿Cómo se llamará tu landing page?', type === 'embed' ? 'Suscripción a mi newsletter' : 'Oferta especial');
  if (!name) return;
  const colors = ['#6fcff5','#f97316','#22c55e','#8b5cf6','#ec4899'];
  demoForms.unshift({ id: Date.now(), name, type, fields: ['Nombre','Email'], subs: 0, status: 'active', color: colors[Math.floor(Math.random()*colors.length)], created: '2026-04-02' });
  renderForms();
  showToast(type === 'embed' ? 'Formulario creado. Copia el código y pégalo en tu sitio.' : 'Landing page creada.');
}

function copyFormCode(id) {
  const f = demoForms.find(x => x.id === id);
  if (!f) return;
  if (f.type === 'embed') {
    const code = `<!-- SkyBrandMX Form: ${f.name} -->\n<div id="skybrand-form-${f.id}"></div>\n<script src="https://app.skybrandmx.com/forms/${f.id}.js"><\/script>`;
    navigator.clipboard.writeText(code).then(() => showToast('Código copiado. Pégalo en tu sitio web.'));
  } else {
    navigator.clipboard.writeText(`https://app.skybrandmx.com/f/${f.id}`).then(() => showToast('Link copiado. Compártelo con tus clientes.'));
  }
}

function previewForm(id) {
  const f = demoForms.find(x => x.id === id);
  if (!f) return;
  alert(`Vista previa: "${f.name}"\n\nCampos: ${f.fields.join(', ')}\nTipo: ${f.type === 'embed' ? 'Formulario embebido' : 'Landing page'}\nSuscriptores: ${f.subs}\n\n(La vista previa completa estará disponible cuando se conecte el backend)`);
}

function toggleDoubleOptin(on) {
  document.getElementById('em-optin-status').textContent = on ? 'Activo' : 'Inactivo';
  document.getElementById('em-optin-status').style.color = on ? '#22c55e' : 'var(--text-faint)';
  showToast(on ? 'Doble confirmación activada' : 'Doble confirmación desactivada');
}

