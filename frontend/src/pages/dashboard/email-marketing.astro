          <div id="em-editor-blocks" style="padding:0;min-height:400px;"></div>
          <div id="em-editor-dropzone" style="border:2px dashed #cbd5e1;border-radius:8px;margin:16px;padding:32px;text-align:center;color:#94a3b8;font-size:13px;cursor:pointer;transition:all 0.2s;" onclick="addBlock('text')" ondragover="event.preventDefault();this.style.borderColor='var(--accent)';this.style.background='rgba(111,207,245,0.05)'" ondragleave="this.style.borderColor='#cbd5e1';this.style.background='transparent'" ondrop="handleBlockDrop(event);this.style.borderColor='#cbd5e1';this.style.background='transparent'">
