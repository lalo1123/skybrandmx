      <button onclick="${i.actionFn}" style="padding:6px 14px;border-radius:8px;border:none;background:${i.color};color:#fff;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">${i.action}</button>
    </div>`).join('');
}

// ═══════ AUTOPILOT ═══════
function renderAdsAutopilot(){
  const el=document.getElementById('ads-autopilot-list');if(!el)return;
  el.innerHTML=adsAutoFlows.map(f=>`<div style="padding:16px;border-radius:12px;border:1px solid ${f.active?f.color+'30':'var(--border)'};background:${f.active?f.color+'08':'var(--input-bg)'};">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;"><div style="display:flex;align-items:center;gap:8px;"><span style="font-size:18px;">${f.icon}</span><span style="font-size:13px;font-weight:800;color:var(--text-primary);">${f.name}</span></div><label class="ads-toggle-wrap"><input type="checkbox" ${f.active?'checked':''} onchange="adsAutoFlows.find(x=>x.id==='${f.id}').active=this.checked;renderAdsAutopilot();showToast(this.checked?'Activado':'Desactivado')"/><span class="ads-toggle-slider" style="${f.active?'--toggle-color:'+f.color:''}"></span></label></div>
    <p style="font-size:11px;color:var(--text-muted);line-height:1.4;">${f.desc}</p></div>`).join('');
}

// ═══════ INIT ═══════
document.addEventListener('DOMContentLoaded',()=>{
  ['campaigns','accounts','analytics'].forEach(t=>{if(localStorage.getItem('ads_help_'+t+'_dismissed')){const el=document.getElementById('ads-help-'+t);if(el)el.style.display='none';}});
  renderAdsRecs();renderAdsStats();renderAdsCampaigns();renderAdsAccounts();renderAdsAnalytics();renderAIcampaigns();renderAIinsights();renderAdsAutopilot();
});
</script>
