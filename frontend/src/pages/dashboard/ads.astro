---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Publicidad">
  <!-- Smart Recommendations -->
  <div id="ads-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Mode toggle: Manual vs IA -->
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
    <div style="display:flex;border:2px solid var(--border);border-radius:12px;overflow:hidden;">
      <button onclick="setAdsMode('manual')" id="ads-mode-manual" class="ads-mode-btn active">📊 Gestionar campañas</button>
      <button onclick="setAdsMode('ai')" id="ads-mode-ai" class="ads-mode-btn">🤖 Modo IA (automático)</button>
    </div>
    <span class="ads-tip" data-tip="En 'Gestionar campañas' tú controlas todo. En 'Modo IA' la inteligencia artificial crea, optimiza y gestiona tus anuncios automáticamente.">?</span>
  </div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ads-stat-label">Gasto del mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ads-stat-spend" class="ads-stat-val">--</p><span id="ads-trend-spend" class="ads-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ads-stat-label">Ventas desde ads <span class="ads-tip" data-tip="Ventas que llegaron directamente desde tus anuncios">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ads-stat-sales" class="ads-stat-val" style="color:#22c55e;">--</p><span id="ads-trend-sales" class="ads-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ads-stat-label">ROAS <span class="ads-tip" data-tip="Por cada peso que gastas en publicidad, ¿cuántos pesos ganas? Si dice 3.5x, significa que por cada $1 gastado ganaste $3.50">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ads-stat-roas" class="ads-stat-val" style="color:var(--accent);">--</p><span id="ads-trend-roas" class="ads-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ads-stat-label">Clics</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ads-stat-clicks" class="ads-stat-val">--</p><span id="ads-trend-clicks" class="ads-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ads-stat-label">Costo por venta <span class="ads-tip" data-tip="Cuánto te cuesta en publicidad conseguir una venta. Mientras más bajo, mejor.">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ads-stat-cpa" class="ads-stat-val" style="color:#f97316;">--</p><span id="ads-trend-cpa" class="ads-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ads-stat-label">Campañas activas</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ads-stat-active" class="ads-stat-val" style="color:#8b5cf6;">--</p></div>
    </div>
  </div>

  <!-- ══════════ MANUAL MODE ══════════ -->
  <div id="ads-panel-manual">
    <!-- Tabs -->
    <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
      <button id="ads-tab-campaigns" class="ads-tab active" onclick="switchAdsTab('campaigns')">Campañas</button>
      <button id="ads-tab-accounts" class="ads-tab" onclick="switchAdsTab('accounts')">Cuentas conectadas</button>
      <button id="ads-tab-analytics" class="ads-tab" onclick="switchAdsTab('analytics')">Analítica</button>
    </div>

    <!-- Tab: Campaigns -->
    <div id="ads-panel-campaigns">
      <div id="ads-help-campaigns" class="ads-help-banner">
        <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aquí ves todas tus campañas de publicidad de Meta (Facebook/Instagram) y Google en un solo lugar.</p>
        <button onclick="adsDismissHelp('campaigns')" class="ads-help-close">&times;</button>
      </div>
      <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
        <div style="flex:1;min-width:200px;position:relative;">
          <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input id="ads-search" type="text" placeholder="Buscar campañas..." oninput="adsFilter()" class="ads-input" style="padding-left:38px;"/>
        </div>
        <select id="ads-filter-platform" onchange="adsFilter()" class="ads-input" style="width:auto;cursor:pointer;">
          <option value="">Todas las plataformas</option>
          <option value="meta">Meta (FB/IG)</option>
          <option value="google">Google</option>
          <option value="tiktok">TikTok</option>
        </select>
        <select id="ads-filter-status" onchange="adsFilter()" class="ads-input" style="width:auto;cursor:pointer;">
          <option value="">Todos los estados</option>
          <option value="active">Activa</option>
          <option value="paused">Pausada</option>
          <option value="ended">Finalizada</option>
        </select>
      </div>
      <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:13px;">
            <thead><tr style="border-bottom:1px solid var(--border);">
              <th class="ads-th">Campaña</th><th class="ads-th">Plataforma</th><th class="ads-th">Estado</th>
              <th class="ads-th" style="text-align:right;">Gasto</th><th class="ads-th" style="text-align:right;">Clics</th>
              <th class="ads-th" style="text-align:right;">Ventas</th><th class="ads-th" style="text-align:right;">ROAS</th>
              <th class="ads-th" style="text-align:center;">Acciones</th>
            </tr></thead>
            <tbody id="ads-campaigns-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Tab: Accounts -->
    <div id="ads-panel-accounts" style="display:none;">
      <div id="ads-help-accounts" class="ads-help-banner">
        <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p style="flex:1;font-size:12px;color:var(--text-secondary);">Conecta tus cuentas de publicidad para ver todas tus campañas aquí. Solo necesitas hacerlo una vez.</p>
        <button onclick="adsDismissHelp('accounts')" class="ads-help-close">&times;</button>
      </div>
      <div id="ads-accounts-list" style="display:flex;flex-direction:column;gap:12px;"></div>
    </div>

    <!-- Tab: Analytics -->
    <div id="ads-panel-analytics" style="display:none;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:20px;">
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Gasto vs Ventas por mes</h4>
          <div id="ads-chart-spend" style="height:200px;display:flex;align-items:flex-end;gap:6px;"></div>
          <div style="display:flex;gap:16px;margin-top:12px;">
            <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:2px;background:#ef4444;"></div><span style="font-size:11px;color:var(--text-muted);">Gasto</span></div>
            <div style="display:flex;align-items:center;gap:6px;"><div style="width:10px;height:10px;border-radius:2px;background:#22c55e;"></div><span style="font-size:11px;color:var(--text-muted);">Ventas</span></div>
          </div>
        </div>
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Rendimiento por plataforma</h4>
          <div id="ads-chart-platforms"></div>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;">
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Top campañas por ROAS</h4>
          <div id="ads-chart-top"></div>
        </div>
        <div class="stat-card animate-in" style="padding:20px;">
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Distribución de presupuesto</h4>
          <div id="ads-chart-budget"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ AI MODE ══════════ -->
  <div id="ads-panel-ai" style="display:none;">
    <div class="ads-help-banner">
      <svg style="width:16px;height:16px;color:#8b5cf6;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">En modo IA, solo dile qué quieres vender y cuánto quieres gastar. La IA se encarga de crear los anuncios, elegir la audiencia y optimizar el presupuesto automáticamente.</p>
    </div>

    <!-- AI Campaign Creator -->
    <div class="stat-card animate-in" style="padding:0;margin-bottom:20px;overflow:hidden;background:linear-gradient(135deg,rgba(139,92,246,0.06),rgba(111,207,245,0.06));border:1px solid rgba(139,92,246,0.15);">
      <div style="padding:24px;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
          <div style="width:40px;height:40px;border-radius:12px;background:linear-gradient(135deg,#8b5cf6,#6fcff5);display:flex;align-items:center;justify-content:center;">
            <svg style="width:20px;height:20px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);">Crear campaña con IA</h3>
            <p style="font-size:12px;color:var(--text-muted);">Dile a la IA qué producto quieres vender y ella hace el resto.</p>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div><label class="ads-label">¿Qué quieres promocionar?</label><input id="ads-ai-product" type="text" placeholder="Ej: Mi nueva colección de blusas bordadas" class="ads-input"/></div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;">
            <div><label class="ads-label">Presupuesto diario</label><input id="ads-ai-budget" type="number" value="200" class="ads-input" placeholder="$200"/></div>
            <div>
              <label class="ads-label">¿Dónde publicar?</label>
              <select id="ads-ai-platforms" class="ads-input" style="cursor:pointer;">
                <option value="all" selected>Todas (recomendado)</option>
                <option value="meta">Solo Meta (FB/IG)</option>
                <option value="google">Solo Google</option>
                <option value="tiktok">Solo TikTok</option>
              </select>
            </div>
            <div>
              <label class="ads-label">Objetivo</label>
              <select id="ads-ai-goal" class="ads-input" style="cursor:pointer;">
                <option value="sales" selected>Vender más</option>
                <option value="traffic">Más visitas a mi tienda</option>
                <option value="leads">Captar contactos</option>
                <option value="awareness">Que me conozcan</option>
              </select>
            </div>
          </div>
          <button onclick="adsAICreate()" style="padding:12px;border-radius:10px;border:none;background:linear-gradient(135deg,#8b5cf6,#6fcff5);color:#fff;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">
            <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            La IA crea mi campaña
          </button>
        </div>
        <div id="ads-ai-result" style="display:none;margin-top:16px;"></div>
      </div>
    </div>

    <!-- AI Active Campaigns -->
    <h3 style="font-size:15px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">Campañas gestionadas por IA</h3>
    <div id="ads-ai-campaigns" style="display:flex;flex-direction:column;gap:12px;margin-bottom:20px;"></div>

    <!-- AI Insights -->
    <h3 style="font-size:15px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">Recomendaciones de la IA</h3>
    <div id="ads-ai-insights" style="display:flex;flex-direction:column;gap:10px;"></div>
  </div>

  <!-- Autopilot -->
  <div class="stat-card animate-in" style="padding:0;margin-top:20px;overflow:hidden;">
    <button onclick="adsToggleSection('ads-autopilot-content')" class="ads-collapse-header">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,rgba(34,197,94,0.15),rgba(111,207,245,0.15));display:flex;align-items:center;justify-content:center;">
          <svg style="width:14px;height:14px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div style="text-align:left;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">Piloto automático de publicidad</p><p style="font-size:11px;color:var(--text-faint);">Deja que la IA optimice tus campañas</p></div>
      </div>
      <svg style="width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </button>
    <div id="ads-autopilot-content" style="display:none;padding:20px;">
      <div id="ads-autopilot-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;"></div>
    </div>
  </div>
</DashboardLayout>

<style>
  .ads-stat-label { font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px; }
  .ads-stat-val { font-size:28px;font-weight:900;color:var(--text-primary); }
  .ads-trend { font-size:11px;font-weight:700; }
  .ads-mode-btn { padding:12px 24px;border:none;background:transparent;color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s; }
  .ads-mode-btn.active { background:var(--accent-bg);color:var(--accent); }
  .ads-tab { padding:10px 20px;border:none;background:transparent;color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;white-space:nowrap; }
  .ads-tab.active { color:var(--accent);border-bottom-color:var(--accent); }
  .ads-th { padding:14px 16px;text-align:left;font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px; }
  .ads-label { font-size:12px;font-weight:700;color:var(--text-muted);margin-bottom:4px;display:block; }
  .ads-input { width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;outline:none;transition:border-color 0.2s; }
  .ads-input:focus { border-color:var(--accent); }
  .ads-tbl-btn { padding:5px 9px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;cursor:pointer;transition:all 0.15s; }
  .ads-tbl-btn:hover { border-color:var(--accent);color:var(--accent); }
  .ads-help-banner { display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:10px;background:var(--accent-bg);border:1px solid rgba(111,207,245,0.15);margin-bottom:16px; }
  .ads-help-close { border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:16px;padding:0 4px; }
  .ads-tip { display:inline-flex;align-items:center;justify-content:center;width:16px;height:16px;border-radius:50%;background:var(--input-bg);color:var(--text-faint);font-size:10px;font-weight:800;cursor:help;position:relative;flex-shrink:0; }
  .ads-tip:hover::after { content:attr(data-tip);position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:var(--bg-sidebar);border:1px solid var(--border);color:var(--text-secondary);padding:10px 14px;border-radius:10px;font-size:12px;font-weight:500;white-space:normal;width:280px;z-index:100;box-shadow:0 4px 20px rgba(0,0,0,0.3);line-height:1.5;pointer-events:none; }
  .ads-tip:hover::before { content:'';position:absolute;bottom:calc(100% + 2px);left:50%;transform:translateX(-50%);border:6px solid transparent;border-top-color:var(--border);z-index:101; }
  .ads-collapse-header { width:100%;display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border:none;background:transparent;cursor:pointer;transition:background 0.15s; }
  .ads-collapse-header:hover { background:var(--nav-hover); }
  .ads-toggle-wrap { position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0; }
  .ads-toggle-wrap input { opacity:0;width:0;height:0; }
  .ads-toggle-slider { position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:var(--border);border-radius:22px;transition:0.3s; }
  .ads-toggle-slider::before { content:'';position:absolute;height:16px;width:16px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:0.3s; }
  .ads-toggle-wrap input:checked + .ads-toggle-slider { background:var(--toggle-color, #22c55e); }
  .ads-toggle-wrap input:checked + .ads-toggle-slider::before { transform:translateX(18px); }
</style>

<script is:inline>
// ═══════ DEMO DATA ═══════
const demoCampaigns = [
  { id:1, name:'Promo Verano - Blusas', platform:'meta', status:'active', spend:4500, clicks:1230, impressions:45000, sales:42, revenue:18900, cpa:107, roas:4.2, date:'2026-03-15' },
  { id:2, name:'Google Shopping - Accesorios', platform:'google', status:'active', spend:3200, clicks:890, impressions:32000, sales:28, revenue:11200, cpa:114, roas:3.5, date:'2026-03-18' },
  { id:3, name:'Instagram Stories - Huaraches', platform:'meta', status:'active', spend:2100, clicks:650, impressions:28000, sales:18, revenue:16020, cpa:117, roas:7.6, date:'2026-03-20' },
  { id:4, name:'Remarketing - Carritos abandonados', platform:'meta', status:'active', spend:1800, clicks:420, impressions:15000, sales:24, revenue:9600, cpa:75, roas:5.3, date:'2026-03-10' },
  { id:5, name:'Google Search - Regalos artesanales', platform:'google', status:'paused', spend:1500, clicks:380, impressions:12000, sales:12, revenue:5400, cpa:125, roas:3.6, date:'2026-03-05' },
  { id:6, name:'TikTok - Colección nueva', platform:'tiktok', status:'active', spend:2800, clicks:2100, impressions:95000, sales:15, revenue:6750, cpa:187, roas:2.4, date:'2026-03-25' },
  { id:7, name:'Meta - Black Friday early', platform:'meta', status:'ended', spend:5200, clicks:3400, impressions:120000, sales:65, revenue:32500, cpa:80, roas:6.3, date:'2026-02-20' },
];

const adsAccounts = [
  { id:'meta', name:'Meta Business (Facebook + Instagram)', icon:'📘', color:'#1877f2', connected:true, accountName:'SkyBrandMX', campaigns:4, spend:'$8,400' },
  { id:'google', name:'Google Ads', icon:'🔍', color:'#4285f4', connected:true, accountName:'SkyBrandMX Ads', campaigns:2, spend:'$4,700' },
  { id:'tiktok', name:'TikTok Ads', icon:'🎵', color:'#000', connected:true, accountName:'@skybrandmx', campaigns:1, spend:'$2,800' },
  { id:'pinterest', name:'Pinterest Ads', icon:'📌', color:'#e60023', connected:false },
  { id:'twitter', name:'X (Twitter) Ads', icon:'🐦', color:'#1da1f2', connected:false },
];

const adsAutoFlows = [
  { id:'optimize', name:'Optimizar presupuesto automático', desc:'La IA mueve presupuesto a las campañas que mejor funcionan', icon:'💰', color:'#22c55e', active:true },
  { id:'pause_bad', name:'Pausar campañas malas', desc:'Pausa automáticamente campañas con ROAS menor a 2x', icon:'⏸', color:'#f97316', active:true },
  { id:'scale_good', name:'Escalar campañas buenas', desc:'Aumenta presupuesto automáticamente a campañas con ROAS mayor a 4x', icon:'📈', color:'#6fcff5', active:false },
  { id:'retarget', name:'Remarketing automático', desc:'Crea campañas de remarketing para personas que visitaron tu tienda sin comprar', icon:'🎯', color:'#8b5cf6', active:true },
  { id:'lookalike', name:'Audiencias similares', desc:'Crea automáticamente audiencias parecidas a tus mejores clientes', icon:'👥', color:'#ec4899', active:false },
  { id:'creative', name:'Rotar creativos', desc:'Prueba diferentes imágenes y textos automáticamente y usa los que funcionan mejor', icon:'🎨', color:'#eab308', active:false },
];

const aiInsights = [
  { icon:'💡', color:'#eab308', text:'Tu campaña "Instagram Stories - Huaraches" tiene un ROAS de 7.6x. La IA recomienda aumentar su presupuesto de $2,100 a $3,500/mes.', action:'Aplicar', actionFn:"showToast('Presupuesto aumentado')" },
