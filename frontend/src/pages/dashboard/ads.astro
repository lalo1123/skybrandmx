// ═══════ HELPERS ═══════
function adsDismissHelp(t){document.getElementById('ads-help-'+t).style.display='none';localStorage.setItem('ads_help_'+t+'_dismissed','1');}
function adsToggleSection(id){const el=document.getElementById(id);el.style.display=el.style.display==='none'?'block':'none';}
function showToast(msg){const ex=document.getElementById('ads-toast');if(ex)ex.remove();const t=document.createElement('div');t.id='ads-toast';t.textContent=msg;Object.assign(t.style,{position:'fixed',bottom:'24px',right:'24px',background:'#22c55e',color:'#fff',padding:'12px 24px',borderRadius:'10px',fontSize:'13px',fontWeight:'700',zIndex:'9999',boxShadow:'0 4px 20px rgba(0,0,0,0.3)'});document.body.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity 0.3s';setTimeout(()=>t.remove(),300);},3000);}

function setAdsMode(mode){
  document.getElementById('ads-mode-manual').classList.toggle('active',mode==='manual');
  document.getElementById('ads-mode-ai').classList.toggle('active',mode==='ai');
  document.getElementById('ads-panel-manual').style.display=mode==='manual'?'':'none';
  document.getElementById('ads-panel-ai').style.display=mode==='ai'?'':'none';
}
function switchAdsTab(tab){
  document.querySelectorAll('.ads-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('ads-tab-'+tab).classList.add('active');
  ['campaigns','accounts','analytics'].forEach(p=>document.getElementById('ads-panel-'+p).style.display=p===tab?'':'none');
}

// ═══════ STATS ═══════
function renderAdsStats(){
  const active=demoCampaigns.filter(c=>c.status==='active');
  const totalSpend=active.reduce((s,c)=>s+c.spend,0);
  const totalSales=active.reduce((s,c)=>s+c.revenue,0);
  const totalClicks=active.reduce((s,c)=>s+c.clicks,0);
  const totalConv=active.reduce((s,c)=>s+c.sales,0);
  document.getElementById('ads-stat-spend').textContent='$'+totalSpend.toLocaleString();
  document.getElementById('ads-stat-sales').textContent='$'+totalSales.toLocaleString();
  document.getElementById('ads-stat-roas').textContent=totalSpend>0?(totalSales/totalSpend).toFixed(1)+'x':'0x';
  document.getElementById('ads-stat-clicks').textContent=totalClicks.toLocaleString();
  document.getElementById('ads-stat-cpa').textContent='$'+(totalConv>0?Math.round(totalSpend/totalConv):0);
  document.getElementById('ads-stat-active').textContent=active.length;
  setT('ads-trend-spend','+12%');setT('ads-trend-sales','+28%');setT('ads-trend-roas','+0.8x');setT('ads-trend-clicks','+15%');setT('ads-trend-cpa','-$18');
}
function setT(id,val){const el=document.getElementById(id);if(!el)return;const up=val.startsWith('+');const color=id.includes('cpa')?(up?'#ef4444':'#22c55e'):id.includes('spend')?(up?'#f97316':'#22c55e'):(up?'#22c55e':'#ef4444');el.innerHTML=`<span style="color:${color};">${up?'▲':'▼'} ${val}</span>`;}

// ═══════ SMART RECS ═══════
function renderAdsRecs(){
  const el=document.getElementById('ads-smart-recs');if(!el)return;const recs=[];
  const bestCamp=demoCampaigns.filter(c=>c.status==='active').sort((a,b)=>b.roas-a.roas)[0];
  if(bestCamp&&bestCamp.roas>4)recs.push({icon:'🚀',color:'#22c55e',title:`"${bestCamp.name}" tiene ROAS de ${bestCamp.roas}x`,desc:'La IA recomienda aumentar su presupuesto para maximizar ventas.',btn:'Escalar',action:"showToast('Presupuesto aumentado por IA')"});
  const worstCamp=demoCampaigns.filter(c=>c.status==='active').sort((a,b)=>a.roas-b.roas)[0];
  if(worstCamp&&worstCamp.roas<3)recs.push({icon:'⚠',color:'#f97316',title:`"${worstCamp.name}" tiene ROAS bajo (${worstCamp.roas}x)`,desc:'Considera pausarla o dejar que la IA optimice el contenido.',btn:'Optimizar con IA',action:"setAdsMode('ai');showToast('Modo IA activado')"});
  if(!recs.length){el.style.display='none';return;}
  el.style.display='flex';
  el.innerHTML=recs.map(r=>`<div style="display:flex;align-items:center;gap:14px;padding:14px 18px;border-radius:12px;background:${r.color}08;border:1px solid ${r.color}20;"><span style="font-size:24px;flex-shrink:0;">${r.icon}</span><div style="flex:1;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">${r.title}</p><p style="font-size:11px;color:var(--text-muted);margin-top:2px;">${r.desc}</p></div><button onclick="${r.action}" style="padding:8px 16px;border-radius:8px;border:none;background:${r.color};color:#fff;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">${r.btn}</button><button onclick="this.closest('div[style]').remove()" style="border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:14px;padding:0 4px;">✕</button></div>`).join('');
}

// ═══════ CAMPAIGNS TABLE ═══════
function renderAdsCampaigns(){
  const tbody=document.getElementById('ads-campaigns-tbody');let data=[...demoCampaigns];
  const search=document.getElementById('ads-search').value.toLowerCase();
  const pf=document.getElementById('ads-filter-platform').value;
  const sf=document.getElementById('ads-filter-status').value;
  if(search)data=data.filter(c=>c.name.toLowerCase().includes(search));
  if(pf)data=data.filter(c=>c.platform===pf);
  if(sf)data=data.filter(c=>c.status===sf);
  if(!data.length){tbody.innerHTML='<tr><td colspan="8" style="padding:40px;text-align:center;color:var(--text-faint);">No se encontraron campañas</td></tr>';return;}
  tbody.innerHTML=data.map(c=>{const pl=platformMap[c.platform];const st=statusMap[c.status];const roasColor=c.roas>=4?'#22c55e':c.roas>=2?'#eab308':'#ef4444';return`<tr style="border-bottom:1px solid var(--border);transition:background 0.15s;" onmouseover="this.style.background='var(--bg-card-hover)'" onmouseout="this.style.background='transparent'">
    <td style="padding:14px 16px;"><p style="font-weight:700;color:var(--text-primary);">${c.name}</p><p style="font-size:11px;color:var(--text-faint);">Desde ${c.date}</p></td>
    <td style="padding:14px 16px;"><div style="display:flex;align-items:center;gap:6px;"><span style="font-size:14px;">${pl.icon}</span><span style="font-size:12px;font-weight:600;color:var(--text-primary);">${pl.l}</span></div></td>
    <td style="padding:14px 16px;"><span style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;color:${st.c};background:${st.b};">${st.l}</span></td>
    <td style="padding:14px 16px;text-align:right;font-weight:700;color:var(--text-primary);">$${c.spend.toLocaleString()}</td>
    <td style="padding:14px 16px;text-align:right;color:var(--text-secondary);">${c.clicks.toLocaleString()}</td>
    <td style="padding:14px 16px;text-align:right;color:#22c55e;font-weight:700;">${c.sales} ($${c.revenue.toLocaleString()})</td>
    <td style="padding:14px 16px;text-align:right;font-weight:900;color:${roasColor};">${c.roas}x</td>
    <td style="padding:14px 16px;text-align:center;"><div style="display:flex;gap:4px;justify-content:center;">
      ${c.status==='active'?`<button onclick="demoCampaigns.find(x=>x.id===${c.id}).status='paused';renderAdsCampaigns();renderAdsStats();showToast('Campaña pausada')" class="ads-tbl-btn" style="border-color:#f97316;color:#f97316;">Pausar</button>`:''}
      ${c.status==='paused'?`<button onclick="demoCampaigns.find(x=>x.id===${c.id}).status='active';renderAdsCampaigns();renderAdsStats();showToast('Campaña reactivada')" class="ads-tbl-btn" style="border-color:#22c55e;color:#22c55e;">Activar</button>`:''}
    </div></td>
  </tr>`;}).join('');
}
function adsFilter(){renderAdsCampaigns();}

