// ═══════ ANALYTICS ═══════
function renderAdsAnalytics(){
  // Spend vs Sales
  const months=['Oct','Nov','Dic','Ene','Feb','Mar'];
  const spends=[8500,12000,18500,14200,16800,21100];const salesA=[28000,38000,62000,48000,56000,72000];const mV=Math.max(...salesA);
  document.getElementById('ads-chart-spend').innerHTML=months.map((m,i)=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;"><div style="width:100%;display:flex;gap:2px;align-items:flex-end;height:170px;"><div style="flex:1;background:#ef4444;border-radius:3px 3px 0 0;height:${(spends[i]/mV)*170}px;opacity:0.8;" title="Gasto: $${spends[i].toLocaleString()}"></div><div style="flex:1;background:#22c55e;border-radius:3px 3px 0 0;height:${(salesA[i]/mV)*170}px;opacity:0.8;" title="Ventas: $${salesA[i].toLocaleString()}"></div></div><span style="font-size:10px;color:var(--text-faint);font-weight:600;">${m}</span></div>`).join('');

  // By platform
  const platforms=[{n:'Meta (FB/IG)',spend:8400,sales:42000,roas:5.0,c:'#1877f2'},{n:'Google',spend:4700,sales:16600,roas:3.5,c:'#4285f4'},{n:'TikTok',spend:2800,sales:6750,roas:2.4,c:'#000'}];
  document.getElementById('ads-chart-platforms').innerHTML=platforms.map(p=>`<div style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);">
    <div style="width:10px;height:10px;border-radius:3px;background:${p.c};flex-shrink:0;"></div>
    <div style="flex:1;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">${p.n}</p><p style="font-size:11px;color:var(--text-faint);">Gasto: $${p.spend.toLocaleString()} · Ventas: $${p.sales.toLocaleString()}</p></div>
    <span style="font-size:16px;font-weight:900;color:${p.roas>=4?'#22c55e':p.roas>=2?'#eab308':'#ef4444'};">${p.roas}x</span>
  </div>`).join('');

  // Top by ROAS
  const top=demoCampaigns.sort((a,b)=>b.roas-a.roas).slice(0,5);
  document.getElementById('ads-chart-top').innerHTML=top.map((c,i)=>`<div style="display:flex;align-items:center;gap:12px;padding:8px 0;${i<top.length-1?'border-bottom:1px solid var(--border);':''}">
    <span style="width:20px;height:20px;border-radius:6px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;color:var(--accent);">${i+1}</span>
    <div style="flex:1;"><p style="font-size:12px;font-weight:700;color:var(--text-primary);">${c.name}</p><p style="font-size:10px;color:var(--text-faint);">${platformMap[c.platform].l}</p></div>
    <span style="font-size:14px;font-weight:900;color:${c.roas>=4?'#22c55e':'#eab308'};">${c.roas}x</span>
  </div>`).join('');

  // Budget distribution
  const totalBudget=demoCampaigns.filter(c=>c.status==='active').reduce((s,c)=>s+c.spend,0);
  const byPlat={};demoCampaigns.filter(c=>c.status==='active').forEach(c=>{byPlat[c.platform]=(byPlat[c.platform]||0)+c.spend;});
  const budgetData=Object.entries(byPlat).map(([k,v])=>({...platformMap[k],spend:v,pct:Math.round(v/totalBudget*100)}));
  document.getElementById('ads-chart-budget').innerHTML=`<div style="display:flex;height:24px;border-radius:12px;overflow:hidden;margin-bottom:16px;">${budgetData.map(p=>`<div style="width:${p.pct}%;background:${p.c};" title="${p.l}: ${p.pct}%"></div>`).join('')}</div>${budgetData.map(p=>`<div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;"><div style="display:flex;align-items:center;gap:8px;"><div style="width:10px;height:10px;border-radius:3px;background:${p.c};"></div><span style="font-size:12px;color:var(--text-secondary);">${p.l}</span></div><span style="font-size:13px;font-weight:800;color:var(--text-primary);">$${p.spend.toLocaleString()} (${p.pct}%)</span></div>`).join('')}`;
}

// ═══════ AI MODE ═══════
function adsAICreate(){
  const product=document.getElementById('ads-ai-product').value.trim();
  if(!product){alert('Escribe qué quieres promocionar');return;}
  const budget=document.getElementById('ads-ai-budget').value||200;
  const goal=document.getElementById('ads-ai-goal').selectedOptions[0]?.text||'Vender más';
  const result=document.getElementById('ads-ai-result');
  result.style.display='block';
  result.innerHTML='<div style="padding:16px;text-align:center;"><p style="color:var(--text-muted);">La IA está creando tu campaña...</p></div>';

  setTimeout(()=>{
    result.innerHTML=`
      <div style="padding:16px;border-top:1px solid var(--border);">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:12px;"><svg style="width:16px;height:16px;color:#8b5cf6;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg><p style="font-size:13px;font-weight:800;color:#8b5cf6;">Campaña generada por IA</p></div>
        <div style="display:grid;grid-template-columns:100px 1fr;gap:8px;font-size:12px;margin-bottom:16px;">
          <span style="color:var(--text-faint);font-weight:700;">Nombre:</span><span style="color:var(--text-primary);font-weight:600;">IA: ${product.substring(0,40)}</span>
          <span style="color:var(--text-faint);font-weight:700;">Plataformas:</span><span style="color:var(--text-primary);">Meta (FB + IG) + Google</span>
          <span style="color:var(--text-faint);font-weight:700;">Presupuesto:</span><span style="color:var(--text-primary);">$${parseInt(budget).toLocaleString()}/día ($${(parseInt(budget)*30).toLocaleString()}/mes)</span>
          <span style="color:var(--text-faint);font-weight:700;">Objetivo:</span><span style="color:var(--text-primary);">${goal}</span>
          <span style="color:var(--text-faint);font-weight:700;">Audiencia:</span><span style="color:var(--text-primary);">Mujeres 25-45, intereses: moda artesanal, regalos mexicanos</span>
          <span style="color:var(--text-faint);font-weight:700;">Textos:</span><span style="color:var(--text-primary);">3 variantes generadas por IA (se prueban automáticamente)</span>
        </div>
        <p style="font-size:11px;color:var(--text-faint);margin-bottom:12px;">La IA creará 3 variantes de anuncio, probará cuál funciona mejor y optimizará automáticamente.</p>
        <div style="display:flex;gap:10px;">
          <button onclick="adsAILaunch('${product.substring(0,40)}',${budget})" style="flex:1;padding:12px;border-radius:10px;border:none;background:linear-gradient(135deg,#8b5cf6,#6fcff5);color:#fff;font-size:13px;font-weight:700;cursor:pointer;">Lanzar campaña</button>
          <button onclick="document.getElementById('ads-ai-result').style.display='none'" style="flex:0;padding:12px 16px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-primary);font-size:13px;font-weight:700;cursor:pointer;">Cancelar</button>
        </div>
      </div>`;
  },1200);
}

function adsAILaunch(name,budget){
  demoCampaigns.unshift({id:Date.now(),name:'IA: '+name,platform:'meta',status:'active',spend:0,clicks:0,impressions:0,sales:0,revenue:0,cpa:0,roas:0,date:'2026-04-02'});
  document.getElementById('ads-ai-result').style.display='none';
  document.getElementById('ads-ai-product').value='';
  renderAdsCampaigns();renderAdsStats();renderAIcampaigns();
  showToast('Campaña lanzada por IA. Se optimizará automáticamente.');
}

function renderAIcampaigns(){
  const el=document.getElementById('ads-ai-campaigns');
  const aiCamps=demoCampaigns.filter(c=>c.name.startsWith('IA:'));
  if(!aiCamps.length){
    el.innerHTML='<div style="text-align:center;padding:24px;color:var(--text-faintest);font-size:13px;">No tienes campañas gestionadas por IA. Crea una arriba.</div>';
    return;
  }
  el.innerHTML=aiCamps.map(c=>{
    const st=statusMap[c.status];
    return`<div class="stat-card" style="padding:16px;background:linear-gradient(135deg,rgba(139,92,246,0.03),rgba(111,207,245,0.03));border:1px solid rgba(139,92,246,0.1);">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
        <div style="display:flex;align-items:center;gap:6px;"><span style="font-size:10px;padding:3px 8px;border-radius:4px;background:rgba(139,92,246,0.1);color:#8b5cf6;font-weight:700;">IA</span><span style="font-size:14px;font-weight:800;color:var(--text-primary);">${c.name.replace('IA: ','')}</span></div>
        <span style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;color:${st.c};background:${st.b};">${st.l}</span>
      </div>
      <div style="display:flex;gap:16px;">
        <div><p style="font-size:10px;color:var(--text-faint);">Gasto</p><p style="font-size:14px;font-weight:800;color:var(--text-primary);">$${c.spend.toLocaleString()}</p></div>
        <div><p style="font-size:10px;color:var(--text-faint);">Ventas</p><p style="font-size:14px;font-weight:800;color:#22c55e;">${c.sales}</p></div>
        <div><p style="font-size:10px;color:var(--text-faint);">ROAS</p><p style="font-size:14px;font-weight:800;color:var(--accent);">${c.roas}x</p></div>
      </div>
    </div>`;
  }).join('');
}

function renderAIinsights(){
  const el=document.getElementById('ads-ai-insights');
  el.innerHTML=aiInsights.map(i=>`
    <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;border-radius:12px;background:${i.color}08;border:1px solid ${i.color}20;">
      <span style="font-size:20px;flex-shrink:0;">${i.icon}</span>
