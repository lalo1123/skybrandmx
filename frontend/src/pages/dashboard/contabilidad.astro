// ═══════ HELPERS ═══════
function conDismissHelp(t) {
  const el = document.getElementById('con-help-' + t);
  if (el) el.style.display = 'none';
  try { localStorage.setItem('con_help_' + t + '_dismissed', '1'); } catch(e){}
}

function conRestoreHelp() {
  ['main','resumen','catalogo','polizas','impuestos','reportes','conciliacion'].forEach(t => {
    try {
      if (localStorage.getItem('con_help_' + t + '_dismissed') === '1') {
        const el = document.getElementById('con-help-' + t);
        if (el) el.style.display = 'none';
      }
    } catch(e){}
  });
}

function conToggleSection(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

function showToast(msg) {
  const ex = document.getElementById('con-toast');
  if (ex) ex.remove();
  const t = document.createElement('div');
  t.id = 'con-toast';
  t.textContent = msg;
  Object.assign(t.style, {
    position: 'fixed', bottom: '24px', right: '24px',
    background: '#22c55e', color: '#fff', padding: '12px 24px',
    borderRadius: '10px', fontSize: '13px', fontWeight: '700',
    zIndex: '9999', boxShadow: '0 4px 20px rgba(0,0,0,0.3)'
  });
  document.body.appendChild(t);
  setTimeout(() => {
    t.style.opacity = '0';
    t.style.transition = 'opacity 0.3s';
    setTimeout(() => t.remove(), 300);
  }, 3000);
}

function switchConTab(tab) {
  document.querySelectorAll('.con-tab').forEach(t => t.classList.remove('active'));
  const tabBtn = document.getElementById('con-tab-' + tab);
  if (tabBtn) tabBtn.classList.add('active');
  ['resumen','catalogo','polizas','impuestos','reportes','conciliacion'].forEach(p => {
    const el = document.getElementById('con-panel-' + p);
    if (el) el.style.display = p === tab ? '' : 'none';
  });
}

function fmt(n) {
  if (n === 0 || n === null || n === undefined) return '$0';
  const neg = n < 0;
  const abs = Math.abs(n);
  return (neg ? '-$' : '$') + abs.toLocaleString('en-US');
}

