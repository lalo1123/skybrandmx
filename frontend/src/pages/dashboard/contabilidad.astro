---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Contabilidad">
  <!-- Smart Recommendations -->
  <div id="con-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Main Help Banner -->
  <div id="con-help-main" class="con-help-banner" style="margin-bottom:20px;">
    <svg style="width:18px;height:18px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <div style="flex:1;">
      <p style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:3px;">Contabilidad sin complicaciones</p>
      <p style="font-size:12px;color:var(--text-secondary);line-height:1.5;">Aqui llevas las cuentas de tu negocio: lo que entra, lo que sale y lo que le debes al SAT. Nosotros clasificamos todo automaticamente y te preparamos tus declaraciones. No necesitas saber contabilidad.</p>
    </div>
    <button onclick="conDismissHelp('main')" class="con-help-close">&times;</button>
  </div>

  <!-- Stats bar (6 stats) -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="con-stat-label">Ingresos del mes</p>
      <p class="con-stat-val" style="color:#22c55e;">$158,200</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="con-stat-label">Gastos del mes</p>
      <p class="con-stat-val" style="color:#ef4444;">$109,600</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="con-stat-label">Utilidad neta <span class="con-tip" data-tip="Lo que realmente ganas despues de todos los gastos">?</span></p>
      <p class="con-stat-val" style="color:var(--accent);">$48,600</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="con-stat-label">IVA por pagar <span class="con-tip" data-tip="IVA que debes declarar al SAT este mes">?</span></p>
      <p class="con-stat-val" style="color:#f97316;">$7,776</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="con-stat-label">ISR estimado <span class="con-tip" data-tip="Impuesto Sobre la Renta - lo que le pagas al SAT sobre tus ganancias">?</span></p>
      <p class="con-stat-val" style="color:#8b5cf6;">$14,580</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="con-stat-label">Proxima declaracion <span class="con-tip" data-tip="Fecha limite para presentar tu declaracion mensual al SAT">?</span></p>
      <p class="con-stat-val" style="color:#ef4444;font-size:22px;">15 dias</p>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="con-tab-resumen" class="con-tab active" onclick="switchConTab('resumen')">Resumen</button>
    <button id="con-tab-catalogo" class="con-tab" onclick="switchConTab('catalogo')">Catalogo de cuentas</button>
    <button id="con-tab-polizas" class="con-tab" onclick="switchConTab('polizas')">Polizas / Movimientos</button>
    <button id="con-tab-impuestos" class="con-tab" onclick="switchConTab('impuestos')">Impuestos (SAT)</button>
    <button id="con-tab-reportes" class="con-tab" onclick="switchConTab('reportes')">Reportes fiscales</button>
    <button id="con-tab-conciliacion" class="con-tab" onclick="switchConTab('conciliacion')">Conciliacion</button>
  </div>

  <!-- ══════════ Tab: Resumen ══════════ -->
  <div id="con-panel-resumen">
    <div id="con-help-resumen" class="con-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">El estado de resultados muestra cuanto ganaste (ingresos), cuanto gastaste (gastos) y cuanto te quedo (utilidad) en cada mes.</p>
      <button onclick="conDismissHelp('resumen')" class="con-help-close">&times;</button>
    </div>

    <div class="stat-card animate-in" style="padding:24px;margin-bottom:20px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px;">
        <div>
          <h3 style="font-size:15px;font-weight:800;color:var(--text-primary);">Estado de resultados (P&amp;L)</h3>
          <p style="font-size:12px;color:var(--text-muted);">Resumen mes por mes</p>
        </div>
        <button onclick="showToast('Descargando estado de resultados...')" class="con-btn-secondary" style="padding:8px 14px;">Descargar PDF</button>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="con-th">Concepto</th>
            <th class="con-th" style="text-align:right;">Enero</th>
            <th class="con-th" style="text-align:right;">Febrero</th>
            <th class="con-th" style="text-align:right;">Marzo</th>
            <th class="con-th" style="text-align:right;">Abril</th>
          </tr></thead>
          <tbody id="con-pl-tbody"></tbody>
        </table>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Utilidad mensual</h4>
        <div id="con-chart-util" style="height:180px;display:flex;align-items:flex-end;gap:10px;"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Margen de utilidad <span class="con-tip" data-tip="Porcentaje que representa tu utilidad de tus ingresos totales">?</span></h4>
        <div style="text-align:center;padding:20px 0;">
          <p style="font-size:48px;font-weight:900;color:var(--accent);">30.7%</p>
          <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">de cada peso vendido, $0.30 es ganancia</p>
          <div style="margin-top:16px;padding:12px;border-radius:10px;background:var(--input-bg);">
            <p style="font-size:11px;color:var(--text-muted);">Comparacion con mes pasado</p>
            <p style="font-size:13px;font-weight:700;color:#ef4444;margin-top:4px;">▼ 2% vs mes anterior</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Catalogo de cuentas ══════════ -->
  <div id="con-panel-catalogo" style="display:none;">
    <div id="con-help-catalogo" class="con-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">El catalogo de cuentas es la lista oficial del SAT con todas las categorias para clasificar tus movimientos. Cada cuenta tiene un codigo y tipo.</p>
      <button onclick="conDismissHelp('catalogo')" class="con-help-close">&times;</button>
    </div>

    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="con-cat-search" type="text" placeholder="Buscar cuenta por codigo o nombre..." oninput="renderCatalogo()" class="con-input" style="padding-left:38px;"/>
      </div>
      <select id="con-cat-filter" onchange="renderCatalogo()" class="con-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los tipos</option>
        <option value="Activo">Activo</option>
        <option value="Pasivo">Pasivo</option>
        <option value="Capital">Capital</option>
        <option value="Ingresos">Ingresos</option>
        <option value="Gastos">Gastos</option>
      </select>
      <button onclick="showToast('Importando catalogo oficial del SAT...')" class="con-btn-primary" style="padding:10px 16px;">Sincronizar con SAT</button>
    </div>

    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="con-th">Codigo</th>
            <th class="con-th">Nombre de cuenta</th>
            <th class="con-th">Tipo</th>
            <th class="con-th" style="text-align:right;">Saldo</th>
          </tr></thead>
          <tbody id="con-cat-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Polizas / Movimientos ══════════ -->
  <div id="con-panel-polizas" style="display:none;">
    <div id="con-help-polizas" class="con-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Una poliza es un registro contable de una operacion (entrada o salida de dinero). Aqui ves todos los movimientos de tu negocio.</p>
      <button onclick="conDismissHelp('polizas')" class="con-help-close">&times;</button>
    </div>

    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="con-pol-search" type="text" placeholder="Buscar por concepto..." oninput="renderPolizas()" class="con-input" style="padding-left:38px;"/>
      </div>
      <select id="con-pol-filter" onchange="renderPolizas()" class="con-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los tipos</option>
        <option value="Ingreso">Ingreso</option>
        <option value="Egreso">Egreso</option>
        <option value="Diario">Diario</option>
      </select>
      <button onclick="conOpenNewPoliza()" class="con-btn-primary" style="padding:10px 16px;display:flex;align-items:center;gap:6px;">
        <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva poliza
      </button>
    </div>

    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="con-th">Fecha</th>
            <th class="con-th">Tipo</th>
            <th class="con-th">Concepto</th>
            <th class="con-th">Cuenta</th>
            <th class="con-th" style="text-align:right;">Cargo</th>
            <th class="con-th" style="text-align:right;">Abono</th>
            <th class="con-th" style="text-align:right;">Saldo</th>
          </tr></thead>
          <tbody id="con-pol-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Impuestos (SAT) ══════════ -->
  <div id="con-panel-impuestos" style="display:none;">
    <div id="con-help-impuestos" class="con-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aqui calculamos cuanto debes pagarle al SAT este mes: IVA, ISR y tus proximas declaraciones. Todo listo para presentar.</p>
      <button onclick="conDismissHelp('impuestos')" class="con-help-close">&times;</button>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px;margin-bottom:16px;">
      <!-- IVA Calculator -->
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:4px;">Calculadora de IVA</h4>
        <p style="font-size:11px;color:var(--text-muted);margin-bottom:14px;">IVA trasladado menos IVA acreditable</p>
        <div style="display:flex;flex-direction:column;gap:10px;">
          <div style="display:flex;justify-content:space-between;padding:10px 12px;border-radius:8px;background:var(--input-bg);">
            <span style="font-size:12px;color:var(--text-muted);">IVA trasladado <span class="con-tip" data-tip="El IVA que cobraste en tus facturas emitidas">?</span></span>
            <span style="font-size:13px;font-weight:800;color:#22c55e;">$25,312</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:10px 12px;border-radius:8px;background:var(--input-bg);">
            <span style="font-size:12px;color:var(--text-muted);">IVA acreditable <span class="con-tip" data-tip="El IVA que pagaste en tus compras y gastos, se resta del trasladado">?</span></span>
            <span style="font-size:13px;font-weight:800;color:#ef4444;">$17,536</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:12px;border-radius:10px;background:var(--accent-bg);border:1px solid var(--accent);">
            <span style="font-size:13px;font-weight:800;color:var(--text-primary);">IVA a pagar al SAT</span>
            <span style="font-size:16px;font-weight:900;color:var(--accent);">$7,776</span>
          </div>
        </div>
      </div>

      <!-- ISR -->
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:4px;">ISR estimado del mes</h4>
        <p style="font-size:11px;color:var(--text-muted);margin-bottom:14px;">Impuesto Sobre la Renta</p>
        <div style="text-align:center;padding:16px 0;">
          <p style="font-size:36px;font-weight:900;color:#8b5cf6;">$14,580</p>
          <p style="font-size:11px;color:var(--text-muted);margin-top:4px;">30% sobre utilidad de $48,600</p>
        </div>
        <div style="padding:10px 12px;border-radius:8px;background:var(--input-bg);margin-top:10px;">
          <p style="font-size:11px;color:var(--text-muted);">Regimen: Simplificado de Confianza (RESICO)</p>
        </div>
      </div>

      <!-- DIOT -->
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:4px;">
          DIOT preview
          <span class="con-tip" data-tip="Declaracion Informativa de Operaciones con Terceros - un reporte mensual al SAT de tus compras con proveedores">?</span>
        </h4>
        <p style="font-size:11px;color:var(--text-muted);margin-bottom:14px;">Declaracion informativa de compras</p>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:12px;">
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">Proveedores registrados</span><span style="font-weight:700;color:var(--text-primary);">12</span></div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">Operaciones del mes</span><span style="font-weight:700;color:var(--text-primary);">28</span></div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">Total compras</span><span style="font-weight:700;color:var(--text-primary);">$109,600</span></div>
          <div style="display:flex;justify-content:space-between;"><span style="color:var(--text-muted);">IVA acreditable</span><span style="font-weight:700;color:var(--text-primary);">$17,536</span></div>
        </div>
        <button onclick="showToast('Generando DIOT del mes...')" class="con-btn-primary" style="width:100%;margin-top:14px;padding:10px;">Generar DIOT</button>
      </div>

      <!-- Carta Porte -->
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:4px;">
          Carta Porte 3.1
          <span class="con-tip" data-tip="Documento obligatorio cuando transportas mercancia. Se agrega al CFDI.">?</span>
        </h4>
        <p style="font-size:11px;color:var(--text-muted);margin-bottom:14px;">Complemento para traslado de mercancia</p>
        <div style="padding:14px;border-radius:10px;background:var(--input-bg);margin-bottom:14px;">
          <p style="font-size:11px;color:var(--text-muted);margin-bottom:4px;">Generadas este mes</p>
          <p style="font-size:24px;font-weight:900;color:var(--accent);">3</p>
        </div>
        <button onclick="showToast('Abriendo generador de Carta Porte 3.1...')" class="con-btn-primary" style="width:100%;padding:10px;">Generar Carta Porte</button>
      </div>
    </div>

    <!-- Proximas fechas -->
    <div class="stat-card animate-in" style="padding:20px;">
      <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:14px;">Proximas fechas de declaracion</h4>
      <div id="con-fechas-list" style="display:flex;flex-direction:column;gap:10px;"></div>
    </div>
  </div>

  <!-- ══════════ Tab: Reportes fiscales ══════════ -->
  <div id="con-panel-reportes" style="display:none;">
    <div id="con-help-reportes" class="con-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Descarga los reportes que te pide tu contador o el SAT. Estan listos para presentar, en el formato oficial.</p>
      <button onclick="conDismissHelp('reportes')" class="con-help-close">&times;</button>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:14px;margin-bottom:20px;" id="con-reportes-grid"></div>

    <div class="stat-card animate-in" style="padding:20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
      <div style="width:44px;height:44px;border-radius:12px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg style="width:22px;height:22px;color:var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <div style="flex:1;min-width:200px;">
        <p style="font-size:14px;font-weight:800;color:var(--text-primary);">Enviar paquete completo a mi contador</p>
        <p style="font-size:12px;color:var(--text-muted);">Empacamos todos los reportes del mes y los enviamos por email</p>
      </div>
      <button onclick="conSendToContador()" class="con-btn-primary" style="padding:12px 20px;">Enviar a mi contador</button>
    </div>
  </div>

  <!-- ══════════ Tab: Conciliacion ══════════ -->
  <div id="con-panel-conciliacion" style="display:none;">
    <div id="con-help-conciliacion" class="con-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">La conciliacion bancaria empareja los movimientos de tu banco con las facturas y gastos que registraste. Asi te aseguras que todo cuadre.</p>
      <button onclick="conDismissHelp('conciliacion')" class="con-help-close">&times;</button>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;margin-bottom:20px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:10px;">Conectar cuenta bancaria</h4>
        <p style="font-size:12px;color:var(--text-muted);margin-bottom:14px;">Sincroniza automaticamente tus movimientos via Belvo (BBVA, Santander, Banorte, HSBC, Banamex).</p>
        <button onclick="showToast('Abriendo conexion bancaria (Belvo)...')" class="con-btn-primary" style="width:100%;padding:10px;">Conectar banco</button>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:10px;">Subir estado de cuenta (CSV)</h4>
