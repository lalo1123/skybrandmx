// ═══════ RESUMEN (P&L) ═══════
function renderPL() {
  const tbody = document.getElementById('con-pl-tbody');
  if (!tbody) return;
  tbody.innerHTML = demoPL.map(row => {
    let colorStyle = 'color:var(--text-primary);';
    let weight = '500';
    if (row.type === 'ingreso') { colorStyle = 'color:#22c55e;'; weight = '700'; }
    if (row.type === 'gasto') { colorStyle = 'color:#ef4444;'; }
    if (row.type === 'subtotal') { colorStyle = 'color:var(--text-primary);'; weight = '800'; }
    if (row.type === 'total') { colorStyle = 'color:var(--accent);'; weight = '900'; }
    const bg = row.type === 'total' ? 'background:var(--accent-bg);' : '';
    return '<tr style="border-bottom:1px solid var(--border);' + bg + '">' +
      '<td class="con-td" style="font-weight:' + weight + ';">' + row.concept + '</td>' +
      '<td class="con-td" style="text-align:right;font-weight:' + weight + ';' + colorStyle + '">' + fmt(row.ene) + '</td>' +
      '<td class="con-td" style="text-align:right;font-weight:' + weight + ';' + colorStyle + '">' + fmt(row.feb) + '</td>' +
      '<td class="con-td" style="text-align:right;font-weight:' + weight + ';' + colorStyle + '">' + fmt(row.mar) + '</td>' +
      '<td class="con-td" style="text-align:right;font-weight:' + weight + ';' + colorStyle + '">' + fmt(row.abr) + '</td>' +
      '</tr>';
  }).join('');
}

function renderUtilChart() {
  const el = document.getElementById('con-chart-util');
  if (!el) return;
  const totals = demoPL.find(r => r.type === 'total');
  if (!totals) return;
  const vals = [
    { label: 'Ene', val: totals.ene },
    { label: 'Feb', val: totals.feb },
    { label: 'Mar', val: totals.mar },
    { label: 'Abr', val: totals.abr }
  ];
  const max = Math.max.apply(null, vals.map(v => v.val));
  el.innerHTML = vals.map(v => {
    const h = Math.max(10, (v.val / max) * 140);
    return '<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;">' +
      '<div style="font-size:10px;font-weight:700;color:var(--text-muted);">' + fmt(v.val) + '</div>' +
      '<div style="width:100%;height:' + h + 'px;background:linear-gradient(180deg,var(--accent),rgba(111,207,245,0.4));border-radius:6px 6px 0 0;"></div>' +
      '<div style="font-size:11px;color:var(--text-faint);font-weight:600;">' + v.label + '</div>' +
    '</div>';
  }).join('');
}

// ═══════ CATALOGO ═══════
function renderCatalogo() {
  const tbody = document.getElementById('con-cat-tbody');
  if (!tbody) return;
  const search = (document.getElementById('con-cat-search').value || '').toLowerCase();
  const filter = document.getElementById('con-cat-filter').value;
  let data = demoCatalogo.filter(c =>
    (!search || c.code.toLowerCase().includes(search) || c.name.toLowerCase().includes(search)) &&
    (!filter || c.type === filter)
  );
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="4" style="padding:40px;text-align:center;color:var(--text-faint);">No se encontraron cuentas</td></tr>';
    return;
  }
  const typeColors = {
    'Activo': '#22c55e', 'Pasivo': '#ef4444', 'Capital': '#8b5cf6',
    'Ingresos': '#6fcff5', 'Gastos': '#f97316'
  };
  tbody.innerHTML = data.map(c => {
    const color = typeColors[c.type] || 'var(--text-muted)';
    return '<tr style="border-bottom:1px solid var(--border);">' +
      '<td class="con-td" style="font-weight:800;color:var(--accent);font-family:monospace;">' + c.code + '</td>' +
      '<td class="con-td">' + c.name + '</td>' +
      '<td class="con-td"><span style="padding:4px 10px;border-radius:6px;background:' + color + '15;color:' + color + ';font-size:11px;font-weight:700;">' + c.type + '</span></td>' +
      '<td class="con-td" style="text-align:right;font-weight:700;">' + fmt(c.balance) + '</td>' +
      '</tr>';
  }).join('');
}

// ═══════ POLIZAS ═══════
function renderPolizas() {
  const tbody = document.getElementById('con-pol-tbody');
  if (!tbody) return;
  const search = (document.getElementById('con-pol-search').value || '').toLowerCase();
  const filter = document.getElementById('con-pol-filter').value;
  let data = demoPolizas.filter(p =>
    (!search || p.concepto.toLowerCase().includes(search)) &&
    (!filter || p.tipo === filter)
  );
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="7" style="padding:40px;text-align:center;color:var(--text-faint);">No hay polizas</td></tr>';
    return;
  }
  const tipoColors = {
    'Ingreso': '#22c55e', 'Egreso': '#ef4444', 'Diario': '#8b5cf6'
  };
  tbody.innerHTML = data.map(p => {
    const color = tipoColors[p.tipo] || 'var(--text-muted)';
    return '<tr style="border-bottom:1px solid var(--border);">' +
      '<td class="con-td" style="color:var(--text-muted);">' + p.fecha + '</td>' +
      '<td class="con-td"><span style="padding:4px 10px;border-radius:6px;background:' + color + '15;color:' + color + ';font-size:11px;font-weight:700;">' + p.tipo + '</span></td>' +
      '<td class="con-td">' + p.concepto + '</td>' +
      '<td class="con-td" style="font-size:12px;color:var(--text-muted);">' + p.cuenta + '</td>' +
      '<td class="con-td" style="text-align:right;color:' + (p.cargo > 0 ? '#22c55e' : 'var(--text-faint)') + ';font-weight:' + (p.cargo > 0 ? '700' : '400') + ';">' + (p.cargo > 0 ? fmt(p.cargo) : '-') + '</td>' +
      '<td class="con-td" style="text-align:right;color:' + (p.abono > 0 ? '#ef4444' : 'var(--text-faint)') + ';font-weight:' + (p.abono > 0 ? '700' : '400') + ';">' + (p.abono > 0 ? fmt(p.abono) : '-') + '</td>' +
      '<td class="con-td" style="text-align:right;font-weight:800;">' + fmt(p.saldo) + '</td>' +
      '</tr>';
  }).join('');
}

function conOpenNewPoliza() {
  showToast('Abriendo formulario de nueva poliza...');
}

// ═══════ FECHAS ═══════
function renderFechas() {
  const el = document.getElementById('con-fechas-list');
  if (!el) return;
  el.innerHTML = demoFechas.map(f =>
    '<div style="display:flex;align-items:center;gap:14px;padding:12px 14px;border-radius:10px;background:' + f.color + '08;border:1px solid ' + f.color + '20;">' +
    '<div style="width:42px;height:42px;border-radius:10px;background:' + f.color + '15;display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
    '<span style="font-size:16px;font-weight:900;color:' + f.color + ';">' + f.dias + '</span></div>' +
    '<div style="flex:1;"><p style="font-size:13px;font-weight:800;color:var(--text-primary);">' + f.concepto + '</p>' +
    '<p style="font-size:11px;color:var(--text-muted);">Vence: ' + f.fecha + ' (en ' + f.dias + ' dias)</p></div>' +
    '<button onclick="showToast(\'Preparando declaracion...\')" style="padding:8px 14px;border-radius:8px;border:1px solid ' + f.color + ';background:transparent;color:' + f.color + ';font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">Preparar</button>' +
    '</div>'
  ).join('');
}

// ═══════ REPORTES ═══════
function renderReportes() {
  const el = document.getElementById('con-reportes-grid');
  if (!el) return;
  el.innerHTML = demoReportes.map(r =>
    '<div class="con-report-card" onclick="conDownloadReport(\'' + r.id + '\', \'' + r.name + '\')">' +
    '<div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">' +
    '<div style="width:40px;height:40px;border-radius:10px;background:' + r.color + '15;display:flex;align-items:center;justify-content:center;font-size:20px;">' + r.icon + '</div>' +
    '<div style="flex:1;"><p style="font-size:13px;font-weight:800;color:var(--text-primary);">' + r.name + '</p>' +
    '<p style="font-size:11px;color:var(--text-muted);">' + r.desc + '</p></div></div>' +
    '<button style="width:100%;padding:8px;border-radius:8px;border:1px solid ' + r.color + ';background:transparent;color:' + r.color + ';font-size:11px;font-weight:700;cursor:pointer;">Descargar</button>' +
    '</div>'
  ).join('');
}

function conDownloadReport(id, name) {
  showToast('Descargando ' + name + '...');
}

function conSendToContador() {
  showToast('Paquete enviado a tu contador');
}

// ═══════ CONCILIACION ═══════
function renderConciliacion() {
  const tbody = document.getElementById('con-conc-tbody');
  if (!tbody) return;
  tbody.innerHTML = demoConciliacion.map((c, idx) => {
    const isMatched = c.estado === 'matched';
    const color = isMatched ? '#22c55e' : '#f97316';
    const label = isMatched ? 'Emparejado' : 'Sin emparejar';
    const monto = c.monto < 0 ? '-' + fmt(Math.abs(c.monto)).replace('-', '') : fmt(c.monto);
    const montoColor = c.monto < 0 ? '#ef4444' : '#22c55e';
    const action = isMatched
      ? '<button onclick="showToast(\'Desvinculando...\')" style="padding:5px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;cursor:pointer;">Desvincular</button>'
      : '<button onclick="conMatchItem(' + idx + ')" style="padding:5px 10px;border-radius:6px;border:1px solid var(--accent);background:transparent;color:var(--accent);font-size:11px;cursor:pointer;">Emparejar</button>';
    return '<tr style="border-bottom:1px solid var(--border);">' +
      '<td class="con-td" style="color:var(--text-muted);">' + c.fecha + '</td>' +
      '<td class="con-td" style="font-size:12px;">' + c.desc + '</td>' +
      '<td class="con-td" style="text-align:right;font-weight:800;color:' + montoColor + ';">' + monto + '</td>' +
      '<td class="con-td"><span style="padding:4px 10px;border-radius:6px;background:' + color + '15;color:' + color + ';font-size:11px;font-weight:700;">' + label + '</span></td>' +
      '<td class="con-td" style="font-size:12px;color:var(--text-muted);">' + (c.match || '-') + '</td>' +
      '<td class="con-td" style="text-align:center;">' + action + '</td>' +
    '</tr>';
  }).join('');
}

function conAutoMatch() {
  showToast('Analizando movimientos y emparejando automaticamente...');
  setTimeout(() => {
    demoConciliacion.forEach(c => {
      if (c.estado === 'unmatched' && c.desc.indexOf('PROV') !== -1) {
        c.estado = 'matched';
        c.match = 'Gasto Distrib. SA';
      }
    });
    renderConciliacion();
    showToast('1 movimiento emparejado');
  }, 1000);
}

function conMatchItem(idx) {
  showToast('Abriendo selector de factura/gasto...');
}

function conUploadStatement(input) {
  const file = input.files && input.files[0];
  if (!file) return;
  showToast('Procesando ' + file.name + '...');
}

// ═══════ AUTOPILOT ═══════
function renderAutopilot() {
  const el = document.getElementById('con-autopilot-list');
  if (!el) return;
  el.innerHTML = conAutopilotOptions.map(a =>
    '<div style="display:flex;align-items:center;gap:12px;padding:14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);">' +
    '<div style="width:36px;height:36px;border-radius:10px;background:' + a.color + '15;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">' + a.icon + '</div>' +
    '<div style="flex:1;min-width:0;"><p style="font-size:12px;font-weight:800;color:var(--text-primary);">' + a.name + '</p>' +
    '<p style="font-size:10px;color:var(--text-muted);margin-top:2px;line-height:1.4;">' + a.desc + '</p></div>' +
    '<label class="con-toggle-wrap"><input type="checkbox" ' + (a.active ? 'checked' : '') + ' onchange="conToggleAuto(\'' + a.id + '\', this.checked)"><span class="con-toggle-slider"></span></label>' +
    '</div>'
  ).join('');
}

function conToggleAuto(id, val) {
  const opt = conAutopilotOptions.find(o => o.id === id);
  if (opt) opt.active = val;
  showToast(val ? 'Automatizacion activada' : 'Automatizacion desactivada');
}

// ═══════ INIT ═══════
document.addEventListener('DOMContentLoaded', function() {
  conRestoreHelp();
  renderConRecs();
  renderPL();
  renderUtilChart();
  renderCatalogo();
  renderPolizas();
  renderFechas();
  renderReportes();
  renderConciliacion();
  renderAutopilot();
});
</script>
