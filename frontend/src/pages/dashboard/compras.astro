      <div style="display:flex;align-items:center;gap:6px;"><span style="color:var(--text-faint);min-width:60px;">Email:</span><span style="color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;">${s.email}</span></div>
      <div style="display:flex;align-items:center;gap:6px;"><span style="color:var(--text-faint);min-width:60px;">Tel:</span><span style="color:var(--text-secondary);">${s.phone}</span></div>
      <div style="display:flex;align-items:center;gap:6px;"><span style="color:var(--text-faint);min-width:60px;">Términos:</span><span style="color:var(--accent);font-weight:700;">${s.terms}</span></div>
    </div>
    <div style="padding-top:12px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
      <span style="font-size:11px;color:var(--text-faint);text-transform:uppercase;font-weight:700;">Compras 2026</span>
      <span style="font-size:15px;font-weight:900;color:var(--text-primary);">${fmt(s.yearTotal)}</span>
    </div>
  </div>`).join('');
