---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Compras">
  <div id="com-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="com-stat-label">Gastos del mes</p>
      <p id="com-stat-monthexp" class="com-stat-val">--</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="com-stat-label">Por pagar <span class="com-tip" data-tip="Facturas de proveedores que debes pagar (cuentas por pagar).">?</span></p>
      <p id="com-stat-topay" class="com-stat-val" style="color:#f97316;">--</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="com-stat-label">Proveedores activos</p>
      <p id="com-stat-suppliers" class="com-stat-val">--</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="com-stat-label">Pedidos pendientes <span class="com-tip" data-tip="Órdenes de compra enviadas a proveedor que aún no has recibido.">?</span></p>
      <p id="com-stat-pending" class="com-stat-val" style="color:var(--accent);">--</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="com-stat-label">Balance bancario</p>
      <p id="com-stat-balance" class="com-stat-val" style="color:#22c55e;">--</p>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="com-stat-label">Conciliadas hoy <span class="com-tip" data-tip="Movimientos bancarios que ya relacionaste con una factura o gasto">?</span></p>
      <p id="com-stat-reconciled" class="com-stat-val">--</p>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="com-tab-pos" class="com-tab active" onclick="switchComTab('pos')">Órdenes de compra</button>
    <button id="com-tab-suppliers" class="com-tab" onclick="switchComTab('suppliers')">Proveedores</button>
    <button id="com-tab-invoices" class="com-tab" onclick="switchComTab('invoices')">Facturas de proveedor</button>
    <button id="com-tab-expenses" class="com-tab" onclick="switchComTab('expenses')">Gastos</button>
    <button id="com-tab-recon" class="com-tab" onclick="switchComTab('recon')">Conciliación bancaria</button>
    <button id="com-tab-analytics" class="com-tab" onclick="switchComTab('analytics')">Analítica</button>
  </div>

  <!-- Tab: Purchase Orders -->
  <div id="com-panel-pos">
    <div id="com-help-pos" class="com-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Una <strong>orden de compra</strong> es el documento con el que le pides mercancía a un proveedor. Al recibir los productos, se convierte en una factura por pagar.</p>
      <button onclick="document.getElementById('com-help-pos').style.display='none'" class="com-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="com-po-search" type="text" placeholder="Buscar por proveedor, folio..." oninput="renderComPOs()" class="com-input" style="padding-left:38px;"/>
      </div>
      <select id="com-po-filter" onchange="renderComPOs()" class="com-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="draft">Borrador</option>
        <option value="sent">Enviada</option>
        <option value="received">Recibida</option>
        <option value="paid">Pagada</option>
      </select>
      <button onclick="showToast('Abriendo nueva orden de compra')" class="com-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva OC
      </button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="com-th">#</th><th class="com-th">Proveedor</th><th class="com-th">Fecha</th>
            <th class="com-th" style="text-align:right;">Monto</th><th class="com-th">Estado</th>
            <th class="com-th" style="text-align:center;">Acciones</th>
          </tr></thead>
          <tbody id="com-pos-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Tab: Suppliers -->
  <div id="com-panel-suppliers" style="display:none;">
    <div class="com-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Administra tus proveedores, sus datos fiscales (RFC) y condiciones de pago. El total del año se actualiza con cada factura recibida.</p>
    </div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;gap:12px;flex-wrap:wrap;">
      <p style="font-size:13px;color:var(--text-muted);">Total: <strong id="com-sup-count" style="color:var(--text-primary);">0</strong> proveedores</p>
      <button onclick="openComSupplierModal()" class="com-btn-primary" style="padding:10px 20px;">+ Nuevo proveedor</button>
    </div>
    <div id="com-suppliers-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:14px;"></div>
  </div>

  <!-- Tab: Received Invoices -->
  <div id="com-panel-invoices" style="display:none;">
    <div class="com-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Un <strong>CFDI recibido</strong> es una factura electrónica que te emite tu proveedor. Súbela aquí para deducir impuestos y llevar tu contabilidad al día.</p>
    </div>
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <p style="flex:1;font-size:12px;color:var(--text-muted);">Sube CFDI o arrastra XML aquí.</p>
      <button onclick="showToast('Importando XML desde SAT')" class="com-btn-secondary" style="padding:9px 16px;">Importar desde SAT</button>
      <button onclick="showToast('Abriendo cargador de CFDI')" class="com-btn-primary" style="padding:9px 16px;">+ Subir factura</button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="com-th">Folio</th><th class="com-th">Proveedor</th><th class="com-th">RFC</th>
            <th class="com-th">Fecha</th><th class="com-th" style="text-align:right;">Total</th>
            <th class="com-th">Estado</th><th class="com-th" style="text-align:center;">Acciones</th>
          </tr></thead>
          <tbody id="com-inv-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Tab: Expenses -->
  <div id="com-panel-expenses" style="display:none;">
    <div class="com-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Los gastos son salidas de dinero sin factura formal: tickets, vales, servicios, viáticos. Regístralos para llevar un control real de tu flujo.</p>
    </div>
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:16px;margin-bottom:20px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:14px;">Por categoría</h4>
        <div id="com-exp-cats"></div>
      </div>
      <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
        <div style="padding:14px 18px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);">
          <h4 style="font-size:13px;font-weight:800;color:var(--text-primary);">Últimos gastos</h4>
          <button onclick="showToast('Abriendo captura de gasto')" class="com-btn-primary" style="padding:8px 14px;font-size:12px;">+ Gasto</button>
        </div>
        <div style="overflow-x:auto;">
          <table style="width:100%;border-collapse:collapse;font-size:13px;">
            <thead><tr style="border-bottom:1px solid var(--border);"><th class="com-th">Fecha</th><th class="com-th">Descripción</th><th class="com-th">Categoría</th><th class="com-th" style="text-align:right;">Monto</th></tr></thead>
            <tbody id="com-exp-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab: Bank Reconciliation -->
  <div id="com-panel-recon" style="display:none;">
    <div class="com-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);"><strong>Conciliación bancaria</strong>: emparejar cada movimiento del banco con una factura o gasto registrado. Así sabes que tu contabilidad cuadra con lo que pasó en la cuenta real.</p>
    </div>
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <p style="flex:1;min-width:180px;font-size:12px;color:var(--text-muted);">Conecta tu banco para importar movimientos automáticamente.</p>
      <button onclick="openComBankModal()" class="com-btn-secondary" style="padding:9px 14px;">Conectar banco</button>
      <button onclick="showToast('Subiendo estado de cuenta CSV')" class="com-btn-secondary" style="padding:9px 14px;">Subir estado de cuenta (CSV)</button>
      <button onclick="comAutoReconcile()" class="com-btn-primary" style="padding:9px 14px;">Auto-conciliar</button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <!-- LEFT: Bank transactions -->
      <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
        <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
          <div>
            <h4 style="font-size:13px;font-weight:800;color:var(--text-primary);">Movimientos del banco</h4>
            <p style="font-size:11px;color:var(--text-faint);margin-top:2px;">BBVA ****3421 · Saldo: <span id="com-bank-balance" style="color:#22c55e;font-weight:700;">$0</span></p>
          </div>
          <span id="com-bank-unmatched" style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;background:rgba(249,115,22,0.1);color:#f97316;">0 pendientes</span>
        </div>
        <div id="com-bank-list" style="max-height:560px;overflow-y:auto;"></div>
      </div>
      <!-- RIGHT: Internal records -->
      <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
        <div style="padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;">
          <div>
            <h4 style="font-size:13px;font-weight:800;color:var(--text-primary);">Tus facturas y gastos</h4>
            <p style="font-size:11px;color:var(--text-faint);margin-top:2px;">Haz clic para emparejar con el movimiento seleccionado</p>
          </div>
          <span id="com-rec-selected" style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;background:var(--accent-bg);color:var(--accent);display:none;">Movimiento seleccionado</span>
        </div>
        <div id="com-records-list" style="max-height:560px;overflow-y:auto;"></div>
      </div>
    </div>
  </div>

  <!-- Tab: Analytics -->
  <div id="com-panel-analytics" style="display:none;">
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Top proveedores</h4>
        <div id="com-chart-top"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Gastos por categoría</h4>
        <div id="com-chart-cats"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;grid-column:1/-1;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Gastos por mes</h4>
        <div id="com-chart-monthly" style="height:180px;display:flex;align-items:flex-end;gap:6px;"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;grid-column:1/-1;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Análisis de términos de pago</h4>
        <div id="com-chart-terms" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;"></div>
      </div>
    </div>
  </div>

  <!-- Autopilot -->
  <div class="stat-card animate-in" style="padding:0;margin-top:20px;overflow:hidden;">
    <button onclick="comToggle('com-auto-content')" class="com-collapse-header">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,rgba(34,197,94,0.15),rgba(111,207,245,0.15));display:flex;align-items:center;justify-content:center;">
          <svg style="width:14px;height:14px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div style="text-align:left;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">Piloto automático</p><p style="font-size:11px;color:var(--text-faint);">Automatiza registros, conciliación y alertas</p></div>
      </div>
      <svg style="width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </button>
    <div id="com-auto-content" style="display:none;padding:20px;">
      <div id="com-auto-list" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;"></div>
    </div>
  </div>

  <!-- Supplier modal -->
  <div id="com-sup-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:1000;align-items:center;justify-content:center;padding:20px;">
    <div class="stat-card" style="max-width:520px;width:100%;padding:24px;max-height:90vh;overflow-y:auto;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
        <h3 id="com-sup-modal-title" style="font-size:17px;font-weight:900;color:var(--text-primary);">Nuevo proveedor</h3>
        <button onclick="closeComSupplierModal()" style="border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:20px;">&times;</button>
      </div>
      <div style="display:grid;gap:12px;">
        <div><label class="com-label">Nombre / Razón social *</label><input id="com-sup-name" type="text" placeholder="Ej: Distribuidora Centro SA" class="com-input"/></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div><label class="com-label">RFC</label><input id="com-sup-rfc" type="text" placeholder="DCE820101AB1" class="com-input"/></div>
          <div><label class="com-label">Contacto</label><input id="com-sup-contact" type="text" placeholder="Nombre" class="com-input"/></div>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
          <div><label class="com-label">Email</label><input id="com-sup-email" type="email" placeholder="compras@proveedor.com" class="com-input"/></div>
          <div><label class="com-label">Teléfono</label><input id="com-sup-phone" type="tel" placeholder="55 1234 5678" class="com-input"/></div>
        </div>
        <div><label class="com-label">Términos de pago</label><select id="com-sup-terms" class="com-input" style="cursor:pointer;"><option value="Contado">Contado</option><option value="15 días" selected>15 días</option><option value="30 días">30 días</option><option value="45 días">45 días</option><option value="60 días">60 días</option></select></div>
      </div>
      <div style="display:flex;gap:10px;margin-top:20px;">
        <button onclick="closeComSupplierModal()" class="com-btn-secondary" style="flex:1;">Cancelar</button>
        <button id="com-sup-save-btn" onclick="saveComSupplier()" class="com-btn-primary" style="flex:1;">Guardar</button>
      </div>
    </div>
  </div>

  <!-- Bank connect modal -->
  <div id="com-bank-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:1000;align-items:center;justify-content:center;padding:20px;">
    <div class="stat-card" style="max-width:460px;width:100%;padding:24px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
        <h3 style="font-size:17px;font-weight:900;color:var(--text-primary);">Conectar banco</h3>
        <button onclick="closeComBankModal()" style="border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:20px;">&times;</button>
      </div>
      <p style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">Selecciona tu banco para importar movimientos de forma automática.</p>
      <div id="com-bank-options" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;"></div>
      <button onclick="closeComBankModal()" class="com-btn-secondary" style="width:100%;margin-top:16px;">Cancelar</button>
    </div>
  </div>
</DashboardLayout>

<style>
  .com-stat-label { font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:4px; }
  .com-stat-val { font-size:26px;font-weight:900;color:var(--text-primary); }
  .com-tab { padding:10px 18px;border:none;background:transparent;color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;white-space:nowrap; }
  .com-tab.active { color:var(--accent);border-bottom-color:var(--accent); }
  .com-th { padding:14px 16px;text-align:left;font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px; }
  .com-label { font-size:12px;font-weight:700;color:var(--text-muted);margin-bottom:4px;display:block; }
  .com-input { width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;outline:none;transition:border-color 0.2s; }
  .com-input:focus { border-color:var(--accent); }
  .com-btn-primary { padding:10px 16px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:700;cursor:pointer;transition:opacity 0.2s; }
  .com-btn-primary:hover { opacity:0.85; }
  .com-btn-secondary { padding:10px 16px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-primary);font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s; }
  .com-btn-secondary:hover { background:var(--nav-hover); }
  .com-tbl-btn { padding:5px 9px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;cursor:pointer;transition:all 0.15s; }
  .com-tbl-btn:hover { border-color:var(--accent);color:var(--accent); }
  .com-help-banner { display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:10px;background:var(--accent-bg);border:1px solid rgba(111,207,245,0.15);margin-bottom:16px; }
  .com-help-close { border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:16px;padding:0 4px; }
  .com-tip { display:inline-flex;align-items:center;justify-content:center;width:16px;height:16px;border-radius:50%;background:var(--input-bg);color:var(--text-faint);font-size:10px;font-weight:800;cursor:help;position:relative;flex-shrink:0; }
