// ============ HELPERS ============
function showToast(msg){
  const ex=document.getElementById('com-toast');if(ex)ex.remove();
  const t=document.createElement('div');t.id='com-toast';t.textContent=msg;
  Object.assign(t.style,{position:'fixed',bottom:'24px',right:'24px',background:'#22c55e',color:'#fff',padding:'12px 24px',borderRadius:'10px',fontSize:'13px',fontWeight:'700',zIndex:'9999',boxShadow:'0 4px 20px rgba(0,0,0,0.3)'});
  document.body.appendChild(t);
  setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity 0.3s';setTimeout(()=>t.remove(),300);},3000);
}
function switchComTab(tab){
  document.querySelectorAll('.com-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('com-tab-'+tab).classList.add('active');
  ['pos','suppliers','invoices','expenses','recon','analytics'].forEach(p=>{
    const el=document.getElementById('com-panel-'+p);if(el)el.style.display=p===tab?'':'none';
  });
  if(tab==='analytics')renderComAnalytics();
}
function comToggle(id){const el=document.getElementById(id);el.style.display=el.style.display==='none'?'block':'none';}
function fmt(n){return '$'+Math.round(n).toLocaleString();}

// ============ STATS ============
function renderComStats(){
  const monthExp = demoExpenses.reduce((s,e)=>s+e.amount,0) + demoInvoices.filter(i=>i.status==='paid').reduce((s,i)=>s+i.total,0);
  document.getElementById('com-stat-monthexp').textContent = fmt(monthExp);
  const topay = demoInvoices.filter(i=>i.status!=='paid').reduce((s,i)=>s+i.total,0);
  document.getElementById('com-stat-topay').textContent = fmt(topay);
  document.getElementById('com-stat-suppliers').textContent = demoSuppliers.length;
  document.getElementById('com-stat-pending').textContent = demoPOs.filter(p=>p.status==='sent').length;
  document.getElementById('com-stat-balance').textContent = fmt(182340);
  document.getElementById('com-stat-reconciled').textContent = demoBankTx.filter(t=>t.matched).length;
}

