// ============ PURCHASE ORDERS ============
function renderComPOs(){
  const tbody=document.getElementById('com-pos-tbody');if(!tbody)return;
  const search=(document.getElementById('com-po-search').value||'').toLowerCase();
  const sf=document.getElementById('com-po-filter').value;
  let data=[...demoPOs];
  if(search)data=data.filter(p=>p.supplier.toLowerCase().includes(search)||p.folio.toLowerCase().includes(search));
  if(sf)data=data.filter(p=>p.status===sf);
  if(!data.length){tbody.innerHTML='<tr><td colspan="6" style="padding:40px;text-align:center;color:var(--text-faint);">Sin resultados</td></tr>';return;}
  tbody.innerHTML=data.map(p=>{const st=poStatusMap[p.status];return `<tr style="border-bottom:1px solid var(--border);">
    <td style="padding:14px 16px;font-weight:700;color:var(--accent);font-size:12px;">${p.folio}</td>
    <td style="padding:14px 16px;font-weight:700;color:var(--text-primary);">${p.supplier}</td>
    <td style="padding:14px 16px;font-size:12px;color:var(--text-muted);">${p.date}</td>
    <td style="padding:14px 16px;text-align:right;font-weight:800;color:var(--text-primary);">${fmt(p.amount)}</td>
    <td style="padding:14px 16px;"><span style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;color:${st.c};background:${st.b};">${st.l}</span></td>
    <td style="padding:14px 16px;text-align:center;"><div style="display:flex;gap:4px;justify-content:center;flex-wrap:wrap;">
      <button onclick="showToast('PDF de ${p.folio} descargado')" class="com-tbl-btn">PDF</button>
      ${p.status==='draft'?`<button onclick="comAdvancePO(${p.id},'sent')" class="com-tbl-btn" style="border-color:#6fcff5;color:#6fcff5;">Enviar</button>`:''}
      ${p.status==='sent'?`<button onclick="comAdvancePO(${p.id},'received')" class="com-tbl-btn" style="border-color:#8b5cf6;color:#8b5cf6;">Recibir</button>`:''}
      ${p.status==='received'?`<button onclick="comAdvancePO(${p.id},'paid')" class="com-tbl-btn" style="border-color:#22c55e;color:#22c55e;">Pagar</button>`:''}
    </div></td>
  </tr>`;}).join('');
}
function comAdvancePO(id,next){const p=demoPOs.find(x=>x.id===id);if(!p)return;p.status=next;renderComPOs();renderComStats();showToast('Estado actualizado a '+poStatusMap[next].l);}

