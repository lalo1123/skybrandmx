function comPayInvoice(id){const i=demoInvoices.find(x=>x.id===id);if(!i)return;i.status='paid';renderComInvoices();renderComStats();showToast('Factura marcada como pagada');}

// ============ EXPENSES ============
function renderComExpenses(){
  const tbody=document.getElementById('com-exp-tbody');if(!tbody)return;
  tbody.innerHTML=demoExpenses.map(e=>`<tr style="border-bottom:1px solid var(--border);">
    <td style="padding:12px 16px;font-size:12px;color:var(--text-muted);">${e.date}</td>
    <td style="padding:12px 16px;font-weight:600;color:var(--text-primary);">${e.desc}</td>
    <td style="padding:12px 16px;"><span style="padding:3px 9px;border-radius:5px;font-size:11px;font-weight:700;color:${categoryColors[e.category]||'#6fcff5'};background:${(categoryColors[e.category]||'#6fcff5')}15;">${e.category}</span></td>
    <td style="padding:12px 16px;text-align:right;font-weight:800;color:var(--text-primary);">${fmt(e.amount)}</td>
  </tr>`).join('');

  const cats={};demoExpenses.forEach(e=>{cats[e.category]=(cats[e.category]||0)+e.amount;});
  const total=Object.values(cats).reduce((s,v)=>s+v,0)||1;
  document.getElementById('com-exp-cats').innerHTML=Object.entries(cats).sort((a,b)=>b[1]-a[1]).map(([k,v])=>{
    const pct=Math.round(v/total*100);const color=categoryColors[k]||'#6fcff5';
    return `<div style="margin-bottom:12px;"><div style="display:flex;justify-content:space-between;margin-bottom:4px;"><span style="font-size:12px;font-weight:700;color:var(--text-secondary);">${k}</span><span style="font-size:12px;font-weight:800;color:var(--text-primary);">${fmt(v)}</span></div><div style="height:6px;background:var(--input-bg);border-radius:3px;overflow:hidden;"><div style="width:${pct}%;height:100%;background:${color};"></div></div></div>`;
  }).join('');
}

// ============ BANK RECONCILIATION ============
function renderComReconciliation(){
  const bankEl=document.getElementById('com-bank-list');if(!bankEl)return;
  const balance=demoBankTx[0]?demoBankTx[0].balance:0;
  document.getElementById('com-bank-balance').textContent=fmt(balance);
  const unmatched=demoBankTx.filter(t=>!t.matched).length;
  document.getElementById('com-bank-unmatched').textContent=unmatched+' pendientes';

  bankEl.innerHTML=demoBankTx.map(t=>{
    const sign=t.amount<0?'#ef4444':'#22c55e';
    const sel=comSelectedBankTx===t.id?'selected':'';
    return `<div class="com-bank-row ${sel}" onclick="comSelectBankTx(${t.id})">
      <div style="width:8px;height:8px;border-radius:50%;background:${t.matched?'#22c55e':'#f97316'};flex-shrink:0;"></div>
      <div style="flex:1;min-width:0;">
        <p style="font-size:12px;font-weight:700;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${t.desc}</p>
        <p style="font-size:10px;color:var(--text-faint);">${t.date} · ${t.matched?'Conciliado':'Pendiente'}</p>
      </div>
      <p style="font-size:13px;font-weight:800;color:${sign};flex-shrink:0;">${t.amount<0?'-':'+'}${fmt(Math.abs(t.amount))}</p>
    </div>`;
  }).join('');

  const recEl=document.getElementById('com-records-list');
  const records=[
    ...demoInvoices.filter(i=>i.status!=='paid').map(i=>({type:'inv',id:'inv-'+i.id,name:i.supplier,desc:'Factura '+i.folio,date:i.date,amount:i.total,matched:false})),
    ...demoExpenses.slice(0,6).map(e=>({type:'exp',id:'exp-'+e.id,name:e.desc,desc:e.category,date:e.date,amount:e.amount,matched:false})),
  ];
  recEl.innerHTML=records.map(r=>`<div class="com-rec-row" onclick="comMatchRecord('${r.id}',${r.amount})">
    <span style="font-size:16px;">${r.type==='inv'?'📄':'💳'}</span>
    <div style="flex:1;min-width:0;">
      <p style="font-size:12px;font-weight:700;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${r.name}</p>
      <p style="font-size:10px;color:var(--text-faint);">${r.desc} · ${r.date}</p>
    </div>
    <p style="font-size:13px;font-weight:800;color:var(--text-primary);flex-shrink:0;">${fmt(r.amount)}</p>
  </div>`).join('');
}
function comSelectBankTx(id){
  const t=demoBankTx.find(x=>x.id===id);if(!t)return;
  if(t.matched){showToast('Este movimiento ya está conciliado');return;}
  comSelectedBankTx=id;
  document.getElementById('com-rec-selected').style.display='inline-block';
  renderComReconciliation();
}
function comMatchRecord(recId,amount){
  if(!comSelectedBankTx){showToast('Primero selecciona un movimiento del banco');return;}
  const t=demoBankTx.find(x=>x.id===comSelectedBankTx);if(!t)return;
  if(Math.abs(Math.abs(t.amount)-amount)>1){
    if(!confirm('Los montos no coinciden exactamente. ¿Conciliar de todas formas?'))return;
  }
  t.matched=true;comSelectedBankTx=null;
  document.getElementById('com-rec-selected').style.display='none';
  renderComReconciliation();renderComStats();
  showToast('Movimiento conciliado');
}
function comAutoReconcile(){
  let count=0;
  demoBankTx.forEach(t=>{if(!t.matched){t.matched=true;count++;}});
  renderComReconciliation();renderComStats();
  showToast(count+' movimientos conciliados automáticamente');
}
function openComBankModal(){
  document.getElementById('com-bank-modal').style.display='flex';
  document.getElementById('com-bank-options').innerHTML=banks.map(b=>`<button onclick="comConnectBank('${b.n}')" style="padding:16px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;font-weight:800;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='${b.c}';this.style.color='${b.c}'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-primary)'">${b.n}</button>`).join('');
}
function closeComBankModal(){document.getElementById('com-bank-modal').style.display='none';}
function comConnectBank(name){closeComBankModal();showToast('Redirigiendo al portal de '+name);}

// ============ ANALYTICS ============
function renderComAnalytics(){
  // Top proveedores
  const sorted=[...demoSuppliers].sort((a,b)=>b.yearTotal-a.yearTotal);
  const max=sorted[0]?sorted[0].yearTotal:1;
  document.getElementById('com-chart-top').innerHTML=sorted.map(s=>`<div style="margin-bottom:10px;"><div style="display:flex;justify-content:space-between;margin-bottom:4px;"><span style="font-size:12px;font-weight:700;color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60%;">${s.name}</span><span style="font-size:12px;font-weight:800;color:var(--text-primary);">${fmt(s.yearTotal)}</span></div><div style="height:6px;background:var(--input-bg);border-radius:3px;overflow:hidden;"><div style="width:${(s.yearTotal/max)*100}%;height:100%;background:var(--accent);"></div></div></div>`).join('');

  // Por categoría
  const cats={};demoExpenses.forEach(e=>{cats[e.category]=(cats[e.category]||0)+e.amount;});
  const total=Object.values(cats).reduce((s,v)=>s+v,0)||1;
  document.getElementById('com-chart-cats').innerHTML=`<div style="display:flex;height:24px;border-radius:12px;overflow:hidden;margin-bottom:14px;">${Object.entries(cats).map(([k,v])=>`<div style="width:${(v/total)*100}%;background:${categoryColors[k]||'#6fcff5'};" title="${k}: ${fmt(v)}"></div>`).join('')}</div>${Object.entries(cats).map(([k,v])=>`<div style="display:flex;align-items:center;justify-content:space-between;padding:6px 0;"><div style="display:flex;align-items:center;gap:8px;"><div style="width:10px;height:10px;border-radius:3px;background:${categoryColors[k]||'#6fcff5'};"></div><span style="font-size:12px;color:var(--text-secondary);">${k}</span></div><span style="font-size:13px;font-weight:800;color:var(--text-primary);">${fmt(v)}</span></div>`).join('')}`;

  // Monthly
  const months=['Nov','Dic','Ene','Feb','Mar','Abr'],vals=[78000,92000,65000,88000,105000,129000],mV=Math.max(...vals);
  document.getElementById('com-chart-monthly').innerHTML=months.map((m,i)=>`<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;"><div style="width:100%;background:var(--accent);border-radius:4px 4px 0 0;height:${(vals[i]/mV)*150}px;opacity:0.8;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'" title="${fmt(vals[i])}"><span style="position:relative;top:-16px;left:50%;transform:translateX(-50%);font-size:9px;font-weight:700;color:var(--text-faint);white-space:nowrap;display:block;text-align:center;">$${(vals[i]/1000).toFixed(0)}k</span></div><span style="font-size:10px;color:var(--text-faint);font-weight:600;">${m}</span></div>`).join('');

  // Payment terms
  const terms={};demoSuppliers.forEach(s=>{terms[s.terms]=(terms[s.terms]||0)+1;});
  document.getElementById('com-chart-terms').innerHTML=Object.entries(terms).map(([k,v])=>`<div style="padding:14px;border-radius:10px;background:var(--input-bg);border:1px solid var(--border);text-align:center;"><p style="font-size:20px;font-weight:900;color:var(--accent);">${v}</p><p style="font-size:11px;color:var(--text-muted);margin-top:2px;font-weight:600;">${k}</p></div>`).join('');
}

// ============ AUTOPILOT ============
function renderComAutopilot(){
  const el=document.getElementById('com-auto-list');if(!el)return;
  el.innerHTML=comAutoFlows.map(f=>`<div style="padding:16px;border-radius:12px;border:1px solid ${f.active?f.color+'30':'var(--border)'};background:${f.active?f.color+'08':'var(--input-bg)'};">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;gap:8px;">
      <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0;"><span style="font-size:18px;flex-shrink:0;">${f.icon}</span><span style="font-size:13px;font-weight:800;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;">${f.name}</span></div>
      <label class="com-toggle-wrap"><input type="checkbox" ${f.active?'checked':''} onchange="comAutoFlows.find(x=>x.id==='${f.id}').active=this.checked;renderComAutopilot();showToast(this.checked?'Activado':'Desactivado')"/><span class="com-toggle-slider" style="${f.active?'--toggle-color:'+f.color:''}"></span></label>
    </div>
    <p style="font-size:11px;color:var(--text-muted);line-height:1.4;">${f.desc}</p></div>`).join('');
}

// ============ INIT ============
document.addEventListener('DOMContentLoaded',()=>{
  renderComRecs();
  renderComStats();
  renderComPOs();
  renderComSuppliers();
  renderComInvoices();
  renderComExpenses();
  renderComReconciliation();
  renderComAutopilot();
});
</script>

