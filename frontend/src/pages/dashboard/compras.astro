function renderComInvoices(){
  const tbody=document.getElementById('com-inv-tbody');if(!tbody)return;
  tbody.innerHTML=demoInvoices.map(i=>{const st=invStatusMap[i.status];return `<tr style="border-bottom:1px solid var(--border);">
    <td style="padding:14px 16px;font-weight:700;color:var(--accent);font-size:12px;">${i.folio}</td>
    <td style="padding:14px 16px;font-weight:700;color:var(--text-primary);">${i.supplier}</td>
    <td style="padding:14px 16px;font-size:11px;font-family:monospace;color:var(--text-muted);">${i.rfc}</td>
    <td style="padding:14px 16px;font-size:12px;color:var(--text-muted);">${i.date}</td>
    <td style="padding:14px 16px;text-align:right;font-weight:800;color:var(--text-primary);">${fmt(i.total)}</td>
    <td style="padding:14px 16px;"><span style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;color:${st.c};background:${st.b};">${st.l}</span></td>
    <td style="padding:14px 16px;text-align:center;"><div style="display:flex;gap:4px;justify-content:center;flex-wrap:wrap;">
      <button onclick="showToast('XML descargado')" class="com-tbl-btn">XML</button>
      <button onclick="showToast('PDF descargado')" class="com-tbl-btn">PDF</button>
      ${i.status!=='paid'?`<button onclick="comPayInvoice(${i.id})" class="com-tbl-btn" style="border-color:#22c55e;color:#22c55e;">Pagar</button>`:''}
    </div></td>
  </tr>`;}).join('');
