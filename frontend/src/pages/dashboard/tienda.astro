---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Tienda Online">
  <!-- Smart Recommendations -->
  <div id="store-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="store-stat-label">Visitas del mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="store-stat-visits" class="store-stat-val">--</p><span id="store-trend-visits" class="store-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="store-stat-label" style="display:flex;align-items:center;gap:4px;">Tasa de conversion <span class="store-tip" data-tip="De cada 100 personas que visitan tu tienda, cuantas terminan comprando algo">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="store-stat-conversion" class="store-stat-val" style="color:#22c55e;">--</p><span id="store-trend-conversion" class="store-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="store-stat-label">Pedidos desde tienda</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="store-stat-orders" class="store-stat-val" style="color:var(--accent);">--</p><span id="store-trend-orders" class="store-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="store-stat-label">Productos publicados</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="store-stat-products" class="store-stat-val">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="store-stat-label">Paginas</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="store-stat-pages" class="store-stat-val">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="store-stat-label" style="display:flex;align-items:center;gap:4px;">Dominio <span class="store-tip" data-tip="Estado de tu dominio personalizado o subdominio de SkyBrandMX">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="store-stat-domain" class="store-stat-val" style="font-size:16px;">--</p></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="store-tab-mi-tienda" class="store-tab active" onclick="switchStoreTab('mi-tienda')">Mi tienda</button>
    <button id="store-tab-diseno" class="store-tab" onclick="switchStoreTab('diseno')">Diseno</button>
    <button id="store-tab-paginas" class="store-tab" onclick="switchStoreTab('paginas')">Paginas</button>
    <button id="store-tab-dominio" class="store-tab" onclick="switchStoreTab('dominio')">Dominio</button>
    <button id="store-tab-analitica" class="store-tab" onclick="switchStoreTab('analitica')">Analitica</button>
  </div>

  <!-- Autopilot bar -->
  <div id="store-autopilot" class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;background:linear-gradient(135deg,rgba(34,197,94,0.06),rgba(111,207,245,0.06));border:1px solid rgba(34,197,94,0.15);">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
      <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#22c55e,#6fcff5);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg style="width:18px;height:18px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <div>
        <h3 style="font-size:14px;font-weight:900;color:var(--text-primary);margin-bottom:1px;">Autopilot de tienda</h3>
        <p style="font-size:11px;color:var(--text-muted);">Automatizaciones que mantienen tu tienda optimizada sin que hagas nada.</p>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;">
      <div class="store-autopilot-item">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:12px;font-weight:700;color:var(--text-secondary);">Auto-publicar productos nuevos</span>
          <label class="store-toggle-wrap"><input type="checkbox" checked onchange="toggleAutopilot('auto-publish',this.checked)"><span class="store-toggle-slider"></span></label>
        </div>
        <p style="font-size:10px;color:var(--text-faint);margin-top:4px;">Publica automaticamente los productos cuando los creas</p>
      </div>
      <div class="store-autopilot-item">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:12px;font-weight:700;color:var(--text-secondary);">SEO automatico</span>
          <label class="store-toggle-wrap"><input type="checkbox" checked onchange="toggleAutopilot('seo',this.checked)"><span class="store-toggle-slider"></span></label>
        </div>
        <p style="font-size:10px;color:var(--text-faint);margin-top:4px;">Genera meta tags, descripciones y URLs amigables</p>
      </div>
      <div class="store-autopilot-item">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:12px;font-weight:700;color:var(--text-secondary);">Certificado SSL automatico</span>
          <label class="store-toggle-wrap"><input type="checkbox" checked onchange="toggleAutopilot('ssl',this.checked)"><span class="store-toggle-slider"></span></label>
        </div>
        <p style="font-size:10px;color:var(--text-faint);margin-top:4px;">Renueva el certificado HTTPS de tu tienda</p>
      </div>
      <div class="store-autopilot-item">
        <div style="display:flex;align-items:center;justify-content:space-between;">
          <span style="font-size:12px;font-weight:700;color:var(--text-secondary);">Sitemap automatico</span>
          <label class="store-toggle-wrap"><input type="checkbox" checked onchange="toggleAutopilot('sitemap',this.checked)"><span class="store-toggle-slider"></span></label>
        </div>
        <p style="font-size:10px;color:var(--text-faint);margin-top:4px;">Actualiza el mapa del sitio para buscadores</p>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Mi tienda ══════════ -->
  <div id="store-panel-mi-tienda">
    <div id="store-help-mi-tienda" class="store-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Este es el panel principal de tu tienda online. Aqui puedes ver el estado general, las visitas y gestionar la configuracion.</p>
      <button onclick="storeDismissHelp('mi-tienda')" class="store-help-close">&times;</button>
    </div>

    <!-- Store status card -->
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;margin-bottom:20px;">
      <div style="display:flex;align-items:stretch;flex-wrap:wrap;">
        <!-- Store info -->
        <div style="flex:1;min-width:280px;padding:24px;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div id="store-logo-placeholder" style="width:64px;height:64px;border-radius:14px;background:linear-gradient(135deg,rgba(111,207,245,0.15),rgba(139,92,246,0.15));display:flex;align-items:center;justify-content:center;border:2px dashed rgba(111,207,245,0.3);cursor:pointer;" onclick="showToast('Sube un logo desde Configuracion')" title="Haz clic para subir un logo">
              <svg style="width:28px;height:28px;color:var(--accent);opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
            </div>
            <div>
              <h2 id="store-name" style="font-size:20px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Artesanias Oaxaquenas</h2>
              <a id="store-url" href="#" style="font-size:13px;color:var(--accent);text-decoration:none;display:flex;align-items:center;gap:4px;" target="_blank">
                <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                artesanias-oaxaquenas.skybrandmx.com
              </a>
            </div>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;">
            <div style="background:var(--input-bg);border-radius:10px;padding:14px;">
              <p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Estado</p>
              <span id="store-status-badge" class="store-badge store-badge-success">Publicada</span>
            </div>
            <div style="background:var(--input-bg);border-radius:10px;padding:14px;">
              <p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Tema activo</p>
              <p style="font-size:14px;font-weight:800;color:var(--text-primary);">Moderno</p>
            </div>
            <div style="background:var(--input-bg);border-radius:10px;padding:14px;">
              <p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Visitantes</p>
              <p style="font-size:14px;font-weight:800;color:var(--text-primary);">1,234</p>
            </div>
            <div style="background:var(--input-bg);border-radius:10px;padding:14px;">
              <p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Pedidos</p>
              <p style="font-size:14px;font-weight:800;color:var(--text-primary);">47</p>
            </div>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <button onclick="previewStore()" class="store-btn-primary" style="display:flex;align-items:center;gap:6px;">
              <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              Vista previa
            </button>
            <button onclick="openStoreSettings()" class="store-btn-secondary" style="display:flex;align-items:center;gap:6px;">
              <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Configuracion
            </button>
            <button onclick="toggleStoreStatus()" class="store-btn-secondary" id="store-toggle-btn" style="display:flex;align-items:center;gap:6px;">
              <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636a9 9 0 11-12.728 0M12 3v9"/></svg>
              Despublicar
            </button>
          </div>
        </div>

        <!-- Store preview -->
        <div style="flex:1;min-width:280px;background:linear-gradient(135deg,rgba(111,207,245,0.04),rgba(139,92,246,0.04));border-left:1px solid var(--border);display:flex;align-items:center;justify-content:center;padding:24px;">
          <div style="width:100%;max-width:320px;background:var(--bg-sidebar);border-radius:12px;overflow:hidden;border:1px solid var(--border);box-shadow:0 4px 20px rgba(0,0,0,0.15);">
            <div style="background:linear-gradient(135deg,#6fcff5,#8b5cf6);padding:12px 16px;display:flex;align-items:center;gap:8px;">
              <div style="width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.4);"></div>
              <div style="width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.4);"></div>
              <div style="width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.4);"></div>
              <div style="flex:1;background:rgba(255,255,255,0.2);border-radius:4px;padding:3px 8px;font-size:9px;color:rgba(255,255,255,0.8);text-align:center;">artesanias-oaxaquenas.skybrandmx.com</div>
            </div>
            <div style="padding:16px;">
              <div style="width:100%;height:80px;background:linear-gradient(135deg,rgba(111,207,245,0.15),rgba(139,92,246,0.1));border-radius:8px;margin-bottom:12px;display:flex;align-items:center;justify-content:center;">
                <p style="font-size:11px;font-weight:800;color:var(--text-primary);opacity:0.6;">Banner principal</p>
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
                <div style="height:50px;background:var(--input-bg);border-radius:6px;"></div>
                <div style="height:50px;background:var(--input-bg);border-radius:6px;"></div>
                <div style="height:50px;background:var(--input-bg);border-radius:6px;"></div>
              </div>
              <div style="margin-top:10px;height:6px;background:var(--input-bg);border-radius:3px;width:60%;"></div>
              <div style="margin-top:6px;height:6px;background:var(--input-bg);border-radius:3px;width:40%;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Store settings modal (inline, toggled) -->
    <div id="store-settings-modal" class="store-modal-overlay" style="display:none;">
      <div class="store-modal">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
          <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);">Configuracion de la tienda</h3>
          <button onclick="closeStoreSettings()" class="store-help-close" style="position:static;">&times;</button>
        </div>
        <div style="display:flex;flex-direction:column;gap:16px;">
          <div>
            <label class="store-form-label">Nombre de la tienda</label>
            <input id="store-setting-name" type="text" class="store-input" value="Artesanias Oaxaquenas" />
          </div>
          <div>
            <label class="store-form-label">Descripcion</label>
            <textarea id="store-setting-desc" class="store-input" rows="3" style="resize:vertical;">Artesanias hechas a mano desde Oaxaca, Mexico. Tradicion y calidad en cada pieza.</textarea>
          </div>
          <div>
            <label class="store-form-label">Moneda</label>
            <select id="store-setting-currency" class="store-input" style="cursor:pointer;">
              <option value="MXN" selected>MXN - Peso mexicano</option>
              <option value="USD">USD - Dolar americano</option>
            </select>
          </div>
          <div>
            <label class="store-form-label">Idioma</label>
            <select id="store-setting-lang" class="store-input" style="cursor:pointer;">
              <option value="es" selected>Espanol</option>
              <option value="en">Ingles</option>
            </select>
          </div>
          <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:8px;">
            <button onclick="closeStoreSettings()" class="store-btn-secondary">Cancelar</button>
            <button onclick="saveStoreSettings()" class="store-btn-primary">Guardar cambios</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Diseno ══════════ -->
  <div id="store-panel-diseno" style="display:none;">
    <div id="store-help-diseno" class="store-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Elige un tema para tu tienda y personaliza los colores, el logo y las fuentes. Los cambios se ven en tiempo real.</p>
      <button onclick="storeDismissHelp('diseno')" class="store-help-close">&times;</button>
    </div>

    <!-- Theme selector -->
    <h3 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:14px;">Elige un tema</h3>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:24px;">
      <!-- Theme: Moderno -->
      <div id="store-theme-moderno" class="store-theme-card store-theme-active" onclick="selectTheme('moderno')">
        <div class="store-theme-preview" style="background:linear-gradient(135deg,#0f172a,#1e293b);">
          <div style="display:flex;gap:6px;margin-bottom:8px;">
            <div style="width:20px;height:20px;border-radius:4px;background:#6fcff5;"></div>
            <div style="flex:1;height:20px;border-radius:4px;background:rgba(255,255,255,0.1);"></div>
          </div>
          <div style="height:40px;background:linear-gradient(135deg,#6fcff5,#8b5cf6);border-radius:6px;margin-bottom:6px;"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;">
            <div style="height:24px;background:rgba(255,255,255,0.06);border-radius:4px;"></div>
            <div style="height:24px;background:rgba(255,255,255,0.06);border-radius:4px;"></div>
          </div>
        </div>
        <div class="store-theme-info">
          <p class="store-theme-name">Moderno</p>
          <p class="store-theme-desc">Limpio y profesional con colores vibrantes</p>
        </div>
        <div class="store-theme-check">
          <svg style="width:16px;height:16px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
      </div>

      <!-- Theme: Artesanal -->
      <div id="store-theme-artesanal" class="store-theme-card" onclick="selectTheme('artesanal')">
        <div class="store-theme-preview" style="background:linear-gradient(135deg,#fef3c7,#fde68a);">
          <div style="display:flex;gap:6px;margin-bottom:8px;">
            <div style="width:20px;height:20px;border-radius:4px;background:#92400e;"></div>
            <div style="flex:1;height:20px;border-radius:4px;background:rgba(0,0,0,0.08);"></div>
          </div>
          <div style="height:40px;background:linear-gradient(135deg,#92400e,#b45309);border-radius:6px;margin-bottom:6px;"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;">
            <div style="height:24px;background:rgba(0,0,0,0.06);border-radius:4px;"></div>
            <div style="height:24px;background:rgba(0,0,0,0.06);border-radius:4px;"></div>
          </div>
        </div>
        <div class="store-theme-info">
          <p class="store-theme-name">Artesanal</p>
          <p class="store-theme-desc">Tonos calidos y texturas naturales</p>
        </div>
        <div class="store-theme-check">
          <svg style="width:16px;height:16px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
      </div>

      <!-- Theme: Minimalista -->
      <div id="store-theme-minimalista" class="store-theme-card" onclick="selectTheme('minimalista')">
        <div class="store-theme-preview" style="background:linear-gradient(135deg,#f8fafc,#e2e8f0);">
          <div style="display:flex;gap:6px;margin-bottom:8px;">
            <div style="width:20px;height:20px;border-radius:4px;background:#1e293b;"></div>
            <div style="flex:1;height:20px;border-radius:4px;background:rgba(0,0,0,0.06);"></div>
          </div>
          <div style="height:40px;background:#1e293b;border-radius:6px;margin-bottom:6px;"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;">
            <div style="height:24px;background:rgba(0,0,0,0.04);border-radius:4px;"></div>
            <div style="height:24px;background:rgba(0,0,0,0.04);border-radius:4px;"></div>
          </div>
        </div>
        <div class="store-theme-info">
          <p class="store-theme-name">Minimalista</p>
          <p class="store-theme-desc">Blanco y negro, elegante y simple</p>
        </div>
        <div class="store-theme-check">
          <svg style="width:16px;height:16px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
      </div>

      <!-- Theme: Colorido -->
      <div id="store-theme-colorido" class="store-theme-card" onclick="selectTheme('colorido')">
        <div class="store-theme-preview" style="background:linear-gradient(135deg,#fdf2f8,#ede9fe);">
          <div style="display:flex;gap:6px;margin-bottom:8px;">
