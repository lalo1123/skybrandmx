// ═══════ CRM AUTOCOMPLETE (busca clientes existentes al escribir nombre) ═══════
function pedCrmAutocomplete(query){
  const box=document.getElementById('ped-crm-sugg');
  if(!box)return;
  const q=(query||'').trim().toLowerCase();
  let contacts=[];
  try{contacts=JSON.parse(localStorage.getItem('crm_contacts'))||[];}catch(e){}
  if(q.length<2){box.style.display='none';return;}
  const matches=contacts.filter(c=>{
    const full=((c.first_name||'')+' '+(c.last_name||'')).toLowerCase();
    return full.includes(q) || (c.email||'').toLowerCase().includes(q) || (c.phone||'').includes(q);
  }).slice(0,6);
  if(matches.length===0){box.style.display='none';return;}
  box.innerHTML=matches.map(c=>{
    const full=`${c.first_name||''} ${c.last_name||''}`.trim();
    const orders=c.total_orders||0;
    const badge=orders>=5?'⭐ VIP':orders>=2?`🔁 ${orders}× pedidos`:'Nuevo';
    const badgeColor=orders>=5?'#f97316':orders>=2?'#8b5cf6':'#6fcff5';
    return `<div style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;gap:10px;" onmousedown="pedCrmPick('${(c.email||'').replace(/'/g,"\\'")}')" onmouseover="this.style.background='rgba(111,207,245,0.1)'" onmouseout="this.style.background='transparent'">
      <div style="flex:1;min-width:0;">
        <p style="font-size:13px;font-weight:800;color:var(--text-primary);">${full}</p>
        <p style="font-size:11px;color:var(--text-muted);">${c.email||'sin email'} · ${c.phone||'sin teléfono'}</p>
      </div>
      <span style="font-size:10px;font-weight:800;padding:3px 8px;border-radius:6px;background:${badgeColor}22;color:${badgeColor};white-space:nowrap;">${badge}</span>
    </div>`;
  }).join('');
  box.style.display='block';
}
function pedCrmPick(email){
  let contacts=[];
  try{contacts=JSON.parse(localStorage.getItem('crm_contacts'))||[];}catch(e){}
  const c=contacts.find(x=>x.email===email);
  if(!c)return;
  const full=`${c.first_name||''} ${c.last_name||''}`.trim();
  document.getElementById('ped-wiz-name').value=full;
  document.getElementById('ped-wiz-email').value=c.email||'';
  document.getElementById('ped-wiz-phone').value=c.phone||'';
  document.getElementById('ped-wiz-address').value=c.address||'';
  // Mark all as touched and validate
  ['name','email','phone','address'].forEach(f=>{
    const el=document.getElementById('ped-wiz-'+f);
    if(el)el.dataset.touched='1';
  });
  pedEzValidate(1);
  document.getElementById('ped-crm-sugg').style.display='none';
  showToast(`✓ Cliente cargado · Ya te compró ${c.total_orders||0} vez${(c.total_orders||0)!==1?'es':''}`);
}

