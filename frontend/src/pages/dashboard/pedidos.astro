function pedWizCancel(){if(confirm('¿Seguro? Se perderán los datos.')){pedEditingId=null;pedWizDone();}}
function pedWizDone(){
  document.getElementById('ped-wizard').style.display='none';
  document.getElementById('ped-easy-home').style.display='block';
  pedEzGoTo(1);
  pedEditingId=null;
  pedUpdateEasyStats();
}
function pedEzGoTo(step){
  pedEzStep=step;
  for(let i=1;i<=5;i++){const el=document.getElementById('ped-wiz-step-'+i);if(el)el.style.display=(step===i)?'block':'none';}
  document.getElementById('ped-wiz-step-done').style.display=step==='done'?'block':'none';
  document.querySelectorAll('.ped-wiz-step-bar').forEach((b,i)=>{
    b.classList.remove('active','done');
    const n=i+1;
    if(typeof step==='number'){if(n<step)b.classList.add('done');else if(n===step)b.classList.add('active');}
    else if(step==='done'){b.classList.add('done');}
  });
  const titles={1:'¿Quién te compró?',2:'¿Qué te pidió?',3:'¿Cómo te pagó?',4:'¿Cómo lo mandas?',5:'Revisa',done:'¡Listo!'};
  document.getElementById('ped-wiz-title').textContent=(pedEditingId?'Editar pedido · ':'Registrar pedido · ')+(titles[step]||'');
  // When entering step 2, render catalog picker
  if(step===2){setTimeout(()=>{if(typeof pedRenderCatalogPicker==='function')pedRenderCatalogPicker();},30);}
  document.getElementById('ped-wiz-subtitle').textContent=step==='done'?'Completado':`Paso ${step} de 5`;
  const back=document.getElementById('ped-wiz-back');
  if(back)back.style.visibility=(step===1||step==='done')?'hidden':'visible';
  if(step===5)pedWizRenderSummary();
  window.scrollTo({top:0,behavior:'smooth'});
}
function pedEzNext(){if(typeof pedEzStep==='number' && pedEzStep<5)pedEzGoTo(pedEzStep+1);}
function pedEzBack(){if(typeof pedEzStep==='number' && pedEzStep>1)pedEzGoTo(pedEzStep-1);}
// Helper: set field state (only show error if user touched the field)
function pedFieldErr(id,msg){
  const input=document.getElementById(id);
  const err=document.getElementById(id+'-err');
  if(!input||!err)return;
  const touched=input.dataset.touched==='1' || input.value.length>0;
  if(msg && touched){
    input.classList.add('invalid');
    err.innerHTML='⚠️ '+msg;
  } else {
    input.classList.remove('invalid');
    err.innerHTML='';
  }
}
// Helper: show "missing" summary box below button
function pedShowMissing(step,missing){
  const box=document.getElementById('ped-wiz-missing-'+step);
  if(!box)return;
  if(missing.length===0){box.style.display='none';return;}
  box.style.display='flex';
  box.innerHTML=`<span style="font-size:16px;flex-shrink:0;">⚠️</span><div><strong>Para continuar te falta:</strong><br/>${missing.map(m=>'• '+m).join('<br/>')}</div>`;
}
function pedEzValidate(step){
  let valid=false;
  let missing=[];
  if(step===1){
    const name=document.getElementById('ped-wiz-name').value.trim();
    const email=document.getElementById('ped-wiz-email').value.trim();
    const phone=document.getElementById('ped-wiz-phone').value.trim();
    const addr=document.getElementById('ped-wiz-address').value.trim();
    // Per-field validation with helpful messages
    pedFieldErr('ped-wiz-name', name.length===0?'El nombre del cliente es obligatorio':name.length<3?'El nombre se ve muy corto, escribe al menos 3 letras':'');
    pedFieldErr('ped-wiz-email', email.length>0 && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)?'Verifica el correo, falta el @ o el dominio':'');
    pedFieldErr('ped-wiz-phone', phone.length===0?'Necesitamos el teléfono por si la paquetería tiene que llamar':phone.length<8?'Faltan números, los teléfonos en México tienen 10 dígitos':'');
    pedFieldErr('ped-wiz-address', addr.length===0?'La dirección completa es obligatoria para poder enviarle':addr.length<10?'Falta detalle: incluye calle, número, colonia, ciudad y CP':'');
    if(name.length<3)missing.push(`Escribe el <strong>nombre</strong> del cliente`);
    if(phone.length<8)missing.push(`Escribe el <strong>teléfono</strong> del cliente`);
    if(addr.length<10)missing.push(`Escribe la <strong>dirección</strong> completa`);
    if(email.length>0 && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email))missing.push(`El <strong>correo</strong> no parece válido`);
    valid=name.length>=3 && phone.length>=8 && addr.length>=10 && (email.length===0 || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email));
  } else if(step===2){
    const total=pedWizItems.reduce((s,i)=>s+(i.qty*i.price),0);
    const allHaveName=pedWizItems.every(i=>i.name.trim().length>0);
    const allHavePrice=pedWizItems.every(i=>i.price>0);
    if(!allHaveName)missing.push(`Cada producto necesita una <strong>descripción</strong>`);
    if(!allHavePrice)missing.push(`Cada producto necesita un <strong>precio mayor a 0</strong>`);
    if(total===0 && allHaveName && allHavePrice)missing.push(`El total no puede ser $0`);
    valid=total>0 && allHaveName && allHavePrice;
  }
  pedShowMissing(step,missing);
  const btn=document.getElementById('ped-wiz-next-'+step);
  if(btn)btn.disabled=!valid;
  return valid;
}
