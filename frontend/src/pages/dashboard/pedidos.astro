---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Pedidos">
  <!-- ════════ MODO FÁCIL / EXPERTO TOGGLE ════════ -->
  <div class="ped-mode-switcher" style="display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:18px;padding:14px 18px;border-radius:14px;background:linear-gradient(135deg,rgba(111,207,245,0.08),rgba(139,92,246,0.08));border:1px solid rgba(111,207,245,0.2);flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:12px;">
      <span style="font-size:24px;">📦</span>
      <div>
        <p id="ped-mode-greeting" style="font-size:13px;font-weight:800;color:var(--text-primary);">Hola, ¿qué quieres hacer hoy?</p>
        <p id="ped-mode-sub" style="font-size:11px;color:var(--text-muted);">Registrar una venta nueva, ver tus pedidos o marcar uno como enviado</p>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <button onclick="pedStartTour()" style="padding:8px 14px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;">🎓 Tour guiado</button>
      <div style="display:flex;background:rgba(0,0,0,0.25);border-radius:10px;padding:3px;gap:2px;">
        <button id="ped-mode-easy" onclick="pedSetMode('easy')" class="ped-mode-btn active">😊 Fácil</button>
        <button id="ped-mode-pro" onclick="pedSetMode('pro')" class="ped-mode-btn">🔧 Experto</button>
      </div>
    </div>
  </div>

  <!-- ════════ MODO FÁCIL ════════ -->
  <div id="ped-easy-mode" style="display:block;">
    <!-- Pantalla de inicio -->
    <div id="ped-easy-home" style="display:block;">
      <div class="ped-easy-hero" style="padding:40px 32px;border-radius:18px;background:linear-gradient(135deg,#084d6e 0%,#f97316 100%);color:#fff;margin-bottom:20px;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-30px;right:-30px;font-size:180px;opacity:0.15;">📦</div>
        <h2 style="font-size:24px;font-weight:900;margin-bottom:8px;">¿Alguien te compró? ¡Vamos a registrarlo! 🛒</h2>
        <p style="font-size:14px;opacity:0.9;margin-bottom:20px;max-width:600px;">En 5 pasos simples capturas un pedido nuevo: quién te compró, qué te pidió, cómo te pagó y cómo lo vas a mandar. Nosotros llevamos el conteo por ti.</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <button onclick="pedWizStart(false)" class="ped-easy-cta-primary">✨ Registrar un pedido</button>
          <button onclick="pedWizStart(true)" class="ped-easy-cta-secondary">👀 Probar con datos de ejemplo</button>
        </div>
      </div>

      <p style="font-size:13px;font-weight:800;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;">¿Qué necesitas hacer?</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-bottom:24px;">
        <button onclick="pedWizStart(false)" class="ped-easy-card">
          <span class="ped-easy-card-emoji">🛒</span>
          <p class="ped-easy-card-title">Registrar un pedido</p>
          <p class="ped-easy-card-desc">Alguien te compró — captura los datos</p>
        </button>
        <button onclick="pedSetMode('pro');setTimeout(()=>{switchPedTab('ship');},200);" class="ped-easy-card">
          <span class="ped-easy-card-emoji">📤</span>
          <p class="ped-easy-card-title">Enviar pedidos pendientes</p>
          <p class="ped-easy-card-desc" id="ped-easy-ship-count">Los que ya te pagaron y faltan mandar</p>
        </button>
        <button onclick="pedSetMode('pro');setTimeout(()=>{switchPedTab('all');},200);" class="ped-easy-card">
          <span class="ped-easy-card-emoji">📋</span>
          <p class="ped-easy-card-title">Ver todos los pedidos</p>
          <p class="ped-easy-card-desc">Historial completo de tus ventas</p>
        </button>
        <button onclick="pedSetMode('pro');setTimeout(()=>{switchPedTab('returns');},200);" class="ped-easy-card">
          <span class="ped-easy-card-emoji">↩️</span>
          <p class="ped-easy-card-title">Devoluciones</p>
          <p class="ped-easy-card-desc">Gestiona si un cliente quiere regresar algo</p>
        </button>
        <button onclick="pedSetMode('pro');setTimeout(()=>{switchPedTab('analytics');},200);" class="ped-easy-card">
          <span class="ped-easy-card-emoji">📊</span>
          <p class="ped-easy-card-title">¿Cómo va mi negocio?</p>
          <p class="ped-easy-card-desc">Ventas del mes, productos top, tendencias</p>
        </button>
        <button onclick="alert('Próximamente: conecta Shopify, WooCommerce, MercadoLibre')" class="ped-easy-card">
          <span class="ped-easy-card-emoji">🔌</span>
          <p class="ped-easy-card-title">Conectar mi tienda</p>
          <p class="ped-easy-card-desc">Shopify, MercadoLibre, WooCommerce</p>
        </button>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;">
        <div class="stat-card" style="padding:18px;text-align:center;">
          <p style="font-size:32px;font-weight:900;color:#22c55e;" id="ped-easy-today">0</p>
          <p style="font-size:12px;color:var(--text-muted);font-weight:700;margin-top:4px;">🎯 Pedidos de hoy</p>
        </div>
        <div class="stat-card" style="padding:18px;text-align:center;">
          <p style="font-size:32px;font-weight:900;color:#f97316;" id="ped-easy-ship">0</p>
          <p style="font-size:12px;color:var(--text-muted);font-weight:700;margin-top:4px;">📦 Por enviar</p>
        </div>
        <div class="stat-card" style="padding:18px;text-align:center;">
          <p style="font-size:32px;font-weight:900;color:#6fcff5;" id="ped-easy-revenue">$0</p>
          <p style="font-size:12px;color:var(--text-muted);font-weight:700;margin-top:4px;">💰 Vendido este mes</p>
        </div>
      </div>
    </div>

    <!-- Wizard -->
    <div id="ped-wizard" style="display:none;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <button onclick="pedEzBack()" id="ped-wiz-back" style="width:36px;height:36px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);cursor:pointer;font-size:18px;">←</button>
          <div>
            <p style="font-size:18px;font-weight:900;color:var(--text-primary);" id="ped-wiz-title">Registrar pedido</p>
            <p style="font-size:12px;color:var(--text-muted);" id="ped-wiz-subtitle">Paso 1 de 5</p>
          </div>
        </div>
        <button onclick="pedWizCancel()" style="padding:8px 14px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;">✕ Cancelar</button>
      </div>

      <div style="display:flex;gap:6px;margin-bottom:28px;">
        <div class="ped-wiz-step-bar active"></div>
        <div class="ped-wiz-step-bar"></div>
        <div class="ped-wiz-step-bar"></div>
        <div class="ped-wiz-step-bar"></div>
        <div class="ped-wiz-step-bar"></div>
      </div>

      <!-- PASO 1: ¿Quién te compró? -->
      <div id="ped-wiz-step-1" class="ped-wiz-step">
        <div class="stat-card" style="padding:32px;max-width:680px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="ped-wiz-step-num">1</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿Quién te compró?</h3>
              <p style="font-size:13px;color:var(--text-muted);">Anota los datos de tu cliente para poder mandarle su paquete y contactarlo si hace falta</p>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:16px;">
            <div>
              <label class="ped-wiz-label">Nombre completo del cliente</label>
              <input id="ped-wiz-name" type="text" class="ped-wiz-input" placeholder="Ej: María García López" oninput="pedEzValidate(1);"/>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div>
                <label class="ped-wiz-label">Email <span class="ped-wiz-help">(para mandarle confirmación)</span></label>
                <input id="ped-wiz-email" type="email" class="ped-wiz-input" placeholder="Ej: maria@gmail.com" oninput="pedEzValidate(1);"/>
              </div>
              <div>
                <label class="ped-wiz-label">Teléfono / WhatsApp</label>
                <input id="ped-wiz-phone" type="tel" class="ped-wiz-input" placeholder="Ej: 55 1234 5678" oninput="pedEzValidate(1);"/>
              </div>
            </div>
            <div>
              <label class="ped-wiz-label">Dirección completa <span class="ped-wiz-help">(a dónde le vas a mandar el paquete)</span></label>
              <textarea id="ped-wiz-address" rows="2" class="ped-wiz-input" placeholder="Ej: Av. Insurgentes 123, Col. Del Valle, CDMX, CP 03100" oninput="pedEzValidate(1);"></textarea>
            </div>
          </div>
          <button onclick="pedEzNext()" id="ped-wiz-next-1" class="ped-wiz-next" disabled>Siguiente →</button>
        </div>
      </div>

      <!-- PASO 2: ¿Qué te pidió? -->
      <div id="ped-wiz-step-2" class="ped-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:780px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="ped-wiz-step-num" style="background:#f97316;">2</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿Qué te pidió?</h3>
              <p style="font-size:13px;color:var(--text-muted);">Lista los productos que compró y a cuánto. Si pidió varios, agrégalos todos</p>
            </div>
          </div>
          <div id="ped-wiz-items" style="display:flex;flex-direction:column;gap:10px;"></div>
          <button onclick="pedWizAddItem()" style="margin-top:10px;padding:10px;border-radius:10px;border:1px dashed var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;width:100%;">+ Agregar otro producto</button>
          <div style="margin-top:20px;padding:16px;border-radius:12px;background:var(--input-bg);border:1px solid var(--border);">
            <div style="display:flex;justify-content:space-between;font-size:18px;font-weight:900;"><span>Total del pedido</span><span id="ped-wiz-total" style="color:var(--accent);">$0.00</span></div>
            <p style="font-size:10px;color:var(--text-faint);margin-top:4px;">Sin envío — el envío lo elegimos en el paso 4</p>
          </div>
          <button onclick="pedEzNext()" id="ped-wiz-next-2" class="ped-wiz-next" disabled>Siguiente →</button>
        </div>
      </div>

      <!-- PASO 3: ¿Cómo te pagó? -->
      <div id="ped-wiz-step-3" class="ped-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:720px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="ped-wiz-step-num" style="background:#22c55e;">3</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿Cómo te pagó?</h3>
              <p style="font-size:13px;color:var(--text-muted);">O si aún no te paga, marca la opción "Pendiente"</p>
            </div>
          </div>
          <div id="ped-wiz-payment-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;"></div>
          <button onclick="pedEzNext()" class="ped-wiz-next">Siguiente →</button>
        </div>
      </div>

      <!-- PASO 4: ¿Cómo se lo vas a mandar? -->
      <div id="ped-wiz-step-4" class="ped-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:720px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="ped-wiz-step-num" style="background:#8b5cf6;">4</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿Cómo se lo vas a mandar?</h3>
              <p style="font-size:13px;color:var(--text-muted);">Puedes generar la guía ahora o después desde el módulo de Envíos</p>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;">
            <div onclick="pedWizPickShip('later')" id="ped-wiz-ship-later" class="ped-wiz-ship-card selected">
              <div style="font-size:36px;">⏰</div>
              <p style="font-size:14px;font-weight:900;color:var(--text-primary);margin-top:8px;">Lo mando después</p>
              <p style="font-size:11px;color:var(--text-muted);margin-top:4px;">Guardo el pedido. Genero la guía cuando pueda desde Envíos</p>
            </div>
            <div onclick="pedWizPickShip('now')" id="ped-wiz-ship-now" class="ped-wiz-ship-card">
              <div style="font-size:36px;">🚀</div>
              <p style="font-size:14px;font-weight:900;color:var(--text-primary);margin-top:8px;">Generar guía ahora</p>
              <p style="font-size:11px;color:var(--text-muted);margin-top:4px;">Voy al módulo de envíos con los datos pre-llenados</p>
            </div>
            <div onclick="pedWizPickShip('pickup')" id="ped-wiz-ship-pickup" class="ped-wiz-ship-card">
              <div style="font-size:36px;">🏪</div>
              <p style="font-size:14px;font-weight:900;color:var(--text-primary);margin-top:8px;">Va a pasar por él</p>
              <p style="font-size:11px;color:var(--text-muted);margin-top:4px;">El cliente recoge en tienda, no necesito envío</p>
            </div>
          </div>
          <div style="margin-top:20px;">
            <label class="ped-wiz-label">¿Algo que deba recordar? <span class="ped-wiz-help">(ej: envolver para regalo, dejar en recepción)</span></label>
            <textarea id="ped-wiz-notes" rows="2" class="ped-wiz-input" placeholder="(opcional)"></textarea>
          </div>
          <button onclick="pedEzNext()" class="ped-wiz-next">Siguiente →</button>
        </div>
      </div>

      <!-- PASO 5: Revisar -->
      <div id="ped-wiz-step-5" class="ped-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:680px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="ped-wiz-step-num" style="background:#22c55e;">5</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">Revisa el pedido</h3>
              <p style="font-size:13px;color:var(--text-muted);">¿Todo se ve bien?</p>
            </div>
          </div>
          <div id="ped-wiz-summary" style="display:flex;flex-direction:column;gap:10px;"></div>
          <button onclick="pedWizConfirm()" class="ped-wiz-next" style="background:#22c55e;font-size:16px;">✅ Guardar pedido</button>
        </div>
      </div>

      <!-- DONE -->
      <div id="ped-wiz-step-done" class="ped-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:48px 32px;max-width:560px;margin:0 auto;text-align:center;">
          <div style="font-size:80px;margin-bottom:16px;">🎉</div>
          <h3 style="font-size:24px;font-weight:900;color:#22c55e;">¡Pedido registrado!</h3>
          <p id="ped-wiz-done-msg" style="font-size:14px;color:var(--text-muted);margin-top:10px;">Ya está guardado en tu lista de pedidos.</p>
          <div style="margin-top:24px;padding:18px;border-radius:12px;background:var(--input-bg);border:1px solid var(--border);text-align:left;">
            <p style="font-size:11px;font-weight:800;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Número de pedido</p>
            <p id="ped-wiz-done-num" style="font-size:18px;font-weight:900;color:var(--accent);font-family:monospace;margin-top:4px;">--</p>
          </div>
          <div style="display:flex;gap:10px;margin-top:24px;justify-content:center;flex-wrap:wrap;">
            <button onclick="pedWizDone()" class="ped-wiz-next" style="flex:1;min-width:180px;margin:0;background:#22c55e;">✅ Registrar otro pedido</button>
          </div>
          <p style="font-size:11px;color:var(--text-faint);margin-top:16px;">¿Otra cosa? <a href="#" onclick="pedWizDone();return false;" style="color:var(--accent);">Volver al inicio</a></p>
        </div>
      </div>
    </div>
  </div>

  <!-- ════════ MODO EXPERTO (todo lo anterior) ════════ -->
  <div id="ped-pro-mode" style="display:none;">
  <!-- Smart Recommendations -->
  <div id="ped-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Pedidos hoy</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-today" class="ped-stat-val">--</p><span id="ped-trend-today" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Ingresos del mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-revenue" class="ped-stat-val" style="color:#22c55e;">--</p><span id="ped-trend-revenue" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Ticket promedio <span class="ped-tip" data-tip="Lo que gasta en promedio cada cliente por pedido">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-avg" class="ped-stat-val" style="color:var(--accent);">--</p><span id="ped-trend-avg" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Pendientes de envío <span class="ped-tip" data-tip="Pedidos que ya están pagados pero aún no se envían al cliente">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-pending" class="ped-stat-val" style="color:#f97316;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Tasa de conversión <span class="ped-tip" data-tip="De cada 100 personas que visitan tu tienda, ¿cuántas terminan comprando?">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-conv" class="ped-stat-val">--</p><span id="ped-trend-conv" class="ped-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="ped-stat-label">Devoluciones <span class="ped-tip" data-tip="Pedidos que el cliente pidió regresar o cancelar después de recibirlos">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="ped-stat-returns" class="ped-stat-val" style="color:#ef4444;">--</p><span id="ped-trend-returns" class="ped-trend"></span></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="ped-tab-all" class="ped-tab active" onclick="switchPedTab('all')">Todos los pedidos</button>
    <button id="ped-tab-ship" class="ped-tab" onclick="switchPedTab('ship')">Por enviar <span id="ped-ship-badge" class="ped-tab-badge">0</span></button>
    <button id="ped-tab-returns" class="ped-tab" onclick="switchPedTab('returns')">Devoluciones</button>
    <button id="ped-tab-analytics" class="ped-tab" onclick="switchPedTab('analytics')">Analítica</button>
  </div>

  <!-- ══════════ Tab: All Orders ══════════ -->
  <div id="ped-panel-all">
    <div id="ped-help-all" class="ped-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aquí ves todos los pedidos de tu tienda. Puedes filtrar por estado, buscar por nombre o número de pedido.</p>
      <button onclick="pedDismissHelp('all')" class="ped-help-close">&times;</button>
    </div>
    <div id="ped-empty-all" style="display:none;" class="ped-empty-state">
      <svg style="width:56px;height:56px;color:var(--accent);opacity:0.5;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      <h3 style="font-size:16px;font-weight:800;color:var(--text-primary);margin:12px 0 6px;">Aún no tienes pedidos</h3>
      <p style="font-size:13px;color:var(--text-muted);max-width:360px;line-height:1.5;">Cuando tus clientes compren en tu tienda, sus pedidos aparecerán aquí automáticamente.</p>
      <button onclick="openOrderWizard()" class="ped-btn-primary" style="margin-top:16px;padding:12px 28px;">Crear pedido manual</button>
    </div>
    <!-- Toolbar -->
    <div id="ped-toolbar" class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
