  board.innerHTML=PED_KANBAN_COLS.map(col=>{
    const orders=demoOrders.filter(o=>o.status===col.id);
    const cards=orders.map(o=>{
      const stats=pedGetCustomerStats(o.email);
      const repeatBadge=stats&&stats.orders>=5?`<span class="ped-vip-badge">⭐ VIP ${stats.orders}×</span>`:stats&&stats.orders>=2?`<span class="ped-repeat-badge">🔁 ${stats.orders}×</span>`:'';
      return `<div class="ped-kanban-card" draggable="true" style="--col-color:${col.color};" ondragstart="pedDragStart(event,${o.id})" ondragend="pedDragEnd(event)" onclick="pedShowDetail(${o.id})">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:6px;">
          <div style="flex:1;min-width:0;">
            <p class="ped-kanban-card-num">${o.num}</p>
            <p class="ped-kanban-card-client">${o.client}</p>
          </div>
          ${repeatBadge}
        </div>
        <p class="ped-kanban-card-total">$${o.total.toLocaleString()}</p>
        <p class="ped-kanban-card-meta">
          <span>${(o.products||[]).length} producto${(o.products||[]).length!==1?'s':''}</span>
          <span>📅 ${o.date}</span>
        </p>
      </div>`;
    }).join('');
    return `<div class="ped-kanban-col" style="--col-color:${col.color};" ondragover="pedDragOver(event,this)" ondragleave="this.classList.remove('drag-over')" ondrop="pedDrop(event,'${col.id}',this)">
      <div class="ped-kanban-col-header">
        <p class="ped-kanban-col-title"><span class="ped-kanban-col-emoji">${col.emoji}</span> ${col.title}</p>
        <span class="ped-kanban-col-count">${orders.length}</span>
      </div>
      <div class="ped-kanban-cards">
        ${cards||'<div class="ped-kanban-empty">Sin pedidos<br/>Arrastra uno aquí</div>'}
      </div>
    </div>`;
  }).join('');
}
function pedDragStart(e,id){pedDraggingId=id;e.dataTransfer.effectAllowed='move';}
function pedDragEnd(e){pedDraggingId=null;document.querySelectorAll('.ped-kanban-col').forEach(c=>c.classList.remove('drag-over'));}
function pedDragOver(e,col){e.preventDefault();col.classList.add('drag-over');}
function pedDrop(e,newStatus,col){
  e.preventDefault();col.classList.remove('drag-over');
  const o=demoOrders.find(x=>x.id===pedDraggingId);
  if(!o||o.status===newStatus)return;
  const oldStatus=o.status;
  o.status=newStatus;
  if(!o.history)o.history=[];
  const labels={new:'Nuevo',paid:'Pagado',preparing:'Preparando',shipped:'Enviado',delivered:'Entregado',cancelled:'Cancelado'};
  o.history.push({date:new Date().toISOString(),event:`Cambió a "${labels[newStatus]||newStatus}"`,actor:'Tú'});
  renderKanban();renderOrders();renderShipList();renderPedStats();renderPedRecs();
  showToast(`✓ ${o.num} → ${labels[newStatus]}`);
}

