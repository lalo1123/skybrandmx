  const mH=Math.max(...hD.flat());
  document.getElementById('ped-chart-hours').innerHTML=`<div style="display:grid;grid-template-columns:40px repeat(${hours.length},1fr);gap:3px;"><div></div>${hours.map(h=>`<div style="text-align:center;font-size:9px;color:var(--text-faint);font-weight:600;">${h}h</div>`).join('')}${days.map((d,di)=>`<div style="font-size:10px;color:var(--text-faint);font-weight:600;display:flex;align-items:center;">${d}</div>${hD[di].map(v=>{const int=v/mH;return`<div style="aspect-ratio:1;border-radius:4px;background:rgba(111,207,245,${0.08+int*0.9});display:flex;align-items:center;justify-content:center;" title="${v} pedidos"><span style="font-size:8px;font-weight:700;color:${int>0.5?'#fff':'transparent'};">${v}</span></div>`;}).join('')}`).join('')}</div>`;

