function renderWizSummary(){const c=document.getElementById('ped-wiz-client').value||'--';const e=document.getElementById('ped-wiz-email').value||'--';const a=document.getElementById('ped-wiz-address').value||'--';const t=pedWizProducts.reduce((s,p)=>s+(p.price*p.qty),0);document.getElementById('ped-wiz-summary').innerHTML=`<div style="display:grid;grid-template-columns:100px 1fr;gap:8px;font-size:12px;"><span style="color:var(--text-faint);font-weight:700;">Cliente:</span><span style="color:var(--text-primary);font-weight:600;">${c}</span><span style="color:var(--text-faint);font-weight:700;">Email:</span><span style="color:var(--text-muted);">${e}</span><span style="color:var(--text-faint);font-weight:700;">Dirección:</span><span style="color:var(--text-muted);">${a}</span><span style="color:var(--text-faint);font-weight:700;">Productos:</span><span style="color:var(--text-primary);">${pedWizProducts.filter(p=>p.name).map(p=>p.name+' x'+p.qty).join(', ')}</span><span style="color:var(--text-faint);font-weight:700;">Total:</span><span style="color:var(--accent);font-weight:900;font-size:16px;">$${t.toLocaleString(undefined,{minimumFractionDigits:2})} MXN</span></div>`;}
function pedWizCreate(){const c=document.getElementById('ped-wiz-client').value.trim();if(!c){alert('Falta el nombre');return;}const t=pedWizProducts.reduce((s,p)=>s+(p.price*p.qty),0);demoOrders.unshift({id:Date.now(),num:'SKY-'+String(demoOrders.length+1).padStart(3,'0'),client:c,email:document.getElementById('ped-wiz-email').value,phone:document.getElementById('ped-wiz-phone').value,address:document.getElementById('ped-wiz-address').value,products:pedWizProducts.filter(p=>p.name).map(p=>({name:p.name,qty:p.qty,price:p.price})),total:t,status:'new',payment:document.getElementById('ped-wiz-payment').value,date:'2026-04-01',notes:document.getElementById('ped-wiz-notes').value});closePedWizard();renderOrders();renderPedStats();renderPedRecs();showToast('Pedido creado: $'+t.toLocaleString()+' MXN');}

