// ═══════ MODO FÁCIL / EXPERTO ═══════
function pedSetMode(mode){
  localStorage.setItem('ped_mode',mode);
  const easy=document.getElementById('ped-easy-mode');
  const pro=document.getElementById('ped-pro-mode');
  const btnEasy=document.getElementById('ped-mode-easy');
  const btnPro=document.getElementById('ped-mode-pro');
  const greeting=document.getElementById('ped-mode-greeting');
  const sub=document.getElementById('ped-mode-sub');
  if(mode==='easy'){
    easy.style.display='block';pro.style.display='none';
    btnEasy.classList.add('active');btnPro.classList.remove('active');
    greeting.textContent='Hola, ¿qué quieres hacer hoy?';
    sub.textContent='Registrar una venta nueva, ver tus pedidos o marcar uno como enviado';
    document.getElementById('ped-easy-home').style.display='block';
    document.getElementById('ped-wizard').style.display='none';
    pedUpdateEasyStats();
  } else {
    easy.style.display='none';pro.style.display='block';
    btnPro.classList.add('active');btnEasy.classList.remove('active');
    greeting.textContent='Modo experto · Todos los controles a tu alcance';
    sub.textContent='¿Prefieres algo más simple? Cambia a modo fácil';
  }
}
function pedUpdateEasyStats(){
  const today=new Date().toISOString().substring(0,10);
  const todayCount=demoOrders.filter(o=>o.date===today||o.date==='2026-04-01').length;
  const ship=demoOrders.filter(o=>o.status==='paid'||o.status==='preparing').length;
  const mes=demoOrders.filter(o=>o.status!=='cancelled').reduce((s,o)=>s+o.total,0);
  const t=document.getElementById('ped-easy-today');if(t)t.textContent=todayCount;
  const s=document.getElementById('ped-easy-ship');if(s)s.textContent=ship;
  const r=document.getElementById('ped-easy-revenue');if(r)r.textContent='$'+Math.round(mes).toLocaleString();
  const sc=document.getElementById('ped-easy-ship-count');
  if(sc)sc.textContent=ship>0?`${ship} pedido${ship>1?'s':''} esperando envío`:'Los que ya te pagaron y faltan mandar';
}

