// ═══════ STATS ═══════
function renderPedStats(){
  const today=demoOrders.filter(o=>o.date==='2026-04-01').length;
  const rev=demoOrders.filter(o=>o.status!=='cancelled').reduce((s,o)=>s+o.total,0);
  const valid=demoOrders.filter(o=>o.status!=='cancelled');
  const avg=valid.length>0?Math.round(rev/valid.length):0;
  const pending=demoOrders.filter(o=>o.status==='paid'||o.status==='preparing').length;
  document.getElementById('ped-stat-today').textContent=today;
  document.getElementById('ped-stat-revenue').textContent='$'+rev.toLocaleString();
  document.getElementById('ped-stat-avg').textContent='$'+avg.toLocaleString();
  document.getElementById('ped-stat-pending').textContent=pending;
  document.getElementById('ped-stat-conv').textContent='3.8%';
  document.getElementById('ped-stat-returns').textContent=demoReturns.length;
  document.getElementById('ped-ship-badge').textContent=pending;
