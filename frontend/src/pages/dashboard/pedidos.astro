  document.getElementById('ped-weekly-report').innerHTML=`<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:10px;"><div style="text-align:center;padding:10px;border-radius:8px;background:var(--bg-card);"><p style="font-size:18px;font-weight:900;color:var(--accent);">${demoOrders.length}</p><p style="font-size:10px;color:var(--text-faint);">Pedidos</p></div><div style="text-align:center;padding:10px;border-radius:8px;background:var(--bg-card);"><p style="font-size:18px;font-weight:900;color:#22c55e;">$${rev.toLocaleString()}</p><p style="font-size:10px;color:var(--text-faint);">Ingresos</p></div><div style="text-align:center;padding:10px;border-radius:8px;background:var(--bg-card);"><p style="font-size:18px;font-weight:900;color:var(--text-primary);">${demoReturns.length}</p><p style="font-size:10px;color:var(--text-faint);">Devoluciones</p></div><div style="text-align:center;padding:10px;border-radius:8px;background:var(--bg-card);"><p style="font-size:18px;font-weight:900;color:#8b5cf6;">52%</p><p style="font-size:10px;color:var(--text-faint);">Pago tarjeta</p></div></div><p style="font-size:11px;color:var(--text-faint);margin-top:10px;">Se envía cada lunes a las 9:00 AM</p>`;
}
