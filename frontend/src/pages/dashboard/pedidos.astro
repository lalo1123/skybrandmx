}

// ═══════ ORDERS TABLE ═══════
function renderOrders(){
  const tbody=document.getElementById('ped-orders-tbody');let data=[...demoOrders];
  const search=document.getElementById('ped-search').value.toLowerCase();
  const sf=document.getElementById('ped-filter-status').value;
  const df=document.getElementById('ped-filter-date').value;
  if(search)data=data.filter(o=>o.client.toLowerCase().includes(search)||o.num.toLowerCase().includes(search)||o.products.some(p=>p.name.toLowerCase().includes(search)));
  if(sf)data=data.filter(o=>o.status===sf);
  if(df==='today')data=data.filter(o=>o.date==='2026-04-01');
  else if(df==='week')data=data.filter(o=>o.date>='2026-03-26');
  else if(df==='month')data=data.filter(o=>o.date>='2026-03-01');
  if(!data.length){tbody.innerHTML='<tr><td colspan="8" style="padding:40px;text-align:center;color:var(--text-faint);font-size:13px;">No se encontraron pedidos</td></tr>';return;}
  tbody.innerHTML=data.map(o=>{const st=statusMap[o.status]||statusMap.new;const prods=o.products.map(p=>p.name).join(', ');const ps=prods.length>35?prods.substring(0,35)+'...':prods;return`<tr style="border-bottom:1px solid var(--border);transition:background 0.15s;cursor:pointer;" onmouseover="this.style.background='var(--bg-card-hover)'" onmouseout="this.style.background='transparent'" onclick="pedShowDetail(${o.id})"><td style="padding:14px 16px;font-weight:700;color:var(--accent);font-size:12px;">${o.num}</td><td style="padding:14px 16px;"><p style="font-weight:700;color:var(--text-primary);">${o.client}</p><p style="font-size:11px;color:var(--text-faint);">${o.email}</p></td><td style="padding:14px 16px;font-size:12px;color:var(--text-secondary);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${prods}">${ps}</td><td style="padding:14px 16px;text-align:right;font-weight:800;color:var(--text-primary);">$${o.total.toLocaleString()}</td><td style="padding:14px 16px;"><span style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;color:${st.c};background:${st.b};">${st.l}</span></td><td style="padding:14px 16px;font-size:12px;color:var(--text-muted);">${payMap[o.payment]||o.payment}</td><td style="padding:14px 16px;font-size:12px;color:var(--text-muted);">${o.date}</td><td style="padding:14px 16px;text-align:center;" onclick="event.stopPropagation()"><div style="display:flex;gap:4px;justify-content:center;flex-wrap:wrap;"><button onclick="pedShowDetail(${o.id})" class="ped-tbl-btn">Ver</button>${o.status==='paid'||o.status==='preparing'?`<button onclick="changeStatus(${o.id},'shipped')" class="ped-tbl-btn" style="border-color:#8b5cf6;color:#8b5cf6;">Enviar</button>`:''}${o.status!=='cancelled'&&o.status!=='delivered'?`<button onclick="changeStatus(${o.id},'cancelled')" class="ped-tbl-btn" style="border-color:#ef4444;color:#ef4444;">Cancelar</button>`:''}</div></td></tr>`;}).join('');
}
function pedFilter(){renderOrders();}

// ═══════ ORDER DETAIL ═══════
function openOrderDetail(id){
  const o=demoOrders.find(x=>x.id===id);if(!o)return;
  document.getElementById('ped-detail-title').textContent='Pedido '+o.num;
  const stages=['new','paid','preparing','shipped','delivered'];const ci=stages.indexOf(o.status);
  document.getElementById('ped-detail-body').innerHTML=`
    <div class="ped-timeline">${stages.map((s,i)=>{const done=i<=ci&&o.status!=='cancelled';const active=i===ci&&o.status!=='cancelled';const si=statusMap[s];return`<div class="ped-timeline-step">${i<stages.length-1?`<div class="ped-timeline-line" style="background:${done&&i<ci?'#22c55e':'var(--border)'};"></div>`:''}<div class="ped-timeline-dot" style="background:${done?'#22c55e':active?si.c:'var(--input-bg)'};color:${done||active?'#fff':'var(--text-faint)'};">${done&&!active?'✓':i+1}</div><span class="ped-timeline-label" style="color:${done?'#22c55e':active?si.c:'var(--text-faint)'};">${si.l}</span></div>`;}).join('')}</div>
    ${o.status==='cancelled'?'<div style="padding:10px 16px;border-radius:8px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);text-align:center;margin-bottom:16px;"><p style="font-size:13px;font-weight:700;color:#ef4444;">Este pedido fue cancelado</p></div>':''}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;"><div><p class="ped-label">Cliente</p><p style="font-size:14px;font-weight:700;color:var(--text-primary);">${o.client}</p><p style="font-size:12px;color:var(--text-muted);">${o.email} · ${o.phone}</p></div><div><p class="ped-label">Dirección de envío</p><p style="font-size:12px;color:var(--text-secondary);line-height:1.5;">${o.address}</p></div></div>
    <div style="border:1px solid var(--border);border-radius:10px;overflow:hidden;margin-bottom:16px;">${o.products.map(p=>`<div style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border);"><div style="width:48px;height:48px;border-radius:8px;background:var(--input-bg);display:flex;align-items:center;justify-content:center;font-size:20px;">🛍</div><div style="flex:1;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">${p.name}</p><p style="font-size:11px;color:var(--text-faint);">Cantidad: ${p.qty}</p></div><p style="font-size:13px;font-weight:800;color:var(--text-primary);">$${(p.price*p.qty).toLocaleString()}</p></div>`).join('')}<div style="padding:12px 16px;display:flex;justify-content:space-between;background:var(--input-bg);"><span style="font-size:13px;font-weight:800;color:var(--text-primary);">Total</span><span style="font-size:16px;font-weight:900;color:var(--accent);">$${o.total.toLocaleString()} MXN</span></div></div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:12px;margin-bottom:16px;"><div style="padding:10px;border-radius:8px;background:var(--input-bg);text-align:center;"><p style="font-size:10px;color:var(--text-faint);text-transform:uppercase;margin-bottom:2px;">Pago</p><p style="font-size:12px;font-weight:700;color:var(--text-primary);">${payMap[o.payment]}</p></div><div style="padding:10px;border-radius:8px;background:var(--input-bg);text-align:center;"><p style="font-size:10px;color:var(--text-faint);text-transform:uppercase;margin-bottom:2px;">Fecha</p><p style="font-size:12px;font-weight:700;color:var(--text-primary);">${o.date}</p></div>${o.tracking?`<div style="padding:10px;border-radius:8px;background:var(--input-bg);text-align:center;"><p style="font-size:10px;color:var(--text-faint);text-transform:uppercase;margin-bottom:2px;">Rastreo</p><p style="font-size:12px;font-weight:700;color:var(--accent);">${o.tracking}</p></div>`:''}</div>
    ${o.notes?`<div style="padding:12px 16px;border-radius:8px;background:rgba(234,179,8,0.06);border:1px solid rgba(234,179,8,0.15);margin-bottom:16px;"><p style="font-size:11px;font-weight:700;color:#eab308;margin-bottom:2px;">Notas del cliente</p><p style="font-size:12px;color:var(--text-secondary);">${o.notes}</p></div>`:''}
    <div style="display:flex;gap:10px;flex-wrap:wrap;">${o.status==='paid'?`<button onclick="changeStatus(${o.id},'preparing');pedShowDetail(${o.id})" class="ped-btn-primary" style="flex:1;">Marcar como "Preparando"</button>`:''}${o.status==='preparing'?`<button onclick="changeStatus(${o.id},'shipped');pedShowDetail(${o.id})" class="ped-btn-primary" style="flex:1;background:#8b5cf6;">Marcar como "Enviado"</button>`:''}${o.status==='shipped'?`<button onclick="changeStatus(${o.id},'delivered');pedShowDetail(${o.id})" class="ped-btn-primary" style="flex:1;background:#22c55e;">Marcar como "Entregado"</button>`:''}    <button onclick="showToast('Ticket impreso')" class="ped-btn-secondary" style="flex:0;padding:12px 16px;">🖨 Imprimir</button></div>`;
  document.getElementById('ped-modal-detail').style.display='flex';
}
function closeOrderDetail(){document.getElementById('ped-modal-detail').style.display='none';}
function changeStatus(id,ns){const o=demoOrders.find(x=>x.id===id);if(!o)return;o.status=ns;if(ns==='shipped'&&!o.tracking)o.tracking='SKY'+Date.now().toString().slice(-9);renderOrders();renderPedStats();renderPedRecs();renderShipList();showToast(`${o.num} → ${statusMap[ns].l}`);}

// ═══════ SHIP TAB ═══════
function renderShipList(){
  const pending=demoOrders.filter(o=>o.status==='paid'||o.status==='preparing');
  const list=document.getElementById('ped-ship-list');const empty=document.getElementById('ped-empty-ship');
  if(!pending.length){list.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
