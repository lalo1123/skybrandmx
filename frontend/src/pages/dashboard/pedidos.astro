const PED_MARKETPLACES=[
  {id:'shopify',name:'Shopify',emoji:'🛍️',color:'#96bf48',bg:'rgba(150,191,72,0.1)',desc:'La tienda online más popular del mundo. Sincronización automática de pedidos, productos e inventario.',orders:127,products:48},
  {id:'mercadolibre',name:'MercadoLibre',emoji:'🟡',color:'#fff159',bg:'rgba(255,241,89,0.1)',desc:'Marketplace #1 de México. Miles de compradores listos. Importa pedidos cada 5 minutos.',orders:89,products:32},
  {id:'woocommerce',name:'WooCommerce',emoji:'🟣',color:'#7f54b3',bg:'rgba(127,84,179,0.1)',desc:'Plugin oficial de WordPress. Conecta tu tienda WooCommerce con tu API key.',orders:0,products:0},
  {id:'amazon',name:'Amazon Seller',emoji:'📦',color:'#ff9900',bg:'rgba(255,153,0,0.1)',desc:'Vende en Amazon México y EE.UU. Gestiona FBA y FBM desde un solo panel.',orders:45,products:21},
  {id:'tiktok',name:'TikTok Shop',emoji:'🎵',color:'#ff0050',bg:'rgba(255,0,80,0.1)',desc:'El nuevo gigante. Llega a Gen Z con tus videos y vende directamente desde la app.',orders:0,products:0},
  {id:'instagram',name:'Instagram Shop',emoji:'📸',color:'#e4405f',bg:'rgba(228,64,95,0.1)',desc:'Cataloga tus productos para que aparezcan en posts y stories de Instagram y Facebook.',orders:34,products:48},
  {id:'tiendanube',name:'Tiendanube',emoji:'☁️',color:'#0094ff',bg:'rgba(0,148,255,0.1)',desc:'La plataforma latinoamericana. Popular en MX, AR, CO. Sincronización completa.',orders:0,products:0},
  {id:'walmart',name:'Walmart MX',emoji:'⭐',color:'#0071ce',bg:'rgba(0,113,206,0.1)',desc:'Vende en Walmart México y Bodega Aurrera. Requiere proceso de aprobación.',orders:0,products:0},
];
function pedGetMpStatus(){try{return JSON.parse(localStorage.getItem('ped_mp_connected'))||{};}catch(e){return {};}}
function pedSaveMpStatus(s){localStorage.setItem('ped_mp_connected',JSON.stringify(s));}
function renderMarketplaces(){
  const el=document.getElementById('ped-marketplaces-grid');if(!el)return;
  const status=pedGetMpStatus();
  // Add a sync bar at top
  const totalConnected=Object.values(status).filter(Boolean).length;
  const totalSynced=PED_MARKETPLACES.filter(m=>status[m.id]).reduce((s,m)=>s+m.orders,0);
  const lastSync=new Date().toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'});
  el.innerHTML=`
    ${totalConnected>0?`<div style="grid-column:1/-1;padding:14px 18px;border-radius:12px;background:linear-gradient(135deg,rgba(34,197,94,0.08),rgba(111,207,245,0.08));border:1px solid rgba(34,197,94,0.2);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
      <div style="display:flex;align-items:center;gap:10px;"><div class="ped-mp-sync-dot"></div><div><p style="font-size:13px;font-weight:800;color:var(--text-primary);">${totalConnected} marketplace${totalConnected>1?'s':''} conectado${totalConnected>1?'s':''} · ${totalSynced} pedidos sincronizados</p><p style="font-size:10px;color:var(--text-muted);">Última sincronización: ${lastSync}</p></div></div>
      <button onclick="showToast('🔄 Sincronizando...');setTimeout(()=>showToast('✓ Sincronización completa'),1200);" style="padding:8px 14px;border-radius:8px;border:1px solid rgba(34,197,94,0.3);background:transparent;color:#22c55e;font-size:11px;font-weight:700;cursor:pointer;">🔄 Sincronizar ahora</button>
    </div>`:''}
    ${PED_MARKETPLACES.map(m=>{
      const isConn=!!status[m.id];
      return `<div class="ped-mp-card" style="--mp-color:${m.color};--mp-bg:${m.bg};">
        <div class="ped-mp-header">
          <div class="ped-mp-logo-box">
            <div class="ped-mp-logo">${m.emoji}</div>
            <div>
              <p class="ped-mp-name">${m.name}</p>
              <span class="ped-mp-status ${isConn?'connected':'disconnected'}">${isConn?'● Conectado':'○ Sin conectar'}</span>
            </div>
          </div>
        </div>
        <p class="ped-mp-desc">${m.desc}</p>
        ${isConn?`<div class="ped-mp-stats">
          <div class="ped-mp-stat"><p class="ped-mp-stat-val">${m.orders}</p><p class="ped-mp-stat-lbl">Pedidos hoy</p></div>
          <div class="ped-mp-stat"><p class="ped-mp-stat-val">${m.products}</p><p class="ped-mp-stat-lbl">Productos</p></div>
        </div>`:''}
        <button onclick="pedToggleMp('${m.id}','${m.name.replace(/'/g,"\\'")}')" class="ped-mp-btn ${isConn?'ped-mp-btn-disconnect':'ped-mp-btn-connect'}">${isConn?'Desconectar':'⚡ Conectar tienda'}</button>
      </div>`;
    }).join('')}
  `;
}
function pedToggleMp(id,name){
  const status=pedGetMpStatus();
  if(status[id]){
    if(!confirm(`¿Desconectar ${name}? Dejarán de llegar pedidos automáticamente.`))return;
    status[id]=false;
    showToast(`${name} desconectado`);
  } else {
    status[id]=true;
    showToast(`✓ ${name} conectado · Pedidos sincronizando...`);
  }
  pedSaveMpStatus(status);
  renderMarketplaces();
}

// ═══════ ORDER DETAIL MODAL (visual timeline) ═══════
function pedShowDetail(id){
  const o=demoOrders.find(x=>x.id===id);if(!o)return;
  const stats=pedGetCustomerStats(o.email);
  const statusLabels={new:'🆕 Nuevo',paid:'💰 Pagado',preparing:'📦 Preparando',shipped:'🚚 Enviado',delivered:'✅ Entregado',cancelled:'❌ Cancelado'};
  const paymentLabels={card:'💳 Tarjeta',transfer:'🏦 Transferencia',cash:'💵 Efectivo',oxxo:'🏪 OXXO',pending:'⏰ Pendiente'};
  const itemsRows=(o.products||[]).map(p=>`<div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px dashed var(--border);font-size:12px;"><span style="color:var(--text-primary);">${p.qty}× ${p.name}</span><span style="color:var(--text-muted);">$${(p.qty*p.price).toFixed(2)}</span></div>`).join('');
  // Build timeline
  let timeline=[];
  if(o.history && o.history.length>0){
    timeline=o.history.map(h=>({title:h.event,meta:`${new Date(h.date).toLocaleString('es-MX')} · ${h.actor||'Sistema'}`,done:true}));
  } else {
    timeline=[{title:'Pedido creado',meta:o.date+' · Tú',done:true}];
    if(['paid','preparing','shipped','delivered'].includes(o.status))timeline.push({title:'Pago confirmado',meta:o.date,done:true});
    if(['preparing','shipped','delivered'].includes(o.status))timeline.push({title:'Preparando paquete',meta:o.date,done:true});
    if(['shipped','delivered'].includes(o.status))timeline.push({title:`Enviado vía paquetería${o.tracking?' · '+o.tracking:''}`,meta:o.date,done:true});
    if(o.status==='delivered')timeline.push({title:'Entregado al cliente',meta:o.date,done:true});
  }
  document.getElementById('ped-detail-num').textContent=o.num;
  document.getElementById('ped-detail-body-new').innerHTML=`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;">
      <div style="padding:14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);">
        <p style="font-size:10px;font-weight:800;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Cliente</p>
        <p style="font-size:14px;font-weight:800;color:var(--text-primary);margin-top:4px;">${o.client}${stats&&stats.orders>=5?' <span class="ped-vip-badge">⭐ VIP</span>':stats&&stats.orders>=2?' <span class="ped-repeat-badge">🔁 Repetidor</span>':''}</p>
        <p style="font-size:11px;color:var(--text-muted);margin-top:2px;">${o.email||'—'} · ${o.phone||'—'}</p>
        ${stats?`<p style="font-size:10px;color:var(--text-faint);margin-top:6px;padding-top:6px;border-top:1px dashed var(--border);"><b style="color:#22c55e;">${stats.orders} pedido${stats.orders!==1?'s':''}</b> en total · LTV <b style="color:var(--accent);">$${stats.spent.toLocaleString()}</b></p>`:''}
      </div>
      <div style="padding:14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);">
        <p style="font-size:10px;font-weight:800;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Estado</p>
        <p style="font-size:14px;font-weight:800;color:var(--text-primary);margin-top:4px;">${statusLabels[o.status]||o.status}</p>
        <p style="font-size:11px;color:var(--text-muted);margin-top:2px;">Pago: ${paymentLabels[o.payment]||o.payment}</p>
        ${o.tracking?`<p style="font-size:10px;font-family:monospace;color:var(--accent);margin-top:6px;">📦 ${o.tracking}</p>`:''}
      </div>
    </div>
    <div style="padding:14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);margin-bottom:20px;">
      <p style="font-size:10px;font-weight:800;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Dirección</p>
      <p style="font-size:12px;color:var(--text-primary);">${o.address||'—'}</p>
    </div>
    <div style="padding:14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);margin-bottom:20px;">
      <p style="font-size:10px;font-weight:800;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Productos</p>
      ${itemsRows||'<p style="font-size:11px;color:var(--text-faint);">Sin productos</p>'}
      <div style="display:flex;justify-content:space-between;padding-top:10px;margin-top:8px;border-top:2px solid var(--border);font-weight:900;font-size:15px;"><span>Total</span><span style="color:#22c55e;">$${o.total.toLocaleString()}</span></div>
    </div>
    ${o.notes?`<div style="padding:14px;border-radius:10px;border:1px solid var(--border);background:rgba(255,107,0,0.05);margin-bottom:20px;"><p style="font-size:10px;font-weight:800;color:#f97316;text-transform:uppercase;letter-spacing:0.5px;">📝 Nota</p><p style="font-size:12px;color:var(--text-primary);margin-top:4px;">${o.notes}</p></div>`:''}
    <div style="padding:14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);margin-bottom:20px;">
      <p style="font-size:10px;font-weight:800;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:14px;">Historial</p>
      <div class="ped-detail-tl">
        ${timeline.map((t,i)=>`<div class="ped-detail-tl-item"><div class="ped-detail-tl-dot ${t.done?'done':''}"></div><div class="ped-detail-tl-content"><p class="ped-detail-tl-title">${t.title}</p><p class="ped-detail-tl-meta">${t.meta}</p></div></div>`).join('')}
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;">
      <button onclick="pedCloseDetail();pedEditOrder(${o.id})" class="ped-wiz-next" style="margin:0;background:var(--accent);color:#0a1520;font-size:12px;padding:12px;">✏️ Editar</button>
      <button onclick="pedCloseDetail();pedDuplicateOrder(${o.id})" class="ped-wiz-next" style="margin:0;background:#6fcff5;color:#0a1520;font-size:12px;padding:12px;">📋 Duplicar</button>
      <button onclick="pedFacturarOrder(${o.id})" class="ped-wiz-next" style="margin:0;background:#8b5cf6;font-size:12px;padding:12px;">🧾 Facturar</button>
      <button onclick="pedSendToShipping(${o.id})" class="ped-wiz-next" style="margin:0;background:#FF6B00;font-size:12px;padding:12px;">📦 Generar guía</button>
      <button onclick="showToast('Recordatorio enviado por WhatsApp')" class="ped-wiz-next" style="margin:0;background:#22c55e;font-size:12px;padding:12px;">💬 WhatsApp</button>
      <button onclick="pedCloseDetail()" style="padding:12px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:800;cursor:pointer;">Cerrar</button>
    </div>
  `;
  document.getElementById('ped-detail-view').classList.add('open');
}
function pedCloseDetail(){document.getElementById('ped-detail-view').classList.remove('open');}

// ═══════ TOUR ═══════
const PED_TOUR_STEPS=[
  {emoji:'📦',title:'¡Hola! Bienvenido a Pedidos',desc:'Aquí registras cada venta que haces. Vamos a explicarte cómo funciona en 30 segundos.'},
  {emoji:'🛒',title:'Captura en 5 pasos sencillos',desc:'Quién te compró, qué te pidió, cómo te pagó, cómo lo mandas y ya. Sin terminología rara.'},
  {emoji:'🔌',title:'O conecta tu tienda',desc:'Si ya vendes en Shopify, MercadoLibre o WooCommerce, los pedidos se sincronizan solos. No tienes que capturar nada.'},
  {emoji:'🎯',title:'¿Probamos?',desc:'Puedes registrar un pedido real o usar datos de ejemplo para ver cómo se ve.'},
];
let pedTourStep=0;
function pedStartTour(){pedTourStep=0;pedRenderTour();document.getElementById('ped-tour').style.display='flex';}
function pedRenderTour(){
  const s=PED_TOUR_STEPS[pedTourStep];
  document.getElementById('ped-tour-emoji').textContent=s.emoji;
  document.getElementById('ped-tour-title').textContent=s.title;
  document.getElementById('ped-tour-desc').textContent=s.desc;
  document.querySelectorAll('.ped-tour-dot').forEach((d,i)=>d.classList.toggle('active',i===pedTourStep));
  document.getElementById('ped-tour-next-btn').textContent=pedTourStep===PED_TOUR_STEPS.length-1?'¡Empezar! 🚀':'Siguiente →';
}
function pedTourNext(){
  if(pedTourStep<PED_TOUR_STEPS.length-1){pedTourStep++;pedRenderTour();}
  else{pedTourSkip();pedWizStart(true);}
}
function pedTourSkip(){
  document.getElementById('ped-tour').style.display='none';
  localStorage.setItem('ped_tour_done','1');
}

// ═══════ SEED CROSS-MODULE DATA (one time, for demo) ═══════
function pedSeedCRMFromOrders(){
  if(localStorage.getItem('crm_contacts'))return; // already seeded
  const contacts={};
  demoOrders.forEach(o=>{
    const k=o.email||o.phone;if(!k)return;
    if(!contacts[k]){
      const [first,...rest]=o.client.split(' ');
      contacts[k]={id:Date.now()+Math.random(),first_name:first,last_name:rest.join(' '),email:o.email,phone:o.phone,address:o.address,pipeline_stage:'cliente',source:'pedido',total_orders:0,total_spent:0,last_order_date:o.date,created_at:new Date().toISOString()};
    }
    contacts[k].total_orders++;
    contacts[k].total_spent+=o.total;
  });
  localStorage.setItem('crm_contacts',JSON.stringify(Object.values(contacts)));
}

document.addEventListener('DOMContentLoaded',()=>{
  ['all','kanban','ship','returns','marketplaces','analytics'].forEach(t=>{if(localStorage.getItem('ped_help_'+t+'_dismissed')){const el=document.getElementById('ped-help-'+t);if(el)el.style.display='none';}});
  pedSeedCRMFromOrders();
  // Seed marketplace connections (demo: Shopify, MercadoLibre, Amazon, Instagram already connected)
  if(!localStorage.getItem('ped_mp_connected')){localStorage.setItem('ped_mp_connected',JSON.stringify({shopify:true,mercadolibre:true,amazon:true,instagram:true}));}
  renderPedRecs();renderPedStats();renderOrders();renderShipList();renderReturns();renderPedAnalytics();renderAutopilot();
  const savedMode=localStorage.getItem('ped_mode')||'easy';
  pedSetMode(savedMode);
  pedUpdateEasyStats();
  if(!localStorage.getItem('ped_tour_done')){setTimeout(()=>pedStartTour(),600);}
});
['ped-modal-detail','ped-modal-wizard'].forEach(id=>{document.getElementById(id)?.addEventListener('click',function(e){if(e.target===this)this.style.display='none';});});
</script>
