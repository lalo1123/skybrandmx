function pedExportCSV(){
  const headers=['Num','Cliente','Email','Telefono','Direccion','Productos','Total','Estado','Pago','Fecha','Tracking','Notas'];
  const rows=demoOrders.map(o=>[
    o.num||'',
    (o.client||'').replace(/"/g,'""'),
    o.email||'',
    o.phone||'',
    (o.address||'').replace(/"/g,'""'),
    (o.products||[]).map(p=>`${p.qty}x ${p.name}`).join('; ').replace(/"/g,'""'),
    o.total||0,
    o.status||'',
    o.payment||'',
    o.date||'',
    o.tracking||'',
    (o.notes||'').replace(/"/g,'""'),
  ]);
  const csv=[headers,...rows].map(r=>r.map(c=>`"${c}"`).join(',')).join('\n');
  const blob=new Blob(['\ufeff'+csv],{type:'text/csv;charset=utf-8'}); // BOM for Excel
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download=`pedidos-${new Date().toISOString().substring(0,10)}.csv`;
  document.body.appendChild(a);a.click();a.remove();
  URL.revokeObjectURL(url);
  showToast(`✓ ${demoOrders.length} pedidos exportados a Excel`);
}

function pedWizConfirm(){
  const clientName=document.getElementById('ped-wiz-name').value;
  const clientEmail=document.getElementById('ped-wiz-email').value;
  const clientPhone=document.getElementById('ped-wiz-phone').value;
  const clientAddress=document.getElementById('ped-wiz-address').value;
  const total=pedWizItems.reduce((s,i)=>s+(i.qty*i.price),0);
  const statusMap={card:'paid',transfer:'paid',cash:'paid',oxxo:'paid',pending:'new'};
  // EDIT MODE: update existing order
  if(pedEditingId){
    const existing=demoOrders.find(x=>x.id===pedEditingId);
    if(existing){
      existing.client=clientName;existing.email=clientEmail;existing.phone=clientPhone;existing.address=clientAddress;
      existing.products=pedWizItems.map(i=>({name:i.name,qty:i.qty,price:i.price}));
      existing.total=total;existing.payment=pedWizPayment;existing.notes=document.getElementById('ped-wiz-notes').value;
      if(!existing.history)existing.history=[];
      existing.history.push({date:new Date().toISOString(),event:'Pedido editado',actor:'Tú'});
      renderOrders();renderShipList();renderPedStats();renderPedRecs();if(typeof renderKanban==='function')renderKanban();
      document.getElementById('ped-wiz-done-num').textContent=existing.num;
      document.getElementById('ped-wiz-done-msg').innerHTML=`Pedido <b>${existing.num}</b> actualizado. Los cambios se aplicaron a <b>${clientName}</b>.`;
      const actionsEl=document.getElementById('ped-wiz-done-actions');
      if(actionsEl)actionsEl.innerHTML=`<button onclick="pedWizDone()" class="ped-wiz-next" style="flex:1;min-width:180px;margin:0;background:#22c55e;">✅ Listo</button>`;
      pedEzGoTo('done');
      pedEditingId=null;
      return;
    }
  }
  // CREATE new order
  const num='SKY-'+String(demoOrders.length+1).padStart(3,'0');
  const newOrder={
    id:Date.now(),num,
    client:clientName,email:clientEmail,phone:clientPhone,address:clientAddress,
    products:pedWizItems.map(i=>({name:i.name,qty:i.qty,price:i.price})),
    total,
    status:statusMap[pedWizPayment]||'new',
    payment:pedWizPayment,
    date:new Date().toISOString().substring(0,10),
    notes:document.getElementById('ped-wiz-notes').value,
    history:[{date:new Date().toISOString(),event:'Pedido creado',actor:'Tú'}],
  };
  demoOrders.unshift(newOrder);

  // 1) PEDIDO → CRM (auto-save customer)
  pedSaveToCRM(newOrder);
  // 2) PEDIDO → STOCK (decrement)
  pedDecrementStock(newOrder);
  // 3) PEDIDO → ENVÍOS (handover if "Generar guía ahora")
  if(pedWizShipOption==='now'){
    const handover={orderId:newOrder.id,orderNum:num,client:clientName,email:clientEmail,phone:clientPhone,address:clientAddress,total};
    localStorage.setItem('env_pending_handover',JSON.stringify(handover));
  }

  renderOrders();renderShipList();renderPedStats();renderPedRecs();renderKanban();
  document.getElementById('ped-wiz-done-num').textContent=num;
  let msg=`Pedido de <b>${clientName}</b> guardado. Total: <b>$${total.toLocaleString()}</b>.`;
  let actions='';
  if(pedWizShipOption==='now'){
    msg+=' Datos transferidos al módulo de Envíos 📦';
    actions=`<a href="/dashboard/envios" class="ped-wiz-next" style="flex:1;min-width:160px;margin:0;background:#FF6B00;text-decoration:none;display:flex;align-items:center;justify-content:center;">📦 Ir a generar la guía</a>`;
  }
  else if(pedWizShipOption==='pickup')msg+=' El cliente va a recoger en tienda 🏪';
  else msg+=' Puedes generar la guía después desde Envíos.';
  document.getElementById('ped-wiz-done-msg').innerHTML=msg;
  // Add quick actions for cross-module
  const actionsEl=document.getElementById('ped-wiz-done-actions');
  if(actionsEl){
    actionsEl.innerHTML=`
      <button onclick="pedFacturarOrder(${newOrder.id})" class="ped-wiz-next" style="flex:1;min-width:160px;margin:0;background:#8b5cf6;">🧾 Facturar este pedido</button>
      ${actions}
      <button onclick="pedWizDone()" class="ped-wiz-next" style="flex:1;min-width:160px;margin:0;background:#22c55e;">✅ Otro pedido</button>
    `;
  }
  pedEzGoTo('done');
}

// ═══════ CROSS-MODULE WIRING ═══════
function pedSaveToCRM(order){
  // Save customer to CRM contacts in localStorage
  let contacts=[];
  try{contacts=JSON.parse(localStorage.getItem('crm_contacts'))||[];}catch(e){}
  const exists=contacts.find(c=>c.email===order.email||(c.phone===order.phone&&order.phone));
  if(exists){
    exists.total_orders=(exists.total_orders||0)+1;
    exists.total_spent=(exists.total_spent||0)+order.total;
    exists.last_order_date=order.date;
  } else {
    const [first,...rest]=order.client.split(' ');
    contacts.push({
      id:Date.now(),
      first_name:first,
      last_name:rest.join(' '),
      email:order.email,
      phone:order.phone,
      address:order.address,
      pipeline_stage:'cliente',
      source:'pedido',
      total_orders:1,
      total_spent:order.total,
      last_order_date:order.date,
      created_at:new Date().toISOString(),
    });
  }
  localStorage.setItem('crm_contacts',JSON.stringify(contacts));
}
function pedDecrementStock(order){
  let products=[];
  try{products=JSON.parse(localStorage.getItem('inventory_stock'))||{};}catch(e){products={};}
  if(typeof products!=='object'||Array.isArray(products))products={};
  order.products.forEach(p=>{
    const key=p.name.toLowerCase().trim();
    if(!products[key])products[key]={name:p.name,stock:50}; // default seed
    products[key].stock=Math.max(0,(products[key].stock||0)-p.qty);
  });
  localStorage.setItem('inventory_stock',JSON.stringify(products));
}
function pedFacturarOrder(orderId){
  const order=demoOrders.find(o=>o.id===orderId);
  if(!order)return;
  // Stash for facturacion module
  const handover={
    orderNum:order.num,
    client:order.client,
    email:order.email,
    items:order.products.map(p=>({desc:p.name,qty:p.qty,price:p.price})),
    total:order.total,
  };
  localStorage.setItem('fac_pending_handover',JSON.stringify(handover));
  showToast('Datos enviados a Facturación. Te llevamos para allá...');
  setTimeout(()=>{window.location.href='/dashboard/facturacion';},900);
}
function pedSendToShipping(orderId){
  const order=demoOrders.find(o=>o.id===orderId);
  if(!order)return;
  const handover={orderId:order.id,orderNum:order.num,client:order.client,email:order.email,phone:order.phone,address:order.address,total:order.total};
  localStorage.setItem('env_pending_handover',JSON.stringify(handover));
  showToast('Datos enviados a Envíos. Te llevamos para allá...');
  setTimeout(()=>{window.location.href='/dashboard/envios';},900);
}
function pedGetCustomerStats(email){
  // Returns repeat customer info + LTV
  let contacts=[];
  try{contacts=JSON.parse(localStorage.getItem('crm_contacts'))||[];}catch(e){}
  const c=contacts.find(x=>x.email===email);
  if(!c)return null;
  return {orders:c.total_orders||0,spent:c.total_spent||0};
}

