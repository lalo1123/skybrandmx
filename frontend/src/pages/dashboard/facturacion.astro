function renderConcepts(){
  const el=document.getElementById('fac-concepts');
  const inputStyle='width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:12px;outline:none;';
  const labelStyle='font-size:12px;font-weight:700;color:var(--text-muted);margin-bottom:4px;display:block;';
  el.innerHTML=facConcepts.map((c,i)=>`
    <div style="display:flex;gap:8px;align-items:end;">
      <div style="flex:3;"><label style="${labelStyle}">Descripción</label><input type="text" placeholder="Ej: Servicio de diseño web" style="${inputStyle}" value="${c.desc}" onchange="facConcepts[${i}].desc=this.value"/></div>
      <div style="flex:1;"><label style="${labelStyle}">Cantidad</label><input type="number" min="1" style="${inputStyle}" value="${c.qty}" onchange="facConcepts[${i}].qty=parseInt(this.value)||1;facUpdateTotals()"/></div>
      <div style="flex:1;"><label style="${labelStyle}">Precio unit.</label><input type="number" min="0" style="${inputStyle}" value="${c.price}" onchange="facConcepts[${i}].price=parseFloat(this.value)||0;facUpdateTotals()"/></div>
      <div style="flex:1;"><label style="${labelStyle}">Clave SAT</label><input type="text" style="${inputStyle}font-size:11px;" value="${c.key||'01010101'}" onchange="facConcepts[${i}].key=this.value" placeholder="01010101"/></div>
      ${facConcepts.length>1?`<button onclick="facConcepts.splice(${i},1);renderConcepts();facUpdateTotals()" style="width:32px;height:38px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text-faint);cursor:pointer;font-size:14px;">✕</button>`:''}
    </div>`).join('');
  facUpdateTotals();
}
function facAddConcept(){facConcepts.push({desc:'',qty:1,price:0,key:'01010101'});renderConcepts();}
function facUpdateTotals(){
  const sub=facConcepts.reduce((s,c)=>s+(c.price*c.qty),0);
  const iva=Math.round(sub*0.16*100)/100;
  document.getElementById('fac-subtotal').textContent='$'+sub.toLocaleString(undefined,{minimumFractionDigits:2});
  document.getElementById('fac-iva-total').textContent='$'+iva.toLocaleString(undefined,{minimumFractionDigits:2});
  document.getElementById('fac-grand-total').textContent='$'+(sub+iva).toLocaleString(undefined,{minimumFractionDigits:2});
}

function facValidateBeforeCreate(){
  const name=document.getElementById('fac-c-name').value.trim();
  const rfc=document.getElementById('fac-c-rfc').value.trim().toUpperCase();
  const regimen=document.getElementById('fac-c-regimen').value;
  const cp=document.getElementById('fac-c-cp').value.trim();
  const errors=[];
  if(!name)errors.push('Falta el nombre o razón social del cliente');
  if(!rfc)errors.push('Falta el RFC del cliente');
  else{
    const isGeneric=rfc==='XAXX010101000'||rfc==='XEXX010101000';
    const isPF=/^[A-ZÑ&]{4}\d{6}[A-Z0-9]{3}$/.test(rfc);
    const isPM=/^[A-ZÑ&]{3}\d{6}[A-Z0-9]{3}$/.test(rfc);
    if(!isGeneric&&!isPF&&!isPM)errors.push('El RFC no tiene un formato válido. Persona física = 13 caracteres, persona moral = 12');
  }
  if(!regimen)errors.push('Selecciona el régimen fiscal del cliente');
  if(!cp)errors.push('Falta el código postal fiscal');
  else if(!/^\d{5}$/.test(cp))errors.push('El código postal debe ser de exactamente 5 dígitos');
  if(!facConcepts.some(c=>c.desc&&c.price>0))errors.push('Agrega al menos un concepto con descripción y precio');
  facConcepts.forEach((c,i)=>{
    if(c.desc&&c.price<=0)errors.push(`Concepto ${i+1} "${c.desc}" no tiene precio`);
    if(c.price>0&&!c.desc)errors.push(`Concepto ${i+1} tiene precio pero no descripción`);
  });
  return errors;
}

function facShowErrors(errors){
  const html='<div id="fac-error-box" style="padding:14px 18px;border-radius:10px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);margin-bottom:16px;">'+
    '<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;"><svg style="width:16px;height:16px;color:#ef4444;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>'+
    '<p style="font-size:13px;font-weight:700;color:#ef4444;">Corrige estos errores antes de continuar:</p></div>'+
    '<ul style="margin:0 0 0 24px;font-size:12px;color:var(--text-secondary);line-height:1.8;">'+errors.map(e=>'<li>'+e+'</li>').join('')+'</ul></div>';
  const existing=document.getElementById('fac-error-box');
  if(existing)existing.remove();
  const container=document.getElementById('fac-panel-create');
  const form=container.querySelector('.stat-card');
  form.insertAdjacentHTML('afterbegin',html);
  form.scrollIntoView({behavior:'smooth',block:'start'});
