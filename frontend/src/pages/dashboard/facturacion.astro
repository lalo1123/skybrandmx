---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Facturación">
  <!-- ════════ MODO FÁCIL / EXPERTO TOGGLE ════════ -->
  <div class="fac-mode-switcher" style="display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:18px;padding:14px 18px;border-radius:14px;background:linear-gradient(135deg,rgba(111,207,245,0.08),rgba(139,92,246,0.08));border:1px solid rgba(111,207,245,0.2);flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:12px;">
      <span style="font-size:24px;">🧾</span>
      <div>
        <p id="fac-mode-greeting" style="font-size:13px;font-weight:800;color:var(--text-primary);">Hola, ¿qué quieres hacer hoy?</p>
        <p id="fac-mode-sub" style="font-size:11px;color:var(--text-muted);">No te preocupes por términos del SAT — te explicamos todo en español</p>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
      <button onclick="facStartTour()" style="padding:8px 14px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;">🎓 Tour guiado</button>
      <div style="display:flex;background:rgba(0,0,0,0.25);border-radius:10px;padding:3px;gap:2px;">
        <button id="fac-mode-easy" onclick="facSetMode('easy')" class="fac-mode-btn active">😊 Fácil</button>
        <button id="fac-mode-pro" onclick="facSetMode('pro')" class="fac-mode-btn">🔧 Experto</button>
      </div>
    </div>
  </div>

  <!-- ════════ MODO FÁCIL ════════ -->
  <div id="fac-easy-mode" style="display:block;">
    <!-- Pantalla de inicio -->
    <div id="fac-easy-home" style="display:block;">
      <div class="fac-easy-hero" style="padding:40px 32px;border-radius:18px;background:linear-gradient(135deg,#084d6e 0%,#8b5cf6 100%);color:#fff;margin-bottom:20px;position:relative;overflow:hidden;">
        <div style="position:absolute;top:-30px;right:-30px;font-size:180px;opacity:0.15;">🧾</div>
        <h2 style="font-size:24px;font-weight:900;margin-bottom:8px;">Facturar es más fácil de lo que crees ✨</h2>
        <p style="font-size:14px;opacity:0.9;margin-bottom:20px;max-width:600px;">Te llevamos paso a paso. Solo necesitas el RFC de tu cliente y qué le vendiste. Nosotros nos encargamos del SAT y la timbramos automáticamente.</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap;">
          <button onclick="facWizStart(false)" class="fac-easy-cta-primary">✨ Crear mi primera factura</button>
          <button onclick="facWizStart(true)" class="fac-easy-cta-secondary">👀 Probar con datos de ejemplo</button>
        </div>
      </div>

      <p style="font-size:13px;font-weight:800;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;">¿Qué necesitas hacer?</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-bottom:24px;">
        <button onclick="facWizStart(false)" class="fac-easy-card">
          <span class="fac-easy-card-emoji">🧾</span>
          <p class="fac-easy-card-title">Hacer una factura</p>
          <p class="fac-easy-card-desc">Te guiamos paso a paso para emitir un CFDI</p>
        </button>
        <button onclick="facSetMode('pro');setTimeout(()=>{switchFacTab('invoices');},200);" class="fac-easy-card">
          <span class="fac-easy-card-emoji">📋</span>
          <p class="fac-easy-card-title">Ver mis facturas</p>
          <p class="fac-easy-card-desc">Todas las facturas que ya emitiste</p>
        </button>
        <button onclick="facSetMode('pro');setTimeout(()=>{switchFacTab('clients');},200);" class="fac-easy-card">
          <span class="fac-easy-card-emoji">👥</span>
          <p class="fac-easy-card-title">Mis clientes</p>
          <p class="fac-easy-card-desc">Guarda los datos de tus clientes para facturar más rápido</p>
        </button>
        <button onclick="facSetMode('pro');setTimeout(()=>{switchFacTab('calendar');},200);" class="fac-easy-card">
          <span class="fac-easy-card-emoji">📅</span>
          <p class="fac-easy-card-title">Fechas importantes</p>
          <p class="fac-easy-card-desc">¿Cuándo declarar al SAT? Te avisamos antes</p>
        </button>
        <button onclick="facOpenSkybot()" class="fac-easy-card">
          <span class="fac-easy-card-emoji">✨</span>
          <p class="fac-easy-card-title">Pregúntale a SkyBot</p>
          <p class="fac-easy-card-desc">¿Tienes dudas del SAT? Te ayuda en español</p>
        </button>
        <button onclick="facOpenEmisor()" class="fac-easy-card">
          <span class="fac-easy-card-emoji">🏢</span>
          <p class="fac-easy-card-title">Mi empresa</p>
          <p class="fac-easy-card-desc">Configura tu logo y datos fiscales</p>
        </button>
      </div>

      <!-- Stats simples -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;">
        <div class="stat-card" style="padding:18px;text-align:center;">
          <p style="font-size:32px;font-weight:900;color:#22c55e;" id="fac-easy-paid">0</p>
          <p style="font-size:12px;color:var(--text-muted);font-weight:700;margin-top:4px;">✅ Facturas pagadas</p>
        </div>
        <div class="stat-card" style="padding:18px;text-align:center;">
          <p style="font-size:32px;font-weight:900;color:#f97316;" id="fac-easy-pending">0</p>
          <p style="font-size:12px;color:var(--text-muted);font-weight:700;margin-top:4px;">💰 Por cobrar</p>
        </div>
        <div class="stat-card" style="padding:18px;text-align:center;">
          <p style="font-size:32px;font-weight:900;color:#8b5cf6;" id="fac-easy-iva">$0</p>
          <p style="font-size:12px;color:var(--text-muted);font-weight:700;margin-top:4px;">📊 IVA del mes</p>
        </div>
      </div>
    </div>

    <!-- Wizard de facturación -->
    <div id="fac-wizard" style="display:none;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <button onclick="facWizBack()" id="fac-wiz-back" style="width:36px;height:36px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);cursor:pointer;font-size:18px;">←</button>
          <div>
            <p style="font-size:18px;font-weight:900;color:var(--text-primary);" id="fac-wiz-title">Crear factura</p>
            <p style="font-size:12px;color:var(--text-muted);" id="fac-wiz-subtitle">Paso 1 de 5</p>
          </div>
        </div>
        <button onclick="facWizCancel()" style="padding:8px 14px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;">✕ Cancelar</button>
      </div>

      <div style="display:flex;gap:6px;margin-bottom:28px;">
        <div class="fac-wiz-step-bar active"></div>
        <div class="fac-wiz-step-bar"></div>
        <div class="fac-wiz-step-bar"></div>
        <div class="fac-wiz-step-bar"></div>
        <div class="fac-wiz-step-bar"></div>
      </div>

      <!-- PASO 1: ¿A quién le vas a facturar? -->
      <div id="fac-wiz-step-1" class="fac-wiz-step">
        <div class="stat-card" style="padding:32px;max-width:680px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="fac-wiz-step-num">1</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿A quién le vas a facturar?</h3>
              <p style="font-size:13px;color:var(--text-muted);">Pídele a tu cliente su <b>Constancia de Situación Fiscal</b> (la del SAT) — ahí vienen todos los datos que necesitas</p>
            </div>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
            <button onclick="facWizPickClient()" class="fac-wiz-hint-btn">👥 Escoger de mis clientes guardados</button>
            <button onclick="facWizPublic()" class="fac-wiz-hint-btn">🛒 Es para "Público en general"</button>
          </div>
          <div style="display:flex;flex-direction:column;gap:16px;">
            <div>
              <label class="fac-wiz-label">Nombre o razón social <span class="fac-wiz-help">(como aparece en el SAT)</span></label>
              <input id="fac-wiz-name" type="text" class="fac-wiz-input" placeholder="Ej: María García López" oninput="document.getElementById('fac-c-name').value=this.value;facWizValidate(1);"/>
            </div>
            <div>
              <label class="fac-wiz-label">RFC <span class="fac-wiz-help">(13 letras y números si es persona física, 12 si es empresa)</span></label>
              <input id="fac-wiz-rfc" type="text" class="fac-wiz-input" placeholder="Ej: GALM850101AB1" maxlength="13" style="text-transform:uppercase;font-family:monospace;letter-spacing:1px;" oninput="this.value=this.value.toUpperCase();document.getElementById('fac-c-rfc').value=this.value;facWizValidateRFC();facWizValidate(1);"/>
              <p id="fac-wiz-rfc-feedback" style="font-size:11px;margin-top:4px;min-height:14px;"></p>
            </div>
            <div>
              <label class="fac-wiz-label">Código postal del cliente</label>
              <input id="fac-wiz-cp" type="text" class="fac-wiz-input" placeholder="Ej: 03100" maxlength="5" oninput="document.getElementById('fac-c-cp').value=this.value;facWizValidate(1);"/>
            </div>
            <div>
              <label class="fac-wiz-label">Email del cliente <span class="fac-wiz-help">(para enviarle la factura)</span></label>
              <input id="fac-wiz-email" type="email" class="fac-wiz-input" placeholder="Ej: cliente@email.com" oninput="document.getElementById('fac-c-email').value=this.value;facWizValidate(1);"/>
            </div>
          </div>
          <button onclick="facWizNext()" id="fac-wiz-next-1" class="fac-wiz-next" disabled>Siguiente →</button>
        </div>
      </div>

      <!-- PASO 2: ¿Qué tipo de cliente es? (régimen) -->
      <div id="fac-wiz-step-2" class="fac-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:780px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="fac-wiz-step-num" style="background:#f97316;">2</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿Qué tipo de cliente es?</h3>
              <p style="font-size:13px;color:var(--text-muted);">Esto se llama <b>Régimen Fiscal</b>. Lo encuentras en su Constancia de Situación Fiscal. Si no estás seguro, escoge la opción que más se parezca</p>
            </div>
          </div>
          <div id="fac-wiz-regime-grid" class="fac-wiz-regime-grid"></div>
          <p style="font-size:11px;color:var(--text-muted);margin-top:14px;padding:10px 12px;border-radius:8px;background:var(--accent-bg);">💡 ¿No estás seguro? Pregúntale a SkyBot abajo o pídele a tu cliente que te mande foto de su Constancia.</p>
          <button onclick="facWizNext()" id="fac-wiz-next-2" class="fac-wiz-next" disabled>Siguiente →</button>
        </div>
      </div>

      <!-- PASO 3: ¿Qué le estás vendiendo? -->
      <div id="fac-wiz-step-3" class="fac-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:780px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="fac-wiz-step-num" style="background:#8b5cf6;">3</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿Qué le estás vendiendo?</h3>
              <p style="font-size:13px;color:var(--text-muted);">Lista los productos o servicios. Puedes agregar varios si vendiste más de una cosa</p>
            </div>
          </div>
          <div id="fac-wiz-items" style="display:flex;flex-direction:column;gap:10px;"></div>
          <button onclick="facWizAddItem()" style="margin-top:10px;padding:10px;border-radius:10px;border:1px dashed var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;width:100%;">+ Agregar otro producto/servicio</button>
          <div style="margin-top:20px;padding:16px;border-radius:12px;background:var(--input-bg);border:1px solid var(--border);">
            <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--text-muted);"><span>Subtotal</span><span id="fac-wiz-subtotal" style="font-weight:700;color:var(--text-primary);">$0.00</span></div>
            <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--text-muted);margin-top:6px;"><span>IVA (16%)</span><span id="fac-wiz-iva" style="font-weight:700;color:var(--text-primary);">$0.00</span></div>
            <div style="display:flex;justify-content:space-between;font-size:18px;font-weight:900;margin-top:10px;padding-top:10px;border-top:1px solid var(--border);"><span>Total a facturar</span><span id="fac-wiz-total" style="color:var(--accent);">$0.00</span></div>
          </div>
          <button onclick="facWizNext()" id="fac-wiz-next-3" class="fac-wiz-next" disabled>Siguiente →</button>
        </div>
      </div>

      <!-- PASO 4: ¿Cómo te pagaron? -->
      <div id="fac-wiz-step-4" class="fac-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:680px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="fac-wiz-step-num" style="background:#22c55e;">4</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">¿Cómo te pagó (o te va a pagar)?</h3>
              <p style="font-size:13px;color:var(--text-muted);">Esto el SAT lo necesita saber. Solo escoge lo que aplique</p>
            </div>
          </div>
          <p class="fac-wiz-label">¿Ya te pagaron o te van a pagar después?</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;">
            <div onclick="facWizPickPayMode('PUE')" id="fac-wiz-paymode-PUE" class="fac-wiz-paymode-card selected">
              <div style="font-size:32px;">💵</div>
              <p style="font-size:14px;font-weight:900;color:var(--text-primary);margin-top:6px;">Ya me pagó</p>
              <p style="font-size:11px;color:var(--text-muted);margin-top:2px;">Recibí el dinero antes o al momento de facturar</p>
              <p style="font-size:9px;color:var(--text-faint);margin-top:4px;font-family:monospace;">PUE</p>
            </div>
            <div onclick="facWizPickPayMode('PPD')" id="fac-wiz-paymode-PPD" class="fac-wiz-paymode-card">
              <div style="font-size:32px;">⏰</div>
              <p style="font-size:14px;font-weight:900;color:var(--text-primary);margin-top:6px;">Me va a pagar después</p>
              <p style="font-size:11px;color:var(--text-muted);margin-top:2px;">Es a crédito (genera complemento de pago al cobrar)</p>
              <p style="font-size:9px;color:var(--text-faint);margin-top:4px;font-family:monospace;">PPD</p>
            </div>
          </div>
          <p class="fac-wiz-label" id="fac-wiz-form-label">¿Cómo te pagó?</p>
          <div id="fac-wiz-payform-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-bottom:20px;"></div>
          <button onclick="facWizNext()" class="fac-wiz-next">Siguiente →</button>
        </div>
      </div>

      <!-- PASO 5: Revisión final -->
      <div id="fac-wiz-step-5" class="fac-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:32px;max-width:680px;margin:0 auto;">
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;">
            <div class="fac-wiz-step-num" style="background:#22c55e;">5</div>
            <div>
              <h3 style="font-size:20px;font-weight:900;color:var(--text-primary);">Revisa y confirma</h3>
              <p style="font-size:13px;color:var(--text-muted);">Todo se ve bien? Si sí, le damos timbre ante el SAT</p>
            </div>
          </div>
          <div id="fac-wiz-summary" style="display:flex;flex-direction:column;gap:12px;"></div>
          <button onclick="facWizConfirm()" class="fac-wiz-next" style="background:#22c55e;font-size:16px;">⚡ Timbrar ante el SAT</button>
          <p style="font-size:11px;color:var(--text-muted);margin-top:10px;text-align:center;">Al timbrar generamos PDF + XML oficiales y se los mandamos al cliente por correo</p>
        </div>
      </div>

      <!-- DONE -->
      <div id="fac-wiz-step-done" class="fac-wiz-step" style="display:none;">
        <div class="stat-card" style="padding:48px 32px;max-width:560px;margin:0 auto;text-align:center;">
          <div style="font-size:80px;margin-bottom:16px;">🎉</div>
          <h3 style="font-size:24px;font-weight:900;color:#22c55e;">¡Listo! Tu factura está timbrada</h3>
          <p id="fac-wiz-done-msg" style="font-size:14px;color:var(--text-muted);margin-top:10px;">Le mandamos el PDF y XML a tu cliente por correo automáticamente.</p>
          <div style="margin-top:24px;padding:18px;border-radius:12px;background:var(--input-bg);border:1px solid var(--border);text-align:left;">
            <p style="font-size:11px;font-weight:800;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Folio de factura</p>
            <p id="fac-wiz-done-folio" style="font-size:18px;font-weight:900;color:var(--accent);font-family:monospace;margin-top:4px;">--</p>
          </div>
          <div style="display:flex;gap:10px;margin-top:24px;justify-content:center;flex-wrap:wrap;">
            <button onclick="showToast('PDF descargado')" class="fac-wiz-next" style="flex:1;min-width:160px;margin:0;">📄 Descargar PDF</button>
            <button onclick="facWizDone()" class="fac-wiz-next" style="flex:1;min-width:160px;margin:0;background:#22c55e;">✅ Hacer otra factura</button>
          </div>
          <p style="font-size:11px;color:var(--text-faint);margin-top:16px;">¿Otra cosa? <a href="#" onclick="facWizDone();return false;" style="color:var(--accent);">Volver al inicio</a></p>
        </div>
      </div>
    </div>
  </div>

  <!-- ════════ MODO EXPERTO (todo lo anterior) ════════ -->
  <div id="fac-pro-mode" style="display:none;">
  <!-- Smart Recommendations -->
  <div id="fac-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Facturas del mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-total" class="fac-stat-val">--</p><span id="fac-trend-total" class="fac-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Total facturado</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-amount" class="fac-stat-val" style="color:#22c55e;">--</p><span id="fac-trend-amount" class="fac-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Por cobrar <span class="fac-tip" data-tip="Facturas emitidas que el cliente aún no ha pagado">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-pending" class="fac-stat-val" style="color:#f97316;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Notas de crédito <span class="fac-tip" data-tip="Facturas que se cancelaron o ajustaron. Se usan cuando hay devoluciones o errores.">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-credit" class="fac-stat-val" style="color:#ef4444;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">IVA del mes <span class="fac-tip" data-tip="Total de IVA (16%) que cobraste en tus facturas. Este es el impuesto que debes declarar al SAT.">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-iva" class="fac-stat-val" style="color:#8b5cf6;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Timbradas hoy</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-today" class="fac-stat-val" style="color:var(--accent);">--</p></div>
    </div>
  </div>

  <!-- ══════════ Health Score + Insights IA ══════════ -->
  <div style="display:grid;grid-template-columns:320px 1fr;gap:16px;margin-bottom:20px;" class="fac-hero-grid">
    <!-- Health Score Gauge -->
    <div class="stat-card" style="padding:20px;position:relative;overflow:hidden;">
      <div style="position:absolute;top:0;right:0;width:120px;height:120px;background:radial-gradient(circle at top right,rgba(111,207,245,0.18),transparent 70%);pointer-events:none;"></div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;position:relative;">
        <p class="fac-stat-label" style="margin:0;">Health score fiscal <span class="fac-tip" data-tip="Qué tan sano está tu negocio ante el SAT. Considera declaraciones, cobros pendientes, errores de timbrado y uso de facturas.">?</span></p>
        <span id="fac-score-delta" style="font-size:11px;font-weight:800;"></span>
      </div>
      <div style="display:flex;align-items:center;gap:18px;position:relative;">
        <div style="position:relative;width:120px;height:120px;flex-shrink:0;">
