    <td style="padding:14px 16px;"><span style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;color:${st.c};background:${st.b};">${st.l}</span></td>
    <td style="padding:14px 16px;font-size:12px;color:var(--text-muted);">${i.date}</td>
    <td style="padding:14px 16px;text-align:center;"><div style="display:flex;gap:4px;justify-content:center;flex-wrap:wrap;">
      ${i.status!=='error'&&i.status!=='draft'?`<button onclick="showToast('PDF descargado')" class="fac-tbl-btn">PDF</button><button onclick="showToast('XML descargado')" class="fac-tbl-btn">XML</button>`:''}
      ${i.email&&i.status!=='error'?`<button onclick="showToast('Factura reenviada a ${i.email}')" class="fac-tbl-btn" style="border-color:#6fcff5;color:#6fcff5;">Reenviar</button>`:''}
      ${i.status==='active'||i.status==='stamped'?`<button onclick="facCancelInvoice(${i.id})" class="fac-tbl-btn" style="border-color:#ef4444;color:#ef4444;">Cancelar</button>`:''}
      ${i.status==='error'?`<button onclick="facRetryStamp(${i.id})" class="fac-tbl-btn" style="border-color:#f97316;color:#f97316;">Reintentar</button><span style="display:block;font-size:10px;color:#ef4444;margin-top:4px;max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${i.errorMsg||''}">${i.errorMsg||'Error desconocido'}</span>`:''}
