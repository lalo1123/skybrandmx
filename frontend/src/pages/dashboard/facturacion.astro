function renderFacRecs(){
  const el=document.getElementById('fac-smart-recs');if(!el)return;const recs=[];
  const unpaid=demoInvoices.filter(i=>i.status==='active');
  if(unpaid.length>0)recs.push({icon:'💰',color:'#f97316',title:`${unpaid.length} factura(s) por cobrar ($${unpaid.reduce((s,i)=>s+i.total,0).toLocaleString()})`,desc:'Envía un recordatorio de pago a tus clientes.',btn:'Enviar recordatorio',action:"showToast('Recordatorios enviados')"});
  // Declaration reminder (17th of each month is SAT deadline)
  const today=new Date();const day=today.getDate();
  if(day>=10&&day<=17)recs.push({icon:'📅',color:'#ef4444',title:'Se acerca la fecha de declaración mensual',desc:`Tienes hasta el día 17 de este mes para presentar tu declaración ante el SAT. IVA del mes: $${demoInvoices.filter(i=>i.status!=='cancelled').reduce((s,i)=>s+i.iva,0).toLocaleString()}`,btn:'Ver resumen fiscal',action:"switchFacTab('analytics')"});
  // Complemento de pago reminder
  const ppdInvoices=demoInvoices.filter(i=>i.status==='paid'&&i.payment==='PPD');
  if(ppdInvoices.length>0)recs.push({icon:'🧾',color:'#8b5cf6',title:`${ppdInvoices.length} factura(s) PPD necesitan complemento de pago`,desc:'Genera el complemento de pago para las facturas que ya fueron pagadas.',btn:'Generar',action:"showToast('Complementos generados')"});
  if(!recs.length){el.style.display='none';return;}
  el.style.display='flex';
  el.innerHTML=recs.map(r=>`<div style="display:flex;align-items:center;gap:14px;padding:14px 18px;border-radius:12px;background:${r.color}08;border:1px solid ${r.color}20;"><span style="font-size:24px;flex-shrink:0;">${r.icon}</span><div style="flex:1;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">${r.title}</p><p style="font-size:11px;color:var(--text-muted);margin-top:2px;">${r.desc}</p></div><button onclick="${r.action}" style="padding:8px 16px;border-radius:8px;border:none;background:${r.color};color:#fff;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">${r.btn}</button><button onclick="this.closest('div[style]').remove()" style="border:none;background:transparent;color:var(--text-faint);cursor:pointer;font-size:14px;padding:0 4px;">✕</button></div>`).join('');
}

