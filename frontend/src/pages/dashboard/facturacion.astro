function facWizCancel(){
  if(confirm('¿Seguro que quieres cancelar? Se perderán los datos de la factura.'))facWizDone();
}
function facWizDone(){
  document.getElementById('fac-wizard').style.display='none';
  document.getElementById('fac-easy-home').style.display='block';
  facWizGoTo(1);
  facUpdateEasyStats();
}

function facWizGoTo(step){
  facWizStep=step;
  for(let i=1;i<=5;i++){const el=document.getElementById('fac-wiz-step-'+i);if(el)el.style.display=(step===i)?'block':'none';}
  document.getElementById('fac-wiz-step-done').style.display=step==='done'?'block':'none';
  document.querySelectorAll('.fac-wiz-step-bar').forEach((b,i)=>{
    b.classList.remove('active','done');
    const n=i+1;
    if(typeof step==='number'){if(n<step)b.classList.add('done');else if(n===step)b.classList.add('active');}
    else if(step==='done'){b.classList.add('done');}
  });
  const titles={1:'¿A quién facturas?',2:'¿Qué tipo de cliente es?',3:'¿Qué le vendes?',4:'¿Cómo te pagaron?',5:'Revisa y confirma',done:'¡Listo!'};
  document.getElementById('fac-wiz-title').textContent='Crear factura · '+(titles[step]||'');
  document.getElementById('fac-wiz-subtitle').textContent=step==='done'?'Completado':`Paso ${step} de 5`;
  const back=document.getElementById('fac-wiz-back');
  if(back)back.style.visibility=(step===1||step==='done')?'hidden':'visible';
  if(step===5)facWizRenderSummary();
  window.scrollTo({top:0,behavior:'smooth'});
}

function facWizNext(){
  if(facWizStep<5)facWizGoTo(facWizStep+1);
}
function facWizBack(){
  if(typeof facWizStep==='number' && facWizStep>1)facWizGoTo(facWizStep-1);
}

function facWizValidate(step){
  let valid=false;
  if(step===1){
    const name=document.getElementById('fac-wiz-name').value.trim();
    const rfc=document.getElementById('fac-wiz-rfc').value.trim();
    const cp=document.getElementById('fac-wiz-cp').value.trim();
    valid=name.length>=3 && (rfc.length===12||rfc.length===13) && cp.length===5;
  } else if(step===3){
    const subtotal=facWizItems.reduce((s,i)=>s+(i.qty*i.price),0);
    valid=subtotal>0 && facWizItems.every(i=>i.desc.trim().length>0);
  }
  const btn=document.getElementById('fac-wiz-next-'+step);
  if(btn)btn.disabled=!valid;
  return valid;
}

function facWizValidateRFC(){
  const rfc=document.getElementById('fac-wiz-rfc').value.trim().toUpperCase();
  const fb=document.getElementById('fac-wiz-rfc-feedback');
  if(!rfc){fb.textContent='';return;}
  const isPF=/^[A-ZÑ&]{4}\d{6}[A-Z0-9]{3}$/.test(rfc);
  const isPM=/^[A-ZÑ&]{3}\d{6}[A-Z0-9]{3}$/.test(rfc);
  const isGen=rfc==='XAXX010101000'||rfc==='XEXX010101000';
  if(isGen){fb.innerHTML='✓ RFC genérico (público en general)';fb.style.color='#22c55e';}
  else if(isPF){fb.innerHTML='✓ Persona física (13 caracteres)';fb.style.color='#22c55e';}
  else if(isPM){fb.innerHTML='✓ Empresa / persona moral (12 caracteres)';fb.style.color='#22c55e';}
