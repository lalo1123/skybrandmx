// ═══════ HEALTH SCORE FISCAL ═══════
function calcFacHealthScore(){
  const active=demoInvoices.filter(i=>i.status!=='cancelled');
  const total=active.length;
  // Breakdown (each out of 25)
  const unpaid=demoInvoices.filter(i=>i.status==='active').length;
  const paymentScore=total>0?Math.round(25*(1-unpaid/total)):25;
  // SAT deadline (day 17): mejor mientras más temprano en el mes
  const day=new Date().getDate();
  const deadlineScore=day<=10?25:day<=17?18:day<=25?12:8;
  // Errores de timbrado
  const errors=demoInvoices.filter(i=>i.status==='error').length;
  const stampScore=Math.max(0,25-errors*8);
  // Uso público en general
  const xaxx=demoInvoices.filter(i=>i.rfc==='XAXX010101000').length;
  const xaxxRatio=total>0?xaxx/total:0;
  const usageScore=xaxxRatio<0.3?25:xaxxRatio<0.5?18:xaxxRatio<0.7?12:6;
  const score=Math.min(100,paymentScore+deadlineScore+stampScore+usageScore);
  return { score, parts:[
    { label:'Cobros al día', val:paymentScore, max:25, color:'#22c55e' },
    { label:'Declaración SAT', val:deadlineScore, max:25, color:'#6fcff5' },
    { label:'Timbrado limpio', val:stampScore, max:25, color:'#8b5cf6' },
    { label:'Uso de RFC', val:usageScore, max:25, color:'#f97316' },
  ]};
}
function renderFacHealthScore(){
  const {score,parts}=calcFacHealthScore();
  const circle=document.getElementById('fac-score-circle');
  const valEl=document.getElementById('fac-score-val');
  const lblEl=document.getElementById('fac-score-label');
  const descEl=document.getElementById('fac-score-desc');
  const deltaEl=document.getElementById('fac-score-delta');
  const barsEl=document.getElementById('fac-score-bars');
  if(!circle||!valEl)return;
  const circumference=2*Math.PI*50;
  circle.setAttribute('stroke-dasharray',circumference);
  circle.setAttribute('stroke-dashoffset',circumference-(score/100)*circumference);
  // Animate counter
  let cur=0; const step=Math.max(1,Math.ceil(score/40));
  const anim=setInterval(()=>{cur+=step;if(cur>=score){cur=score;clearInterval(anim);}valEl.textContent=cur;},30);
  // Label
  const labels=score>=85?{l:'Excelente 🎉',c:'#22c55e',d:'Tu negocio está al día con el SAT. Sigue así.'}:score>=70?{l:'Bien ✓',c:'#6fcff5',d:'Buen estado fiscal. Hay pequeñas oportunidades de mejora.'}:score>=50?{l:'Atención',c:'#f97316',d:'Algunos puntos requieren tu atención antes de la próxima declaración.'}:{l:'Urgente ⚠️',c:'#ef4444',d:'Varias obligaciones pendientes. Revisa los puntos rojos.'};
  lblEl.textContent=labels.l; lblEl.style.color=labels.c;
  descEl.textContent=labels.d;
  deltaEl.innerHTML='<span style="color:#22c55e;">▲ +4</span>';
  barsEl.innerHTML=parts.map(p=>{const pct=Math.round((p.val/p.max)*100);return `<div class="fac-score-bar"><span style="width:90px;">${p.label}</span><div class="fac-score-bar-track"><div class="fac-score-bar-fill" style="width:${pct}%;background:${p.color};"></div></div><span style="width:28px;text-align:right;color:${p.color};font-weight:800;">${p.val}</span></div>`;}).join('');
}

// ═══════ INSIGHTS IA ═══════
function genFacInsights(){
  const insights=[];
  const active=demoInvoices.filter(i=>i.status!=='cancelled');
  const totalAmount=active.reduce((s,i)=>s+i.total,0);
  const unpaid=demoInvoices.filter(i=>i.status==='active');
  const unpaidTotal=unpaid.reduce((s,i)=>s+i.total,0);

  // Top cliente
  const byClient={};
  active.forEach(i=>{byClient[i.client]=(byClient[i.client]||0)+i.total;});
  const topClient=Object.entries(byClient).sort((a,b)=>b[1]-a[1])[0];
  if(topClient){
    const pct=Math.round((topClient[1]/totalAmount)*100);
    insights.push({icon:'🚀',color:'#22c55e',bg:'rgba(34,197,94,0.1)',title:`${topClient[0]} es tu mejor cliente`,desc:`Representa el ${pct}% de tus ingresos fiscales ($${topClient[1].toLocaleString()} este periodo). Considera enviarle un descuento o newsletter personalizado.`,action:'Ver perfil',fn:`switchFacTab('clients')`});
  }

  // Cobros pendientes
  if(unpaid.length>0){
    const oldest=unpaid.reduce((a,b)=>a.date<b.date?a:b);
    const daysAgo=Math.max(1,Math.ceil((new Date()-new Date(oldest.date))/(1000*60*60*24)));
    insights.push({icon:'💰',color:'#f97316',bg:'rgba(249,115,22,0.1)',title:`${unpaid.length} factura${unpaid.length>1?'s':''} por cobrar: $${unpaidTotal.toLocaleString()}`,desc:`La más antigua es ${oldest.folio} de ${oldest.client} (hace ${daysAgo} días). Enviar recordatorio automático puede subir tu tasa de cobro 34%.`,action:'Enviar recordatorios',fn:`showToast('Recordatorios programados para ${unpaid.length} clientes')`});
  }

  // IVA del mes
  const ivaMes=active.reduce((s,i)=>s+i.iva,0);
  const day=new Date().getDate();
  const daysLeft=Math.max(0,17-day);
  if(daysLeft<=10){
    insights.push({icon:'📅',color:'#ef4444',bg:'rgba(239,68,68,0.1)',title:`Declaración SAT en ${daysLeft} día${daysLeft!==1?'s':''}`,desc:`Debes declarar $${ivaMes.toLocaleString()} de IVA antes del día 17. Descarga el resumen fiscal listo para tu contador.`,action:'Descargar resumen',fn:`showToast('Resumen fiscal descargado')`});
  }

  // Anomalía: cliente con facturación inusualmente alta
  const monthFacs=active.filter(i=>i.date>='2026-03-01');
  if(monthFacs.length>0){
    const clientCount={};
    monthFacs.forEach(i=>{clientCount[i.client]=(clientCount[i.client]||0)+1;});
    const heavy=Object.entries(clientCount).find(([n,c])=>c>=2);
    if(heavy){
      insights.push({icon:'📈',color:'#8b5cf6',bg:'rgba(139,92,246,0.1)',title:`${heavy[0]} facturó ${heavy[1]} veces este mes`,desc:`230% más que el promedio. Podría ser cliente recurrente — crea un esquema de facturación automática mensual para ahorrarle (y ahorrarte) tiempo.`,action:'Crear automatización',fn:`showToast('Automatización creada')`});
    }
  }

  return insights.slice(0,4);
}
function renderFacInsights(refresh){
  const el=document.getElementById('fac-insights');
  if(!el)return;
  if(refresh){
    el.innerHTML='<div style="padding:20px;text-align:center;grid-column:1/-1;"><div style="display:inline-block;width:24px;height:24px;border:2px solid var(--border);border-top-color:#8b5cf6;border-radius:50%;animation:spin 0.7s linear infinite;"></div><p style="font-size:11px;color:var(--text-muted);margin-top:8px;">SkyBot analizando datos...</p></div>';
    setTimeout(()=>renderFacInsights(false),900);return;
  }
  const items=genFacInsights();
  if(items.length===0){el.innerHTML='<div style="padding:20px;text-align:center;grid-column:1/-1;color:var(--text-muted);font-size:12px;">Todo en orden ✨ SkyBot no detectó nada urgente.</div>';return;}
  el.innerHTML=items.map(ins=>`<div class="fac-insight" style="--insight-color:${ins.color};">
    <div class="fac-insight-icon" style="background:${ins.bg};">${ins.icon}</div>
