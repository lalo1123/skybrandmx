function facUploadLogo(event){
  const file=event.target.files[0];
  if(!file)return;
  if(file.size>2*1024*1024){alert('La imagen debe pesar menos de 2MB');return;}
  const reader=new FileReader();
  reader.onload=(e)=>{
    const cfg=facLoadConfig();
    cfg.logo=e.target.result;
    facSaveConfig(cfg);
    document.getElementById('fac-emisor-logo-preview').innerHTML=`<img src="${cfg.logo}" style="width:100%;height:100%;object-fit:cover;"/>`;
    renderCfdiPreview();
    showToast('Logo subido ✓');
  };
  reader.readAsDataURL(file);
}
