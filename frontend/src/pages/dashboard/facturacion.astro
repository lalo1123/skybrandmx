---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Facturación">
  <!-- Smart Recommendations -->
  <div id="fac-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Facturas del mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-total" class="fac-stat-val">--</p><span id="fac-trend-total" class="fac-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Total facturado</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-amount" class="fac-stat-val" style="color:#22c55e;">--</p><span id="fac-trend-amount" class="fac-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Por cobrar <span class="fac-tip" data-tip="Facturas emitidas que el cliente aún no ha pagado">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-pending" class="fac-stat-val" style="color:#f97316;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Notas de crédito <span class="fac-tip" data-tip="Facturas que se cancelaron o ajustaron. Se usan cuando hay devoluciones o errores.">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-credit" class="fac-stat-val" style="color:#ef4444;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">IVA del mes <span class="fac-tip" data-tip="Total de IVA (16%) que cobraste en tus facturas. Este es el impuesto que debes declarar al SAT.">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-iva" class="fac-stat-val" style="color:#8b5cf6;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="fac-stat-label">Timbradas hoy</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="fac-stat-today" class="fac-stat-val" style="color:var(--accent);">--</p></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="fac-tab-invoices" class="fac-tab active" onclick="switchFacTab('invoices')">Facturas</button>
    <button id="fac-tab-create" class="fac-tab" onclick="switchFacTab('create')">Nueva factura</button>
    <button id="fac-tab-credits" class="fac-tab" onclick="switchFacTab('credits')">Notas de crédito</button>
    <button id="fac-tab-clients" class="fac-tab" onclick="switchFacTab('clients')">Clientes fiscales</button>
    <button id="fac-tab-analytics" class="fac-tab" onclick="switchFacTab('analytics')">Analítica</button>
  </div>

  <!-- ══════════ Tab: Facturas ══════════ -->
  <div id="fac-panel-invoices">
    <div id="fac-help-invoices" class="fac-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Todas las facturas que has emitido. Puedes descargar el XML y PDF, reenviar por email o cancelar ante el SAT.</p>
      <button onclick="facDismissHelp('invoices')" class="fac-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="fac-search" type="text" placeholder="Buscar por folio, cliente, RFC..." oninput="facFilter()" class="fac-input" style="padding-left:38px;"/>
      </div>
      <select id="fac-filter-status" onchange="facFilter()" class="fac-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="active">Vigente</option>
        <option value="paid">Pagada</option>
        <option value="cancelled">Cancelada</option>
      </select>
      <button onclick="switchFacTab('create')" class="fac-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva factura
      </button>
      <button onclick="facExportZIP()" class="fac-btn-secondary" style="padding:10px 14px;display:flex;align-items:center;gap:4px;font-size:12px;" title="Descarga todos los XML del mes en un ZIP para tu contador">
        📁 Exportar XML
      </button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="fac-th">Folio</th><th class="fac-th">Cliente</th><th class="fac-th">RFC</th>
            <th class="fac-th" style="text-align:right;">Subtotal</th><th class="fac-th" style="text-align:right;">IVA</th>
            <th class="fac-th" style="text-align:right;">Total</th><th class="fac-th">Estado</th>
            <th class="fac-th">Fecha</th><th class="fac-th" style="text-align:center;">Acciones</th>
          </tr></thead>
          <tbody id="fac-invoices-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Nueva factura ══════════ -->
  <div id="fac-panel-create" style="display:none;">
    <div id="fac-help-create" class="fac-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Llena los datos y generamos tu factura CFDI 4.0 timbrada ante el SAT. Se envía automáticamente por email al cliente.</p>
      <button onclick="facDismissHelp('create')" class="fac-help-close">&times;</button>
    </div>
    <!-- Quick actions -->
    <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
      <button onclick="facQuickPublic()" style="flex:1;min-width:180px;padding:14px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;transition:all 0.2s;text-align:left;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
        <span style="font-size:20px;">👤</span>
        <p style="font-size:13px;font-weight:800;color:var(--text-primary);margin-top:6px;">Público en general</p>
        <p style="font-size:11px;color:var(--text-faint);">Factura rápida sin pedir datos al cliente</p>
      </button>
      <button onclick="facQuickFromOrder()" style="flex:1;min-width:180px;padding:14px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;transition:all 0.2s;text-align:left;" onmouseover="this.style.borderColor='#8b5cf6'" onmouseout="this.style.borderColor='var(--border)'">
        <span style="font-size:20px;">📦</span>
        <p style="font-size:13px;font-weight:800;color:var(--text-primary);margin-top:6px;">Desde un pedido</p>
        <p style="font-size:11px;color:var(--text-faint);">Auto-llena datos del pedido existente</p>
      </button>
      <button onclick="facQuickMass()" style="flex:1;min-width:180px;padding:14px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;transition:all 0.2s;text-align:left;" onmouseover="this.style.borderColor='#f97316'" onmouseout="this.style.borderColor='var(--border)'">
        <span style="font-size:20px;">📋</span>
        <p style="font-size:13px;font-weight:800;color:var(--text-primary);margin-top:6px;">Facturación masiva</p>
        <p style="font-size:11px;color:var(--text-faint);">Factura varios pedidos de golpe</p>
      </button>
    </div>

    <div class="stat-card animate-in" style="padding:24px;">
      <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:4px;">Crear factura CFDI 4.0</h3>
      <p style="font-size:12px;color:var(--text-muted);margin-bottom:20px;">Completa los datos y nosotros la timbramos ante el SAT automáticamente.</p>

      <!-- Receptor -->
      <div style="border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:16px;">
        <p style="font-size:12px;font-weight:800;color:var(--accent);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;">Datos del cliente (receptor)</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
          <div><label class="fac-label">Nombre o razón social *</label><input id="fac-c-name" type="text" placeholder="Ej: María García López" class="fac-input" list="fac-client-list"/><datalist id="fac-client-list"></datalist></div>
          <div><label class="fac-label">RFC *</label><div style="display:flex;gap:6px;"><input id="fac-c-rfc" type="text" placeholder="XAXX010101000" class="fac-input" style="text-transform:uppercase;flex:1;" maxlength="13"/><button onclick="facValidateRFC()" style="padding:8px 12px;border-radius:10px;border:1px solid var(--accent);background:transparent;color:var(--accent);font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;" onmouseover="this.style.background='var(--accent-bg)'" onmouseout="this.style.background='transparent'">Validar</button></div><p id="fac-rfc-status" style="font-size:10px;margin-top:4px;display:none;"></p></div>
          <div>
            <label class="fac-label">Régimen fiscal * <span class="fac-tip" data-tip="Pregúntale a tu cliente su régimen fiscal, viene en su Constancia de Situación Fiscal del SAT">?</span></label>
            <select id="fac-c-regimen" class="fac-input" style="cursor:pointer;">
              <option value="">Seleccionar...</option>
              <option value="601">601 - General de Ley</option>
              <option value="603">603 - Personas Morales sin fines de lucro</option>
              <option value="612">612 - Personas Físicas con Act. Empresarial</option>
              <option value="616">616 - Sin obligaciones fiscales</option>
              <option value="621">621 - Incorporación Fiscal</option>
              <option value="626">626 - Simplificado de Confianza (RESICO)</option>
            </select>
          </div>
          <div><label class="fac-label">Código postal fiscal *</label><input id="fac-c-cp" type="text" placeholder="03100" class="fac-input" maxlength="5"/></div>
          <div><label class="fac-label">Email (para enviar la factura)</label><input id="fac-c-email" type="email" placeholder="cliente@email.com" class="fac-input"/></div>
          <div>
            <label class="fac-label">Uso de CFDI * <span class="fac-tip" data-tip="Para qué va a usar tu cliente esta factura. Si no sabes, pon 'Gastos en general' (G03).">?</span></label>
            <select id="fac-c-uso" class="fac-input" style="cursor:pointer;">
              <option value="G03" selected>G03 - Gastos en general</option>
              <option value="G01">G01 - Adquisición de mercancías</option>
              <option value="G02">G02 - Devoluciones, descuentos o bonificaciones</option>
              <option value="I01">I01 - Construcciones</option>
              <option value="P01">P01 - Por definir</option>
              <option value="S01">S01 - Sin efectos fiscales</option>
              <option value="CP01">CP01 - Pagos</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Conceptos -->
      <div style="border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:16px;">
        <p style="font-size:12px;font-weight:800;color:var(--accent);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;">Conceptos (productos o servicios)</p>
        <div id="fac-concepts" style="display:flex;flex-direction:column;gap:10px;"></div>
        <button onclick="facAddConcept()" style="margin-top:10px;padding:8px 16px;border-radius:8px;border:1px dashed var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:600;cursor:pointer;width:100%;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">+ Agregar concepto</button>
        <!-- Totals -->
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
          <div style="display:flex;gap:20px;"><span style="font-size:13px;color:var(--text-muted);min-width:100px;text-align:right;">Subtotal:</span><span id="fac-subtotal" style="font-size:13px;font-weight:700;color:var(--text-primary);min-width:100px;text-align:right;">$0.00</span></div>
          <div style="display:flex;gap:20px;"><span style="font-size:13px;color:var(--text-muted);min-width:100px;text-align:right;">IVA (16%):</span><span id="fac-iva-total" style="font-size:13px;font-weight:700;color:var(--text-primary);min-width:100px;text-align:right;">$0.00</span></div>
          <div style="display:flex;gap:20px;"><span style="font-size:15px;font-weight:800;color:var(--text-primary);min-width:100px;text-align:right;">Total:</span><span id="fac-grand-total" style="font-size:18px;font-weight:900;color:var(--accent);min-width:100px;text-align:right;">$0.00</span></div>
        </div>
      </div>

      <!-- Método y forma de pago -->
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;">
        <div>
          <label class="fac-label">Método de pago * <span class="fac-tip" data-tip="PUE = el cliente ya pagó todo. PPD = el cliente va a pagar después (a crédito).">?</span></label>
          <select id="fac-metodo" class="fac-input" style="cursor:pointer;">
            <option value="PUE">PUE - Pago en una sola exhibición</option>
            <option value="PPD">PPD - Pago en parcialidades o diferido</option>
          </select>
        </div>
        <div>
          <label class="fac-label">Forma de pago *</label>
          <select id="fac-forma" class="fac-input" style="cursor:pointer;">
            <option value="01">01 - Efectivo</option>
            <option value="03" selected>03 - Transferencia electrónica</option>
            <option value="04">04 - Tarjeta de crédito</option>
            <option value="28">28 - Tarjeta de débito</option>
            <option value="99">99 - Por definir</option>
          </select>
        </div>
        <div>
          <label class="fac-label">Moneda</label>
          <select id="fac-moneda" class="fac-input" style="cursor:pointer;">
            <option value="MXN" selected>MXN - Peso mexicano</option>
            <option value="USD">USD - Dólar americano</option>
          </select>
        </div>
      </div>

      <div style="display:flex;gap:10px;">
        <button onclick="facCreateInvoice('draft')" class="fac-btn-secondary" style="flex:1;">Guardar borrador</button>
        <button onclick="facCreateInvoice('preview')" class="fac-btn-secondary" style="flex:1;border-color:#8b5cf6;color:#8b5cf6;">Vista previa</button>
        <button onclick="facCreateInvoice('stamp')" class="fac-btn-primary" style="flex:1;background:#22c55e;display:flex;align-items:center;justify-content:center;gap:6px;">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Timbrar ante SAT
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Notas de crédito ══════════ -->
  <div id="fac-panel-credits" style="display:none;">
    <div id="fac-help-credits" class="fac-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Las notas de crédito se usan cuando necesitas cancelar una factura o hacer un ajuste (devolución, descuento, error).</p>
      <button onclick="facDismissHelp('credits')" class="fac-help-close">&times;</button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="fac-th">Folio NC</th><th class="fac-th">Factura original</th><th class="fac-th">Cliente</th>
            <th class="fac-th">Motivo</th><th class="fac-th" style="text-align:right;">Monto</th><th class="fac-th">Fecha</th>
          </tr></thead>
          <tbody id="fac-credits-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Clientes fiscales ══════════ -->
  <div id="fac-panel-clients" style="display:none;">
    <div id="fac-help-clients" class="fac-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Guarda los datos fiscales de tus clientes frecuentes para no tener que escribirlos cada vez que hagas una factura.</p>
      <button onclick="facDismissHelp('clients')" class="fac-help-close">&times;</button>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
      <button onclick="facAddClient()" class="fac-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Agregar cliente fiscal
      </button>
    </div>
    <div id="fac-clients-list" style="display:flex;flex-direction:column;gap:10px;"></div>
  </div>

  <!-- ══════════ Tab: Analítica ══════════ -->
  <div id="fac-panel-analytics" style="display:none;">
    <div id="fac-help-analytics" class="fac-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Mira cuánto has facturado, cuánto IVA debes declarar y quiénes son tus mejores clientes.</p>
      <button onclick="facDismissHelp('analytics')" class="fac-help-close">&times;</button>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:20px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Facturado por mes</h4>
        <div id="fac-chart-monthly" style="height:200px;display:flex;align-items:flex-end;gap:6px;"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Top clientes</h4>
        <div id="fac-chart-clients"></div>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;">
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">IVA mensual <span class="fac-tip" data-tip="El IVA que debes declarar al SAT cada mes. Es el 16% de tus ventas facturadas.">?</span></h4>
        <div id="fac-chart-iva"></div>
      </div>
      <div class="stat-card animate-in" style="padding:20px;">
        <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:16px;">Formas de pago</h4>
        <div id="fac-chart-payments"></div>
      </div>
    </div>
  </div>

  <!-- Autopilot -->
  <div class="stat-card animate-in" style="padding:0;margin-top:20px;overflow:hidden;">
    <button onclick="facToggleSection('fac-autopilot-content')" class="fac-collapse-header">
      <div style="display:flex;align-items:center;gap:8px;">
        <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,rgba(34,197,94,0.15),rgba(111,207,245,0.15));display:flex;align-items:center;justify-content:center;">
          <svg style="width:14px;height:14px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div style="text-align:left;"><p style="font-size:13px;font-weight:700;color:var(--text-primary);">Piloto automático de facturación</p><p style="font-size:11px;color:var(--text-faint);">Factura automáticamente sin que hagas nada</p></div>
      </div>
      <svg style="width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </button>
