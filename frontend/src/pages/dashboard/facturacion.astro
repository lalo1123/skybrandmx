        </button>
        <div id="fac-retenciones-body" style="display:none;padding:0 16px 16px 16px;">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <label style="display:flex;align-items:center;gap:10px;padding:10px;border-radius:10px;border:1px solid var(--border);cursor:pointer;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
              <input id="fac-ret-isr-chk" type="checkbox" onchange="facUpdateTotals();renderCfdiPreview();" style="accent-color:var(--accent);cursor:pointer;"/>
              <div style="flex:1;">
                <p style="font-size:12px;font-weight:700;color:var(--text-primary);">Retención ISR</p>
                <p style="font-size:10px;color:var(--text-faint);">Honorarios y arrendamientos</p>
              </div>
              <input id="fac-ret-isr-rate" type="number" value="10" step="0.01" min="0" max="40" style="width:55px;padding:4px 6px;border-radius:6px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:11px;text-align:right;" oninput="facUpdateTotals();renderCfdiPreview();"/>
              <span style="font-size:11px;color:var(--text-muted);">%</span>
            </label>
            <label style="display:flex;align-items:center;gap:10px;padding:10px;border-radius:10px;border:1px solid var(--border);cursor:pointer;" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
              <input id="fac-ret-iva-chk" type="checkbox" onchange="facUpdateTotals();renderCfdiPreview();" style="accent-color:var(--accent);cursor:pointer;"/>
