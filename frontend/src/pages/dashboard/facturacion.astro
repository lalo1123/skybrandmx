function facSaveTemplate(){
  const name=prompt('Nombre de la plantilla (ej: "Mensualidad hosting Café Maya"):');
  if(!name)return;
  const tpl={
    id:Date.now(), name,
    client:{name:document.getElementById('fac-c-name').value,rfc:document.getElementById('fac-c-rfc').value,regimen:document.getElementById('fac-c-regimen').value,cp:document.getElementById('fac-c-cp').value,email:document.getElementById('fac-c-email').value,uso:document.getElementById('fac-c-uso').value},
    concepts:[...facConcepts],
    payment:{metodo:document.getElementById('fac-metodo').value,forma:document.getElementById('fac-forma').value,moneda:document.getElementById('fac-moneda').value},
    retenciones:{isr:document.getElementById('fac-ret-isr-chk')?.checked,iva:document.getElementById('fac-ret-iva-chk')?.checked,isrRate:document.getElementById('fac-ret-isr-rate')?.value,ivaRate:document.getElementById('fac-ret-iva-rate')?.value}
  };
  const list=facGetTemplates();list.unshift(tpl);facSaveTemplatesList(list);
  facRenderTemplatesDropdown();
