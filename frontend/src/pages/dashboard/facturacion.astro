          <div style="display:flex;gap:20px;"><span style="font-size:13px;color:var(--text-muted);min-width:100px;text-align:right;">IVA (16%):</span><span id="fac-iva-total" style="font-size:13px;font-weight:700;color:#22c55e;min-width:100px;text-align:right;">$0.00</span></div>
          <div id="fac-ret-isr-row" style="display:none;gap:20px;"><span style="font-size:12px;color:var(--text-muted);min-width:100px;text-align:right;">Ret. ISR:</span><span id="fac-ret-isr-amt" style="font-size:13px;font-weight:700;color:#ef4444;min-width:100px;text-align:right;">-$0.00</span></div>
          <div id="fac-ret-iva-row" style="display:none;gap:20px;"><span style="font-size:12px;color:var(--text-muted);min-width:100px;text-align:right;">Ret. IVA:</span><span id="fac-ret-iva-amt" style="font-size:13px;font-weight:700;color:#ef4444;min-width:100px;text-align:right;">-$0.00</span></div>
          <div style="display:flex;gap:20px;"><span style="font-size:15px;font-weight:800;color:var(--text-primary);min-width:100px;text-align:right;">Total:</span><span id="fac-grand-total" style="font-size:18px;font-weight:900;color:var(--accent);min-width:100px;text-align:right;">$0.00</span></div>
        </div>
      </div>

      <!-- Método y forma de pago -->
