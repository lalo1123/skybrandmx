        <div style="display:flex;gap:6px;flex-wrap:wrap;">
          <button onclick="facOpenEmisor()" class="fac-toolbar-btn">🏢 Mi empresa</button>
          <select id="fac-tpl-select" onchange="if(this.value)facUseTemplate(this.value);this.value='';" class="fac-toolbar-btn" style="cursor:pointer;"><option value="">📋 Plantillas</option></select>
          <button onclick="facSaveTemplate()" class="fac-toolbar-btn">💾 Guardar</button>
          <button onclick="facOpenCSV()" class="fac-toolbar-btn">📥 CSV</button>
          <button onclick="facOpenSkybot()" class="fac-toolbar-btn" style="background:linear-gradient(135deg,rgba(139,92,246,0.15),rgba(111,207,245,0.15));border-color:rgba(139,92,246,0.3);color:#a78bfa;">✨ SkyBot</button>
          <button onclick="document.querySelector('.fac-preview-col').classList.toggle('fac-preview-hidden');this.textContent=document.querySelector('.fac-preview-col').classList.contains('fac-preview-hidden')?'👁️ Mostrar preview':'👁️ Ocultar preview'" class="fac-preview-toggle fac-toolbar-btn">👁️ Ocultar preview</button>
        </div>
