        <div class="fac-cfdi-col" style="max-width:120px;"><div class="fac-cfdi-lbl">RFC</div><div class="fac-cfdi-val ${!rfc?'empty':''}">${rfc||'—'}</div></div>
      </div>
      <div class="fac-cfdi-row">
        <div class="fac-cfdi-col"><div class="fac-cfdi-lbl">Régimen fiscal</div><div class="fac-cfdi-val ${!regimen?'empty':''}">${regimen||'—'}</div></div>
        <div class="fac-cfdi-col" style="max-width:100px;"><div class="fac-cfdi-lbl">CP</div><div class="fac-cfdi-val ${!cp?'empty':''}">${cp||'—'}</div></div>
        <div class="fac-cfdi-col"><div class="fac-cfdi-lbl">Uso CFDI</div><div class="fac-cfdi-val">${uso}</div></div>
      </div>
      ${email?`<div class="fac-cfdi-row"><div class="fac-cfdi-col"><div class="fac-cfdi-lbl">Email</div><div class="fac-cfdi-val" style="font-size:9px;">${email}</div></div></div>`:''}
    </div>

    <table class="fac-cfdi-table">
      <thead><tr><th style="width:28px;">#</th><th>Concepto</th><th class="num" style="width:40px;">Cant</th><th class="num" style="width:70px;">P. Unit</th><th class="num" style="width:70px;">Importe</th></tr></thead>
      <tbody>
        ${items.length===0?`<tr><td colspan="5" style="text-align:center;color:#bbb;font-style:italic;padding:20px;">(agrega conceptos abajo)</td></tr>`:items.map((i,idx)=>`<tr><td>${idx+1}</td><td>${i.desc||'<span style="color:#bbb;">Concepto sin descripción</span>'}</td><td class="num">${i.qty}</td><td class="num">${mx(i.price)}</td><td class="num">${mx(i.subtotal)}</td></tr>`).join('')}
      </tbody>
    </table>

    <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:start;">
      <div class="fac-cfdi-box" style="margin:0;">
        <div class="fac-cfdi-box-title">Pago</div>
        <div style="font-size:9px;color:#333;"><b>${metodo}</b> · ${metodo==='PUE'?'Pago en una exhibición':'Pago diferido'}</div>
        <div style="font-size:9px;color:#555;">Forma: ${forma} - ${formasMap[forma]||forma}</div>
        <div style="font-size:9px;color:#555;">Moneda: ${moneda}</div>
      </div>
      <div class="fac-cfdi-totals">
        <div class="fac-cfdi-total-row"><span style="color:#666;min-width:80px;">Subtotal</span><span style="min-width:80px;text-align:right;">${mx(subtotal)}</span></div>
        <div class="fac-cfdi-total-row"><span style="color:#666;min-width:80px;">IVA 16%</span><span style="min-width:80px;text-align:right;">${mx(iva)}</span></div>
        <div class="fac-cfdi-total-row grand"><span style="min-width:80px;">TOTAL</span><span style="min-width:80px;text-align:right;">${mx(total)} ${moneda}</span></div>
      </div>
    </div>

    <div class="fac-cfdi-footer">
      <div class="fac-cfdi-seal">✓ Listo para timbrar ante SAT</div>
      <div style="margin-top:6px;">Este documento es una vista previa. Al timbrar se genera UUID oficial y sellos digitales del SAT.</div>
    </div>
  `;
}

// ═══════ CALENDARIO FISCAL ═══════
let facCalDate=new Date();
function facGetCalEvents(year,month){
  // Eventos demo + derivados de facturas reales
  const events=[];
  // SAT deadline día 17 (declaración mensual)
  events.push({date:new Date(year,month,17),type:'sat',color:'#ef4444',title:'Declaración mensual SAT',desc:'IVA mensual + ingresos/egresos',time:'Antes 23:59'});
  // DIOT día 31 (último día del mes siguiente)
  const lastDay=new Date(year,month+1,0).getDate();
  events.push({date:new Date(year,month,Math.min(lastDay,31)),type:'sat',color:'#ef4444',title:'DIOT',desc:'Declaración informativa de operaciones con terceros',time:'Último día'});
  // Facturas PPD esperadas de cobro
  const ppdUnpaid=demoInvoices.filter(i=>i.status==='active');
  ppdUnpaid.forEach((inv,idx)=>{
    const d=new Date(inv.date);d.setDate(d.getDate()+30);
    if(d.getMonth()===month&&d.getFullYear()===year){
      events.push({date:new Date(d),type:'cobro',color:'#f97316',title:`Cobro esperado ${inv.folio}`,desc:`${inv.client} · $${inv.total.toLocaleString()}`,time:'Vence'});
    }
  });
  // Facturas timbradas este mes
  demoInvoices.forEach(inv=>{
    const d=new Date(inv.date);
    if(d.getMonth()===month&&d.getFullYear()===year&&inv.status!=='cancelled'){
      events.push({date:d,type:'timbrada',color:'#22c55e',title:inv.folio,desc:`${inv.client} · $${inv.total.toLocaleString()}`,time:'Timbrada'});
    }
  });
  // PPD vencimiento complemento de pago (a 30 días)
  events.push({date:new Date(year,month,10),type:'ppd',color:'#8b5cf6',title:'Complemento de pago',desc:'Fecha límite para PPD pendientes',time:'Día 10'});
  return events;
}
function facCalNav(delta){
  if(delta===0){ facCalDate=new Date(); } else { facCalDate.setMonth(facCalDate.getMonth()+delta); }
  renderFacCalendar();
}
function renderFacCalendar(){
  const monthNames=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const weekdays=['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
  const year=facCalDate.getFullYear(), month=facCalDate.getMonth();
  document.getElementById('fac-cal-title').textContent=`${monthNames[month]} ${year}`;
  // Weekdays header
  document.getElementById('fac-cal-weekdays').innerHTML=weekdays.map(d=>`<div class="fac-cal-weekday">${d}</div>`).join('');
  // Events
  const events=facGetCalEvents(year,month);
  const eventsByDay={};
  events.forEach(e=>{const key=e.date.getDate();if(!eventsByDay[key])eventsByDay[key]=[];eventsByDay[key].push(e);});
  // Calendar grid — start on Monday
  const firstDay=new Date(year,month,1).getDay(); // 0=Sun
  const offset=firstDay===0?6:firstDay-1;
  const daysInMonth=new Date(year,month+1,0).getDate();
  const today=new Date();
  const isCurrentMonth=today.getFullYear()===year&&today.getMonth()===month;
  let html='';
  for(let i=0;i<offset;i++) html+='<div class="fac-cal-day empty"></div>';
  for(let d=1;d<=daysInMonth;d++){
    const evts=eventsByDay[d]||[];
    const isToday=isCurrentMonth&&today.getDate()===d;
    const pills=evts.slice(0,2).map(e=>`<span class="fac-cal-evt-pill" style="background:${e.color}22;color:${e.color};border:1px solid ${e.color}44;">${e.title.substring(0,18)}</span>`).join('');
    const extra=evts.length>2?`<span class="fac-cal-evt-pill" style="background:rgba(255,255,255,0.05);color:var(--text-muted);">+${evts.length-2}</span>`:'';
    html+=`<div class="fac-cal-day${isToday?' today':''}" onclick="facShowDayEvents(${d})">
      <span class="fac-cal-day-num">${d}</span>
      <div class="fac-cal-day-events">${pills}${extra}</div>
    </div>`;
  }
  document.getElementById('fac-cal-grid').innerHTML=html;
  // Upcoming events sidebar
  const now=new Date();
  const upcoming=events.filter(e=>e.date>=new Date(now.getFullYear(),now.getMonth(),now.getDate())).sort((a,b)=>a.date-b.date).slice(0,10);
  document.getElementById('fac-cal-events').innerHTML=upcoming.length===0
    ?'<p style="color:var(--text-faint);font-size:11px;text-align:center;padding:20px;">Sin eventos próximos este mes.</p>'
    :upcoming.map(e=>{
      const daysLeft=Math.ceil((e.date-now)/(1000*60*60*24));
      const when=daysLeft===0?'Hoy':daysLeft===1?'Mañana':`En ${daysLeft} días`;
      return `<div class="fac-cal-event-item" style="--evt-color:${e.color};">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
          <p style="font-size:12px;font-weight:800;color:var(--text-primary);line-height:1.2;">${e.title}</p>
          <span style="font-size:9px;font-weight:700;padding:2px 6px;border-radius:5px;background:${e.color}22;color:${e.color};white-space:nowrap;">${when}</span>
        </div>
        <p style="font-size:10px;color:var(--text-muted);margin-top:3px;">${e.desc}</p>
        <p style="font-size:9px;color:var(--text-faint);margin-top:4px;">📅 ${e.date.toLocaleDateString('es-MX',{weekday:'long',day:'numeric',month:'short'})} · ${e.time}</p>
      </div>`;
    }).join('');
}
function facShowDayEvents(day){
  const events=facGetCalEvents(facCalDate.getFullYear(),facCalDate.getMonth()).filter(e=>e.date.getDate()===day);
  if(events.length===0)return;
  showToast(`${events.length} evento${events.length>1?'s':''} el día ${day}`);
}

// ═══════ INIT ═══════
document.addEventListener('DOMContentLoaded',()=>{
  ['invoices','create','credits','clients','calendar','analytics'].forEach(t=>{if(localStorage.getItem('fac_help_'+t+'_dismissed')){const el=document.getElementById('fac-help-'+t);if(el)el.style.display='none';}});
  renderFacRecs();renderFacStats();renderInvoices();renderConcepts();renderCredits();renderFiscalClients();renderFacAnalytics();renderFacAutopilot();
  renderFacHealthScore();renderFacInsights();renderCfdiPreview();
});
</script>
