let facSkybotHistory=[];
function facOpenSkybot(){
  facSkybotHistory=[];
  facSkybotRender('root');
  facOpenModal('skybot');
}
function facSkybotReset(){facSkybotHistory=[];facSkybotRender('root');}
function facSkybotRender(key){
  const body=document.getElementById('fac-skybot-body');
  const node=SKYBOT_TREE[key];
  if(!node)return;
  const botMsg=document.createElement('div');botMsg.className='fac-sb-msg bot';botMsg.innerHTML=node.q;
  body.appendChild(botMsg);
  // Options
  const opts=document.createElement('div');opts.style.cssText='display:flex;flex-direction:column;gap:6px;align-self:flex-start;max-width:95%;';
  node.options.forEach(opt=>{
    const b=document.createElement('button');b.className='fac-sb-option';b.textContent=opt.txt;
    b.onclick=()=>{
      const userMsg=document.createElement('div');userMsg.className='fac-sb-msg user';userMsg.textContent=opt.txt;body.appendChild(userMsg);
      opts.remove();
      if(opt.answer){
        const ans=document.createElement('div');ans.className='fac-sb-msg bot';ans.innerHTML=opt.answer;body.appendChild(ans);
        // Follow-up
        const followUp=document.createElement('div');followUp.style.cssText='display:flex;flex-direction:column;gap:6px;align-self:flex-start;';
        const back=document.createElement('button');back.className='fac-sb-option';back.textContent='↺ Otra pregunta';back.onclick=()=>{followUp.remove();facSkybotRender('root');};
        followUp.appendChild(back);body.appendChild(followUp);
      } else if(opt.next){
        facSkybotRender(opt.next);
      }
      setTimeout(()=>{body.scrollTop=body.scrollHeight;},50);
    };
    opts.appendChild(b);
  });
  body.appendChild(opts);
  setTimeout(()=>{body.scrollTop=body.scrollHeight;},50);
}

