function facDismissHelp(t){document.getElementById('fac-help-'+t).style.display='none';localStorage.setItem('fac_help_'+t+'_dismissed','1');}
function facToggleSection(id){const el=document.getElementById(id);el.style.display=el.style.display==='none'?'block':'none';}
function showToast(msg){const ex=document.getElementById('fac-toast');if(ex)ex.remove();const t=document.createElement('div');t.id='fac-toast';t.textContent=msg;Object.assign(t.style,{position:'fixed',bottom:'24px',right:'24px',background:'#22c55e',color:'#fff',padding:'12px 24px',borderRadius:'10px',fontSize:'13px',fontWeight:'700',zIndex:'9999',boxShadow:'0 4px 20px rgba(0,0,0,0.3)'});document.body.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity 0.3s';setTimeout(()=>t.remove(),300);},3000);}
