// ═══════ RFC VALIDATOR ═══════
function facValidateRFC(){
  const rfc=document.getElementById('fac-c-rfc').value.trim().toUpperCase();
  const status=document.getElementById('fac-rfc-status');
  status.style.display='block';
  if(!rfc){status.textContent='Ingresa un RFC';status.style.color='#ef4444';return;}
  // Basic RFC validation
  const isPersonaFisica=/^[A-ZÑ&]{4}\d{6}[A-Z0-9]{3}$/.test(rfc);
  const isPersonaMoral=/^[A-ZÑ&]{3}\d{6}[A-Z0-9]{3}$/.test(rfc);
  const isGeneric=rfc==='XAXX010101000'||rfc==='XEXX010101000';
  if(isGeneric){status.innerHTML='✓ RFC genérico válido (público en general o extranjero)';status.style.color='#22c55e';}
  else if(isPersonaFisica){status.innerHTML='✓ RFC válido — Persona Física (13 caracteres)';status.style.color='#22c55e';}
  else if(isPersonaMoral){status.innerHTML='✓ RFC válido — Persona Moral (12 caracteres)';status.style.color='#22c55e';}
  else{
    status.innerHTML='⚠ El RFC no parece válido. Verifica que tenga 12 (moral) o 13 (física) caracteres.';status.style.color='#ef4444';
  }
}

