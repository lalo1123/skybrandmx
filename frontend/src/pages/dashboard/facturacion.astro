function facCreateInvoice(action){
  // Remove previous errors
  document.getElementById('fac-error-box')?.remove();

  const name=document.getElementById('fac-c-name').value.trim();
  const rfc=document.getElementById('fac-c-rfc').value.trim().toUpperCase();
  const sub=facConcepts.reduce((s,c)=>s+(c.price*c.qty),0);
  const iva=Math.round(sub*0.16*100)/100;

  // Preview mode
  if(action==='preview'){
    const regName=document.getElementById('fac-c-regimen').selectedOptions[0]?.text||'';
    const usoName=document.getElementById('fac-c-uso').selectedOptions[0]?.text||'';
    alert(`Vista previa CFDI 4.0:\n\nCliente: ${name}\nRFC: ${rfc}\nRégimen: ${regName}\nUso CFDI: ${usoName}\n\nConceptos:\n${facConcepts.filter(c=>c.desc).map((c,i)=>`  ${i+1}. ${c.desc} x${c.qty} = $${(c.price*c.qty).toLocaleString()}`).join('\n')}\n\nSubtotal: $${sub.toLocaleString()}\nIVA (16%): $${iva.toLocaleString()}\nTotal: $${(sub+iva).toLocaleString()} MXN`);
    return;
  }

  // Validate (except drafts which can be incomplete)
  if(action!=='draft'){
    const errors=facValidateBeforeCreate();
    if(errors.length){facShowErrors(errors);return;}
  } else {
    if(!name){alert('Al menos ingresa el nombre del cliente para guardar borrador');return;}
  }

  // Show loading state on button
  const stampBtn=document.querySelector('[onclick*="facCreateInvoice(\'stamp\')"]');
  const origText=stampBtn?.innerHTML;
  if(stampBtn&&action==='stamp'){
    stampBtn.innerHTML='<span style="display:flex;align-items:center;justify-content:center;gap:6px;"><svg style="width:16px;height:16px;animation:spin 1s linear infinite;" viewBox="0 0 24 24" fill="none"><circle style="opacity:0.25;" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path style="opacity:0.75;" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Timbrando ante el SAT...</span>';
    stampBtn.disabled=true;
    stampBtn.style.opacity='0.7';
  }

  const folio='A-'+String(demoInvoices.length+1).padStart(3,'0');
  const newInvoice={id:Date.now(),folio,client:name,rfc,subtotal:sub,iva,total:sub+iva,status:action==='draft'?'draft':'stamping',payment:document.getElementById('fac-forma').selectedOptions[0]?.text?.split(' - ')[1]||'Transferencia',date:new Date().toISOString().split('T')[0],uso:document.getElementById('fac-c-uso').value,email:document.getElementById('fac-c-email').value,errorMsg:null};
  demoInvoices.unshift(newInvoice);

  if(action==='draft'){
    switchFacTab('invoices');renderInvoices();renderFacStats();
    showToast('Borrador guardado. Podrás timbrarlo después.');
    return;
  }

  // Simulate stamping (with delay for realism)
  switchFacTab('invoices');renderInvoices();

  setTimeout(()=>{
    // Simulate: 80% success, 20% error (for demo)
    const success=Math.random()>0.2;
    if(success){
      newInvoice.status='stamped';
      newInvoice.errorMsg=null;
      showToast(`✅ Factura ${folio} timbrada exitosamente ante el SAT`);
    } else {
      newInvoice.status='error';
      newInvoice.errorMsg='Error: El RFC del receptor no se encontró en la lista del SAT (EFOS). Verifica que el RFC sea correcto.';
      showToast('❌ Error al timbrar. Revisa los detalles en la tabla.');
    }
    renderInvoices();renderFacStats();renderFacRecs();

    // Restore button
    if(stampBtn){stampBtn.innerHTML=origText;stampBtn.disabled=false;stampBtn.style.opacity='1';}
  },2000);
}

function facRetryStamp(id){
  const inv=demoInvoices.find(x=>x.id===id);
  if(!inv)return;
  inv.status='stamping';inv.errorMsg=null;
  renderInvoices();
  showToast('Reintentando timbrado...');
  setTimeout(()=>{
    inv.status='stamped';inv.errorMsg=null;
    renderInvoices();renderFacStats();
    showToast(`✅ Factura ${inv.folio} timbrada exitosamente`);
  },1500);
}

