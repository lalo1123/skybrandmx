}
function facRenderTemplatesDropdown(){
  const sel=document.getElementById('fac-tpl-select');
  if(!sel)return;
  const list=facGetTemplates();
  sel.innerHTML='<option value="">📋 Plantillas ('+list.length+')</option>'+list.map(t=>`<option value="${t.id}">${t.name}</option>`).join('')+(list.length>0?'<option value="__clear">🗑️ Borrar todas</option>':'');
}
function facUseTemplate(id){
  if(id==='__clear'){if(confirm('¿Borrar todas las plantillas?')){facSaveTemplatesList([]);facRenderTemplatesDropdown();showToast('Plantillas eliminadas');}return;}
  const tpl=facGetTemplates().find(t=>String(t.id)===String(id));
  if(!tpl)return;
  document.getElementById('fac-c-name').value=tpl.client.name||'';
  document.getElementById('fac-c-rfc').value=tpl.client.rfc||'';
  document.getElementById('fac-c-regimen').value=tpl.client.regimen||'';
  document.getElementById('fac-c-cp').value=tpl.client.cp||'';
  document.getElementById('fac-c-email').value=tpl.client.email||'';
  document.getElementById('fac-c-uso').value=tpl.client.uso||'G03';
  document.getElementById('fac-metodo').value=tpl.payment.metodo||'PUE';
  document.getElementById('fac-forma').value=tpl.payment.forma||'03';
  document.getElementById('fac-moneda').value=tpl.payment.moneda||'MXN';
  facConcepts=tpl.concepts&&tpl.concepts.length>0?[...tpl.concepts]:[{desc:'',qty:1,price:0,key:''}];
  renderConcepts();
  if(tpl.retenciones){
    const isrChk=document.getElementById('fac-ret-isr-chk');if(isrChk)isrChk.checked=!!tpl.retenciones.isr;
    const ivaChk=document.getElementById('fac-ret-iva-chk');if(ivaChk)ivaChk.checked=!!tpl.retenciones.iva;
    if(tpl.retenciones.isrRate)document.getElementById('fac-ret-isr-rate').value=tpl.retenciones.isrRate;
    if(tpl.retenciones.ivaRate)document.getElementById('fac-ret-iva-rate').value=tpl.retenciones.ivaRate;
  }
  facUpdateTotals();renderCfdiPreview();
  showToast('Plantilla "'+tpl.name+'" aplicada');
}

// ═══════ CSV IMPORT ═══════
function facOpenCSV(){document.getElementById('fac-csv-text').value='';facOpenModal('csv');}
function facImportCSV(){
  const text=document.getElementById('fac-csv-text').value.trim();
  if(!text){alert('Pega el CSV primero');return;}
  const lines=text.split(/\r?\n/).filter(l=>l.trim());
  const hasHeader=/descripcion|descripción|concepto/i.test(lines[0]);
  const rows=hasHeader?lines.slice(1):lines;
  const imported=rows.map(line=>{
    const parts=line.split(/[,;\t]/).map(p=>p.trim().replace(/^"|"$/g,''));
    return { desc:parts[0]||'', qty:parseFloat(parts[1])||1, price:parseFloat(parts[2])||0, key:parts[3]||'01010101' };
  }).filter(r=>r.desc);
  if(imported.length===0){alert('No se pudieron leer conceptos. Verifica el formato.');return;}
  facConcepts=imported;
  renderConcepts();facUpdateTotals();renderCfdiPreview();
  facCloseModal('csv');
  showToast(imported.length+' conceptos importados ✓');
}

