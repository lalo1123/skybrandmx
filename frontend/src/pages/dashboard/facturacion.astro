  if(search)data=data.filter(i=>i.folio.toLowerCase().includes(search)||i.client.toLowerCase().includes(search)||i.rfc.toLowerCase().includes(search));
  if(sf)data=data.filter(i=>i.status===sf);
  if(!data.length){tbody.innerHTML='<tr><td colspan="9" style="padding:40px;text-align:center;color:var(--text-faint);">No se encontraron facturas</td></tr>';return;}
