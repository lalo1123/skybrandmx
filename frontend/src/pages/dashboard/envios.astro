function envOpenCSV(){document.getElementById('env-csv-text').value='';envOpenModal('csv-new');}
function envImportCSV(){
  const text=document.getElementById('env-csv-text').value.trim();
  if(!text){alert('Pega el CSV');return;}
  const lines=text.split(/\r?\n/).filter(l=>l.trim());
  const hasHeader=/cliente|nombre|destino/i.test(lines[0]);
  const rows=hasHeader?lines.slice(1):lines;
  let created=0;
  rows.forEach(line=>{
    const [client,cp,peso,valor,content,phone]=line.split(/[,;\t]/).map(p=>p.trim().replace(/^"|"$/g,''));
    if(!client)return;
    const carriers=['DHL','FedEx','Estafeta','Redpack','99Min'];
    const carrier=carriers[Math.floor(Math.random()*carriers.length)];
    const cost=Math.floor(150+Math.random()*200);
    demoShipments.unshift({id:Date.now()+created,tracking:carrier.substring(0,3).toUpperCase()+Date.now().toString().slice(-9)+created,carrier,client,origin:'CDMX (03100)',dest:(cp||'')+'',status:'created',cost,weight:(peso||'1')+'kg',date:new Date().toISOString().substring(0,10),events:[{date:new Date().toISOString().substring(0,16).replace('T',' '),text:'Guía creada (import CSV)',loc:'CDMX'}]});
    created++;
  });
  if(created===0){alert('No se pudo leer ninguna línea');return;}
  envCloseModal('csv-new');
  renderShipments();renderEnvStats();renderEnvInsights();
  showToast(`${created} guía${created>1?'s':''} generada${created>1?'s':''} ✓`);
}

