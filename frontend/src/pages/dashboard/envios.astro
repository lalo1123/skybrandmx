// ═══════ REGLAS AUTO ═══════
function envGetRules(){try{return JSON.parse(localStorage.getItem('env_rules'))||[];}catch(e){return [];}}
function envSaveRules(r){localStorage.setItem('env_rules',JSON.stringify(r));}
function envAddRule(){document.getElementById('env-rule-name').value='';document.getElementById('env-rule-val').value='';envOpenModal('rule');}
function envSaveRule(){
  const name=document.getElementById('env-rule-name').value.trim();
  if(!name){alert('Escribe un nombre');return;}
  const rule={id:Date.now(),name,active:true,
    field:document.getElementById('env-rule-field').value,
    op:document.getElementById('env-rule-op').value,
    val:document.getElementById('env-rule-val').value,
    action:document.getElementById('env-rule-action').value,
    actionVal:document.getElementById('env-rule-action-val').value};
  const list=envGetRules();list.unshift(rule);envSaveRules(list);
  envCloseModal('rule');renderEnvRules();showToast('Regla creada ✓');
}
function envToggleRule(id){const list=envGetRules();const r=list.find(x=>x.id===id);if(r){r.active=!r.active;envSaveRules(list);renderEnvRules();}}
function envDeleteRule(id){if(!confirm('¿Borrar esta regla?'))return;envSaveRules(envGetRules().filter(r=>r.id!==id));renderEnvRules();showToast('Regla eliminada');}
function renderEnvRules(){
  const el=document.getElementById('env-rules-list');if(!el)return;
  const rules=envGetRules();
  if(rules.length===0){el.innerHTML='<div class="stat-card" style="padding:40px;text-align:center;"><p style="font-size:14px;color:var(--text-muted);">No hay reglas configuradas</p><p style="font-size:12px;color:var(--text-faint);margin-top:4px;">Crea reglas para automatizar la selección de paquetería, seguros, etc.</p></div>';return;}
  el.innerHTML=rules.map(r=>`<div class="env-rule-card">
    <div style="font-size:24px;">⚡</div>
    <div style="flex:1;min-width:0;">
      <p style="font-size:13px;font-weight:900;color:var(--text-primary);">${r.name}</p>
      <p style="font-size:11px;color:var(--text-muted);margin-top:3px;">SI <b style="color:var(--accent);">${r.field} ${r.op} ${r.val}</b> → ENTONCES <b style="color:#22c55e;">${r.action} = ${r.actionVal}</b></p>
    </div>
    <span class="env-rule-badge" style="background:${r.active?'rgba(34,197,94,0.15)':'rgba(100,116,139,0.15)'};color:${r.active?'#22c55e':'#64748b'};">${r.active?'Activa':'Inactiva'}</span>
    <button onclick="envToggleRule(${r.id})" class="env-tbl-btn fac-tbl-btn" style="padding:5px 9px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;cursor:pointer;">${r.active?'Pausar':'Activar'}</button>
    <button onclick="envDeleteRule(${r.id})" style="padding:5px 9px;border-radius:6px;border:1px solid var(--border);background:transparent;color:#ef4444;font-size:11px;cursor:pointer;">✕</button>
  </div>`).join('');
}

// ═══════ HEATMAP MÉXICO ═══════
let envHeatMap=null;
function renderEnvHeatmap(){
  if(typeof L==='undefined'){setTimeout(renderEnvHeatmap,500);return;}
  const container=document.getElementById('env-heatmap');
  if(!container)return;
  if(envHeatMap){envHeatMap.remove();envHeatMap=null;}
  const map=L.map('env-heatmap',{zoomControl:true}).setView([23.5,-102],5);
  envHeatMap=map;
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'© OpenStreetMap © CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);
  // Count shipments by city
  const cityCounts={};
  demoShipments.forEach(s=>{
    const city=(s.dest||'').replace(/\(\d+\)/,'').trim();
    const coords=envGeocode(city);
    if(!coords)return;
    const key=city+'|'+coords.join(',');
    if(!cityCounts[key])cityCounts[key]={count:0,coords,city,totalCost:0};
    cityCounts[key].count++;
    cityCounts[key].totalCost+=s.cost;
  });
  const entries=Object.values(cityCounts);
  const maxCount=Math.max(...entries.map(e=>e.count),1);
  entries.forEach(e=>{
    const radius=15+((e.count/maxCount)*30);
    const color=e.count>=3?'#ef4444':e.count>=2?'#FF6B00':'#6fcff5';
    L.circleMarker(e.coords,{radius,color:'#fff',weight:2,fillColor:color,fillOpacity:0.65}).addTo(map).bindPopup(`<b>${e.city}</b><br>${e.count} envío${e.count>1?'s':''}<br>Costo prom: $${Math.round(e.totalCost/e.count)}`);
  });
  // Ranking
  const rank=entries.sort((a,b)=>b.count-a.count);
  const rankEl=document.getElementById('env-heat-ranking');
  if(rankEl){
    rankEl.innerHTML=rank.map((e,i)=>`<div class="env-heat-rank-item">
      <div class="env-heat-rank-num">${i+1}</div>
      <div style="flex:1;min-width:0;">
        <p style="font-size:12px;font-weight:800;color:var(--text-primary);">${e.city}</p>
        <p style="font-size:10px;color:var(--text-muted);margin-top:2px;">${e.count} envío${e.count>1?'s':''} · $${Math.round(e.totalCost/e.count)} prom</p>
      </div>
    </div>`).join('');
  }
}

