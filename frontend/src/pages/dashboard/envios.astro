  /* ════ Insight cards ════ */
  .env-insight { padding:14px;border-radius:12px;border:1px solid var(--border);background:var(--card-bg,var(--input-bg));position:relative;overflow:hidden;animation:envFadeIn 0.4s ease-out; }
  .env-insight::before { content:'';position:absolute;top:0;left:0;bottom:0;width:3px;background:var(--ins-color,#8b5cf6); }
  .env-insight-icon { width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;margin-bottom:8px; }
