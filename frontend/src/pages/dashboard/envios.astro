---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Envíos">
  <!-- Smart Recommendations -->
  <div id="env-smart-recs" style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px;"></div>

  <!-- Stats bar -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:20px;">
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Guías generadas</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-total" class="env-stat-val">--</p><span id="env-trend-total" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">En tránsito</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-transit" class="env-stat-val" style="color:#8b5cf6;">--</p></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Entregadas</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-delivered" class="env-stat-val" style="color:#22c55e;">--</p><span id="env-trend-delivered" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Costo promedio <span class="env-tip" data-tip="Lo que te cuesta en promedio enviar un paquete">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-avg" class="env-stat-val" style="color:var(--accent);">--</p><span id="env-trend-avg" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Gasto total mes</p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-spent" class="env-stat-val" style="color:#f97316;">--</p><span id="env-trend-spent" class="env-trend"></span></div>
    </div>
    <div class="stat-card animate-in" style="padding:18px 20px;">
      <p class="env-stat-label">Devoluciones <span class="env-tip" data-tip="Paquetes que fueron devueltos por el cliente o por la paquetería">?</span></p>
      <div style="display:flex;align-items:baseline;gap:8px;"><p id="env-stat-returns" class="env-stat-val" style="color:#ef4444;">--</p></div>
    </div>
  </div>

  <!-- ══════════ Health Score + Insights IA ══════════ -->
  <div style="display:grid;grid-template-columns:320px 1fr;gap:16px;margin-bottom:20px;" class="env-hero-grid">
    <!-- Health Score Envíos -->
    <div class="stat-card" style="padding:20px;position:relative;overflow:hidden;">
      <div style="position:absolute;top:0;right:0;width:120px;height:120px;background:radial-gradient(circle at top right,rgba(34,197,94,0.18),transparent 70%);pointer-events:none;"></div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;position:relative;">
        <p class="env-stat-label" style="margin:0;">Health score logístico <span class="env-tip" data-tip="Qué tan bien va tu operación de envíos: entregas a tiempo, devoluciones, costo vs industria, guías recolectadas.">?</span></p>
        <span id="env-score-delta" style="font-size:11px;font-weight:800;"></span>
      </div>
      <div style="display:flex;align-items:center;gap:18px;position:relative;">
        <div style="position:relative;width:120px;height:120px;flex-shrink:0;">
          <svg width="120" height="120" viewBox="0 0 120 120" style="transform:rotate(-90deg);">
            <circle cx="60" cy="60" r="50" fill="none" stroke="var(--border)" stroke-width="10"/>
            <circle id="env-score-circle" cx="60" cy="60" r="50" fill="none" stroke="url(#envScoreGrad)" stroke-width="10" stroke-linecap="round" stroke-dasharray="314" stroke-dashoffset="314" style="transition:stroke-dashoffset 1.4s cubic-bezier(0.4,0,0.2,1);filter:drop-shadow(0 0 6px rgba(34,197,94,0.5));"/>
            <defs>
              <linearGradient id="envScoreGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#ef4444"/>
                <stop offset="50%" stop-color="#f97316"/>
                <stop offset="100%" stop-color="#22c55e"/>
              </linearGradient>
            </defs>
          </svg>
          <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
            <p id="env-score-val" style="font-size:32px;font-weight:900;color:var(--text-primary);line-height:1;">--</p>
            <p style="font-size:9px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">de 100</p>
          </div>
        </div>
        <div style="flex:1;min-width:0;">
          <p id="env-score-label" style="font-size:16px;font-weight:900;color:#22c55e;line-height:1.1;">--</p>
          <p id="env-score-desc" style="font-size:11px;color:var(--text-muted);margin-top:4px;line-height:1.4;"></p>
          <div id="env-score-bars" style="display:flex;flex-direction:column;gap:4px;margin-top:10px;"></div>
        </div>
      </div>
    </div>

    <!-- Insights IA de envíos -->
    <div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#8b5cf6,#6fcff5);display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 10px rgba(139,92,246,0.4);">✨</div>
          <p style="font-size:12px;font-weight:800;color:var(--text-primary);text-transform:uppercase;letter-spacing:0.5px;">Insights de SkyBot</p>
          <span style="font-size:9px;font-weight:700;padding:2px 8px;border-radius:10px;background:rgba(139,92,246,0.15);color:#a78bfa;text-transform:uppercase;letter-spacing:0.5px;">IA</span>
        </div>
        <button onclick="renderEnvInsights(true)" style="padding:4px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:10px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:4px;" onmouseover="this.style.color='var(--accent)';this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-muted)';this.style.borderColor='var(--border)'">
          <svg style="width:10px;height:10px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Actualizar
        </button>
      </div>
      <div id="env-insights" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:10px;"></div>
    </div>
  </div>

  <!-- Tabs -->
  <div style="display:flex;gap:4px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:0;overflow-x:auto;">
    <button id="env-tab-shipments" class="env-tab active" onclick="switchEnvTab('shipments')">Mis guías</button>
    <button id="env-tab-quote" class="env-tab" onclick="switchEnvTab('quote')">Cotizar envío</button>
    <button id="env-tab-tracking" class="env-tab" onclick="switchEnvTab('tracking')">Rastrear paquete</button>
    <button id="env-tab-returns" class="env-tab" onclick="switchEnvTab('returns')">Devoluciones</button>
    <button id="env-tab-compare" class="env-tab" onclick="switchEnvTab('compare')">Comparador</button>
    <button id="env-tab-rules" class="env-tab" onclick="switchEnvTab('rules')">Reglas auto</button>
    <button id="env-tab-heatmap" class="env-tab" onclick="switchEnvTab('heatmap')">Mapa México</button>
    <button id="env-tab-analytics" class="env-tab" onclick="switchEnvTab('analytics')">Analítica</button>
  </div>

  <!-- Toolbar -->
  <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px;">
    <button onclick="envOpenEmisor()" class="env-toolbar-btn">🏢 Mi empresa</button>
    <select id="env-tpl-select" onchange="if(this.value)envUseTemplate(this.value);this.value='';" class="env-toolbar-btn" style="cursor:pointer;"><option value="">📋 Plantillas</option></select>
    <button onclick="envSaveTemplate()" class="env-toolbar-btn">💾 Guardar plantilla</button>
    <button onclick="envOpenCSV()" class="env-toolbar-btn">📥 CSV masivo</button>
    <button onclick="envOpenFragile()" class="env-toolbar-btn">🏷️ Etiqueta frágil</button>
    <button onclick="envOpenPickup()" class="env-toolbar-btn">📅 Pickup</button>
    <button onclick="envOpenSkybot()" class="env-toolbar-btn" style="background:linear-gradient(135deg,rgba(139,92,246,0.15),rgba(111,207,245,0.15));border-color:rgba(139,92,246,0.3);color:#a78bfa;">✨ SkyBot</button>
  </div>

  <!-- ══════════ Tab: Mis guías ══════════ -->
  <div id="env-panel-shipments">
    <div id="env-help-shipments" class="env-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Aquí ves todas las guías de envío que has generado. Puedes rastrear cada paquete en tiempo real.</p>
      <button onclick="envDismissHelp('shipments')" class="env-help-close">&times;</button>
    </div>
    <div id="env-toolbar" class="stat-card animate-in" style="padding:16px 20px;margin-bottom:20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;position:relative;">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--text-faint);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input id="env-search" type="text" placeholder="Buscar por guía, cliente, destino..." oninput="envFilter()" class="env-input" style="padding-left:38px;"/>
      </div>
      <select id="env-filter-carrier" onchange="envFilter()" class="env-input" style="width:auto;cursor:pointer;">
        <option value="">Todas las paqueterías</option>
        <option value="DHL">DHL</option>
        <option value="Estafeta">Estafeta</option>
        <option value="FedEx">FedEx</option>
        <option value="Redpack">Redpack</option>
        <option value="99Min">99 Minutos</option>
      </select>
      <select id="env-filter-status" onchange="envFilter()" class="env-input" style="width:auto;cursor:pointer;">
        <option value="">Todos los estados</option>
        <option value="created">Creada</option>
        <option value="picked_up">Recolectada</option>
        <option value="in_transit">En tránsito</option>
        <option value="out_for_delivery">En reparto</option>
        <option value="delivered">Entregada</option>
        <option value="returned">Devuelta</option>
      </select>
      <button onclick="switchEnvTab('quote')" class="env-btn-primary" style="display:flex;align-items:center;gap:6px;padding:10px 20px;">
        <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nueva guía
      </button>
    </div>
    <div class="stat-card animate-in" style="padding:0;overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead><tr style="border-bottom:1px solid var(--border);">
            <th class="env-th"># Guía</th><th class="env-th">Paquetería</th><th class="env-th">Cliente / Destino</th>
            <th class="env-th">Estado</th><th class="env-th" style="text-align:right;">Costo</th><th class="env-th">Peso</th>
            <th class="env-th">Fecha</th><th class="env-th" style="text-align:center;">Acciones</th>
          </tr></thead>
          <tbody id="env-shipments-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ Tab: Cotizar envío ══════════ -->
  <div id="env-panel-quote" style="display:none;">
    <div id="env-help-quote" class="env-help-banner">
      <svg style="width:16px;height:16px;color:var(--accent);flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p style="flex:1;font-size:12px;color:var(--text-secondary);">Compara precios de diferentes paqueterías y genera la guía con la mejor opción. Nosotros negociamos las tarifas por ti.</p>
      <button onclick="envDismissHelp('quote')" class="env-help-close">&times;</button>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <!-- Left: Form -->
      <div class="stat-card animate-in" style="padding:24px;">
        <h3 style="font-size:16px;font-weight:900;color:var(--text-primary);margin-bottom:16px;">Datos del envío</h3>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <!-- ORIGEN -->
          <div style="border:1px solid var(--border);border-radius:12px;padding:14px;">
            <p style="font-size:11px;font-weight:800;color:var(--accent);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">📍 Origen (de dónde sale)</p>
            <div style="display:grid;grid-template-columns:120px 1fr;gap:10px;margin-bottom:10px;">
              <div><label class="env-label">CP</label><input id="env-q-origin" type="text" value="03100" maxlength="5" class="env-input" placeholder="03100" oninput="envLookupCP('origin',this.value)"/></div>
              <div><label class="env-label">Colonia <span id="env-origin-loading" style="display:none;font-size:10px;color:var(--accent);">cargando...</span></label><select id="env-q-origin-col" class="env-input" style="cursor:pointer;"><option value="">Escribe el CP para cargar</option></select></div>
            </div>
            <div id="env-origin-address" style="display:none;display:flex;flex-direction:column;gap:10px;">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div><label class="env-label">Ciudad</label><input id="env-q-origin-city" type="text" class="env-input" readonly style="opacity:0.7;"/></div>
                <div><label class="env-label">Estado</label><input id="env-q-origin-state" type="text" class="env-input" readonly style="opacity:0.7;"/></div>
              </div>
              <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:10px;">
                <div><label class="env-label">Calle</label><input id="env-q-origin-street" type="text" class="env-input" placeholder="Av. Insurgentes Sur"/></div>
                <div><label class="env-label">No. Ext.</label><input id="env-q-origin-ext" type="text" class="env-input" placeholder="1234"/></div>
                <div><label class="env-label">No. Int.</label><input id="env-q-origin-int" type="text" class="env-input" placeholder="(opcional)"/></div>
              </div>
              <div><label class="env-label">Nombre de quien envía</label><input id="env-q-origin-name" type="text" class="env-input" placeholder="Ej: SkyBrandMX" value="SkyBrandMX"/></div>
              <div><label class="env-label">Teléfono</label><input id="env-q-origin-phone" type="tel" class="env-input" placeholder="55 1234 5678"/></div>
            </div>
          </div>
          <!-- DESTINO -->
          <div style="border:1px solid var(--border);border-radius:12px;padding:14px;">
            <p style="font-size:11px;font-weight:800;color:#f97316;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">📦 Destino (a dónde llega)</p>
            <div style="display:grid;grid-template-columns:120px 1fr;gap:10px;margin-bottom:10px;">
              <div><label class="env-label">CP</label><input id="env-q-dest" type="text" maxlength="5" class="env-input" placeholder="44100" oninput="envLookupCP('dest',this.value)"/></div>
              <div><label class="env-label">Colonia <span id="env-dest-loading" style="display:none;font-size:10px;color:var(--accent);">cargando...</span></label><select id="env-q-dest-col" class="env-input" style="cursor:pointer;"><option value="">Escribe el CP para cargar</option></select></div>
            </div>
            <div id="env-dest-address" style="display:none;display:flex;flex-direction:column;gap:10px;">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div><label class="env-label">Ciudad</label><input id="env-q-dest-city" type="text" class="env-input" readonly style="opacity:0.7;"/></div>
                <div><label class="env-label">Estado</label><input id="env-q-dest-state" type="text" class="env-input" readonly style="opacity:0.7;"/></div>
              </div>
              <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:10px;">
                <div><label class="env-label">Calle</label><input id="env-q-dest-street" type="text" class="env-input" placeholder="Calle Morelos"/></div>
                <div><label class="env-label">No. Ext.</label><input id="env-q-dest-ext" type="text" class="env-input" placeholder="567"/></div>
                <div><label class="env-label">No. Int.</label><input id="env-q-dest-int" type="text" class="env-input" placeholder="(opcional)"/></div>
              </div>
              <div><label class="env-label">Nombre de quien recibe</label><input id="env-q-dest-name" type="text" class="env-input" placeholder="Ej: Carlos Hernández"/></div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div><label class="env-label">Teléfono</label><input id="env-q-dest-phone" type="tel" class="env-input" placeholder="33 1234 5678"/></div>
                <div><label class="env-label">Email (para enviar rastreo)</label><input id="env-q-dest-email" type="email" class="env-input" placeholder="cliente@email.com"/></div>
              </div>
            </div>
          </div>
          <!-- Caja 3D + inputs de dimensiones -->
          <div style="display:grid;grid-template-columns:1fr 160px;gap:14px;align-items:stretch;">
            <div style="display:flex;flex-direction:column;gap:10px;">
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
                <div><label class="env-label">Largo (cm)</label><input id="env-q-largo" type="number" value="30" class="env-input" oninput="envCalcVolumetric();envRenderBox3D()"/></div>
                <div><label class="env-label">Ancho (cm)</label><input id="env-q-ancho" type="number" value="20" class="env-input" oninput="envCalcVolumetric();envRenderBox3D()"/></div>
                <div><label class="env-label">Alto (cm)</label><input id="env-q-alto" type="number" value="15" class="env-input" oninput="envCalcVolumetric();envRenderBox3D()"/></div>
              </div>
              <div><label class="env-label">Peso real (kg)</label><input id="env-q-peso" type="number" value="2" class="env-input" oninput="envCalcVolumetric()"/></div>
            </div>
            <div class="env-box3d-wrap" style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px;border:1px solid var(--border);border-radius:12px;background:linear-gradient(135deg,rgba(111,207,245,0.04),rgba(139,92,246,0.04));">
              <div id="env-box3d" class="env-box3d">
                <div class="env-box-face env-box-front"></div>
                <div class="env-box-face env-box-back"></div>
                <div class="env-box-face env-box-right"></div>
                <div class="env-box-face env-box-left"></div>
                <div class="env-box-face env-box-top"></div>
                <div class="env-box-face env-box-bottom"></div>
              </div>
              <p id="env-box3d-size" style="font-size:9px;color:var(--text-faint);margin-top:6px;font-family:monospace;">30×20×15</p>
            </div>
          </div>
          <!-- Peso volumétrico auto-calc -->
          <div id="env-vol-weight" style="padding:10px 14px;border-radius:10px;background:rgba(234,179,8,0.06);border:1px solid rgba(234,179,8,0.15);display:flex;align-items:center;gap:10px;">
            <svg style="width:16px;height:16px;color:#eab308;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <div style="flex:1;">
              <p style="font-size:11px;color:#eab308;font-weight:700;">Peso volumétrico: <span id="env-vol-val">1.8 kg</span></p>
              <p style="font-size:10px;color:var(--text-faint);" id="env-vol-msg">Las paqueterías cobran el peso mayor entre real y volumétrico</p>
            </div>
          </div>
          <div><label class="env-label">Contenido</label><input id="env-q-contenido" type="text" class="env-input" placeholder="Ej: Ropa, accesorios" oninput="envCheckRestrictions(this.value)"/></div>
          <div id="env-restrictions-alert" style="display:none;padding:10px 14px;border-radius:10px;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25);"></div>
          <!-- Valor declarado + seguro -->
          <div style="display:grid;grid-template-columns:1fr auto;gap:12px;align-items:end;">
            <div><label class="env-label">Valor del paquete (MXN) <span class="env-tip" data-tip="Para calcular el costo del seguro de envío">?</span></label><input id="env-q-valor" type="number" value="0" class="env-input" placeholder="0"/></div>
            <label style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);cursor:pointer;white-space:nowrap;">
              <input type="checkbox" id="env-q-seguro" style="accent-color:var(--accent);"/>
              <span style="font-size:12px;font-weight:600;color:var(--text-secondary);">Agregar seguro</span>
            </label>
          </div>
          <!-- Guías masivas link -->
          <div style="display:flex;justify-content:flex-end;">
            <button onclick="openEnvMassModal()" style="padding:6px 14px;border-radius:8px;border:1px dashed var(--border);background:transparent;color:var(--text-faint);font-size:11px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:4px;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-faint)'">📄 Generar guías masivas (CSV)</button>
          </div>
