let envPickupSelected=null;
function envOpenPickup(){
  // Render next 14 days
  const days=document.getElementById('env-pickup-days');
  const wd=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  const now=new Date();
  let html='';
  for(let i=0;i<14;i++){
    const d=new Date(now);d.setDate(d.getDate()+i);
    const isWeekend=d.getDay()===0;
    html+=`<div class="env-pickup-day${isWeekend?' disabled':''}" ${isWeekend?'':`onclick="envPickupPick(${d.getTime()})"`} data-time="${d.getTime()}">
      <span class="env-pickup-day-wd">${wd[d.getDay()]}</span>
      <span class="env-pickup-day-num">${d.getDate()}</span>
    </div>`;
  }
  days.innerHTML=html;
  // Time pickers
  const from=document.getElementById('env-pickup-from');
  const to=document.getElementById('env-pickup-to');
  from.innerHTML='';to.innerHTML='';
  for(let h=9;h<=17;h++){from.innerHTML+=`<option value="${h}">${h}:00</option>`;to.innerHTML+=`<option value="${h+1}" ${h+1===18?'selected':''}>${h+1}:00</option>`;}
  envPickupSelected=null;
  envOpenModal('pickup');
}
function envPickupPick(time){
  envPickupSelected=time;
  document.querySelectorAll('#env-pickup-days .env-pickup-day').forEach(d=>d.classList.toggle('selected',parseInt(d.dataset.time)===time));
}
function envConfirmPickup(){
  if(!envPickupSelected){alert('Selecciona un día');return;}
  const d=new Date(envPickupSelected);
  const from=document.getElementById('env-pickup-from').value;
  const to=document.getElementById('env-pickup-to').value;
  const qty=document.getElementById('env-pickup-qty').value;
  const carrier=document.getElementById('env-pickup-carrier').value;
  envCloseModal('pickup');
  showToast(`Recolección ${carrier} el ${d.toLocaleDateString('es-MX',{day:'numeric',month:'short'})} ${from}:00-${to}:00 · ${qty} paquete${qty>1?'s':''}`);
}

