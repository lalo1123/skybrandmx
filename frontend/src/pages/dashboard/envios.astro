  @keyframes envFadeIn { from{opacity:0;transform:translateY(4px);} to{opacity:1;transform:translateY(0);} }

  /* ════ 3D Box ════ */
  .env-box3d-wrap { perspective:600px; }
  .env-box3d { position:relative;width:80px;height:60px;transform-style:preserve-3d;transform:rotateX(-20deg) rotateY(-30deg);animation:envBoxRot 12s linear infinite; }
  @keyframes envBoxRot { 0%{transform:rotateX(-20deg) rotateY(-30deg);} 100%{transform:rotateX(-20deg) rotateY(330deg);} }
  .env-box-face { position:absolute;border:1.5px solid #FF6B00;background:rgba(255,107,0,0.08); }
  .env-box-front { width:var(--bx-w,80px);height:var(--bx-h,60px);transform:translateZ(calc(var(--bx-d,40px)/2)); }
  .env-box-back { width:var(--bx-w,80px);height:var(--bx-h,60px);transform:translateZ(calc(-1*var(--bx-d,40px)/2)) rotateY(180deg); }
  .env-box-right { width:var(--bx-d,40px);height:var(--bx-h,60px);left:var(--bx-w,80px);transform-origin:left;transform:rotateY(90deg) translateZ(calc(-1*var(--bx-d,40px)/2)); }
