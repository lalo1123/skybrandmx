  {keyword:['animal','mascota','perro','gato'],msg:'⚠️ Animales vivos: requieren permiso SAGARPA y transporte especial. Pocas paqueterías lo aceptan.'},
];
function envCheckRestrictions(text){
  const alert=document.getElementById('env-restrictions-alert');
  if(!alert)return;
  const t=(text||'').toLowerCase();
  if(!t.trim()){alert.style.display='none';return;}
  const matches=ENV_RESTRICTIONS.filter(r=>r.keyword.some(k=>t.includes(k)));
  if(matches.length===0){alert.style.display='none';return;}
  alert.style.display='block';
  alert.innerHTML=matches.map(m=>`<p style="margin:2px 0;">${m.msg}</p>`).join('');
}

