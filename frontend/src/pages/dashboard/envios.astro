// ═══════ ANALYTICS ═══════
function renderEnvAnalytics(){
  // By carrier
  const carriers=[{n:'DHL',c:2,cost:355,color:'#FFCC00'},{n:'FedEx',c:2,cost:380,color:'#4D148C'},{n:'Estafeta',c:2,cost:280,color:'#ED1C24'},{n:'Redpack',c:1,cost:265,color:'#E31937'},{n:'99 Min',c:1,cost:89,color:'#00C853'}];
  const maxCost=Math.max(...carriers.map(c=>c.cost));
  document.getElementById('env-chart-carriers').innerHTML=carriers.map(c=>`<div style="display:flex;align-items:center;gap:12px;padding:8px 0;"><div style="display:flex;align-items:center;gap:6px;min-width:80px;"><div style="width:10px;height:10px;border-radius:3px;background:${c.color};"></div><span style="font-size:12px;font-weight:600;color:var(--text-primary);">${c.n}</span></div><div style="flex:1;height:8px;border-radius:4px;background:var(--input-bg);overflow:hidden;"><div style="height:100%;width:${(c.cost/maxCost)*100}%;background:${c.color};border-radius:4px;"></div></div><span style="font-size:12px;font-weight:800;color:var(--text-primary);min-width:60px;text-align:right;">$${c.cost}</span></div>`).join('');

  // Delivery times
  const times=[{n:'99 Min',days:0.2,color:'#00C853'},{n:'DHL',days:1.8,color:'#FFCC00'},{n:'FedEx',days:2.5,color:'#4D148C'},{n:'Estafeta',days:3.5,color:'#ED1C24'},{n:'Redpack',days:4.0,color:'#E31937'}];
  document.getElementById('env-chart-times').innerHTML=times.map(t=>`<div style="display:flex;align-items:center;gap:12px;padding:8px 0;"><span style="min-width:70px;font-size:12px;font-weight:600;color:var(--text-primary);">${t.n}</span><div style="flex:1;height:8px;border-radius:4px;background:var(--input-bg);overflow:hidden;"><div style="height:100%;width:${(t.days/4)*100}%;background:${t.color};border-radius:4px;"></div></div><span style="font-size:12px;font-weight:800;color:var(--text-primary);min-width:50px;text-align:right;">${t.days}d</span></div>`).join('');

  // Destinations
  const dests=[{city:'Guadalajara',pct:22},{city:'Monterrey',pct:28},{city:'CDMX',pct:18},{city:'Puebla',pct:12},{city:'Cancún',pct:10},{city:'Querétaro',pct:10}];
