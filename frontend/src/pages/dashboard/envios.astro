let envSkybotHistory=[];
function envOpenSkybot(){envSkybotHistory=[];envSkybotRender('root');envOpenModal('skybot');}
function envSkybotReset(){envSkybotHistory=[];document.getElementById('env-skybot-body').innerHTML='';envSkybotRender('root');}
function envSkybotRender(key){
  const body=document.getElementById('env-skybot-body');
  const node=ENV_SKYBOT_TREE[key];
  if(!node)return;
  const botMsg=document.createElement('div');botMsg.className='env-sb-msg bot';botMsg.innerHTML=node.q;body.appendChild(botMsg);
  const opts=document.createElement('div');opts.style.cssText='display:flex;flex-direction:column;gap:6px;align-self:flex-start;max-width:95%;';
  node.options.forEach(opt=>{
    const b=document.createElement('button');b.className='env-sb-option';b.textContent=opt.txt;
    b.onclick=()=>{
      const userMsg=document.createElement('div');userMsg.className='env-sb-msg user';userMsg.textContent=opt.txt;body.appendChild(userMsg);
      opts.remove();
      if(opt.answer){
        const ans=document.createElement('div');ans.className='env-sb-msg bot';ans.innerHTML=opt.answer;body.appendChild(ans);
        const followUp=document.createElement('div');followUp.style.cssText='display:flex;flex-direction:column;gap:6px;align-self:flex-start;';
        const back=document.createElement('button');back.className='env-sb-option';back.textContent='↺ Otra pregunta';back.onclick=()=>{followUp.remove();envSkybotRender('root');};
        followUp.appendChild(back);body.appendChild(followUp);
      } else if(opt.next){envSkybotRender(opt.next);}
      setTimeout(()=>{body.scrollTop=body.scrollHeight;},50);
    };
    opts.appendChild(b);
  });
  body.appendChild(opts);
  setTimeout(()=>{body.scrollTop=body.scrollHeight;},50);
}

