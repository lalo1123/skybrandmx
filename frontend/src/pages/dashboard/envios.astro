<!-- Estilos globales del mapa (Astro no aplica scope a HTML inyectado dinámicamente) -->
<style is:global>
  .env-track-grid { display:grid;grid-template-columns:1.3fr 1fr;gap:20px;align-items:start; }
  @media(max-width:900px){ .env-track-grid{ grid-template-columns:1fr; } }
  .env-map-container { position:relative;border-radius:14px;overflow:hidden;border:1px solid rgba(255,255,255,0.08);background:#0a1520;height:520px; }
  #env-map { width:100%;height:520px;background:#0a1520; }
  .env-map-overlay { position:absolute;top:16px;left:16px;right:16px;z-index:500;pointer-events:none; }
  .env-map-card { background:rgba(15,27,39,0.92);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border:1px solid rgba(111,207,245,0.2);border-radius:12px;padding:14px 18px;pointer-events:auto; }
  .env-progress-bar { height:6px;background:rgba(255,255,255,0.08);border-radius:10px;overflow:hidden;margin-top:10px; }
  .env-progress-fill { height:100%;background:linear-gradient(90deg,#6fcff5 0%,#FF6B00 50%,#22c55e 100%);border-radius:10px;transition:width 1s cubic-bezier(0.4,0,0.2,1);box-shadow:0 0 12px rgba(255,107,0,0.6); }
  .env-route-stats { display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:10px; }
  .env-route-stat { text-align:center; }
  .env-route-stat-val { font-size:15px;font-weight:900;color:#fff;line-height:1.1; }
  .env-route-stat-lbl { font-size:9px;font-weight:700;color:rgba(255,255,255,0.55);text-transform:uppercase;letter-spacing:0.5px;margin-top:2px; }
  .env-map-marker { background:transparent;border:none; }
  .env-pulse-marker { width:28px;height:28px;position:relative;display:flex;align-items:center;justify-content:center; }
  .env-pulse-marker::before { content:'';position:absolute;inset:0;border-radius:50%;background:#FF6B00;opacity:0.35;animation:envMapPulse 1.8s ease-out infinite; }
  .env-pulse-marker::after { content:'';position:absolute;inset:0;border-radius:50%;background:#FF6B00;opacity:0.15;animation:envMapPulse 1.8s ease-out infinite 0.6s; }
  .env-pulse-marker-dot { width:14px;height:14px;border-radius:50%;background:#FF6B00;border:3px solid #fff;box-shadow:0 0 12px rgba(255,107,0,0.9);z-index:2;position:relative; }
  .env-pin-marker { width:22px;height:22px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid #fff;box-shadow:0 2px 8px rgba(0,0,0,0.4); }
  .env-pin-marker.origin { background:#6fcff5; }
  .env-pin-marker.dest { background:#22c55e; }
  .env-pin-marker.dest-pending { background:transparent;border:3px dashed #6fcff5; }
  .leaflet-popup-content-wrapper { background:#0f1b27;color:#fff;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,0.5); }
  .leaflet-popup-tip { background:#0f1b27; }
  .leaflet-popup-content { margin:10px 14px;font-size:12px;font-weight:600; }
  .leaflet-container a.leaflet-popup-close-button { color:rgba(255,255,255,0.5); }
  .leaflet-control-attribution { background:rgba(10,21,32,0.8) !important;color:rgba(255,255,255,0.4) !important;font-size:9px !important; }
  .leaflet-control-attribution a { color:rgba(111,207,245,0.6) !important; }
