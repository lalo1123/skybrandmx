              <p style="font-size:11px;color:var(--text-muted);">${q.type} · ${q.days}</p>
            </div>
          </div>
          <div style="text-align:right;">
            <p style="font-size:20px;font-weight:900;color:var(--text-primary);">$${q.price}</p>
            <p style="font-size:10px;color:var(--text-faint);">MXN + IVA</p>
          </div>
        </div>
      </div>`).join('')}
      <p style="font-size:11px;color:var(--text-faint);text-align:center;margin-top:4px;">Precios incluyen recolección. Haz clic para generar la guía.</p>
    </div>`;
  },800);
}

function envSelectQuote(carrier,price){
  demoShipments.unshift({id:Date.now(),tracking:carrier.substring(0,3).toUpperCase()+Date.now().toString().slice(-9),carrier:carrier.replace('99 Minutos','99Min'),client:'(Nueva guía)',origin:document.getElementById('env-q-origin').value,dest:document.getElementById('env-q-dest').value,status:'created',cost:price,weight:document.getElementById('env-q-peso').value+'kg',date:'2026-04-01',events:[{date:'2026-04-01',text:'Guía creada',loc:'CDMX'}]});
  renderShipments();renderEnvStats();switchEnvTab('shipments');
  showToast(`Guía generada con ${carrier} por $${price} MXN`);
}

// ═══════ TRACKING ═══════
// Geocoding: coordenadas aproximadas de ciudades mexicanas (lat, lng)
const MX_CITIES = {
  'cdmx':[19.4326,-99.1332],'ciudad de mexico':[19.4326,-99.1332],'mexico':[19.4326,-99.1332],
  'guadalajara':[20.6597,-103.3496],'gdl':[20.6597,-103.3496],
  'monterrey':[25.6866,-100.3161],'mty':[25.6866,-100.3161],
  'puebla':[19.0414,-98.2063],
  'queretaro':[20.5888,-100.3899],'querétaro':[20.5888,-100.3899],
  'cancun':[21.1619,-86.8515],'cancún':[21.1619,-86.8515],
  'merida':[20.9674,-89.5926],'mérida':[20.9674,-89.5926],
  'tijuana':[32.5149,-117.0382],
  'leon':[21.1250,-101.6860],'león':[21.1250,-101.6860],
  'toluca':[19.2826,-99.6557],
  'acapulco':[16.8531,-99.8237],
  'veracruz':[19.1738,-96.1342],
  'aguascalientes':[21.8853,-102.2916],
  'san luis potosi':[22.1565,-100.9855],'san luis potosí':[22.1565,-100.9855],'slp':[22.1565,-100.9855],
  'morelia':[19.7069,-101.1950],
  'chihuahua':[28.6329,-106.0691],
  'hermosillo':[29.0729,-110.9559],
  'culiacan':[24.8091,-107.3940],'culiacán':[24.8091,-107.3940],
  'saltillo':[25.4232,-101.0053],
  'zapopan':[20.7167,-103.3917],
  'mixcoac':[19.3767,-99.1869],
  'roma norte':[19.4184,-99.1674],
};
function envGeocode(place){
  if(!place)return null;
  const p=place.toLowerCase().replace(/[()]/g,'').trim();
  // Intenta match exacto, luego parcial
  if(MX_CITIES[p])return MX_CITIES[p];
  for(const key in MX_CITIES){ if(p.includes(key))return MX_CITIES[key]; }
  // Extrae posible nombre de ciudad (primera palabra antes de número/CP)
  const parts=p.split(/[\s,]+/);
  for(const part of parts){ if(MX_CITIES[part])return MX_CITIES[part]; }
  return null;
}
// Distancia Haversine en km
function envDistance(a,b){
  if(!a||!b)return 0;
  const R=6371, toRad=d=>d*Math.PI/180;
  const dLat=toRad(b[0]-a[0]), dLng=toRad(b[1]-a[1]);
  const x=Math.sin(dLat/2)**2+Math.cos(toRad(a[0]))*Math.cos(toRad(b[0]))*Math.sin(dLng/2)**2;
  return Math.round(R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x)));
}
let envMapInstance=null;
function envTrack(){
  const num=document.getElementById('env-track-num').value.trim();
  if(!num){alert('Ingresa un número de guía');return;}
  const el=document.getElementById('env-track-result');
  el.innerHTML=`<div style="padding:60px 16px;text-align:center;"><div style="display:inline-block;width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:envSpin 0.8s linear infinite;"></div><p style="color:var(--text-muted);font-size:13px;margin-top:14px;">Rastreando paquete en tiempo real...</p></div>`;

  setTimeout(()=>{
    const found=demoShipments.find(s=>s.tracking.toLowerCase()===num.toLowerCase());
    if(!found){
      el.innerHTML=`<div style="padding:40px;text-align:center;border-radius:14px;border:1px solid var(--border);background:var(--card-bg);">
        <div style="font-size:48px;margin-bottom:12px;">📭</div>
        <p style="font-size:15px;font-weight:800;color:var(--text-primary);">No se encontró la guía <span style="color:var(--accent);">${num}</span></p>
        <p style="font-size:12px;color:var(--text-faint);margin-top:6px;">Verifica el número e intenta de nuevo. Si el envío se creó hace menos de 30 min, espera unos momentos.</p>
      </div>`;
      return;
    }

    const st=statusMap[found.status];
    const originCoords=envGeocode(found.origin);
    const destCoords=envGeocode(found.dest);
    // Ubicación actual = coords del evento más reciente
    const lastEvent=found.events[0];
    const currentCoords=envGeocode(lastEvent.loc) || originCoords;
    const totalKm=envDistance(originCoords,destCoords);
    const coveredKm=found.status==='delivered'?totalKm:envDistance(originCoords,currentCoords);
    const progress=totalKm>0?Math.min(100,Math.round((coveredKm/totalKm)*100)):0;
    const isDelivered=found.status==='delivered';
    const isReturned=found.status==='returned';
    // ETA calculation (demo)
    let eta='—';
    if(isDelivered && found.deliveredDate){ eta='Entregado '+found.deliveredDate; }
    else if(isReturned){ eta='Devuelto al remitente'; }
    else {
      const daysLeft=Math.max(1,Math.ceil((100-progress)/30));
      eta=daysLeft===1?'Hoy mismo':`En ${daysLeft} días`;
    }

    el.innerHTML=`
      <!-- Status banner -->
      <div class="stat-card animate-in" style="padding:18px 22px;margin-bottom:18px;display:flex;align-items:center;gap:16px;border-left:4px solid ${st.c};">
        <div style="width:54px;height:54px;border-radius:12px;background:${st.b};display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;">${isDelivered?'✅':isReturned?'↩️':found.status==='out_for_delivery'?'🛵':'📦'}</div>
        <div style="flex:1;min-width:0;">
          <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Estado actual</p>
          <p style="font-size:19px;font-weight:900;color:${st.c};line-height:1.2;">${st.l}</p>
          <p style="font-size:12px;color:var(--text-muted);margin-top:2px;">${found.carrier} · <span style="font-family:monospace;color:var(--accent);">${found.tracking}</span> · ${found.client}</p>
        </div>
        <div style="text-align:right;flex-shrink:0;">
          <p style="font-size:11px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">ETA</p>
          <p style="font-size:15px;font-weight:900;color:var(--text-primary);line-height:1.2;">${eta}</p>
        </div>
      </div>

      <!-- Two-column: map + timeline -->
      <div class="env-track-grid">
        <!-- MAPA -->
        <div>
          <div class="env-map-container">
            <div id="env-map"></div>
            <div class="env-map-overlay">
              <div class="env-map-card">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                  <div style="flex:1;min-width:0;">
                    <p style="font-size:10px;font-weight:700;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.5px;">Ubicación actual</p>
                    <p style="font-size:14px;font-weight:900;color:#fff;line-height:1.2;">📍 ${lastEvent.loc}</p>
                    <p style="font-size:10px;color:rgba(255,255,255,0.5);margin-top:2px;">${lastEvent.date}</p>
                  </div>
                  <div style="text-align:right;flex-shrink:0;">
                    <p style="font-size:22px;font-weight:900;color:#FF6B00;line-height:1;">${progress}%</p>
                    <p style="font-size:9px;font-weight:700;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.5px;">completado</p>
                  </div>
                </div>
                <div class="env-progress-bar"><div class="env-progress-fill" style="width:${progress}%;"></div></div>
                <div class="env-route-stats">
                  <div class="env-route-stat"><p class="env-route-stat-val">${coveredKm} km</p><p class="env-route-stat-lbl">Recorridos</p></div>
                  <div class="env-route-stat"><p class="env-route-stat-val">${totalKm-coveredKm} km</p><p class="env-route-stat-lbl">Restantes</p></div>
                  <div class="env-route-stat"><p class="env-route-stat-val">${totalKm} km</p><p class="env-route-stat-lbl">Total ruta</p></div>
                </div>
              </div>
            </div>
          </div>
          <!-- Actions -->
          <div style="display:flex;gap:10px;margin-top:12px;">
            <button onclick="navigator.clipboard.writeText('${found.tracking}');showToast('Guía copiada')" style="flex:1;padding:10px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-primary);font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">📋 Copiar guía</button>
            <button onclick="window.open('/track?guide=${found.tracking}','_blank')" style="flex:1;padding:10px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text-primary);font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">🔗 Link público</button>
            <button onclick="showToast('Notificación enviada a '+'${found.client}')" style="flex:1;padding:10px;border-radius:10px;border:1px solid var(--accent);background:var(--accent);color:#0a1520;font-size:12px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">📲 Notificar cliente</button>
          </div>
        </div>

        <!-- TIMELINE -->
        <div class="stat-card" style="padding:22px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
            <h3 style="font-size:14px;font-weight:900;color:var(--text-primary);">Historial de eventos</h3>
            <span style="font-size:11px;color:var(--text-faint);">${found.events.length} eventos</span>
          </div>
          <div style="position:relative;">
            ${found.events.map((e,i)=>{
              const isLatest=i===0;
              const dotColor=isLatest?st.c:'var(--border)';
              const dotSize=isLatest?'14px':'10px';
              return `<div style="display:flex;gap:14px;position:relative;padding-bottom:${i<found.events.length-1?'18px':'0'};">
                ${i<found.events.length-1?`<div style="position:absolute;left:6px;top:16px;bottom:0;width:2px;background:linear-gradient(180deg,${dotColor},var(--border));"></div>`:''}
                <div style="width:${dotSize};height:${dotSize};border-radius:50%;background:${dotColor};flex-shrink:0;margin-top:3px;${isLatest?`box-shadow:0 0 0 4px ${st.b};animation:envMapPulse 2s ease-out infinite;`:''}"></div>
                <div style="flex:1;min-width:0;">
                  <p style="font-size:13px;font-weight:${isLatest?'800':'600'};color:${isLatest?st.c:'var(--text-primary)'};line-height:1.3;">${e.text}</p>
                  <p style="font-size:11px;color:var(--text-muted);margin-top:3px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                    <span style="display:inline-flex;align-items:center;gap:3px;">🕐 ${e.date}</span>
                    <span style="display:inline-flex;align-items:center;gap:3px;">📍 ${e.loc}</span>
                  </p>
                </div>
              </div>`;
            }).join('')}
          </div>
          <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div><p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Origen</p><p style="font-size:12px;font-weight:700;color:var(--text-primary);margin-top:2px;">${found.origin}</p></div>
            <div><p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Destino</p><p style="font-size:12px;font-weight:700;color:var(--text-primary);margin-top:2px;">${found.dest}</p></div>
            <div><p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Peso</p><p style="font-size:12px;font-weight:700;color:var(--text-primary);margin-top:2px;">${found.weight}</p></div>
            <div><p style="font-size:10px;font-weight:700;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.5px;">Costo</p><p style="font-size:12px;font-weight:700;color:var(--text-primary);margin-top:2px;">$${found.cost} MXN</p></div>
          </div>
        </div>
      </div>`;

    // ═══ Renderizar mapa con Leaflet ═══
    if(typeof L==='undefined'){ console.warn('Leaflet no cargó');return; }
    setTimeout(()=>{
      if(envMapInstance){ envMapInstance.remove(); envMapInstance=null; }
      if(!originCoords||!destCoords){
        document.getElementById('env-map').innerHTML='<div style="display:flex;align-items:center;justify-content:center;height:100%;color:rgba(255,255,255,0.4);font-size:12px;text-align:center;padding:20px;">Ubicación geográfica no disponible para esta ruta</div>';
        return;
      }
      const map=L.map('env-map',{zoomControl:true,attributionControl:true}).setView([23.5,-102],5);
      envMapInstance=map;
      // Dark tiles (CARTO Dark Matter)
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{
        attribution:'© OpenStreetMap © CARTO',
        maxZoom:19,
        subdomains:'abcd'
      }).addTo(map);

      // Markers
      const originIcon=L.divIcon({className:'env-map-marker',html:'<div class="env-pin-marker origin"></div>',iconSize:[22,22],iconAnchor:[11,22]});
      const destIcon=L.divIcon({className:'env-map-marker',html:`<div class="env-pin-marker ${isDelivered?'dest':'dest-pending'}"></div>`,iconSize:[22,22],iconAnchor:[11,22]});
      const currentIcon=L.divIcon({className:'env-map-marker',html:'<div class="env-pulse-marker"><div class="env-pulse-marker-dot"></div></div>',iconSize:[28,28],iconAnchor:[14,14]});

      L.marker(originCoords,{icon:originIcon}).addTo(map).bindPopup(`<b>📤 Origen</b><br>${found.origin}`);
      L.marker(destCoords,{icon:destIcon}).addTo(map).bindPopup(`<b>🎯 Destino</b><br>${found.dest}`);
      if(!isDelivered && currentCoords && (currentCoords[0]!==originCoords[0]||currentCoords[1]!==originCoords[1]) && (currentCoords[0]!==destCoords[0]||currentCoords[1]!==destCoords[1])){
        L.marker(currentCoords,{icon:currentIcon,zIndexOffset:1000}).addTo(map).bindPopup(`<b>🚚 Paquete aquí ahora</b><br>${lastEvent.loc}<br><small style="opacity:0.6;">${lastEvent.date}</small>`).openPopup();
      } else if(isDelivered){
        L.marker(destCoords,{icon:currentIcon,zIndexOffset:1000}).addTo(map);
      }

      // Polyline: recorrido completado (sólido) + restante (punteado)
      if(!isDelivered && currentCoords){
        L.polyline([originCoords,currentCoords],{color:'#FF6B00',weight:4,opacity:0.85}).addTo(map);
        L.polyline([currentCoords,destCoords],{color:'#6fcff5',weight:3,opacity:0.5,dashArray:'8,8'}).addTo(map);
      } else {
        L.polyline([originCoords,destCoords],{color:isDelivered?'#22c55e':'#FF6B00',weight:4,opacity:0.85}).addTo(map);
      }

      // Fit bounds with padding for overlay card
      const bounds=L.latLngBounds([originCoords,destCoords,currentCoords].filter(Boolean));
      // Padding: más arriba para que el overlay no tape marcadores
      map.fitBounds(bounds,{paddingTopLeft:[40,200],paddingBottomRight:[40,50],maxZoom:8});
    },50);
  },600);
}

