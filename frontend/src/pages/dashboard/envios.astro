// ═══════ HEALTH SCORE ENVÍOS ═══════
function calcEnvHealthScore(){
  const total=demoShipments.length||1;
  const delivered=demoShipments.filter(s=>s.status==='delivered').length;
  const returned=demoShipments.filter(s=>s.status==='returned').length;
  const created=demoShipments.filter(s=>s.status==='created').length;
  const ontime=25*(delivered/total); // max 25
  const returnScore=Math.max(0,25-(returned/total*100)); // max 25
  const costs=demoShipments.map(s=>s.cost);
  const avg=costs.reduce((a,b)=>a+b,0)/costs.length;
  const costScore=avg<200?25:avg<300?18:avg<400?12:6;
  const pickupScore=created===0?25:created<=1?20:created<=3?12:5;
  const score=Math.min(100,Math.round(ontime+returnScore+costScore+pickupScore));
  return {score,parts:[
    {label:'Entregas a tiempo',val:Math.round(ontime),max:25,color:'#22c55e'},
    {label:'Tasa devolución',val:Math.round(returnScore),max:25,color:'#6fcff5'},
    {label:'Costo vs industria',val:costScore,max:25,color:'#8b5cf6'},
    {label:'Pickups pendientes',val:pickupScore,max:25,color:'#f97316'},
  ]};
}
function renderEnvHealthScore(){
  const {score,parts}=calcEnvHealthScore();
  const circle=document.getElementById('env-score-circle');
  const valEl=document.getElementById('env-score-val');
  const lblEl=document.getElementById('env-score-label');
  const descEl=document.getElementById('env-score-desc');
  const deltaEl=document.getElementById('env-score-delta');
  const barsEl=document.getElementById('env-score-bars');
  if(!circle||!valEl)return;
  const circumference=2*Math.PI*50;
  circle.setAttribute('stroke-dasharray',circumference);
  circle.setAttribute('stroke-dashoffset',circumference-(score/100)*circumference);
  let cur=0;const step=Math.max(1,Math.ceil(score/40));
  const anim=setInterval(()=>{cur+=step;if(cur>=score){cur=score;clearInterval(anim);}valEl.textContent=cur;},30);
  const labels=score>=85?{l:'Excelente 🚀',c:'#22c55e',d:'Tu operación logística está top. Pocos otros envían tan bien.'}:score>=70?{l:'Bien ✓',c:'#6fcff5',d:'Buen rendimiento. Revisa los puntos bajos para subir.'}:score>=50?{l:'Atención',c:'#f97316',d:'Hay oportunidades claras de mejora en tu operación.'}:{l:'Urgente ⚠️',c:'#ef4444',d:'Revisa urgente las guías pendientes y devoluciones.'};
  lblEl.textContent=labels.l;lblEl.style.color=labels.c;
  descEl.textContent=labels.d;
  deltaEl.innerHTML='<span style="color:#22c55e;">▲ +6</span>';
  barsEl.innerHTML=parts.map(p=>{const pct=Math.round((p.val/p.max)*100);return `<div class="env-score-bar"><span style="width:110px;">${p.label}</span><div class="env-score-bar-track"><div class="env-score-bar-fill" style="width:${pct}%;background:${p.color};"></div></div><span style="width:28px;text-align:right;color:${p.color};font-weight:800;">${p.val}</span></div>`;}).join('');
}

// ═══════ INSIGHTS IA ENVÍOS ═══════
function genEnvInsights(){
  const insights=[];
  const total=demoShipments.length;
  const delivered=demoShipments.filter(s=>s.status==='delivered');
  const returned=demoShipments.filter(s=>s.status==='returned');
  const created=demoShipments.filter(s=>s.status==='created');
  const transit=demoShipments.filter(s=>s.status==='in_transit');

  // Comparativa paqueterías
  const byCarrier={};
  demoShipments.forEach(s=>{if(!byCarrier[s.carrier])byCarrier[s.carrier]={count:0,total:0};byCarrier[s.carrier].count++;byCarrier[s.carrier].total+=s.cost;});
  const carriers=Object.entries(byCarrier).map(([c,v])=>({carrier:c,avg:v.total/v.count,count:v.count})).sort((a,b)=>a.avg-b.avg);
  if(carriers.length>=2){
    const cheap=carriers[0],expensive=carriers[carriers.length-1];
    const pct=Math.round(((expensive.avg-cheap.avg)/cheap.avg)*100);
    insights.push({icon:'💸',color:'#f97316',bg:'rgba(249,115,22,0.1)',title:`${expensive.carrier} cuesta ${pct}% más que ${cheap.carrier}`,desc:`Precio promedio: ${expensive.carrier} $${Math.round(expensive.avg)} vs ${cheap.carrier} $${Math.round(cheap.avg)}. Considera migrar rutas similares.`,action:'Ver comparador',fn:`switchEnvTab('compare')`});
  }

  // Guías sin recolectar
  if(created.length>0){
    insights.push({icon:'📦',color:'#ef4444',bg:'rgba(239,68,68,0.1)',title:`${created.length} guía${created.length>1?'s':''} sin recolectar`,desc:`Llevan días esperando al mensajero. Programa un pickup hoy para no retrasar entregas.`,action:'Programar pickup',fn:`envOpenPickup()`});
  }

  // Mejor destino
  const byState={};
  demoShipments.forEach(s=>{const city=(s.dest||'').split('(')[0].trim();byState[city]=(byState[city]||0)+1;});
  const top=Object.entries(byState).sort((a,b)=>b[1]-a[1])[0];
  if(top){
    insights.push({icon:'📍',color:'#22c55e',bg:'rgba(34,197,94,0.1)',title:`${top[0]} es tu mercado #1`,desc:`${top[1]} envío${top[1]>1?'s':''} este periodo. Considera negociar tarifa especial con paquetería frecuente.`,action:'Ver mapa',fn:`switchEnvTab('heatmap')`});
  }

  // Rate de devolución
  if(returned.length>=1){
    const pct=Math.round((returned.length/total)*100);
    insights.push({icon:'↩️',color:'#8b5cf6',bg:'rgba(139,92,246,0.1)',title:`Tasa de devolución: ${pct}%`,desc:`${returned.length} paquete${returned.length>1?'s':''} regresó. Revisa calidad de empaque, claridad en descripción o fraude.`,action:'Ver devoluciones',fn:`switchEnvTab('returns')`});
  }
  return insights.slice(0,4);
}
function renderEnvInsights(refresh){
  const el=document.getElementById('env-insights');
  if(!el)return;
  if(refresh){
    el.innerHTML='<div style="padding:20px;text-align:center;grid-column:1/-1;"><div style="display:inline-block;width:24px;height:24px;border:2px solid var(--border);border-top-color:#8b5cf6;border-radius:50%;animation:envSpin 0.7s linear infinite;"></div><p style="font-size:11px;color:var(--text-muted);margin-top:8px;">SkyBot analizando rutas...</p></div>';
    setTimeout(()=>renderEnvInsights(false),900);return;
  }
  const items=genEnvInsights();
  if(items.length===0){el.innerHTML='<div style="padding:20px;text-align:center;grid-column:1/-1;color:var(--text-muted);font-size:12px;">Todo bajo control ✨</div>';return;}
  el.innerHTML=items.map(ins=>`<div class="env-insight" style="--ins-color:${ins.color};">
    <div class="env-insight-icon" style="background:${ins.bg};">${ins.icon}</div>
    <p class="env-insight-title">${ins.title}</p>
    <p class="env-insight-desc">${ins.desc}</p>
    <button class="env-insight-action" onclick="${ins.fn}">${ins.action} →</button>
  </div>`).join('');
}

// ═══════ 3D BOX ═══════
function envRenderBox3D(){
  const box=document.getElementById('env-box3d');
  const sizeEl=document.getElementById('env-box3d-size');
  if(!box)return;
  const l=parseFloat(document.getElementById('env-q-largo')?.value)||30;
  const w=parseFloat(document.getElementById('env-q-ancho')?.value)||20;
  const h=parseFloat(document.getElementById('env-q-alto')?.value)||15;
  // Normalize to ~80px max
  const max=Math.max(l,w,h);
  const scale=80/max;
  const bw=Math.round(l*scale);
  const bh=Math.round(h*scale);
  const bd=Math.round(w*scale);
  box.style.setProperty('--bx-w',bw+'px');
  box.style.setProperty('--bx-h',bh+'px');
  box.style.setProperty('--bx-d',bd+'px');
  box.style.width=bw+'px';box.style.height=bh+'px';
  if(sizeEl)sizeEl.textContent=`${l}×${w}×${h} cm`;
}

