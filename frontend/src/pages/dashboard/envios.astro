// ═══════ SEPOMEX CP LOOKUP ═══════
var _cpTimers = {};
function envLookupCP(type, cp) {
  clearTimeout(_cpTimers[type]);
  if (!cp || cp.length !== 5) return;
  _cpTimers[type] = setTimeout(async function() {
    var loading = document.getElementById('env-' + type + '-loading');
    if (loading) loading.style.display = 'inline';

    try {
      var res = await fetch('/api/v1/shipping/zipcode/' + cp);
      var data = await res.json();

      if (data.found) {
        // Fill colony dropdown
        var colSel = document.getElementById('env-q-' + type + '-col');
        if (colSel) {
          colSel.innerHTML = '';
          if (data.colonies && data.colonies.length > 1) {
            colSel.innerHTML = '<option value="">Selecciona colonia...</option>';
          }
          (data.colonies || []).forEach(function(c) {
            var opt = document.createElement('option');
            opt.value = c; opt.textContent = c;
            colSel.appendChild(opt);
          });
          if (data.colonies && data.colonies.length === 1) colSel.value = data.colonies[0];
        }
        // Fill city/state
        var cityEl = document.getElementById('env-q-' + type + '-city');
        var stateEl = document.getElementById('env-q-' + type + '-state');
        if (cityEl) cityEl.value = data.city || data.municipality || '';
        if (stateEl) stateEl.value = data.state || '';

        // Show address fields
        var addrDiv = document.getElementById('env-' + type + '-address');
        if (addrDiv) addrDiv.style.display = 'flex';

        showToast('CP ' + cp + ': ' + (data.city || '') + ', ' + (data.state || ''));
      } else {
        showToast('CP ' + cp + ' no encontrado');
      }
    } catch(e) {
      // Fallback for common CPs
      var fallback = {
        '03100': { colonies: ['Del Valle Centro','Del Valle Norte','Del Valle Sur'], city: 'Ciudad de México', state: 'CDMX' },
        '06700': { colonies: ['Roma Norte','Roma Sur'], city: 'Ciudad de México', state: 'CDMX' },
        '44100': { colonies: ['Centro','Americana'], city: 'Guadalajara', state: 'Jalisco' },
        '64060': { colonies: ['Obispado'], city: 'Monterrey', state: 'Nuevo León' },
      };
      if (fallback[cp]) {
        var d = fallback[cp];
        var colSel = document.getElementById('env-q-' + type + '-col');
        if (colSel) { colSel.innerHTML = d.colonies.map(function(c){return '<option value="'+c+'">'+c+'</option>';}).join(''); }
        var cityEl = document.getElementById('env-q-' + type + '-city');
        var stateEl = document.getElementById('env-q-' + type + '-state');
        if (cityEl) cityEl.value = d.city;
        if (stateEl) stateEl.value = d.state;
        var addrDiv = document.getElementById('env-' + type + '-address');
        if (addrDiv) addrDiv.style.display = 'flex';
      }
    } finally {
      if (loading) loading.style.display = 'none';
    }
  }, 500);
}

