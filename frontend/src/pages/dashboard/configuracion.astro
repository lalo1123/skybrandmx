---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || '';
---

<DashboardLayout title="Configuración">
  <!-- Tabs lateral -->
  <div style="display:grid;grid-template-columns:220px 1fr;gap:20px;">
    <!-- Left: Menu -->
    <div>
      <div class="stat-card animate-in" style="padding:8px;">
        <button onclick="switchCfgTab('company')" id="cfg-nav-company" class="cfg-nav-item active">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          Mi empresa
        </button>
        <button onclick="switchCfgTab('account')" id="cfg-nav-account" class="cfg-nav-item">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          Mi cuenta
        </button>
        <button onclick="switchCfgTab('team')" id="cfg-nav-team" class="cfg-nav-item">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Equipo
        </button>
        <button onclick="switchCfgTab('integrations')" id="cfg-nav-integrations" class="cfg-nav-item">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          Integraciones
        </button>
        <button onclick="switchCfgTab('notifications')" id="cfg-nav-notifications" class="cfg-nav-item">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          Notificaciones
        </button>
        <button onclick="switchCfgTab('billing')" id="cfg-nav-billing" class="cfg-nav-item">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          Suscripción y pagos
        </button>
        <button onclick="switchCfgTab('appearance')" id="cfg-nav-appearance" class="cfg-nav-item">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          Apariencia
        </button>
        <button onclick="switchCfgTab('security')" id="cfg-nav-security" class="cfg-nav-item">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Seguridad
        </button>
        <div style="border-top:1px solid var(--border);margin:8px 0;"></div>
        <button onclick="switchCfgTab('danger')" id="cfg-nav-danger" class="cfg-nav-item" style="color:#ef4444;">
          <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          Zona de peligro
        </button>
      </div>
    </div>

    <!-- Right: Content -->
    <div>
      <!-- ══════════ Mi empresa ══════════ -->
      <div id="cfg-panel-company" class="cfg-panel">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Mi empresa</h3>
          <p class="cfg-section-desc">La información de tu negocio. Se usa en facturas, emails y tu panel.</p>
          <!-- Logo -->
          <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;padding:16px;border-radius:12px;background:var(--input-bg);">
            <div id="cfg-logo" style="width:72px;height:72px;border-radius:16px;background:linear-gradient(135deg,var(--accent-gradient-start),var(--accent-gradient-end));display:flex;align-items:center;justify-content:center;cursor:pointer;overflow:hidden;flex-shrink:0;" onclick="document.getElementById('cfg-logo-file').click()">
              <span id="cfg-logo-initial" style="font-size:28px;font-weight:900;color:#fff;">S</span>
              <input type="file" id="cfg-logo-file" accept="image/*" style="display:none;" onchange="cfgUploadLogo(this)"/>
            </div>
            <div>
              <p style="font-size:13px;font-weight:700;color:var(--text-primary);">Logo de tu empresa</p>
              <p style="font-size:11px;color:var(--text-faint);">JPG, PNG o SVG. Máximo 2MB. Se muestra en facturas, emails y tu panel.</p>
              <button onclick="document.getElementById('cfg-logo-file').click()" style="margin-top:6px;padding:5px 14px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:11px;font-weight:600;cursor:pointer;">Subir logo</button>
            </div>
          </div>
          <!-- Form -->
          <div style="display:grid;gap:16px;">
            <div><label class="cfg-label">Nombre de la empresa</label><input id="cfg-company-name" type="text" value="SkyBrandMX" class="cfg-input"/></div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div><label class="cfg-label">RFC</label><input id="cfg-rfc" type="text" placeholder="XAXX010101000" class="cfg-input"/></div>
              <div>
                <label class="cfg-label">Régimen fiscal</label>
                <select id="cfg-regimen" class="cfg-input" style="cursor:pointer;">
                  <option value="">Seleccionar...</option>
                  <option value="601">601 - General de Ley</option>
                  <option value="603">603 - Personas Morales sin fines de lucro</option>
                  <option value="612" selected>612 - Personas Físicas con Act. Empresarial</option>
                  <option value="621">621 - Incorporación Fiscal</option>
                  <option value="626">626 - Simplificado de Confianza</option>
                </select>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div><label class="cfg-label">Teléfono</label><input id="cfg-phone" type="tel" placeholder="+52 55 1234 5678" class="cfg-input"/></div>
              <div><label class="cfg-label">Sitio web</label><input id="cfg-website" type="url" placeholder="https://mitienda.com" class="cfg-input"/></div>
            </div>
            <div><label class="cfg-label">Dirección fiscal</label><input id="cfg-address" type="text" placeholder="Calle, Número, Colonia, CP, Ciudad, Estado" class="cfg-input"/></div>
          </div>
          <button onclick="cfgSave('empresa')" class="cfg-save-btn">Guardar cambios</button>
        </div>
      </div>

      <!-- ══════════ Mi cuenta ══════════ -->
      <div id="cfg-panel-account" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Mi cuenta</h3>
          <p class="cfg-section-desc">Tu información personal como administrador.</p>
          <div style="display:grid;gap:16px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div><label class="cfg-label">Nombre completo</label><input id="cfg-fullname" type="text" value="Eduardo Serratos" class="cfg-input"/></div>
              <div><label class="cfg-label">Email</label><input id="cfg-email" type="email" value="serratos@skybrandmx.com" class="cfg-input" disabled style="opacity:0.6;"/><p style="font-size:10px;color:var(--text-faint);margin-top:4px;">Para cambiar email, contacta soporte</p></div>
            </div>
            <div><label class="cfg-label">Idioma</label><select id="cfg-lang" class="cfg-input" style="cursor:pointer;"><option value="es" selected>Español (México)</option><option value="en">English</option><option value="pt">Português</option></select></div>
            <div><label class="cfg-label">Zona horaria</label><select id="cfg-tz" class="cfg-input" style="cursor:pointer;"><option value="America/Mexico_City" selected>Ciudad de México (GMT-6)</option><option value="America/Cancun">Cancún (GMT-5)</option><option value="America/Tijuana">Tijuana (GMT-8)</option><option value="America/Hermosillo">Hermosillo (GMT-7)</option></select></div>
          </div>
          <button onclick="cfgSave('cuenta')" class="cfg-save-btn">Guardar cambios</button>
        </div>
      </div>

      <!-- ══════════ Equipo ══════════ -->
      <div id="cfg-panel-team" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Mi equipo</h3>
          <p class="cfg-section-desc">Invita a tu equipo y asígnales un rol. Cada persona solo ve lo que necesita.</p>
          <div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
            <button onclick="cfgInviteTeam()" style="padding:10px 20px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;">
              <svg style="width:16px;height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Invitar persona
            </button>
          </div>
          <div id="cfg-team-list" style="display:flex;flex-direction:column;gap:10px;"></div>
        </div>
      </div>

      <!-- ══════════ Integraciones ══════════ -->
      <div id="cfg-panel-integrations" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Integraciones</h3>
          <p class="cfg-section-desc">Conecta tus herramientas favoritas. Solo haz clic en "Conectar" y sigue los pasos.</p>
          <div id="cfg-integrations-list" style="display:flex;flex-direction:column;gap:12px;"></div>
        </div>
      </div>

      <!-- ══════════ Notificaciones ══════════ -->
      <div id="cfg-panel-notifications" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Notificaciones</h3>
          <p class="cfg-section-desc">Elige cómo y cuándo quieres que te avisemos. Puedes activar o desactivar cada una.</p>
          <div id="cfg-notif-list" style="display:flex;flex-direction:column;gap:0;"></div>
        </div>
      </div>

      <!-- ══════════ Suscripción y pagos ══════════ -->
      <div id="cfg-panel-billing" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Mi suscripción</h3>
          <p class="cfg-section-desc">Tu plan actual y facturas.</p>
          <div id="cfg-plan-card" style="padding:20px;border-radius:12px;background:linear-gradient(135deg,rgba(111,207,245,0.06),rgba(139,92,246,0.06));border:1px solid rgba(111,207,245,0.15);margin-bottom:20px;"></div>
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">Historial de pagos</h4>
          <div id="cfg-invoices-list" style="display:flex;flex-direction:column;gap:0;"></div>
          <h4 style="font-size:14px;font-weight:800;color:var(--text-primary);margin:20px 0 12px;">Método de pago</h4>
          <div id="cfg-payment-method" style="display:flex;align-items:center;gap:12px;padding:14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);"></div>
        </div>
      </div>

      <!-- ══════════ Apariencia ══════════ -->
      <div id="cfg-panel-appearance" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Apariencia</h3>
          <p class="cfg-section-desc">Personaliza cómo se ve tu panel. Los cambios son solo para ti.</p>
          <!-- Theme -->
          <div style="margin-bottom:20px;">
            <label class="cfg-label">Modo</label>
            <div style="display:flex;gap:10px;">
              <button onclick="cfgSetTheme('dark')" id="cfg-theme-dark" class="cfg-theme-btn active">
                <span style="font-size:20px;">🌙</span><span style="font-size:12px;font-weight:700;">Oscuro</span>
              </button>
              <button onclick="cfgSetTheme('light')" id="cfg-theme-light" class="cfg-theme-btn">
                <span style="font-size:20px;">☀️</span><span style="font-size:12px;font-weight:700;">Claro</span>
              </button>
            </div>
          </div>
          <!-- Color -->
          <div>
            <label class="cfg-label">Color de tu panel</label>
            <div style="display:flex;gap:8px;margin-bottom:12px;" id="cfg-color-presets"></div>
            <div style="display:flex;gap:10px;align-items:center;">
              <input type="color" id="cfg-color-picker" value="#6fcff5" style="width:40px;height:40px;border:none;border-radius:8px;cursor:pointer;"/>
              <input type="text" id="cfg-color-hex" value="#6fcff5" class="cfg-input" style="width:120px;font-family:monospace;font-size:12px;" oninput="document.getElementById('cfg-color-picker').value=this.value"/>
              <button onclick="cfgApplyColor()" style="padding:8px 16px;border-radius:8px;border:none;background:var(--accent);color:#fff;font-size:12px;font-weight:700;cursor:pointer;">Aplicar</button>
            </div>
          </div>
        </div>
      </div>

      <!-- ══════════ Seguridad ══════════ -->
      <div id="cfg-panel-security" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;">
          <h3 class="cfg-section-title">Seguridad</h3>
          <p class="cfg-section-desc">Protege tu cuenta con una contraseña fuerte y verificación en dos pasos.</p>
          <!-- Password -->
          <div style="margin-bottom:24px;">
            <h4 style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">Cambiar contraseña</h4>
            <div style="display:grid;gap:12px;max-width:400px;">
              <div><label class="cfg-label">Contraseña actual</label><input type="password" id="cfg-pw-current" class="cfg-input" placeholder="••••••••"/></div>
              <div><label class="cfg-label">Nueva contraseña</label><input type="password" id="cfg-pw-new" class="cfg-input" placeholder="Mínimo 8 caracteres"/></div>
              <div><label class="cfg-label">Confirmar nueva contraseña</label><input type="password" id="cfg-pw-confirm" class="cfg-input" placeholder="Repite la nueva contraseña"/></div>
              <button onclick="cfgChangePassword()" style="padding:10px 20px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:700;cursor:pointer;width:fit-content;">Cambiar contraseña</button>
            </div>
          </div>
          <!-- 2FA -->
          <div style="padding:16px;border-radius:12px;border:1px solid var(--border);background:var(--input-bg);">
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:36px;height:36px;border-radius:10px;background:rgba(34,197,94,0.1);display:flex;align-items:center;justify-content:center;">
                  <svg style="width:18px;height:18px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <p style="font-size:13px;font-weight:700;color:var(--text-primary);">Verificación en dos pasos (2FA)</p>
                  <p style="font-size:11px;color:var(--text-faint);">Te enviamos un código por email cada vez que inicias sesión</p>
                </div>
              </div>
              <span style="padding:4px 12px;border-radius:6px;font-size:11px;font-weight:700;color:#22c55e;background:rgba(34,197,94,0.1);">Activo</span>
            </div>
          </div>
          <!-- Sessions -->
          <div style="margin-top:20px;">
            <h4 style="font-size:13px;font-weight:800;color:var(--text-primary);margin-bottom:12px;">Sesiones activas</h4>
            <div id="cfg-sessions-list"></div>
          </div>
        </div>
      </div>

      <!-- ══════════ Zona de peligro ══════════ -->
      <div id="cfg-panel-danger" class="cfg-panel" style="display:none;">
        <div class="stat-card animate-in" style="padding:24px;border-color:rgba(239,68,68,0.2);">
          <h3 class="cfg-section-title" style="color:#ef4444;">Zona de peligro</h3>
          <p class="cfg-section-desc">Acciones irreversibles. Ten cuidado.</p>
          <div style="display:flex;flex-direction:column;gap:16px;">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:16px;border-radius:10px;border:1px solid var(--border);">
              <div><p style="font-size:13px;font-weight:700;color:var(--text-primary);">Exportar todos mis datos</p><p style="font-size:11px;color:var(--text-faint);">Descarga una copia de toda tu información</p></div>
              <button onclick="cfgToast('Exportación iniciada. Te enviaremos un link por email.')" style="padding:8px 16px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--text-muted);font-size:12px;font-weight:700;cursor:pointer;">Exportar</button>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:16px;border-radius:10px;border:1px solid var(--border);">
              <div><p style="font-size:13px;font-weight:700;color:var(--text-primary);">Cerrar sesión en todos los dispositivos</p><p style="font-size:11px;color:var(--text-faint);">Cierra tu cuenta en todas las computadoras y celulares</p></div>
              <button onclick="if(confirm('¿Cerrar sesión en todos tus dispositivos?')){localStorage.removeItem('skybrand_token');window.location.href='/login';}" style="padding:8px 16px;border-radius:8px;border:1px solid #f97316;background:transparent;color:#f97316;font-size:12px;font-weight:700;cursor:pointer;">Cerrar todas</button>
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:16px;border-radius:10px;border:1px solid rgba(239,68,68,0.3);background:rgba(239,68,68,0.03);">
              <div><p style="font-size:13px;font-weight:700;color:#ef4444;">Eliminar mi cuenta</p><p style="font-size:11px;color:var(--text-faint);">Se borran todos tus datos permanentemente. No se puede deshacer.</p></div>
              <button onclick="if(confirm('⚠ ¿Estás SEGURO? Se eliminarán TODOS tus datos, contactos, pedidos y configuraciones. Esta acción NO se puede deshacer.')){cfgToast('Solicitud enviada. Te contactaremos para confirmar.');}" style="padding:8px 16px;border-radius:8px;border:1px solid #ef4444;background:transparent;color:#ef4444;font-size:12px;font-weight:700;cursor:pointer;">Eliminar cuenta</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<style>
  .cfg-nav-item { width:100%;display:flex;align-items:center;gap:10px;padding:10px 14px;border:none;background:transparent;color:var(--text-muted);font-size:13px;font-weight:600;cursor:pointer;border-radius:8px;transition:all 0.15s;text-align:left; }
  .cfg-nav-item:hover { background:var(--nav-hover);color:var(--text-secondary); }
  .cfg-nav-item.active { background:var(--accent-bg);color:var(--accent); }
  .cfg-panel { }
  .cfg-section-title { font-size:18px;font-weight:900;color:var(--text-primary);margin-bottom:4px; }
  .cfg-section-desc { font-size:12px;color:var(--text-muted);margin-bottom:20px; }
  .cfg-label { font-size:12px;font-weight:700;color:var(--text-muted);margin-bottom:4px;display:block; }
  .cfg-input { width:100%;padding:10px 14px;border-radius:10px;border:1px solid var(--border);background:var(--input-bg);color:var(--text-primary);font-size:13px;outline:none;transition:border-color 0.2s; }
  .cfg-input:focus { border-color:var(--accent); }
  .cfg-save-btn { margin-top:20px;padding:10px 24px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-size:13px;font-weight:700;cursor:pointer;transition:opacity 0.2s; }
  .cfg-save-btn:hover { opacity:0.85; }
  .cfg-theme-btn { display:flex;flex-direction:column;align-items:center;gap:6px;padding:16px 24px;border-radius:12px;border:2px solid var(--border);background:transparent;cursor:pointer;transition:all 0.2s;flex:1; }
  .cfg-theme-btn.active { border-color:var(--accent);background:var(--accent-bg); }
  .cfg-theme-btn:hover:not(.active) { border-color:var(--border-hover); }
  .cfg-toggle-wrap { position:relative;display:inline-block;width:40px;height:22px;flex-shrink:0; }
  .cfg-toggle-wrap input { opacity:0;width:0;height:0; }
  .cfg-toggle-slider { position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:var(--border);border-radius:22px;transition:0.3s; }
  .cfg-toggle-slider::before { content:'';position:absolute;height:16px;width:16px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:0.3s; }
  .cfg-toggle-wrap input:checked + .cfg-toggle-slider { background:#22c55e; }
  .cfg-toggle-wrap input:checked + .cfg-toggle-slider::before { transform:translateX(18px); }
</style>

<script is:inline>
const cfgTabs = ['company','account','team','integrations','notifications','billing','appearance','security','danger'];

function switchCfgTab(tab) {
  cfgTabs.forEach(t => {
    const nav = document.getElementById('cfg-nav-'+t);
    const panel = document.getElementById('cfg-panel-'+t);
    if (nav) nav.classList.toggle('active', t === tab);
    if (panel) panel.style.display = t === tab ? '' : 'none';
  });
}

function cfgToast(msg) {
  const ex = document.getElementById('cfg-toast'); if (ex) ex.remove();
  const t = document.createElement('div'); t.id = 'cfg-toast'; t.textContent = msg;
  Object.assign(t.style, { position:'fixed', bottom:'24px', right:'24px', background:'#22c55e', color:'#fff', padding:'12px 24px', borderRadius:'10px', fontSize:'13px', fontWeight:'700', zIndex:'9999', boxShadow:'0 4px 20px rgba(0,0,0,0.3)' });
  document.body.appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.3s'; setTimeout(() => t.remove(), 300); }, 3000);
}

function cfgSave(section) { cfgToast('Cambios guardados en ' + section); }

function cfgUploadLogo(input) {
  const file = input.files[0]; if (!file) return;
  if (file.size > 2 * 1024 * 1024) { alert('El archivo excede 2MB'); return; }
  const reader = new FileReader();
  reader.onload = function(e) {
    const logo = document.getElementById('cfg-logo');
    logo.innerHTML = `<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover;"/>`;
    cfgToast('Logo actualizado');
  };
  reader.readAsDataURL(file);
}

