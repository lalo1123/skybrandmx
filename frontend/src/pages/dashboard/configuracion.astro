function cfgSetTheme(theme) {
  document.documentElement.setAttribute('data-theme', theme);
  localStorage.setItem('skybrand_theme', theme);
  document.getElementById('cfg-theme-dark').classList.toggle('active', theme === 'dark');
  document.getElementById('cfg-theme-light').classList.toggle('active', theme === 'light');
  cfgToast('Tema cambiado a ' + (theme === 'dark' ? 'oscuro' : 'claro'));
}

function cfgApplyColor() {
  const color = document.getElementById('cfg-color-hex').value;
  document.documentElement.style.setProperty('--accent', color);
  cfgToast('Color aplicado: ' + color);
}

// ═══════ SECURITY ═══════
function cfgChangePassword() {
  const current = document.getElementById('cfg-pw-current').value;
  const newPw = document.getElementById('cfg-pw-new').value;
  const confirm = document.getElementById('cfg-pw-confirm').value;
  if (!current || !newPw || !confirm) { alert('Completa todos los campos'); return; }
  if (newPw.length < 8) { alert('La contraseña debe tener al menos 8 caracteres'); return; }
  if (newPw !== confirm) { alert('Las contraseñas no coinciden'); return; }
  cfgToast('Contraseña actualizada');
  document.getElementById('cfg-pw-current').value = '';
  document.getElementById('cfg-pw-new').value = '';
  document.getElementById('cfg-pw-confirm').value = '';
}

