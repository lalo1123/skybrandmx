---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Gestiona tu negocio desde un solo panel: CRM, facturación CFDI, guías de envío, pedidos y automatización de marketing. Diseñado para PYMES en México y Latam." } = Astro.props;
import '../styles/tailwind.css';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-slate-50 text-slate-900 antialiased selection:bg-brand-primary/30 min-h-screen flex flex-col">
        <!-- GLOBAL HEADER -->
        <nav class="py-4 fixed top-0 w-full z-50 bg-[#081014]/80 backdrop-blur-xl border-b border-white/5 transition-all duration-300">
            <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
                <a href="/" class="block">
                    <div class="group relative" aria-label="SkybrandMX">
                        <h1 class="font-bold text-2xl tracking-tight transition-colors duration-300 text-white"><span>SKYBR</span><span class="bg-gradient-to-br from-[#6fcff5] to-white bg-clip-text text-transparent">A</span><span class="bg-gradient-to-br from-[#6fcff5] to-white bg-clip-text text-transparent">N</span><span>DM</span><span class="bg-gradient-to-br from-[#6fcff5] to-white bg-clip-text text-transparent">X</span></h1>
                        <div class="absolute -bottom-1 left-0 h-[3px] w-1/3 rounded-full bg-gradient-to-r from-[#70D1C6] to-[#105971] transition-all duration-500 ease-out group-hover:w-full" style="filter: saturate(1.2);"></div>
                    </div>
                </a>

                <!-- Desktop Menu -->
                <div class="hidden lg:flex gap-8 items-center text-sm font-bold tracking-wider">
                    <div class="relative group py-2">
                        <button class="flex items-center gap-1.5 text-slate-300 hover:text-white transition-colors focus:outline-none">
                            Soluciones B2B
                            <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div class="absolute top-full left-0 mt-2 w-52 bg-[#0a151b]/95 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top-left -translate-y-2 group-hover:translate-y-0 overflow-hidden">
                            <a href="/soluciones/pymes" class="block px-6 py-4 text-slate-400 font-bold hover:text-[#70D1C6] hover:bg-white/5 transition-colors border-b border-white/5">PYMES</a>
                            <a href="/soluciones/medianas" class="block px-6 py-4 text-slate-400 font-bold hover:text-[#70D1C6] hover:bg-white/5 transition-colors border-b border-white/5">Medianas</a>
                            <a href="/soluciones/enterprise" class="block px-6 py-4 text-slate-400 font-bold hover:text-[#70D1C6] hover:bg-white/5 transition-colors">Enterprise</a>
                        </div>
                    </div>

                    <div class="relative group py-2">
                        <button class="flex items-center gap-1.5 text-slate-300 hover:text-white transition-colors focus:outline-none">
                            Módulos
                            <svg class="w-4 h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div class="absolute top-full left-0 mt-2 w-60 bg-[#0a151b]/95 backdrop-blur-xl border border-white/10 rounded-2xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top-left -translate-y-2 group-hover:translate-y-0 overflow-hidden">
                            <a href="/modulos/logistica" class="block px-6 py-4 text-slate-400 font-bold hover:text-[#70D1C6] hover:bg-white/5 transition-colors border-b border-white/5 text-sm">Logística y Envíos</a>
                            <a href="/modulos/crm" class="block px-6 py-4 text-slate-400 font-bold hover:text-[#70D1C6] hover:bg-white/5 transition-colors border-b border-white/5 text-sm">CRM y Ventas</a>
                            <a href="/modulos/facturacion" class="block px-6 py-4 text-slate-400 font-bold hover:text-[#70D1C6] hover:bg-white/5 transition-colors text-sm">Facturación SAT 4.0</a>
                        </div>
                    </div>

                    <a href="/integraciones" class="text-slate-300 hover:text-white transition-colors py-2">Integraciones</a>
                    <a href="/planes" class="text-slate-300 hover:text-white transition-colors py-2">Planes</a>
                    <a href="/#faq" class="text-slate-300 hover:text-white transition-colors py-2">FAQ</a>
                </div>

                <!-- Desktop Actions -->
                <div class="hidden md:flex gap-4 items-center">
                    <a href="/login" class="px-5 py-2.5 rounded-xl border border-[#70D1C6]/30 text-[#70D1C6] text-sm font-bold hover:bg-[#70D1C6]/10 hover:border-[#70D1C6]/50 transition-all">Login</a>
                    <a href="https://web.whatsapp.com/send?phone=5525582310" class="px-5 py-2.5 rounded-xl border border-white/20 text-white text-sm font-bold hover:bg-white/10 hover:border-white/30 transition-all">Chatear</a>
                    <a href="/planes" class="px-5 py-2.5 rounded-xl bg-[#FF6B00] text-white text-sm font-bold shadow-lg shadow-orange-500/20 hover:-translate-y-0.5 transition-all">Empezar Gratis</a>
                </div>

                <!-- Mobile Menu Button -->
                <button id="menu-toggle" class="lg:hidden text-white p-2 focus:outline-none">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
                </button>
            </div>
        </nav>

        <!-- MOBILE MENU OVERLAY -->
        <div id="mobile-menu" class="fixed inset-0 z-[60] bg-[#081014] translate-x-full transition-transform duration-500 ease-in-out lg:hidden">
            <div class="p-6 flex flex-col h-full">
                <div class="flex justify-between items-center mb-12">
                    <a href="/" class="block">
                        <h1 class="font-bold text-2xl text-white">SKYBRANDMX</h1>
                    </a>
                    <button id="close-menu" class="text-white p-2">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
                
                <div class="flex flex-col gap-6 overflow-y-auto pb-10">
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-4">Soluciones</p>
                        <div class="flex flex-col gap-4 pl-4 border-l border-white/10">
                            <a href="/soluciones/pymes" class="text-xl font-bold text-white hover:text-[#70D1C6]">PYMES</a>
                            <a href="/soluciones/medianas" class="text-xl font-bold text-white hover:text-[#70D1C6]">Medianas</a>
                            <a href="/soluciones/enterprise" class="text-xl font-bold text-white hover:text-[#70D1C6]">Enterprise</a>
                        </div>
                    </div>

                    <div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-4">Módulos</p>
                        <div class="flex flex-col gap-4 pl-4 border-l border-white/10">
                            <a href="/modulos/logistica" class="text-xl font-bold text-white hover:text-[#70D1C6]">Logística</a>
                            <a href="/modulos/crm" class="text-xl font-bold text-white hover:text-[#70D1C6]">CRM y Ventas</a>
                            <a href="/modulos/facturacion" class="text-xl font-bold text-white hover:text-[#70D1C6]">Facturación SAT</a>
                        </div>
                    </div>

                    <a href="/integraciones" class="text-2xl font-black text-white py-2">Integraciones</a>
                    <a href="/planes" class="text-2xl font-black text-white py-2">Planes</a>
                    <a href="/#faq" class="text-2xl font-black text-white py-2">FAQ</a>
                </div>

                <div class="mt-auto pt-10 border-t border-white/10 flex flex-col gap-4">
                    <a href="https://web.whatsapp.com/send?phone=5525582310" class="w-full py-4 rounded-2xl border border-white/20 text-white text-center font-bold">Chatear con experto</a>
                    <a href="/planes" class="w-full py-4 rounded-2xl bg-[#FF6B00] text-white text-center font-bold shadow-lg shadow-orange-500/20">Empezar Gratis</a>
                </div>
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <main class="flex-1">
		    <slot />
        </main>

        <!-- GLOBAL FOOTER -->
        <footer class="bg-white py-24 border-t border-slate-100">
            <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-12">
                <div class="flex flex-col items-center md:items-start text-center md:text-left">
                    <a href="/" class="block mb-4">
                        <div class="group relative inline-block" aria-label="SkybrandMX">
                            <span class="font-black text-3xl tracking-tighter transition-colors duration-300 text-[#084d6e]"><span>SKYBR</span><span class="bg-gradient-to-br from-[#6fcff5] to-[#084d6e] bg-clip-text text-transparent">A</span><span class="bg-gradient-to-br from-[#6fcff5] to-[#084d6e] bg-clip-text text-transparent">N</span><span>DM</span><span class="bg-gradient-to-br from-[#6fcff5] to-[#084d6e] bg-clip-text text-transparent">X</span></span>
                            <div class="absolute -bottom-1 left-0 h-[3px] w-1/3 rounded-full bg-gradient-to-r from-[#70D1C6] to-[#105971] transition-all duration-500 ease-out group-hover:w-full" style="filter: saturate(1.2);"></div>
                        </div>
                    </a>
                    <p class="text-slate-500 text-sm font-bold max-w-xs">El sistema neuro-operativo diseñado para escalar empresas en la era digital.</p>
                </div>
                <div class="flex flex-wrap justify-center gap-10">
                    <a href="/privacidad" class="text-slate-400 hover:text-slate-950 transition-colors text-xs font-black uppercase tracking-widest">Privacidad</a>
                    <a href="/cookies" class="text-slate-400 hover:text-slate-950 transition-colors text-xs font-black uppercase tracking-widest">Cookies</a>
                    <a href="/terminos" class="text-slate-400 hover:text-slate-950 transition-colors text-xs font-black uppercase tracking-widest">Términos</a>
                </div>
                <div class="text-slate-300 text-[10px] font-black uppercase tracking-[0.2em]">
                    &copy; 2026 SkyBrandMX. Industrial Strength SaaS.
                </div>
            </div>
        </footer>

        <script>
            // Mobile Menu Toggle
            const menuToggle = document.getElementById('menu-toggle');
            const closeMenu = document.getElementById('close-menu');
            const mobileMenu = document.getElementById('mobile-menu');
            const mobileLinks = mobileMenu.querySelectorAll('a');

            const toggleMenu = () => {
                mobileMenu.classList.toggle('translate-x-full');
                document.body.classList.toggle('overflow-hidden');
            };

            menuToggle?.addEventListener('click', toggleMenu);
            closeMenu?.addEventListener('click', toggleMenu);
            mobileLinks.forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenu.classList.add('translate-x-full');
                    document.body.classList.remove('overflow-hidden');
                });
            });

            // Scroll Effect
            const nav = document.querySelector('nav');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    nav?.classList.add('bg-[#081014]/95', 'py-3');
                    nav?.classList.remove('bg-[#081014]/80', 'py-4');
                } else {
                    nav?.classList.remove('bg-[#081014]/95', 'py-3');
                    nav?.classList.add('bg-[#081014]/80', 'py-4');
                }
            });
        </script>
	</body>
</html>
