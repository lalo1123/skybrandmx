<script>
    function setupTabs() {
        const tabs = document.querySelectorAll('.segment-pill');
        const panes = document.querySelectorAll('.tab-pane');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const target = tab.getAttribute('data-target');

                // Update Pills UI
                tabs.forEach(t => {
                    t.classList.remove('active');
                    t.classList.add('text-slate-500');
                    (t as HTMLElement).style.backgroundColor = '';
                    (t as HTMLElement).style.color = '';
                    (t as HTMLElement).style.boxShadow = '';
                });
                
                tab.classList.add('active');
                tab.classList.remove('text-slate-500');

                // Update Content
                panes.forEach(p => {
                    p.classList.add('hidden');
                    p.classList.remove('active');
                });

                const activePane = document.getElementById(target as string);
                if (activePane) {
                    activePane.classList.remove('hidden');
                    activePane.classList.add('active');
                }
            });
        });
    }

    // Initialize on page load
    setupTabs();
    
    // Support Astro View Transitions if any
    document.addEventListener('astro:page-load', setupTabs);
</script>

